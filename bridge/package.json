{
  "name": "atleta-bridge",
  "version": "1.0.0",
  "description": "Atleta Bridge — reads iRacing telemetry and serves it to web overlays",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "node-irsdk": "^2.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.atleta.bridge",
    "productName": "Atleta Bridge",
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  }
}
