{
  "name": "atleta-bridge",
  "version": "1.0.0",
  "description": "Atleta Bridge — reads iRacing telemetry and serves it to web overlays",
  "author": "Atleta",
  "repository": "https://github.com/ricardosilva1998/atleta-notifications-helper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "@emiliosp/node-iracing-sdk": "^1.0.10"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.atleta.bridge",
    "productName": "Atleta Bridge",
    "directories": {
      "buildResources": "build"
    },
    "extraResources": [
      { "from": "build/icon.png", "to": "icon.png" }
    ],
    "files": [
      "**/*",
      "build/icon.png"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh"
    }
  }
}
