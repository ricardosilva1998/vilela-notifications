<%- include('header', { title: 'Report an Issue', streamer: streamer }) %>

<a href="/dashboard" style="color: #adadb8; font-size: 14px;">&larr; Back to Dashboard</a>
<h2 style="margin: 12px 0 20px;">Report an Issue</h2>

<% if (msg === 'submitted') { %>
  <div class="alert alert-success">Your issue has been submitted. We'll look into it!</div>
<% } %>
<% if (msg === 'missing_fields') { %>
  <div class="alert" style="background: #e74c3c33; border: 1px solid #e74c3c;">Please fill in all fields.</div>
<% } %>

<div class="card">
  <p style="color: #adadb8; font-size: 14px; margin-bottom: 16px;">Found a bug or have a suggestion? Let us know and we'll take a look.</p>
  <form method="POST" action="/dashboard/report">
    <div class="form-group">
      <label>Subject</label>
      <input type="text" name="subject" placeholder="Brief description of the issue" required>
    </div>
    <div class="form-group">
      <label>Description</label>
      <textarea name="description" placeholder="Describe the issue in detail. Include steps to reproduce if it's a bug." required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Submit Issue</button>
  </form>
</div>

<%- include('footer') %>
