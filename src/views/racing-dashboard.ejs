<%- include('header', { title: 'Racing — Atleta', streamer: streamer }) %>
<div style="padding:24px 0;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
    <div>
      <h1 style="font-size:28px;font-weight:800;margin-bottom:4px;">Racing</h1>
      <p style="color:var(--text-secondary);font-size:14px;">Welcome, <strong><%= racingUser.username %></strong><%= racingUser.iracing_name ? ' (' + racingUser.iracing_name + ')' : '' %></p>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
    <a href="/tracks" class="card" style="padding:28px 24px;text-decoration:none;color:inherit;">
      <div style="display:flex;align-items:center;gap:16px;">
        <div style="width:52px;height:52px;border-radius:12px;background:rgba(62,207,142,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3ecf8e" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <div>
          <h3 style="font-size:17px;font-weight:700;margin-bottom:4px;">Track Database</h3>
          <p style="color:var(--text-muted);font-size:13px;">Browse tracks & statistics</p>
        </div>
      </div>
    </a>
    <a href="/racing/account" class="card" style="padding:28px 24px;text-decoration:none;color:inherit;">
      <div style="display:flex;align-items:center;gap:16px;">
        <div style="width:52px;height:52px;border-radius:12px;background:rgba(145,70,255,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div>
          <h3 style="font-size:17px;font-weight:700;margin-bottom:4px;">Account</h3>
          <p style="color:var(--text-muted);font-size:13px;">Settings, sessions & linked accounts</p>
        </div>
      </div>
    </a>
    <a href="/racing/team" class="card" style="padding:28px 24px;text-decoration:none;color:inherit;<%= (typeof pendingTeamInvites !== 'undefined' && pendingTeamInvites && pendingTeamInvites.length > 0) ? 'border:1px solid rgba(247,201,72,0.3);' : '' %>">
      <div style="display:flex;align-items:center;gap:16px;">
        <div style="width:52px;height:52px;border-radius:12px;background:rgba(59,130,246,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
          <h3 style="font-size:17px;font-weight:700;margin-bottom:4px;">
            My Team
            <% if (typeof pendingTeamInvites !== 'undefined' && pendingTeamInvites && pendingTeamInvites.length > 0) { %>
              <span style="background:#f7c948;color:#000;font-size:10px;font-weight:700;padding:2px 6px;border-radius:8px;margin-left:6px;"><%= pendingTeamInvites.length %></span>
            <% } %>
          </h3>
          <p style="color:var(--text-muted);font-size:13px;">
            <% if (typeof team !== 'undefined' && team) { %><%= team.team_name %><% } else { %>Create or join a team<% } %>
          </p>
        </div>
      </div>
    </a>
    <% if (typeof team !== 'undefined' && team) { %>
    <a href="/racing/pitwall" class="card" style="padding:28px 24px;text-decoration:none;color:inherit;border:1px solid rgba(62,207,142,0.15);">
      <div style="display:flex;align-items:center;gap:16px;">
        <div style="width:52px;height:52px;border-radius:12px;background:rgba(62,207,142,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3ecf8e" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div>
          <h3 style="font-size:17px;font-weight:700;margin-bottom:4px;">Pitwall</h3>
          <p style="color:var(--text-muted);font-size:13px;">Watch teammates live</p>
        </div>
      </div>
    </a>
    <% } %>
    <% if (isAdmin) { %>
    <a href="/racing/admin" class="card" style="padding:28px 24px;text-decoration:none;color:inherit;border:1px solid rgba(240,68,56,0.15);">
      <div style="display:flex;align-items:center;gap:16px;">
        <div style="width:52px;height:52px;border-radius:12px;background:rgba(240,68,56,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <h3 style="font-size:17px;font-weight:700;margin-bottom:4px;">Admin</h3>
          <p style="color:var(--text-muted);font-size:13px;">Bridge users & Racing accounts</p>
        </div>
      </div>
    </a>
    <% } %>
  </div>
</div>
<%- include('footer') %>
