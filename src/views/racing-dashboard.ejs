<%- include('header', { title: 'Racing — Atleta', streamer: streamer }) %>
<div style="padding:24px 0;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
    <div>
      <h1 style="font-size:28px;font-weight:800;margin-bottom:4px;">Racing</h1>
      <p style="color:var(--text-secondary);font-size:14px;">Welcome, <strong><%= racingUser.username %></strong><%= racingUser.iracing_name ? ' (' + racingUser.iracing_name + ')' : '' %></p>
    </div>
  </div>

  <!-- Quick links -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:32px;">
    <a href="/tracks" class="card" style="padding:16px;text-decoration:none;color:inherit;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:8px;background:rgba(62,207,142,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3ecf8e" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <div>
          <h3 style="font-size:14px;margin-bottom:2px;">Track Database</h3>
          <p style="color:var(--text-muted);font-size:11px;">Browse tracks & statistics</p>
        </div>
      </div>
    </a>
    <a href="/racing/account" class="card" style="padding:16px;text-decoration:none;color:inherit;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:8px;background:rgba(145,70,255,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div>
          <h3 style="font-size:14px;margin-bottom:2px;">Account</h3>
          <p style="color:var(--text-muted);font-size:11px;">Settings & linked accounts</p>
        </div>
      </div>
    </a>
    <a href="/racing/team" class="card" style="padding:16px;text-decoration:none;color:inherit;<%= (typeof pendingTeamInvites !== 'undefined' && pendingTeamInvites && pendingTeamInvites.length > 0) ? 'border:1px solid rgba(247,201,72,0.3);' : '' %>">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:8px;background:rgba(59,130,246,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
          <h3 style="font-size:14px;margin-bottom:2px;">
            My Team
            <% if (typeof pendingTeamInvites !== 'undefined' && pendingTeamInvites && pendingTeamInvites.length > 0) { %>
              <span style="background:#f7c948;color:#000;font-size:10px;font-weight:700;padding:1px 5px;border-radius:8px;margin-left:4px;"><%= pendingTeamInvites.length %></span>
            <% } %>
          </h3>
          <p style="color:var(--text-muted);font-size:11px;">
            <% if (typeof team !== 'undefined' && team) { %><%= team.team_name %><% } else { %>Create or join a team<% } %>
          </p>
        </div>
      </div>
    </a>
    <% if (typeof team !== 'undefined' && team) { %>
    <a href="/racing/pitwall" class="card" style="padding:16px;text-decoration:none;color:inherit;border:1px solid rgba(62,207,142,0.15);">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:8px;background:rgba(62,207,142,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3ecf8e" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div>
          <h3 style="font-size:14px;margin-bottom:2px;">Pitwall</h3>
          <p style="color:var(--text-muted);font-size:11px;">Watch teammates live</p>
        </div>
      </div>
    </a>
    <% } %>
    <% if (isAdmin) { %>
    <a href="/racing/admin" class="card" style="padding:16px;text-decoration:none;color:inherit;border:1px solid rgba(240,68,56,0.15);">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:8px;background:rgba(240,68,56,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <h3 style="font-size:14px;margin-bottom:2px;">Admin</h3>
          <p style="color:var(--text-muted);font-size:11px;">Bridge users & Racing accounts</p>
        </div>
      </div>
    </a>
    <% } %>
  </div>

  <!-- Recent sessions -->
  <div style="margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;">
    <h2 style="font-size:18px;font-weight:700;">My Sessions</h2>
    <% if (racingUser.bridge_id) { %>
      <span style="font-size:11px;color:var(--text-muted);background:rgba(62,207,142,0.1);padding:3px 8px;border-radius:4px;color:#3ecf8e;">Bridge linked</span>
    <% } else { %>
      <span style="font-size:11px;color:var(--text-muted);">Link Bridge to see session data</span>
    <% } %>
  </div>

  <% if (sessions && sessions.length > 0) { %>
    <div class="card" style="overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Date</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Track</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Type</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Car</th>
            <th style="padding:10px 14px;text-align:right;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Best Lap</th>
            <th style="padding:10px 14px;text-align:right;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Laps</th>
            <th style="padding:10px 14px;text-align:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Status</th>
          </tr>
        </thead>
        <tbody>
          <% sessions.forEach(function(s) { %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);cursor:pointer;" onclick="window.location='/api/session/<%= s.id %>?bridge_id=<%= racingUser.bridge_id || '' %>'">
              <td style="padding:10px 14px;color:var(--text-secondary);font-size:12px;"><%= new Date(s.created_at).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></td>
              <td style="padding:10px 14px;font-weight:600;"><%= s.track_name %></td>
              <td style="padding:10px 14px;">
                <span style="padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;
                  <% if (s.session_type === 'practice') { %>background:rgba(62,207,142,0.1);color:#3ecf8e;<% } else if (s.session_type === 'qualify') { %>background:rgba(247,201,72,0.1);color:#f7c948;<% } else { %>background:rgba(145,70,255,0.1);color:#b18cff;<% } %>
                "><%= s.session_type.charAt(0).toUpperCase() + s.session_type.slice(1) %></span>
                <% if (s.race_type) { %><span style="font-size:10px;color:var(--text-muted);margin-left:4px;"><%= s.race_type %></span><% } %>
              </td>
              <td style="padding:10px 14px;color:var(--text-secondary);font-size:12px;"><%= s.car_name || s.car_class %></td>
              <td style="padding:10px 14px;text-align:right;font-family:'JetBrains Mono',monospace;font-weight:600;color:#f7c948;">
                <% if (s.best_lap_time && s.best_lap_time > 0) { %>
                  <% var m = Math.floor(s.best_lap_time / 60); var sec = (s.best_lap_time % 60).toFixed(3); %>
                  <%= m > 0 ? m + ':' + sec.padStart(6, '0') : sec %>
                <% } else { %>--<% } %>
              </td>
              <td style="padding:10px 14px;text-align:right;color:var(--text-secondary);"><%= s.actual_laps || s.lap_count || 0 %></td>
              <td style="padding:10px 14px;text-align:center;">
                <% if (s.is_public) { %>
                  <span style="font-size:10px;color:#3ecf8e;" title="Public">&#127760;</span>
                <% } else { %>
                  <span style="font-size:10px;color:var(--text-muted);" title="Private">&#128274;</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="card" style="padding:40px;text-align:center;">
      <p style="color:var(--text-muted);font-size:14px;margin-bottom:8px;">No sessions recorded yet</p>
      <p style="color:var(--text-secondary);font-size:12px;">Sessions are automatically captured when you race with Atleta Bridge</p>
    </div>
  <% } %>
</div>
<%- include('footer') %>
