<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VTuber Face Tracker</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      overflow: hidden;
      background: <% if (mode === 'stream') { %>transparent<% } else { %>#1a1a2e<% } %>;
      font-family: 'Segoe UI', system-ui, sans-serif;
    }
    #canvas3d {
      width: 100vw;
      height: 100vh;
      display: block;
    }
    <% if (mode !== 'stream') { %>
    #webcam-preview {
      position: fixed;
      bottom: 12px;
      left: 12px;
      width: 160px;
      height: 120px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.15);
      object-fit: cover;
      z-index: 10;
      background: #000;
    }
    #status-bar {
      position: fixed;
      top: 12px;
      right: 12px;
      background: rgba(0,0,0,0.6);
      border-radius: 8px;
      padding: 6px 12px;
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      font-family: monospace;
      z-index: 10;
    }
    #loading-screen {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      background: #1a1a2e;
      z-index: 100;
      color: rgba(255,255,255,0.6);
      font-size: 14px;
      gap: 12px;
    }
    .spinner {
      width: 32px; height: 32px;
      border: 3px solid rgba(255,255,255,0.1);
      border-top-color: #667eea;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    <% } %>
    <% if (mode === 'stream') { %>
    #loading-screen {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      z-index: 100;
      color: rgba(255,255,255,0.4);
      font-size: 14px;
    }
    <% } %>
    #error-msg {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      background: #1a1a2e;
      z-index: 200;
      color: #e74c3c;
      font-size: 14px;
      gap: 8px;
    }
  </style>
</head>
<body>
  <canvas id="canvas3d"></canvas>
  <% if (mode !== 'stream') { %>
    <video id="webcam-preview" autoplay playsinline muted></video>
    <div id="status-bar">Loading...</div>
  <% } %>
  <div id="loading-screen">
    <% if (mode !== 'stream') { %><div class="spinner"></div><% } %>
    <span id="loading-text">Loading face tracker...</span>
  </div>
  <div id="error-msg"></div>

  <!-- Catch unhandled module errors -->
  <script>
    window.addEventListener('error', function(e) {
      var el = document.getElementById('error-msg');
      var ld = document.getElementById('loading-screen');
      if (el && ld) {
        el.innerHTML = '<span style="max-width:400px;text-align:center;">' + (e.message || 'An error occurred loading the face tracker.') + '</span>';
        el.style.display = 'flex';
        ld.style.display = 'none';
      }
    });
    window.addEventListener('unhandledrejection', function(e) {
      var el = document.getElementById('error-msg');
      var ld = document.getElementById('loading-screen');
      if (el && ld) {
        el.innerHTML = '<span style="max-width:400px;text-align:center;">' + (e.reason && e.reason.message ? e.reason.message : 'Failed to initialize face tracker.') + '</span>';
        el.style.display = 'flex';
        ld.style.display = 'none';
      }
    });
  </script>

  <!-- CDN Libraries -->
  <script type="importmap">
  {
    "imports": {
      "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js",
      "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.170.0/examples/jsm/",
      "@pixiv/three-vrm": "https://cdn.jsdelivr.net/npm/@pixiv/three-vrm@3/lib/three-vrm.module.min.js"
    }
  }
  </script>

  <script type="module">
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
    import { VRMLoaderPlugin, VRMUtils } from '@pixiv/three-vrm';
    import { FilesetResolver, FaceLandmarker } from 'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision/vision_bundle.mjs';

    const MODE = '<%= mode %>';
    const MODEL_URL = <%- modelUrl ? JSON.stringify(modelUrl) : 'null' %>;
    const canvas = document.getElementById('canvas3d');
    const loading = document.getElementById('loading-screen');
    const errorEl = document.getElementById('error-msg');
    const statusBar = document.getElementById('status-bar');

    function showError(msg) {
      errorEl.innerHTML = `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg><span>${msg}</span>`;
      errorEl.style.display = 'flex';
      loading.style.display = 'none';
    }

    const loadingText = document.getElementById('loading-text');
    function setLoadingStep(msg) { if (loadingText) loadingText.textContent = msg; }

    if (!MODEL_URL) {
      showError('No model selected. Pick a model in the dashboard first.');
      throw new Error('No model');
    }

    setLoadingStep('Setting up 3D renderer...');

    // --- Check WebGL support ---
    const testCanvas = document.createElement('canvas');
    const gl = testCanvas.getContext('webgl2') || testCanvas.getContext('webgl');
    if (!gl) {
      showError('WebGL is not available. Please enable hardware acceleration in your browser settings (Chrome: chrome://settings/system → "Use hardware acceleration when available") and restart your browser.');
      throw new Error('No WebGL');
    }

    // --- Three.js Setup ---
    let renderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: MODE === 'stream', antialias: true });
    } catch (e) {
      showError('Failed to create 3D renderer. Please enable hardware acceleration in your browser settings and restart.');
      throw e;
    }
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    if (MODE === 'stream') {
      renderer.setClearColor(0x000000, 0);
    }

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(20, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.set(0, 1.35, 1.5);
    camera.lookAt(0, 1.35, 0);

    // Lighting
    const ambient = new THREE.AmbientLight(0xffffff, 0.7);
    scene.add(ambient);
    const directional = new THREE.DirectionalLight(0xffffff, 0.8);
    directional.position.set(1, 2, 3);
    scene.add(directional);
    const fill = new THREE.DirectionalLight(0x8888ff, 0.3);
    fill.position.set(-1, 1, -1);
    scene.add(fill);

    setLoadingStep('Loading 3D avatar model...');

    // --- Load VRM Model ---
    const loader = new GLTFLoader();
    loader.register((parser) => new VRMLoaderPlugin(parser));

    let vrm = null;

    try {
      const gltf = await loader.loadAsync(MODEL_URL);
      vrm = gltf.userData.vrm;
      // rotateVRM0 only applies to VRM 0.x — safe no-op for 1.0 but let's check
      if (vrm.meta?.metaVersion === '0') {
        VRMUtils.rotateVRM0(vrm);
      }
      scene.add(vrm.scene);

      // Center the model
      const box = new THREE.Box3().setFromObject(vrm.scene);
      const center = box.getCenter(new THREE.Vector3());
      const height = box.max.y - box.min.y;
      camera.position.set(0, center.y + height * 0.1, height * 0.9);
      camera.lookAt(0, center.y + height * 0.1, 0);
    } catch (e) {
      showError('Failed to load model. Try a different avatar.');
      throw e;
    }

    setLoadingStep('Loading face detection AI...');

    // --- MediaPipe Face Landmarker ---
    let faceLandmarker = null;
    let videoEl = null;

    try {
      const vision = await FilesetResolver.forVisionTasks(
        'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision/wasm'
      );
      // Try GPU first, fall back to CPU
      let delegate = 'GPU';
      try {
        faceLandmarker = await FaceLandmarker.createFromOptions(vision, {
          baseOptions: {
            modelAssetPath: 'https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task',
            delegate: 'GPU'
          },
          runningMode: 'VIDEO',
          numFaces: 1,
          outputFaceBlendshapes: true,
          outputFacialTransformationMatrixes: true
        });
      } catch (gpuErr) {
        console.warn('GPU delegate failed, falling back to CPU:', gpuErr);
        setLoadingStep('Loading face detection AI (CPU mode)...');
        faceLandmarker = await FaceLandmarker.createFromOptions(vision, {
          baseOptions: {
            modelAssetPath: 'https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task',
            delegate: 'CPU'
          },
          runningMode: 'VIDEO',
          numFaces: 1,
          outputFaceBlendshapes: true,
          outputFacialTransformationMatrixes: true
        });
      }
    } catch (e) {
      showError('Failed to load face detection model.');
      throw e;
    }

    setLoadingStep('Requesting camera access...');

    // --- Webcam ---
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { width: 640, height: 480, facingMode: 'user' }
      });
      videoEl = document.createElement('video');
      videoEl.srcObject = stream;
      videoEl.autoplay = true;
      videoEl.playsInline = true;
      await videoEl.play();

      // Show webcam preview in dashboard mode
      if (MODE !== 'stream') {
        const preview = document.getElementById('webcam-preview');
        if (preview) preview.srcObject = stream;
      }
    } catch (e) {
      showError('Camera access denied. Please allow camera and reload.');
      throw e;
    }

    loading.style.display = 'none';

    // --- Helpers ---
    function getBS(blendShapes, name) {
      if (!blendShapes || !blendShapes[0]) return 0;
      const s = blendShapes[0].categories.find(c => c.categoryName === name);
      return s ? s.score : 0;
    }

    const smooth = {};
    function lerp(key, target, factor = 0.3) {
      if (smooth[key] === undefined) smooth[key] = target;
      smooth[key] += (target - smooth[key]) * factor;
      return smooth[key];
    }

    // Compute head rotation from face landmarks (nose tip, forehead, chin, ears)
    function computeHeadRotation(landmarks) {
      if (!landmarks || !landmarks[0]) return null;
      const lm = landmarks[0];
      // Key points: nose tip(1), chin(152), forehead(10), left ear(234), right ear(454)
      const nose = lm[1];
      const chin = lm[152];
      const forehead = lm[10];
      const leftEar = lm[234];
      const rightEar = lm[454];

      // Yaw: horizontal angle from ears
      const earDx = rightEar.x - leftEar.x;
      const earDz = rightEar.z - leftEar.z;
      const yaw = Math.atan2(earDz, earDx);

      // Pitch: vertical angle from forehead to chin
      const faceDy = chin.y - forehead.y;
      const faceDz = chin.z - forehead.z;
      const pitch = Math.atan2(faceDz, faceDy);

      // Roll: tilt from ear heights
      const earDy = rightEar.y - leftEar.y;
      const earDist = Math.sqrt(earDx * earDx + earDy * earDy);
      const roll = Math.atan2(earDy, earDist);

      return { pitch, yaw, roll };
    }

    // Cache raw bone references
    const headBone = vrm.humanoid.getRawBoneNode('head');
    const neckBone = vrm.humanoid.getRawBoneNode('neck');
    const spineBone = vrm.humanoid.getRawBoneNode('upperChest') || vrm.humanoid.getRawBoneNode('spine');

    // Store rest quaternions so we can compose on top of them
    const headRest = headBone ? headBone.quaternion.clone() : null;
    const neckRest = neckBone ? neckBone.quaternion.clone() : null;
    const spineRest = spineBone ? spineBone.quaternion.clone() : null;

    console.log('Bone setup — head:', !!headBone, 'neck:', !!neckBone, 'spine:', !!spineBone);

    // --- Animation Loop ---
    const clock = new THREE.Clock();
    let frameCount = 0;
    let lastFpsUpdate = 0;
    let fps = 0;
    let faceDetected = false;

    function animate() {
      requestAnimationFrame(animate);
      const delta = clock.getDelta();

      if (vrm && faceLandmarker && videoEl && videoEl.readyState >= 2) {
        const now = performance.now();
        let result;
        try {
          result = faceLandmarker.detectForVideo(videoEl, now);
        } catch (e) {
          renderer.render(scene, camera);
          return;
        }

        faceDetected = !!(result.faceBlendshapes && result.faceBlendshapes.length > 0);

        if (faceDetected) {
          const bs = result.faceBlendshapes;

          // --- Expressions ---
          vrm.expressionManager.setValue('blinkLeft', lerp('blinkL', getBS(bs, 'eyeBlinkLeft'), 0.5));
          vrm.expressionManager.setValue('blinkRight', lerp('blinkR', getBS(bs, 'eyeBlinkRight'), 0.5));

          const jawOpen = getBS(bs, 'jawOpen');
          const smile = (getBS(bs, 'mouthSmileLeft') + getBS(bs, 'mouthSmileRight')) / 2;
          vrm.expressionManager.setValue('aa', lerp('mouth', jawOpen * 1.2, 0.4));
          vrm.expressionManager.setValue('happy', lerp('smile', smile, 0.3));

          vrm.expressionManager.setValue('surprised', lerp('browUp', getBS(bs, 'browInnerUp') * 0.7, 0.3));
          vrm.expressionManager.setValue('angry', lerp('browDown', (getBS(bs, 'browDownLeft') + getBS(bs, 'browDownRight')) / 2 * 0.5, 0.3));

          vrm.expressionManager.setValue('lookLeft', lerp('lookL', getBS(bs, 'eyeLookOutLeft'), 0.3));
          vrm.expressionManager.setValue('lookRight', lerp('lookR', getBS(bs, 'eyeLookOutRight'), 0.3));
          vrm.expressionManager.setValue('lookUp', lerp('lookUp', getBS(bs, 'eyeLookUpLeft'), 0.3));
          vrm.expressionManager.setValue('lookDown', lerp('lookDown', getBS(bs, 'eyeLookDownLeft'), 0.3));
        }

        // Let VRM system apply expressions and internal updates
        vrm.update(delta);

        // --- Head rotation: apply on RAW bones AFTER vrm.update() ---
        if (faceDetected && result.faceLandmarks && result.faceLandmarks.length > 0) {
          const rot = computeHeadRotation(result.faceLandmarks);
          if (rot) {
            const p = lerp('headP', rot.pitch, 0.3);
            const y = lerp('headY', rot.yaw, 0.3);
            const r = lerp('headR', rot.roll, 0.3);

            // Head: main rotation
            if (headBone && headRest) {
              const q = new THREE.Quaternion().setFromEuler(new THREE.Euler(p * 0.6, y * 0.6, r * 0.4));
              headBone.quaternion.copy(headRest).multiply(q);
            }

            // Neck: subtle follow
            if (neckBone && neckRest) {
              const q = new THREE.Quaternion().setFromEuler(new THREE.Euler(p * 0.2, y * 0.2, r * 0.1));
              neckBone.quaternion.copy(neckRest).multiply(q);
            }

            // Spine: very subtle
            if (spineBone && spineRest) {
              const q = new THREE.Quaternion().setFromEuler(new THREE.Euler(p * 0.05, y * 0.05, 0));
              spineBone.quaternion.copy(spineRest).multiply(q);
            }
          }
        }
      }

      // FPS counter
      if (MODE !== 'stream' && statusBar) {
        frameCount++;
        const now = performance.now();
        if (now - lastFpsUpdate > 1000) {
          fps = frameCount;
          frameCount = 0;
          lastFpsUpdate = now;
          const camReady = videoEl && videoEl.readyState >= 2;
          const status = !camReady ? 'No camera' : !faceDetected ? 'No face' : 'Tracking';
          statusBar.textContent = `${fps} FPS | ${status}`;
        }
      }

      renderer.render(scene, camera);
    }

    animate();

    // --- Resize ---
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  </script>
</body>
</html>
