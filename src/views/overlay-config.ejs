      <button type="button" class="btn btn-secondary" id="trim-upload-full-btn" onclick="uploadFull()">Upload Full</button>
      <button type="button" class="btn btn-primary" id="trim-apply-btn" onclick="applyTrimAndUpload()">Trim &amp; Upload</button>
    </div>
  </div>
</div>

<script>
  // ─── Audio synth (default sound previews) ───────────────────────────────────
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

  function createNoise(duration, vol) {
    const buffer = audioCtx.createBuffer(1, audioCtx.sampleRate * duration, audioCtx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1);
    const source = audioCtx.createBufferSource();
    source.buffer = buffer;
    const gain = audioCtx.createGain();
    gain.gain.value = vol;
    source.connect(gain);
    return { source, gain };
  }

  function engineRev(startFreq, endFreq, duration, vol) {
    const t = audioCtx.currentTime;
    const osc1 = audioCtx.createOscillator();
    osc1.type = 'sawtooth';
    osc1.frequency.setValueAtTime(startFreq, t);
    osc1.frequency.exponentialRampToValueAtTime(endFreq, t + duration * 0.7);
    osc1.frequency.exponentialRampToValueAtTime(endFreq * 0.8, t + duration);
    const osc2 = audioCtx.createOscillator();
    osc2.type = 'sawtooth';
    osc2.frequency.setValueAtTime(startFreq / 2, t);
    osc2.frequency.exponentialRampToValueAtTime(endFreq / 2, t + duration * 0.7);
    const distortion = audioCtx.createWaveShaper();
    const curve = new Float32Array(256);
    for (let i = 0; i < 256; i++) { const x = (i * 2) / 256 - 1; curve[i] = (Math.PI + 3.4) * x / (Math.PI + 3.4 * Math.abs(x)); }
    distortion.curve = curve;
    const gain = audioCtx.createGain();
    gain.gain.setValueAtTime(vol, t);
    gain.gain.setValueAtTime(vol, t + duration * 0.8);
    gain.gain.exponentialRampToValueAtTime(0.001, t + duration);
    osc1.connect(distortion); osc2.connect(distortion);
    distortion.connect(gain); gain.connect(audioCtx.destination);
    osc1.start(t); osc1.stop(t + duration);
    osc2.start(t); osc2.stop(t + duration);
  }

  function turboBlowoff(vol) {
    const t = audioCtx.currentTime;
    const spool = audioCtx.createOscillator();
    spool.type = 'sine';
    spool.frequency.setValueAtTime(2000, t);
    spool.frequency.exponentialRampToValueAtTime(6000, t + 0.3);
    const spoolGain = audioCtx.createGain();
    spoolGain.gain.setValueAtTime(vol * 0.3, t);
    spoolGain.gain.exponentialRampToValueAtTime(0.001, t + 0.35);
    spool.connect(spoolGain); spoolGain.connect(audioCtx.destination);
    spool.start(t); spool.stop(t + 0.35);
    const { source: noise, gain: noiseGain } = createNoise(0.25, vol * 0.4);
    const filter = audioCtx.createBiquadFilter();
    filter.type = 'bandpass';
    filter.frequency.setValueAtTime(4000, t + 0.3);
    filter.frequency.exponentialRampToValueAtTime(800, t + 0.55);
    filter.Q.value = 2;
    noiseGain.disconnect(); noise.connect(noiseGain); noiseGain.connect(filter);
    const noiseEnv = audioCtx.createGain();
    noiseEnv.gain.setValueAtTime(vol * 0.5, t + 0.3);
    noiseEnv.gain.exponentialRampToValueAtTime(0.001, t + 0.55);
    filter.connect(noiseEnv); noiseEnv.connect(audioCtx.destination);
    noise.start(t + 0.3); noise.stop(t + 0.55);
  }

  function tireScreech(vol) {
    const t = audioCtx.currentTime;
    const { source: noise, gain: noiseGain } = createNoise(0.3, vol * 0.3);
    const filter = audioCtx.createBiquadFilter();
    filter.type = 'highpass';
    filter.frequency.setValueAtTime(3000, t);
    filter.frequency.exponentialRampToValueAtTime(6000, t + 0.15);
    filter.frequency.exponentialRampToValueAtTime(2000, t + 0.3);
    filter.Q.value = 8;
    noiseGain.disconnect(); noise.connect(noiseGain); noiseGain.connect(filter);
    const env = audioCtx.createGain();
    env.gain.setValueAtTime(vol * 0.35, t);
    env.gain.exponentialRampToValueAtTime(0.001, t + 0.3);
    filter.connect(env); env.connect(audioCtx.destination);
    noise.start(t); noise.stop(t + 0.3);
  }

  const defaultSounds = {
    follow: () => { tireScreech(0.3); setTimeout(() => engineRev(80, 200, 0.4, 0.2), 200); },
    subscription: () => { engineRev(60, 180, 0.6, 0.15); turboBlowoff(0.25); },
    bits: () => { engineRev(100, 400, 0.15, 0.2); setTimeout(() => engineRev(200, 600, 0.15, 0.25), 120); setTimeout(() => engineRev(300, 800, 0.2, 0.3), 240); },
    donation: () => { engineRev(40, 60, 0.3, 0.15); setTimeout(() => engineRev(60, 300, 0.5, 0.25), 250); },
    raid: () => { engineRev(50, 150, 0.6, 0.12); setTimeout(() => engineRev(60, 180, 0.5, 0.15), 100); setTimeout(() => engineRev(70, 200, 0.5, 0.18), 200); setTimeout(() => tireScreech(0.2), 500); },
    yt_superchat: () => { engineRev(80, 250, 0.5, 0.2); setTimeout(() => turboBlowoff(0.2), 300); },
    yt_member: () => { engineRev(50, 150, 0.6, 0.15); },
    yt_giftmember: () => { engineRev(80, 300, 0.3, 0.2); setTimeout(() => engineRev(100, 400, 0.3, 0.25), 250); },
  };

  // ─── Sound status ────────────────────────────────────────────────────────────
  let customSounds = {};

  async function loadSoundStatus() {
    const res = await fetch('/dashboard/overlay/sounds/status');
    customSounds = await res.json();
    Object.keys(customSounds).forEach(type => {
      const statusEl = document.getElementById('sound-status-' + type);
      const removeBtn = document.getElementById('remove-btn-' + type);
      if (customSounds[type]) {
        if (statusEl) { statusEl.textContent = 'Custom'; statusEl.className = 'sound-badge custom'; }
        if (removeBtn) removeBtn.style.display = '';
      } else {
        if (statusEl) { statusEl.textContent = 'Default'; statusEl.className = 'sound-badge'; }
        if (removeBtn) removeBtn.style.display = 'none';
      }
    });
  }

  // Volume slider — update all sliders + hidden input + label
  function updateVolume(slider) {
    const val = slider.value;
    // Update hidden input
    document.querySelector('input[name="overlay_volume"]').value = (val / 100).toFixed(2);
    // Sync all sliders and labels
    document.querySelectorAll('.volume-slider').forEach(s => { s.value = val; });
    document.querySelectorAll('.vol-val').forEach(s => { s.textContent = val + '%'; });
  }

  function previewSound(type) {
    if (audioCtx.state === 'suspended') audioCtx.resume();
    if (customSounds[type]) {
      const audio = new Audio('/overlay/sounds/' + type + '.mp3?t=' + Date.now());
      audio.volume = parseFloat(document.getElementById('overlay_volume').value) || 0.8;
      audio.play().catch(() => {});
    } else if (defaultSounds[type]) {
      defaultSounds[type]();
    }
  }

  async function removeSound(type) {
    if (!confirm('Remove custom sound and revert to default?')) return;
    await fetch('/dashboard/overlay/sounds/' + type + '/delete', { method: 'POST' });
    loadSoundStatus();
  }

  loadSoundStatus();

  // ─── Copy overlay URL ────────────────────────────────────────────────────────
  function copyOverlayUrl() {
    const input = document.getElementById('overlay-url-input');
    if (!input) return;
    navigator.clipboard.writeText(input.value).then(() => {
      const btn = document.getElementById('copy-btn');
      const orig = btn.innerHTML;
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
      btn.style.color = 'var(--success)';
      btn.style.borderColor = 'var(--success)';
      setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; btn.style.borderColor = ''; }, 2000);
    }).catch(() => { input.select(); document.execCommand('copy'); });
  }

  // ─── Preview alert modal ─────────────────────────────────────────────────────
  let previewAutoClose = null;

  function openPreview(type) {
    const modal = document.getElementById('preview-modal');
    const iframe = document.getElementById('preview-iframe');
    const statusEl = document.getElementById('preview-status');
    const overlayUrlBase = document.getElementById('overlay-url-input') ? document.getElementById('overlay-url-input').value : '';

    if (!overlayUrlBase) return;

    // Clear any previous auto-close
    if (previewAutoClose) { clearTimeout(previewAutoClose); previewAutoClose = null; }

    statusEl.textContent = 'Firing test event...';
    iframe.src = overlayUrlBase;
    modal.classList.add('open');

    // Duration map for auto-close timing
    const durationMap = {
      follow: parseInt(document.querySelector('[name="overlay_follow_duration"]')?.value) || 5,
      subscription: parseInt(document.querySelector('[name="overlay_sub_duration"]')?.value) || 7,
      bits: parseInt(document.querySelector('[name="overlay_bits_duration"]')?.value) || 6,
      donation: parseInt(document.querySelector('[name="overlay_donation_duration"]')?.value) || 6,
      raid: 6,
    };
    const alertDuration = durationMap[type] || 6;

    // Fire the test event after iframe has a moment to load and connect SSE
    setTimeout(() => {
      fetch('/dashboard/overlay/test/' + type, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
          if (data.ok) {
            statusEl.textContent = 'Alert fired — watch the preview screen.';
            // Auto-close after alert duration + small buffer
            previewAutoClose = setTimeout(() => closePreview(), alertDuration * 1000 + 2000);
          } else {
            statusEl.textContent = 'Error: ' + (data.error || 'Unknown error');
          }
        })
        .catch(err => { statusEl.textContent = 'Request failed: ' + err.message; });
    }, 1500);
  }

  function closePreview() {
    const modal = document.getElementById('preview-modal');
    const iframe = document.getElementById('preview-iframe');
    modal.classList.remove('open');
    iframe.src = '';
    if (previewAutoClose) { clearTimeout(previewAutoClose); previewAutoClose = null; }
  }

  // Close on Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      closePreview();
      closeTrimModal();
    }
  });

  // ─── Sound trim modal ────────────────────────────────────────────────────────
  let trimEventType = null;
  let trimAudioBuffer = null;
  let trimFile = null;
  let trimDuration = 0;

  function openTrimModal(type) {
    trimEventType = type;
    trimAudioBuffer = null;
    trimFile = null;

    // Open file picker first
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = 'audio/*,.mp3,.wav,.ogg,.m4a';
    input.onchange = async () => {
      const file = input.files[0];
      if (!file) return;
      trimFile = file;

      // Load into audio element for playback
      const url = URL.createObjectURL(file);
      const player = document.getElementById('trim-audio-player');
      player.src = url;

      // Decode for Web Audio
      const arrayBuf = await file.arrayBuffer();
      try {
        trimAudioBuffer = await audioCtx.decodeAudioData(arrayBuf);
        trimDuration = trimAudioBuffer.duration;
      } catch (e) {
        // If decode fails (e.g. format not supported) still let user upload full
        trimDuration = 0;
        trimAudioBuffer = null;
      }

      // Set slider max to duration
      const startSlider = document.getElementById('trim-start');
      const endSlider = document.getElementById('trim-end');
      startSlider.max = trimDuration > 0 ? trimDuration : 100;
      startSlider.value = 0;
      endSlider.max = trimDuration > 0 ? trimDuration : 100;
      endSlider.value = trimDuration > 0 ? trimDuration : 100;
      document.getElementById('trim-start-val').textContent = '0.00s';
      document.getElementById('trim-end-val').textContent = trimDuration > 0 ? trimDuration.toFixed(2) + 's' : '—';

      document.getElementById('trim-apply-btn').disabled = !trimAudioBuffer;
      document.getElementById('trim-modal').classList.add('open');
    };
    input.click();
  }

  function onTrimSlider(which) {
    const startSlider = document.getElementById('trim-start');
    const endSlider = document.getElementById('trim-end');
    let startVal = parseFloat(startSlider.value);
    let endVal = parseFloat(endSlider.value);

    // Clamp: start cannot exceed end
    if (which === 'start' && startVal >= endVal) {
      startVal = endVal - 0.1;
      startSlider.value = startVal;
    }
    if (which === 'end' && endVal <= startVal) {
      endVal = startVal + 0.1;
      endSlider.value = endVal;
    }

    document.getElementById('trim-start-val').textContent = startVal.toFixed(2) + 's';
    document.getElementById('trim-end-val').textContent = endVal.toFixed(2) + 's';
  }

  function closeTrimModal() {
    document.getElementById('trim-modal').classList.remove('open');
    const player = document.getElementById('trim-audio-player');
    player.pause();
    player.src = '';
    trimEventType = null;
    trimAudioBuffer = null;
    trimFile = null;
  }

  async function uploadFull() {
    if (!trimFile || !trimEventType) return;
    const data = await trimFile.arrayBuffer();
    const res = await fetch('/dashboard/overlay/sounds/' + trimEventType, {
      method: 'POST',
      headers: { 'Content-Type': 'audio/mpeg' },
      body: data,
    });
    const result = await res.json();
    if (result.ok) { loadSoundStatus(); closeTrimModal(); }
    else alert('Upload failed: ' + (result.error || 'Unknown error'));
  }

  async function applyTrimAndUpload() {
    if (!trimAudioBuffer || !trimEventType) return;
    const startVal = parseFloat(document.getElementById('trim-start').value);
    const endVal = parseFloat(document.getElementById('trim-end').value);

    const wavBlob = audioBufferToWav(trimAudioBuffer, startVal, endVal);
    const arrayBuf = await wavBlob.arrayBuffer();

    const res = await fetch('/dashboard/overlay/sounds/' + trimEventType, {
      method: 'POST',
      headers: { 'Content-Type': 'audio/mpeg' },
      body: arrayBuf,
    });
    const result = await res.json();
    if (result.ok) { loadSoundStatus(); closeTrimModal(); }
    else alert('Upload failed: ' + (result.error || 'Unknown error'));
  }

  function writeString(view, offset, str) {
    for (let i = 0; i < str.length; i++) view.setUint8(offset + i, str.charCodeAt(i));
  }

  function audioBufferToWav(buffer, start, end) {
    const sampleRate = buffer.sampleRate;
    const numChannels = buffer.numberOfChannels;
    const startSample = Math.floor(start * sampleRate);
    const endSample = Math.floor(end * sampleRate);
    const length = Math.max(0, endSample - startSample);

    const wavBuffer = new ArrayBuffer(44 + length * numChannels * 2);
    const view = new DataView(wavBuffer);

    writeString(view, 0, 'RIFF');
    view.setUint32(4, 36 + length * numChannels * 2, true);
    writeString(view, 8, 'WAVE');
    writeString(view, 12, 'fmt ');
    view.setUint32(16, 16, true);
    view.setUint16(20, 1, true); // PCM
    view.setUint16(22, numChannels, true);
    view.setUint32(24, sampleRate, true);
    view.setUint32(28, sampleRate * numChannels * 2, true);
    view.setUint16(32, numChannels * 2, true);
    view.setUint16(34, 16, true);
    writeString(view, 36, 'data');
    view.setUint32(40, length * numChannels * 2, true);

    let offset = 44;
    for (let i = 0; i < length; i++) {
      for (let ch = 0; ch < numChannels; ch++) {
        const channelData = buffer.getChannelData(ch);
        const s = Math.max(-1, Math.min(1, channelData[startSample + i]));
        view.setInt16(offset, s < 0 ? s * 0x8000 : s * 0x7FFF, true);
        offset += 2;
      }
    }
    return new Blob([wavBuffer], { type: 'audio/wav' });
  }
</script>

<div id="clear-status" style="margin-top: 8px; font-size: 12px; color: var(--text-muted); display: none; text-align: center;"></div>

<script>
async function clearOverlayAlerts() {
  try {
    const res = await fetch('/overlay/clear', { method: 'POST' });
    const data = await res.json();
    if (data.ok) {
      const el = document.getElementById('clear-status');
      el.style.display = 'block';
      el.style.color = 'var(--success)';
      el.textContent = 'Overlay cleared!';
      setTimeout(() => { el.style.display = 'none'; }, 3000);
    }
  } catch (e) {}
}

// Keep sendTestAlert for Preview Alert buttons (they still use the test endpoint internally)
async function sendTestAlert(type, amount) {
  const statusEl = document.getElementById('test-alert-status');
  statusEl.style.display = 'block';
  statusEl.style.color = 'var(--text-muted)';
  statusEl.textContent = 'Sending test alert...';

  try {
    const res = await fetch('/overlay/test-alert', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type, amount: parseInt(amount) || undefined }),
    });
    const data = await res.json();
    if (data.ok) {
      statusEl.style.color = 'var(--success)';
      statusEl.textContent = `Test ${type} alert sent! Check your OBS overlay.`;
    } else {
      statusEl.style.color = 'var(--danger)';
      statusEl.textContent = data.error || 'Failed to send test alert.';
    }
  } catch (e) {
    statusEl.style.color = 'var(--danger)';
    statusEl.textContent = 'Error sending test alert.';
  }

  setTimeout(() => { statusEl.style.display = 'none'; }, 5000);
}
</script>

