<%- include('header', { title: 'Overlay Config', streamer: streamer }) %>

<style>
  /* Pill toggle */
  .pill-toggle { position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; }
  .pill-toggle input { opacity: 0; width: 0; height: 0; }
  .pill-toggle .slider { position: absolute; cursor: pointer; inset: 0; background: var(--bg-elevated); border-radius: 24px; border: 1px solid var(--border); transition: 0.3s; }
  .pill-toggle .slider:before { content: ''; position: absolute; height: 18px; width: 18px; left: 2px; bottom: 2px; background: #fff; border-radius: 50%; transition: 0.3s; }
  .pill-toggle input:checked + .slider { background: var(--accent); border-color: var(--accent); }
  .pill-toggle input:checked + .slider:before { transform: translateX(20px); }

  /* Alert card — Option A compact layout */
  .alert-card { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 20px; margin-bottom: 12px; transition: border-color 0.2s; }
  .alert-card:hover { border-color: rgba(145,70,255,0.3); }
  .alert-card { display: flex; flex-direction: column; }
  .alert-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .alert-card-info { display: flex; align-items: center; gap: 10px; }
  .alert-card-icon { font-size: 20px; }
  .alert-card-title { font-size: 15px; font-weight: 700; color: var(--text-primary); }
  .alert-card-desc { font-size: 11px; color: var(--text-muted); }
  .alert-card-controls { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; padding-top: 14px; margin-top: auto; border-top: 1px solid var(--border); }
  .alert-ctrl { display: flex; align-items: center; gap: 6px; }
  .alert-ctrl-label { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .alert-ctrl input[type=number] { width: 56px; padding: 5px 8px; background: var(--bg-base); border: 1px solid var(--border); border-radius: 6px; color: var(--text-primary); font-size: 13px; outline: none; text-align: center; }
  .alert-ctrl input[type=range] { width: 90px; accent-color: var(--accent); cursor: pointer; }
  .alert-ctrl .vol-val { font-size: 12px; color: var(--text-muted); min-width: 30px; }
  .alert-card-footer { display: flex; align-items: center; justify-content: flex-end; gap: 6px; margin-top: 14px; }
  .sound-row { display: flex; align-items: center; gap: 8px; margin-right: auto; }
  .sound-row .btn { font-size: 13px !important; padding: 7px 14px !important; }
  .sound-badge { font-size: 10px; padding: 2px 8px; border-radius: 10px; background: var(--bg-elevated); color: var(--text-muted); font-weight: 600; }
  .sound-badge.custom { background: rgba(145,71,255,0.15); color: #9146ff; }

  /* Volume slider */
  .vol-row { display: flex; align-items: center; gap: 10px; }
  .vol-row input[type=range] { flex: 1; accent-color: var(--accent); cursor: pointer; }
  .vol-val { font-family: var(--font-display); font-weight: 600; font-size: 13px; min-width: 36px; text-align: right; }

  /* Preview modal */
  .preview-modal { display: none; position: fixed; inset: 0; z-index: 9999; }
  .preview-modal.open { display: flex; align-items: center; justify-content: center; }
  .preview-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(4px); }
  .preview-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 24px; max-width: 900px; width: 95vw; }
  .preview-screen { width: 100%; aspect-ratio: 16/9; background: #0a0a0a; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); overflow: hidden; position: relative; box-shadow: 0 0 60px rgba(0,0,0,0.6); }
  .preview-screen iframe { width: 100%; height: 100%; border: none; display: block; }
  .preview-screen-label { position: absolute; top: 10px; left: 12px; font-size: 11px; color: rgba(255,255,255,0.3); font-family: var(--font-display); pointer-events: none; }
  .preview-actions { display: flex; gap: 10px; align-items: center; }
  .preview-status { font-size: 12px; color: rgba(255,255,255,0.5); font-family: var(--font-display); }

  /* Trim modal */
  .trim-modal { display: none; position: fixed; inset: 0; z-index: 10000; }
  .trim-modal.open { display: flex; align-items: center; justify-content: center; }
  .trim-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.75); }
  .trim-content { position: relative; z-index: 1; background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; width: 480px; max-width: 95vw; }
  .trim-content h4 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .trim-content p { font-size: 13px; color: var(--text-secondary); margin-bottom: 20px; }
  .trim-field { margin-bottom: 16px; }
  .trim-field label { display: flex; justify-content: space-between; font-size: 12px; font-weight: 600; color: var(--text-secondary); font-family: var(--font-display); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
  .trim-field input[type=range] { width: 100%; accent-color: var(--accent); cursor: pointer; }
  .trim-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
  #trim-audio-player { width: 100%; margin-bottom: 16px; border-radius: 4px; }
</style>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<div style="display: flex; align-items: center; justify-content: space-between; margin: 16px 0 8px; flex-wrap: wrap; gap: 12px;">
  <h2 style="font-size: 24px; font-weight: 700;" class="animate-in">Overlay Configuration</h2>
  <a id="builder-link" href="/dashboard/overlay-builder" style="font-size: 13px; padding: 8px 14px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; background: rgba(145,71,255,0.1); border: 1px solid rgba(145,71,255,0.25); border-radius: var(--radius-sm); color: #9146ff; font-family: var(--font-display); font-weight: 600; transition: background 0.15s;" onmouseover="this.style.background='rgba(145,71,255,0.2)'" onmouseout="this.style.background='rgba(145,71,255,0.1)'">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
    Customize Visual Design →
  </a>
  <script>
    // Preserve tab context when navigating back to builder
    const tab = new URLSearchParams(window.location.search).get('tab');
    if (tab) document.getElementById('builder-link').href = '/dashboard/overlay-builder?tab=' + tab;
  </script>
</div>
<p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 24px;">Set up your stream overlay to show live alerts for follows, subscriptions, bits, and donations.</p>

<% if (needsReauth) { %>
  <div class="alert alert-warning">
    <strong>Broadcaster re-authentication required.</strong>
    Your Twitch broadcaster token is missing required scopes (<code>moderator:read:followers</code>, <code>bits:read</code>).
    <a href="/auth/broadcaster" style="color: var(--warning); text-decoration: underline; margin-left: 6px;">Re-authenticate now &rarr;</a>
  </div>
<% } %>

<!-- Overlay URL -->
<div class="card animate-in">
  <h3>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2"/></svg>
    OBS Overlay URL
  </h3>
  <% if (overlayUrl) { %>
    <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 12px;">
      Add these as separate Browser Sources in OBS. Recommended size: <strong>1920 &times; 1080</strong>.
    </p>
    <div style="margin-bottom: 10px;">
      <label style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 4px;">Alerts (follows, subs, bits, donations, raids)</label>
      <div style="display: flex; gap: 8px; align-items: center;">
        <input type="text" id="overlay-url-input" value="<%= overlayUrl %>" readonly
          style="flex: 1; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border);
                 border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body);
                 font-size: 13px; outline: none;">
        <button onclick="copyOverlayUrl()" class="btn btn-secondary" id="copy-btn" style="flex-shrink: 0;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copy
        </button>
      </div>
    </div>
    <div>
      <label style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 4px;">Sponsors (image rotation)</label>
      <div style="display: flex; gap: 8px; align-items: center;">
        <input type="text" id="sponsor-url-input" value="<%= overlayUrl.replace('/overlay/', '/overlay/sponsors/') %>" readonly
          style="flex: 1; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border);
                 border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body);
                 font-size: 13px; outline: none;">
        <button onclick="navigator.clipboard.writeText(document.getElementById('sponsor-url-input').value); this.textContent='Copied!'; setTimeout(() => this.innerHTML='<svg width=14 height=14 viewBox=&quot;0 0 24 24&quot; fill=none stroke=currentColor stroke-width=2><rect x=9 y=9 width=13 height=13 rx=2/><path d=&quot;M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1&quot;/></svg> Copy', 1500);" class="btn btn-secondary" style="flex-shrink: 0;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copy
        </button>
      </div>
    </div>
    <!-- Custom overlay URLs — DISABLED for now -->
  <% } else { %>
    <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 16px;">
      Generate a unique overlay URL to use in OBS as a Browser Source.
    </p>
    <form method="POST" action="/dashboard/overlay/generate-token" style="margin: 0;">
      <button type="submit" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        Generate Overlay URL
      </button>
    </form>
  <% } %>
</div>

<!-- Main Settings Form -->
<form method="POST" action="/dashboard/overlay">

  <!-- Overlay Status -->
  <div class="card animate-in animate-in-delay-1">
    <h3>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
      Overlay Status
    </h3>
    <div class="toggle">
      <input type="checkbox" id="overlay_enabled" name="overlay_enabled" value="1" <%= streamer.overlay_enabled ? 'checked' : '' %>>
      <label for="overlay_enabled">Enable overlay (connect EventSub + StreamElements)</label>
    </div>
    <p style="color: var(--text-muted); font-size: 13px;">When enabled, the overlay will receive live events from Twitch and StreamElements.</p>
  </div>

  <!-- Alerts Section -->
  <div class="animate-in animate-in-delay-2">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
      <div>
        <h3 style="margin: 0 0 4px; font-size: 17px; display: flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
          Alerts
        </h3>
        <p style="color: var(--text-secondary); font-size: 13px; margin: 0;">Configure each event alert individually.</p>
      </div>
      <button onclick="clearOverlayAlerts()" class="btn btn-danger" style="padding: 7px 16px; font-size: 12px; white-space: nowrap;">Clear All Alerts</button>
    </div>
    <input type="hidden" name="overlay_volume" value="<%= streamer.overlay_volume != null ? streamer.overlay_volume : 0.8 %>">

    <!-- Follow -->
    <div class="alert-card">
      <div class="alert-card-header">
        <div class="alert-card-info">
          <span class="alert-card-icon">🏁</span>
          <div>
            <div class="alert-card-title">Follow</div>
            <div class="alert-card-desc">Alert when someone follows your channel</div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" name="overlay_follow_enabled" value="1" <%= streamer.overlay_follow_enabled !== 0 ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="alert-card-controls">
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Duration</span>
          <input type="number" name="overlay_follow_duration" value="<%= streamer.overlay_follow_duration || 5 %>" min="1" max="30">
          <span style="font-size: 12px; color: var(--text-muted);">s</span>
        </div>
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Volume</span>
          <input type="range" min="0" max="100" value="<%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>" class="volume-slider" oninput="updateVolume(this)">
          <span class="vol-val"><%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>%</span>
        </div>
        <div class="sound-row" style="margin-left: auto;">
          <span class="sound-badge" id="sound-status-follow">Default</span>
          <button type="button" onclick="previewSound('follow')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">▶ Play</button>
          <button type="button" onclick="openTrimModal('follow')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">Upload</button>
          <button type="button" onclick="removeSound('follow')" class="btn btn-secondary" id="remove-btn-follow" style="font-size: 13px; padding: 7px 14px; color: var(--danger); display: none;">✕</button>
        </div>
        <% if (overlayUrl) { %>
        <button type="button" onclick="openPreview('follow')" class="btn btn-primary" style="font-size: 13px; padding: 8px 18px; display: flex; align-items: center; gap: 6px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Preview Alert
        </button>
        <% } %>
      </div>
    </div>

    <!-- Subscription -->
    <div class="alert-card">
      <div class="alert-card-header">
        <div class="alert-card-info">
          <span class="alert-card-icon">🏆</span>
          <div>
            <div class="alert-card-title">Subscription</div>
            <div class="alert-card-desc">Alert for new subs and resubs</div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" name="overlay_sub_enabled" value="1" <%= streamer.overlay_sub_enabled !== 0 ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="alert-card-controls">
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Duration</span>
          <input type="number" name="overlay_sub_duration" value="<%= streamer.overlay_sub_duration || 7 %>" min="1" max="30">
          <span style="font-size: 12px; color: var(--text-muted);">s</span>
        </div>
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Volume</span>
          <input type="range" min="0" max="100" value="<%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>" class="volume-slider" oninput="updateVolume(this)">
          <span class="vol-val"><%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>%</span>
        </div>
        <div class="sound-row" style="margin-left: auto;">
          <span class="sound-badge" id="sound-status-subscription">Default</span>
          <button type="button" onclick="previewSound('subscription')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">▶ Play</button>
          <button type="button" onclick="openTrimModal('subscription')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">Upload</button>
          <button type="button" onclick="removeSound('subscription')" class="btn btn-secondary" id="remove-btn-subscription" style="font-size: 13px; padding: 7px 14px; color: var(--danger); display: none;">✕</button>
        </div>
        <% if (overlayUrl) { %>
        <button type="button" onclick="openPreview('subscription')" class="btn btn-primary" style="font-size: 13px; padding: 8px 18px; display: flex; align-items: center; gap: 6px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Preview Alert
        </button>
        <% } %>
      </div>
    </div>

    <!-- Bits -->
    <div class="alert-card">
      <div class="alert-card-header">
        <div class="alert-card-info">
          <span class="alert-card-icon">⛽</span>
          <div>
            <div class="alert-card-title">Bits / Cheers</div>
            <div class="alert-card-desc">Alert when someone cheers bits</div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" name="overlay_bits_enabled" value="1" <%= streamer.overlay_bits_enabled !== 0 ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="alert-card-controls">
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Duration</span>
          <input type="number" name="overlay_bits_duration" value="<%= streamer.overlay_bits_duration || 6 %>" min="1" max="30">
          <span style="font-size: 12px; color: var(--text-muted);">s</span>
        </div>
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Volume</span>
          <input type="range" min="0" max="100" value="<%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>" class="volume-slider" oninput="updateVolume(this)">
          <span class="vol-val"><%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>%</span>
        </div>
        <div class="sound-row" style="margin-left: auto;">
          <span class="sound-badge" id="sound-status-bits">Default</span>
          <button type="button" onclick="previewSound('bits')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">▶ Play</button>
          <button type="button" onclick="openTrimModal('bits')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">Upload</button>
          <button type="button" onclick="removeSound('bits')" class="btn btn-secondary" id="remove-btn-bits" style="font-size: 13px; padding: 7px 14px; color: var(--danger); display: none;">✕</button>
        </div>
        <% if (overlayUrl) { %>
        <button type="button" onclick="openPreview('bits')" class="btn btn-primary" style="font-size: 13px; padding: 8px 18px; display: flex; align-items: center; gap: 6px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Preview Alert
        </button>
        <% } %>
      </div>
    </div>

    <!-- Donation -->
    <div class="alert-card">
      <div class="alert-card-header">
        <div class="alert-card-info">
          <span class="alert-card-icon">💰</span>
          <div>
            <div class="alert-card-title">Donation</div>
            <div class="alert-card-desc">Alert for StreamElements donations</div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" name="overlay_donation_enabled" value="1" <%= streamer.overlay_donation_enabled !== 0 ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="alert-card-controls">
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Duration</span>
          <input type="number" name="overlay_donation_duration" value="<%= streamer.overlay_donation_duration || 6 %>" min="1" max="30">
          <span style="font-size: 12px; color: var(--text-muted);">s</span>
        </div>
        <div class="alert-ctrl">
          <span class="alert-ctrl-label">Volume</span>
          <input type="range" min="0" max="100" value="<%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>" class="volume-slider" oninput="updateVolume(this)">
          <span class="vol-val"><%= Math.round((streamer.overlay_volume != null ? streamer.overlay_volume : 0.8) * 100) %>%</span>
        </div>
        <div class="sound-row" style="margin-left: auto;">
          <span class="sound-badge" id="sound-status-donation">Default</span>
          <button type="button" onclick="previewSound('donation')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">▶ Play</button>
          <button type="button" onclick="openTrimModal('donation')" class="btn btn-secondary" style="font-size: 13px; padding: 7px 14px;">Upload</button>
          <button type="button" onclick="removeSound('donation')" class="btn btn-secondary" id="remove-btn-donation" style="font-size: 13px; padding: 7px 14px; color: var(--danger); display: none;">✕</button>
        </div>
        <% if (overlayUrl) { %>
        <button type="button" onclick="openPreview('donation')" class="btn btn-primary" style="font-size: 13px; padding: 8px 18px; display: flex; align-items: center; gap: 6px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Preview Alert
        </button>
        <% } %>
      </div>
    </div>

    <!-- Raid -->
    <div class="alert-card">
      <div class="alert-card-header">
        <div class="alert-card-info">
          <span class="alert-card-icon">🏎️</span>
          <div>
            <div class="alert-card-title">Raid</div>
            <div class="alert-card-desc">Alert when someone raids your channel</div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" name="overlay_raid_enabled" value="1" <%= streamer.overlay_raid_enabled !== 0 ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
