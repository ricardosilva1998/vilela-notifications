<%- include('header', { title: 'Sponsor Messages', streamer: streamer }) %>

<style>
  .sp-input {
    width: 100%; padding: 10px 14px;
    background: var(--bg-base); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text-primary);
    font-family: var(--font-body); font-size: 13px; outline: none;
    transition: border-color 0.2s;
  }
  .sp-input:focus { border-color: var(--accent); }
  .sp-input::placeholder { color: var(--text-muted); }
  .sp-label {
    display: block; font-size: 12px; font-weight: 600;
    color: var(--text-secondary); margin-bottom: 6px;
    font-family: var(--font-display); text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .toggle-pill { position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; }
  .toggle-pill input { opacity: 0; width: 0; height: 0; }
  .toggle-pill-slider { position: absolute; cursor: pointer; inset: 0; background: var(--border); border-radius: 24px; transition: 0.2s; }
  .toggle-pill-slider:before { position: absolute; content: ''; height: 18px; width: 18px; left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: 0.2s; }
  .toggle-pill input:checked + .toggle-pill-slider { background: var(--success); }
  .toggle-pill input:checked + .toggle-pill-slider:before { transform: translateX(20px); }

  .settings-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .settings-row:last-child { margin-bottom: 0; }
  .settings-row-label { flex: 1; font-size: 14px; color: var(--text-primary); font-weight: 500; }
  .settings-row-sub { font-size: 12px; color: var(--text-muted); margin-top: 1px; }

  .msg-card {
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius); margin-bottom: 12px;
    transition: border-color 0.2s; overflow: hidden;
  }
  .msg-card:hover { border-color: rgba(145,70,255,0.3); }
  .msg-card-body { padding: 16px 18px; }
  .msg-text { font-size: 14px; color: var(--text-primary); font-weight: 500; margin-bottom: 4px; word-break: break-word; }
  .msg-url { font-size: 12px; color: var(--accent); word-break: break-all; }
  .msg-url a { color: inherit; text-decoration: none; }
  .msg-url a:hover { text-decoration: underline; }
  .msg-card-footer {
    border-top: 1px solid var(--border); padding: 12px 18px;
    display: flex; align-items: center; gap: 8px;
    background: var(--bg-elevated);
  }
  .msg-card-footer .btn { font-size: 12px; padding: 6px 13px; }
  .msg-card-footer .spacer { flex: 1; }

  .inline-edit-wrap { overflow: hidden; max-height: 0; transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1), opacity 0.3s ease; opacity: 0; }
  .inline-edit-wrap.visible { max-height: 600px; opacity: 1; }
  .inline-edit-inner { border-top: 2px solid var(--accent); padding: 20px 18px; background: var(--bg-surface); }
  .inline-edit-inner h4 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--accent); margin-bottom: 16px; }

  .empty-state { text-align: center; padding: 56px 24px; background: var(--bg-surface); border: 1px dashed var(--border); border-radius: var(--radius); }
  .empty-state-icon { width: 56px; height: 56px; margin: 0 auto 16px; background: var(--bg-elevated); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .empty-state h4 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .empty-state p { font-size: 14px; color: var(--text-muted); }

  .status-msg {
    display: none; padding: 10px 16px; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 600; margin-bottom: 16px;
    background: rgba(62,207,142,0.1); color: var(--success); border: 1px solid rgba(62,207,142,0.2);
  }
  .status-msg.visible { display: block; }
</style>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<h2 style="margin: 16px 0 6px; font-size: 24px; font-weight: 700;" class="animate-in">Sponsor Chat Messages</h2>
<p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 28px;">
  Send rotating sponsor messages to your Twitch chat at set intervals. For sponsor image overlays, use the
  <a href="/dashboard/overlay-builder" style="color: var(--accent);">Overlay Builder</a> (Timed tab).
</p>

<div id="status-msg" class="status-msg"></div>

<!-- Settings Card -->
<div class="card animate-in" style="margin-bottom: 24px;">
  <h3 style="margin-bottom: 20px; font-size: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px;">
    <span style="width: 30px; height: 30px; background: rgba(145,70,255,0.12); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9146ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 1 1 4.93 19.07"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M2 12h2"/><path d="M20 12h2"/></svg>
    </span>
    Chat Settings
  </h3>

  <div class="settings-row">
    <div class="settings-row-label">
      Enable Chat Messages
      <div class="settings-row-sub">Automatically send sponsor messages to Twitch chat</div>
    </div>
    <label class="toggle-pill">
      <input type="checkbox" id="chat-enabled" <%= streamer.sponsor_send_chat ? 'checked' : '' %>>
      <span class="toggle-pill-slider"></span>
    </label>
  </div>

  <div class="settings-row" style="margin-top: 16px;">
    <div class="settings-row-label">
      Interval Between Messages
      <div class="settings-row-sub">How long to wait between each chat message</div>
    </div>
    <select id="chat-interval" class="sp-input" style="width: auto; min-width: 160px;">
      <% [5,10,15,20,30].forEach(function(m){ %>
        <option value="<%= m %>" <%= (streamer.sponsor_chat_interval_minutes || 10) == m ? 'selected' : '' %>>Every <%= m %> min</option>
      <% }); %>
    </select>
  </div>

  <div style="margin-top: 20px;">
    <button type="button" class="btn btn-primary" onclick="saveChatSettings()">Save Settings</button>
  </div>
</div>

<!-- Add Message Card -->
<div class="card animate-in" style="margin-bottom: 24px;">
  <h3 style="margin-bottom: 20px; font-size: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px;">
    <span style="width: 30px; height: 30px; background: rgba(145,70,255,0.12); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9146ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </span>
    Add Message
  </h3>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px;">
    <div>
      <label class="sp-label">Message Text</label>
      <input type="text" id="new-msg-text" class="sp-input" placeholder="e.g. Check out our sponsor Acme Corp!">
    </div>
    <div>
      <label class="sp-label">URL <span style="font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--text-muted);">(optional)</span></label>
      <input type="text" id="new-msg-url" class="sp-input" placeholder="e.g. https://acme.com">
    </div>
  </div>

  <button type="button" class="btn btn-primary" onclick="addMessage()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Add Message
  </button>
</div>

<!-- Messages List -->
<% if (messages.length === 0) { %>

  <div class="empty-state animate-in" id="empty-state">
    <div class="empty-state-icon">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </div>
    <h4>No messages yet</h4>
    <p>Add your first sponsor chat message above.</p>
  </div>

<% } else { %>

  <div class="animate-in" id="messages-container">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
      <h3 style="font-size: 14px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.06em;">
        Messages
        <span style="font-size: 12px; font-weight: 600; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 20px; padding: 1px 8px; margin-left: 6px; color: var(--text-muted); letter-spacing: 0;" id="msg-count"><%= messages.length %></span>
      </h3>
    </div>

    <% messages.forEach(function(m) { %>
    <div class="msg-card" id="msg-card-<%= m.id %>">
      <div class="msg-card-body">
        <div class="msg-text"><%= m.message_text %></div>
        <% if (m.url) { %>
          <div class="msg-url">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 3px;"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <a href="<%= m.url %>" target="_blank" rel="noopener"><%= m.url.length > 60 ? m.url.substring(0, 60) + '...' : m.url %></a>
          </div>
        <% } %>
      </div>

      <div class="msg-card-footer">
        <button type="button" class="btn btn-secondary" onclick="toggleEdit(<%= m.id %>)">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Edit
        </button>

        <label class="toggle-pill" title="<%= m.enabled ? 'Enabled' : 'Disabled' %>">
          <input type="checkbox" <%= m.enabled ? 'checked' : '' %> onchange="toggleMessage(<%= m.id %>, this.checked)">
          <span class="toggle-pill-slider"></span>
        </label>

        <div class="spacer"></div>

        <button type="button" class="btn btn-danger" onclick="deleteMessage(<%= m.id %>)">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
          Delete
        </button>
      </div>

      <!-- Inline edit -->
      <div class="inline-edit-wrap" id="edit-<%= m.id %>">
        <div class="inline-edit-inner">
          <h4>Edit Message</h4>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px;">
            <div>
              <label class="sp-label">Message Text</label>
              <input type="text" id="edit-text-<%= m.id %>" class="sp-input" value="<%= m.message_text %>">
            </div>
            <div>
              <label class="sp-label">URL</label>
              <input type="text" id="edit-url-<%= m.id %>" class="sp-input" value="<%= m.url || '' %>" placeholder="https://...">
            </div>
          </div>
          <div style="display: flex; gap: 8px;">
            <button type="button" class="btn btn-primary" style="padding: 9px 20px;" onclick="saveMessage(<%= m.id %>)">Save Changes</button>
            <button type="button" class="btn btn-secondary" style="padding: 9px 20px;" onclick="toggleEdit(<%= m.id %>)">Cancel</button>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

<% } %>

<script>
function showStatus(text) {
  const el = document.getElementById('status-msg');
  el.textContent = text;
  el.classList.add('visible');
  setTimeout(() => el.classList.remove('visible'), 3000);
}

function toggleEdit(id) {
  document.getElementById('edit-' + id).classList.toggle('visible');
}

async function saveChatSettings() {
  const enabled = document.getElementById('chat-enabled').checked;
  const interval = parseInt(document.getElementById('chat-interval').value) || 10;
  await fetch('/dashboard/sponsor-messages/settings', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ enabled: enabled ? '1' : '', interval_minutes: interval }),
  });
  showStatus('Settings saved!');
}

async function addMessage() {
  const text = document.getElementById('new-msg-text').value.trim();
  const url = document.getElementById('new-msg-url').value.trim();
  if (!text) return alert('Please enter a message');
  const res = await fetch('/dashboard/sponsor-messages/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ message_text: text, url: url || null }),
  });
  const data = await res.json();
  if (data.ok) window.location.reload();
}

async function saveMessage(id) {
  const text = document.getElementById('edit-text-' + id).value.trim();
  const url = document.getElementById('edit-url-' + id).value.trim();
  if (!text) return alert('Message text is required');
  await fetch(`/dashboard/sponsor-messages/${id}/update`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ message_text: text, url: url || null, enabled: '1' }),
  });
  window.location.reload();
}

async function toggleMessage(id, enabled) {
  const card = document.getElementById('msg-card-' + id);
  const textEl = card.querySelector('.msg-text');
  const text = textEl?.textContent || '';
  const urlEl = card.querySelector('.msg-url a');
  const url = urlEl?.getAttribute('href') || '';
  await fetch(`/dashboard/sponsor-messages/${id}/update`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ message_text: text, url: url || null, enabled: enabled ? '1' : '' }),
  });
}

async function deleteMessage(id) {
  if (!confirm('Delete this message?')) return;
  await fetch(`/dashboard/sponsor-messages/${id}/delete`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
  });
  const card = document.getElementById('msg-card-' + id);
  if (card) card.remove();
  showStatus('Message deleted');
}
</script>

<%- include('footer') %>
