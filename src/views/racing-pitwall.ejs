<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pitwall — <%= team.team_name %> — Atleta</title>
  <link rel="icon" href="/images/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
      --bg-base: #0c0d14;
      --bg-surface: #141520;
      --bg-elevated: #1a1b2e;
      --bg-hover: #1f2037;
      --border: rgba(255,255,255,0.06);
      --border-focus: rgba(145,70,255,0.4);
      --text-primary: #e8e6f0;
      --text-secondary: #8b8a9e;
      --text-muted: #5c5b6e;
      --accent: #9146ff;
      --accent-glow: rgba(145,70,255,0.15);
      --accent-hover: #a56bff;
      --success: #3ecf8e;
      --danger: #f04438;
      --warning: #f79009;
      --font-display: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      --timing-bar-h: 48px;
      --bottom-strip-h: 80px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: var(--font-body);
      background: var(--bg-base);
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Timing Bar ── */
    .timing-bar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--timing-bar-h);
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 12px;
      gap: 10px;
      z-index: 100;
    }

    .timing-bar .back-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 6px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-secondary);
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      flex-shrink: 0;
    }
    .timing-bar .back-btn:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .live-badge {
      display: none;
      align-items: center;
      gap: 5px;
      background: #e10600;
      color: #fff;
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
      padding: 3px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      flex-shrink: 0;
    }
    .live-badge.active { display: flex; }
    .live-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #fff;
      animation: live-pulse 1.5s ease-in-out infinite;
    }
    @keyframes live-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .driver-info {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      min-width: 0;
    }
    .driver-info .pos-badge {
      display: none;
      align-items: center;
      justify-content: center;
      width: 26px; height: 26px;
      border-radius: 4px;
      background: var(--accent);
      color: #fff;
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
    }
    .driver-info .driver-name {
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
      color: var(--text-secondary);
    }
    .driver-info .driver-name.has-driver { color: var(--text-primary); }
    .driver-info .lap-time {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .session-info {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .session-info span {
      font-size: 11px;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .timing-spacer { flex: 1; }

    .ws-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--text-muted);
      flex-shrink: 0;
      transition: background var(--transition);
    }

    .driver-dots {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }

    .driver-dot {
      position: relative;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--bg-elevated);
      border: 2px solid var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 9px;
      font-weight: 700;
      color: var(--text-secondary);
      cursor: pointer;
      transition: var(--transition);
      user-select: none;
    }
    .driver-dot:hover { border-color: var(--text-secondary); }
    .driver-dot.online { border-color: var(--success); }
    .driver-dot.selected {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .driver-dot.self {
      opacity: 0.4;
      cursor: default;
    }
    .driver-dot .tooltip {
      display: none;
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      color: var(--text-primary);
      font-size: 11px;
      font-weight: 500;
      padding: 4px 8px;
      border-radius: 4px;
      white-space: nowrap;
      pointer-events: none;
      z-index: 200;
    }
    .driver-dot:hover .tooltip { display: block; }

    .edit-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 6px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-muted);
      cursor: pointer;
      transition: var(--transition);
      flex-shrink: 0;
    }
    .edit-btn:hover { background: var(--bg-hover); color: var(--text-secondary); }
    .edit-btn.active { background: var(--accent-glow); border-color: var(--border-focus); color: var(--accent); }

    /* ── Panel Grid ── */
    .pitwall-grid {
      position: fixed;
      top: var(--timing-bar-h);
      left: 0; right: 0;
      bottom: var(--bottom-strip-h);
      display: grid;
      grid-template-columns: 5fr 2fr 2fr 1.5fr 1.5fr;
      grid-template-rows: 3fr 2fr;
      gap: 1px;
      background: var(--border);
    }

    .panel {
      position: relative;
      background: var(--bg-base);
      overflow: hidden;
    }

    .panel[data-panel="standings"]    { grid-column: 1; grid-row: 1 / 3; }
    .panel[data-panel="relative"]     { grid-column: 2 / 4; grid-row: 1; }
    .panel[data-panel="fuel"]         { grid-column: 2; grid-row: 2; }
    .panel[data-panel="raceduration"] { grid-column: 3; grid-row: 2; }
    .panel[data-panel="trackmap"]     { grid-column: 4 / 6; grid-row: 1; }
    .panel[data-panel="weather"]      { grid-column: 4; grid-row: 2; }
    .panel[data-panel="wind"]         { grid-column: 5; grid-row: 2; }

    .panel-label {
      position: absolute;
      top: 6px; left: 8px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      z-index: 2;
      pointer-events: none;
    }

    .panel .placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%; height: 100%;
      color: rgba(255,255,255,0.12);
      font-size: 12px;
    }

    .panel iframe {
      display: none;
      width: 100%;
      height: 100%;
      border: none;
      background: transparent;
    }

    /* ── Bottom Strip ── */
    .pitwall-strip {
      position: fixed;
      left: 0; right: 0;
      bottom: 0;
      height: var(--bottom-strip-h);
      display: grid;
      grid-template-columns: 1fr 2.5fr;
      gap: 1px;
      background: var(--border);
    }

    .pitwall-strip .panel { background: var(--bg-base); }
  </style>
</head>
<body>

  <!-- Timing Bar -->
  <div class="timing-bar">
    <a href="/racing/teams" class="back-btn" title="Back to teams">
      <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
    </a>

    <div class="live-badge" id="live-badge">LIVE</div>

    <div class="driver-info">
      <div class="pos-badge" id="pos-badge"></div>
      <span class="driver-name" id="driver-name">Select a driver</span>
      <span class="lap-time" id="lap-time"></span>
    </div>

    <div class="session-info">
      <span id="lap-count"></span>
      <span id="time-remaining"></span>
    </div>

    <div class="timing-spacer"></div>

    <div class="ws-dot" id="ws-dot" title="Disconnected"></div>

    <div class="driver-dots">
      <% members.forEach(function(m) { %>
        <div class="driver-dot<%= m.user_id === racingUser.id ? ' self' : '' %>"
             data-user-id="<%= m.user_id %>"
             data-name="<%= (m.display_name || m.username).replace(/"/g, '&quot;') %>"
             <% if (m.user_id !== racingUser.id) { %>onclick="selectDriver(<%= m.user_id %>, this.dataset.name)"<% } %>>
          <%= (m.display_name || m.username).substring(0, 2).toUpperCase() %>
          <span class="tooltip"><%= m.display_name || m.username %><%= m.user_id === racingUser.id ? ' (You)' : '' %></span>
        </div>
      <% }); %>
    </div>

    <button class="edit-btn" id="edit-btn" onclick="toggleEditMode()" title="Edit layout">
      <i data-lucide="settings" style="width:16px;height:16px;"></i>
    </button>
  </div>

  <!-- Main Grid (9 panels: 7 in grid + 2 in bottom strip) -->
  <div class="pitwall-grid">
    <% var gridPanels = [
      { id: 'standings', label: 'Standings' },
      { id: 'relative', label: 'Relative' },
      { id: 'fuel', label: 'Fuel' },
      { id: 'raceduration', label: 'Race Duration' },
      { id: 'trackmap', label: 'Track Map' },
      { id: 'weather', label: 'Weather' },
      { id: 'wind', label: 'Wind' },
    ]; gridPanels.forEach(function(p) { %>
      <div class="panel" data-panel="<%= p.id %>">
        <div class="panel-label"><%= p.label %></div>
        <div class="placeholder" id="placeholder-<%= p.id %>">Waiting for driver...</div>
        <iframe id="iframe-<%= p.id %>" loading="lazy"></iframe>
      </div>
    <% }); %>
  </div>

  <!-- Bottom Strip -->
  <div class="pitwall-strip">
    <div class="panel" data-panel="inputs">
      <div class="panel-label">Inputs</div>
      <div class="placeholder" id="placeholder-inputs">Waiting for driver...</div>
      <iframe id="iframe-inputs" loading="lazy"></iframe>
    </div>
    <div class="panel" data-panel="stintlaps">
      <div class="panel-label">Session Laps</div>
      <div class="placeholder" id="placeholder-stintlaps">Waiting for driver...</div>
      <iframe id="iframe-stintlaps" loading="lazy"></iframe>
    </div>
  </div>

  <script>
  (function() {
    var WS_URL = (location.protocol === 'https:' ? 'wss://' : 'ws://') + location.host + '/ws/pitwall';
    var OVERLAY_BASE = '/pitwall/overlays';
    var ALL_CHANNELS = ['standings', 'relative', 'fuel', 'wind', 'trackmap', 'inputs', 'session'];
    var OVERLAY_MAP = {
      standings: 'standings.html',
      relative: 'relative.html',
      fuel: 'fuel.html',
      inputs: 'inputs.html',
      trackmap: 'trackmap.html',
      weather: 'weather.html',
      wind: 'wind.html',
      stintlaps: 'stintlaps.html',
      raceduration: 'raceduration.html'
    };

    var ws = null;
    var reconnectTimer = null;
    var selectedDriverId = null;
    var onlineDrivers = new Set();

    function connect() {
      setStatus('connecting');
      ws = new WebSocket(WS_URL);

      ws.onopen = function() {
        setStatus('connected');
        ws.send(JSON.stringify({ type: 'select-team', teamId: <%= team.team_id %> }));
        if (selectedDriverId) {
          ws.send(JSON.stringify({ type: 'subscribe', channels: ALL_CHANNELS, driverId: selectedDriverId }));
        }
      };

      ws.onmessage = function(e) {
        var msg;
        try { msg = JSON.parse(e.data); } catch(err) { return; }

        if (msg.type === 'auth-ok') {
          ws.send(JSON.stringify({ type: 'select-team', teamId: <%= team.team_id %> }));
        } else if (msg.type === 'team-selected') {
          (msg.activeDrivers || []).forEach(function(d) {
            onlineDrivers.add(d.userId);
          });
          updateDriverDots();
        } else if (msg.type === 'driver-online') {
          onlineDrivers.add(msg.userId);
          updateDriverDots();
        } else if (msg.type === 'driver-offline') {
          onlineDrivers.delete(msg.userId);
          updateDriverDots();
        }
      };

      ws.onclose = function() {
        setStatus('disconnected');
        scheduleReconnect();
      };

      ws.onerror = function() {
        ws.close();
      };
    }

    function scheduleReconnect() {
      if (reconnectTimer) return;
      reconnectTimer = setTimeout(function() {
        reconnectTimer = null;
        connect();
      }, 3000);
    }

    function setStatus(state) {
      var dot = document.getElementById('ws-dot');
      var colors = { connected: 'var(--success)', connecting: 'var(--warning)', disconnected: 'var(--text-muted)', error: 'var(--danger)' };
      var titles = { connected: 'Connected', connecting: 'Connecting...', disconnected: 'Disconnected', error: 'Error' };
      dot.style.background = colors[state] || 'var(--text-muted)';
      dot.title = titles[state] || state;
    }

    function updateDriverDots() {
      document.querySelectorAll('.driver-dot').forEach(function(el) {
        var uid = parseInt(el.dataset.userId);
        el.classList.toggle('online', onlineDrivers.has(uid));
      });
    }

    function loadOverlayIframes(driverId) {
      var wsParam = encodeURIComponent(WS_URL);
      for (var key in OVERLAY_MAP) {
        var iframe = document.getElementById('iframe-' + key);
        var placeholder = document.getElementById('placeholder-' + key);
        if (iframe) {
          iframe.src = OVERLAY_BASE + '/' + OVERLAY_MAP[key] + '?ws=' + wsParam + '&driver=' + driverId;
          iframe.style.display = 'block';
        }
        if (placeholder) placeholder.style.display = 'none';
      }
    }

    function clearOverlayIframes() {
      for (var key in OVERLAY_MAP) {
        var iframe = document.getElementById('iframe-' + key);
        var placeholder = document.getElementById('placeholder-' + key);
        if (iframe) { iframe.src = 'about:blank'; iframe.style.display = 'none'; }
        if (placeholder) placeholder.style.display = 'flex';
      }
    }

    window.selectDriver = function(userId, name) {
      // Toggle off if same driver
      if (selectedDriverId === userId) {
        window.deselectDriver();
        return;
      }

      selectedDriverId = userId;

      // Update timing bar
      var nameEl = document.getElementById('driver-name');
      nameEl.textContent = name;
      nameEl.classList.add('has-driver');
      document.getElementById('live-badge').classList.add('active');

      // Highlight selected dot
      document.querySelectorAll('.driver-dot').forEach(function(el) {
        var uid = parseInt(el.dataset.userId);
        el.classList.toggle('selected', uid === userId);
      });

      // Load overlay iframes
      loadOverlayIframes(userId);

      // Subscribe on WS
      if (ws && ws.readyState === 1) {
        ws.send(JSON.stringify({ type: 'subscribe', channels: ALL_CHANNELS, driverId: userId }));
      }
    };

    window.deselectDriver = function() {
      selectedDriverId = null;

      var nameEl = document.getElementById('driver-name');
      nameEl.textContent = 'Select a driver';
      nameEl.classList.remove('has-driver');
      document.getElementById('live-badge').classList.remove('active');
      document.getElementById('lap-time').textContent = '';
      document.getElementById('lap-count').textContent = '';
      document.getElementById('time-remaining').textContent = '';

      document.querySelectorAll('.driver-dot').forEach(function(el) {
        el.classList.remove('selected');
      });

      clearOverlayIframes();
    };

    window.toggleEditMode = function() {
      document.body.classList.toggle('edit-mode');
      document.getElementById('edit-btn').classList.toggle('active');
    };

    // ESC key handler
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (document.body.classList.contains('edit-mode')) {
          window.toggleEditMode();
        } else {
          window.location.href = '/racing/teams';
        }
      }
    });

    connect();
  })();
  </script>

  <script>lucide.createIcons();</script>
</body>
</html>
