<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pitwall — <%= team.team_name %> — Atleta</title>
  <link rel="icon" type="image/png" href="/app-icon/honest_graphic-running-athlete-9715727.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <style>
    :root {
      --bg-base: #0c0d14;
      --bg-surface: #141520;
      --bg-elevated: #1a1b2e;
      --bg-hover: #1f2037;
      --border: rgba(255,255,255,0.06);
      --border-focus: rgba(145,70,255,0.4);
      --text-primary: #e8e6f0;
      --text-secondary: #8b8a9e;
      --text-muted: #5c5b6e;
      --accent: #9146ff;
      --accent-glow: rgba(145,70,255,0.15);
      --accent-hover: #a56bff;
      --success: #3ecf8e;
      --danger: #f04438;
      --warning: #f79009;
      --font-display: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      --timing-bar-h: 48px;
      --bottom-strip-h: 80px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: var(--font-body);
      background: var(--bg-base);
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Timing Bar ── */
    .timing-bar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--timing-bar-h);
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 12px;
      gap: 10px;
      z-index: 100;
    }

    .timing-bar .back-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 6px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-secondary);
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      flex-shrink: 0;
    }
    .timing-bar .back-btn:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .live-badge {
      display: none;
      align-items: center;
      gap: 5px;
      background: #e10600;
      color: #fff;
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
      padding: 3px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      flex-shrink: 0;
    }
    .live-badge.active { display: flex; }
    .live-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #fff;
      animation: live-pulse 1.5s ease-in-out infinite;
    }
    @keyframes live-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .driver-info {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      min-width: 0;
    }
    .driver-info .pos-badge {
      display: none;
      align-items: center;
      justify-content: center;
      width: 26px; height: 26px;
      border-radius: 4px;
      background: var(--accent);
      color: #fff;
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
    }
    .driver-info .driver-name {
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
      color: var(--text-secondary);
    }
    .driver-info .driver-name.has-driver { color: var(--text-primary); }
    .driver-info .lap-time {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .session-info {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .session-info span {
      font-size: 11px;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .timing-spacer { flex: 1; }

    .ws-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--text-muted);
      flex-shrink: 0;
      transition: background var(--transition);
    }

    .driver-dots {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }

    .driver-dot {
      position: relative;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--bg-elevated);
      border: 2px solid var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 9px;
      font-weight: 700;
      color: var(--text-secondary);
      cursor: pointer;
      transition: var(--transition);
      user-select: none;
    }
    .driver-dot:hover { border-color: var(--text-secondary); }
    .driver-dot.online { border-color: var(--success); }
    .driver-dot.selected {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .driver-dot.self {
      opacity: 0.4;
      cursor: default;
    }
    .driver-dot .tooltip {
      display: none;
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      color: var(--text-primary);
      font-size: 11px;
      font-weight: 500;
      padding: 4px 8px;
      border-radius: 4px;
      white-space: nowrap;
      pointer-events: none;
      z-index: 200;
    }
    .driver-dot:hover .tooltip { display: block; }

    .edit-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 6px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-muted);
      cursor: pointer;
      transition: var(--transition);
      flex-shrink: 0;
    }
    .edit-btn:hover { background: var(--bg-hover); color: var(--text-secondary); }
    .edit-btn.active { background: var(--accent-glow); border-color: var(--border-focus); color: var(--accent); }

    /* ── Panel Grid ── */
    .pitwall-grid {
      position: fixed;
      top: var(--timing-bar-h);
      left: 0; right: 0;
      bottom: var(--bottom-strip-h);
      display: grid;
      grid-template-columns: 5fr 2fr 2fr 1.5fr 1.5fr;
      grid-template-rows: 3fr 2fr;
      gap: 1px;
      background: var(--border);
    }

    .panel {
      position: relative;
      background: var(--bg-base);
      overflow: hidden;
    }

    .panel[data-panel="standings"]    { grid-column: 1; grid-row: 1 / 3; }
    .panel[data-panel="relative"]     { grid-column: 2 / 4; grid-row: 1; }
    .panel[data-panel="fuel"]         { grid-column: 2; grid-row: 2; }
    .panel[data-panel="raceduration"] { grid-column: 3; grid-row: 2; }
    .panel[data-panel="trackmap"]     { grid-column: 4 / 6; grid-row: 1; }
    .panel[data-panel="weather"]      { grid-column: 4; grid-row: 2; }
    .panel[data-panel="wind"]         { grid-column: 5; grid-row: 2; }

    .panel-label {
      position: absolute;
      top: 6px; left: 8px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      z-index: 2;
      pointer-events: none;
    }

    .panel .placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%; height: 100%;
      color: rgba(255,255,255,0.12);
      font-size: 12px;
    }

    .panel iframe {
      display: none;
      width: 100%;
      height: 100%;
      border: none;
      background: transparent;
    }

    /* ── Bottom Strip ── */
    .pitwall-strip {
      position: fixed;
      left: 0; right: 0;
      bottom: 0;
      height: var(--bottom-strip-h);
      display: grid;
      grid-template-columns: 1fr 2.5fr;
      gap: 1px;
      background: var(--border);
    }

    .pitwall-strip .panel { background: var(--bg-base); }

    /* ── Edit Mode ── */
    body.edit-mode .panel {
      outline: 1px solid transparent;
      transition: outline var(--transition);
      cursor: grab;
      user-select: none;
    }
    body.edit-mode .panel:hover { outline: 1px solid var(--accent); }
    body.edit-mode .panel:active { cursor: grabbing; }
    body.edit-mode .panel-label {
      pointer-events: none;
      background: var(--accent);
      color: #fff;
      padding: 2px 8px;
      border-radius: 4px;
    }
    body.edit-mode .placeholder { pointer-events: none; }
    body.edit-mode iframe { pointer-events: none; }
    .drag-ghost {
      position: fixed;
      pointer-events: none;
      z-index: 999;
      background: rgba(145,70,255,0.25);
      border: 1px solid var(--accent);
      color: var(--text-primary);
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 6px;
      white-space: nowrap;
    }
    .panel.drag-over { outline: 2px solid var(--accent) !important; }
    .reset-layout-btn {
      position: fixed;
      bottom: calc(var(--bottom-strip-h) + 8px);
      right: 12px;
      z-index: 101;
      display: none;
      align-items: center;
      gap: 4px;
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      color: var(--text-secondary);
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 600;
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      transition: var(--transition);
    }
    .reset-layout-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
    body.edit-mode .reset-layout-btn { display: flex; }

    /* ── Grid Transitions (disabled during resize) ── */
    .pitwall-grid, .pitwall-strip {
      transition: grid-template-columns 0.15s ease, grid-template-rows 0.15s ease;
    }
    body.resizing .pitwall-grid, body.resizing .pitwall-strip { transition: none; }

    /* ── Edit Mode Banner ── */
    body.edit-mode::after {
      content: 'EDIT MODE — Drag panels to rearrange, drag borders to resize';
      position: fixed;
      top: var(--timing-bar-h);
      left: 0; right: 0;
      height: 24px;
      background: var(--accent);
      color: #fff;
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.3px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 99;
    }
    body.edit-mode .pitwall-grid { top: calc(var(--timing-bar-h) + 24px); }
  </style>
</head>
<body>

  <!-- Timing Bar -->
  <div class="timing-bar">
    <a href="/racing/teams" class="back-btn" title="Back to teams">
      <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
    </a>

    <div class="live-badge" id="live-badge">LIVE</div>

    <div class="driver-info">
      <div class="pos-badge" id="pos-badge"></div>
      <span class="driver-name" id="driver-name">Select a driver</span>
      <span class="lap-time" id="lap-time"></span>
    </div>

    <div class="session-info">
      <span id="lap-count"></span>
      <span id="time-remaining"></span>
    </div>

    <div class="timing-spacer"></div>

    <div class="ws-dot" id="ws-dot" title="Disconnected"></div>

    <div class="driver-dots">
      <% members.forEach(function(m) { %>
        <div class="driver-dot<%= m.user_id === racingUser.id ? ' self' : '' %>"
             data-user-id="<%= m.user_id %>"
             data-name="<%= (m.display_name || m.username).replace(/"/g, '&quot;') %>"
             <% if (m.user_id !== racingUser.id) { %>onclick="selectDriver(<%= m.user_id %>, this.dataset.name)"<% } %>>
          <%= (m.display_name || m.username).substring(0, 2).toUpperCase() %>
          <span class="tooltip"><%= m.display_name || m.username %><%= m.user_id === racingUser.id ? ' (You)' : '' %></span>
        </div>
      <% }); %>
    </div>

    <button class="edit-btn" id="edit-btn" onclick="toggleEditMode()" title="Edit layout">
      <i data-lucide="settings" style="width:16px;height:16px;"></i>
    </button>
  </div>

  <!-- Main Grid (9 panels: 7 in grid + 2 in bottom strip) -->
  <div class="pitwall-grid" id="pitwall-grid">
    <% var gridPanels = [
      { id: 'standings', label: 'Standings' },
      { id: 'relative', label: 'Relative' },
      { id: 'fuel', label: 'Fuel' },
      { id: 'raceduration', label: 'Race Duration' },
      { id: 'trackmap', label: 'Track Map' },
      { id: 'weather', label: 'Weather' },
      { id: 'wind', label: 'Wind' },
    ]; gridPanels.forEach(function(p) { %>
      <div class="panel" data-panel="<%= p.id %>">
        <div class="panel-label"><%= p.label %></div>
        <div class="placeholder" id="placeholder-<%= p.id %>">Waiting for driver...</div>
        <iframe id="iframe-<%= p.id %>" loading="lazy"></iframe>
      </div>
    <% }); %>
  </div>

  <!-- Bottom Strip -->
  <div class="pitwall-strip" id="pitwall-strip">
    <div class="panel" data-panel="inputs">
      <div class="panel-label">Inputs</div>
      <div class="placeholder" id="placeholder-inputs">Waiting for driver...</div>
      <iframe id="iframe-inputs" loading="lazy"></iframe>
    </div>
    <div class="panel" data-panel="stintlaps">
      <div class="panel-label">Session Laps</div>
      <div class="placeholder" id="placeholder-stintlaps">Waiting for driver...</div>
      <iframe id="iframe-stintlaps" loading="lazy"></iframe>
    </div>
  </div>

  <button class="reset-layout-btn" onclick="resetLayout()">Reset layout</button>

  <script>
  (function() {
    var WS_URL = (location.protocol === 'https:' ? 'wss://' : 'ws://') + location.host + '/ws/pitwall';
    var OVERLAY_BASE = '/pitwall/overlays';
    var ALL_CHANNELS = ['standings', 'relative', 'fuel', 'wind', 'trackmap', 'inputs', 'session'];
    var OVERLAY_MAP = {
      standings: 'standings.html',
      relative: 'relative.html',
      fuel: 'fuel.html',
      inputs: 'inputs.html',
      trackmap: 'trackmap.html',
      weather: 'weather.html',
      wind: 'wind.html',
      stintlaps: 'stintlaps.html',
      raceduration: 'raceduration.html'
    };

    var ws = null;
    var reconnectTimer = null;
    var selectedDriverId = null;
    var onlineDrivers = new Set();

    function connect() {
      setStatus('connecting');
      ws = new WebSocket(WS_URL);

      ws.onopen = function() {
        setStatus('connected');
        ws.send(JSON.stringify({ type: 'select-team', teamId: <%= team.team_id %> }));
        if (selectedDriverId) {
          ws.send(JSON.stringify({ type: 'subscribe', channels: ALL_CHANNELS, driverId: selectedDriverId }));
        }
      };

      ws.onmessage = function(e) {
        var msg;
        try { msg = JSON.parse(e.data); } catch(err) { return; }

        if (msg.type === 'auth-ok') {
          ws.send(JSON.stringify({ type: 'select-team', teamId: <%= team.team_id %> }));
        } else if (msg.type === 'team-selected') {
          (msg.activeDrivers || []).forEach(function(d) {
            onlineDrivers.add(d.userId);
          });
          updateDriverDots();
          // If we already had a driver selected (reconnect), notify iframes
          if (selectedDriverId) postToIframes({ type: 'status', iracing: true });
        } else if (msg.type === 'driver-online') {
          onlineDrivers.add(msg.userId);
          updateDriverDots();
        } else if (msg.type === 'driver-offline') {
          onlineDrivers.delete(msg.userId);
          updateDriverDots();
        } else if (msg.type === 'data') {
          // Forward telemetry data to overlay iframes
          postToIframes(msg);
        }
      };

      ws.onclose = function() {
        setStatus('disconnected');
        postToIframes({ type: 'status', iracing: false });
        scheduleReconnect();
      };

      ws.onerror = function() {
        ws.close();
      };
    }

    function scheduleReconnect() {
      if (reconnectTimer) return;
      reconnectTimer = setTimeout(function() {
        reconnectTimer = null;
        connect();
      }, 3000);
    }

    function setStatus(state) {
      var dot = document.getElementById('ws-dot');
      var colors = { connected: 'var(--success)', connecting: 'var(--warning)', disconnected: 'var(--text-muted)', error: 'var(--danger)' };
      var titles = { connected: 'Connected', connecting: 'Connecting...', disconnected: 'Disconnected', error: 'Error' };
      dot.style.background = colors[state] || 'var(--text-muted)';
      dot.title = titles[state] || state;
    }

    function updateDriverDots() {
      document.querySelectorAll('.driver-dot').forEach(function(el) {
        var uid = parseInt(el.dataset.userId);
        el.classList.toggle('online', onlineDrivers.has(uid));
      });
    }

    // Forward a message to all loaded overlay iframes via postMessage
    function postToIframes(msg) {
      for (var key in OVERLAY_MAP) {
        var iframe = document.getElementById('iframe-' + key);
        if (iframe && iframe.contentWindow && iframe.style.display !== 'none') {
          iframe.contentWindow.postMessage(msg, '*');
        }
      }
    }

    function loadOverlayIframes(driverId) {
      for (var key in OVERLAY_MAP) {
        var iframe = document.getElementById('iframe-' + key);
        var placeholder = document.getElementById('placeholder-' + key);
        if (iframe) {
          iframe.src = OVERLAY_BASE + '/' + OVERLAY_MAP[key] + '?pitwall=1&driver=' + driverId;
          iframe.style.display = 'block';
          // Once iframe loads, send it the connection status
          iframe.onload = (function() {
            var iframeRef = iframe;
            return function() {
              if (iframeRef.contentWindow) {
                iframeRef.contentWindow.postMessage({ type: 'bridge-connected' }, '*');
                iframeRef.contentWindow.postMessage({ type: 'status', iracing: true }, '*');
              }
            };
          })();
        }
        if (placeholder) placeholder.style.display = 'none';
      }
    }

    function clearOverlayIframes() {
      for (var key in OVERLAY_MAP) {
        var iframe = document.getElementById('iframe-' + key);
        var placeholder = document.getElementById('placeholder-' + key);
        if (iframe) { iframe.src = 'about:blank'; iframe.style.display = 'none'; }
        if (placeholder) placeholder.style.display = 'flex';
      }
    }

    window.selectDriver = function(userId, name) {
      // Toggle off if same driver
      if (selectedDriverId === userId) {
        window.deselectDriver();
        return;
      }

      selectedDriverId = userId;

      // Update timing bar
      var nameEl = document.getElementById('driver-name');
      nameEl.textContent = name;
      nameEl.classList.add('has-driver');
      document.getElementById('live-badge').classList.add('active');

      // Highlight selected dot
      document.querySelectorAll('.driver-dot').forEach(function(el) {
        var uid = parseInt(el.dataset.userId);
        el.classList.toggle('selected', uid === userId);
      });

      // Load overlay iframes
      loadOverlayIframes(userId);

      // Subscribe on WS
      if (ws && ws.readyState === 1) {
        ws.send(JSON.stringify({ type: 'subscribe', channels: ALL_CHANNELS, driverId: userId }));
      }
    };

    window.deselectDriver = function() {
      selectedDriverId = null;

      var nameEl = document.getElementById('driver-name');
      nameEl.textContent = 'Select a driver';
      nameEl.classList.remove('has-driver');
      document.getElementById('live-badge').classList.remove('active');
      document.getElementById('lap-time').textContent = '';
      document.getElementById('lap-count').textContent = '';
      document.getElementById('time-remaining').textContent = '';

      document.querySelectorAll('.driver-dot').forEach(function(el) {
        el.classList.remove('selected');
      });

      clearOverlayIframes();
    };

    /* ── Layout Persistence (Task 5) ── */
    var LAYOUT_KEY = 'pitwall-layout-v1';
    var RATIOS_KEY = 'pitwall-ratios-v1';
    var gridEl = document.getElementById('pitwall-grid');
    var stripEl = document.getElementById('pitwall-strip');

    var GRID_AREAS = [
      'grid-column:1; grid-row:1/3;',
      'grid-column:2/4; grid-row:1;',
      'grid-column:2; grid-row:2;',
      'grid-column:3; grid-row:2;',
      'grid-column:4/6; grid-row:1;',
      'grid-column:4; grid-row:2;',
      'grid-column:5; grid-row:2;'
    ];

    function getDefaultLayout() {
      return { grid: ['standings','relative','fuel','raceduration','trackmap','weather','wind'], strip: ['inputs','stintlaps'], version: 1 };
    }

    function loadLayout() {
      try {
        var stored = localStorage.getItem(LAYOUT_KEY);
        if (stored) {
          var layout = JSON.parse(stored);
          if (layout && layout.version === 1 && layout.grid && layout.grid.length === 7 && layout.strip && layout.strip.length === 2) return layout;
        }
      } catch(e) {}
      return getDefaultLayout();
    }

    function saveLayout(layout) {
      localStorage.setItem(LAYOUT_KEY, JSON.stringify(layout));
    }

    function applyLayout(layout) {
      // Reorder grid children
      var gridPanels = Array.from(gridEl.querySelectorAll('.panel'));
      layout.grid.forEach(function(panelId) {
        var panel = gridPanels.find(function(p) { return p.dataset.panel === panelId; });
        if (panel) gridEl.appendChild(panel);
      });
      // Reorder strip children
      var stripPanels = Array.from(stripEl.querySelectorAll('.panel'));
      layout.strip.forEach(function(panelId) {
        var panel = stripPanels.find(function(p) { return p.dataset.panel === panelId; });
        if (panel) stripEl.appendChild(panel);
      });
      updateGridAreas();
    }

    function updateGridAreas() {
      var panels = Array.from(gridEl.querySelectorAll('.panel'));
      panels.forEach(function(panel, i) {
        if (GRID_AREAS[i]) {
          panel.style.cssText = GRID_AREAS[i];
        }
      });
    }

    function getCurrentLayout() {
      var grid = Array.from(gridEl.querySelectorAll('.panel')).map(function(p) { return p.dataset.panel; });
      var strip = Array.from(stripEl.querySelectorAll('.panel')).map(function(p) { return p.dataset.panel; });
      return { grid: grid, strip: strip, version: 1 };
    }

    /* ── Drag-to-Swap (Task 5) ── */
    var dragSource = null;
    var dragGhost = null;
    var dragContainer = null;

    function isNearAnyBoundary(x, y) {
      var currentRatios = loadRatios();
      var threshold = 6;
      var gridRect = gridEl.getBoundingClientRect();
      if (x >= gridRect.left && x <= gridRect.right && y >= gridRect.top && y <= gridRect.bottom) {
        var colInfo = getBoundaryPositions(gridEl, currentRatios.cols, 'col');
        if (findNearBoundary(x, colInfo.positions, threshold) !== -1) return true;
        var rowInfo = getBoundaryPositions(gridEl, currentRatios.rows, 'row');
        if (findNearBoundary(y, rowInfo.positions, threshold) !== -1) return true;
      }
      var stripRect = stripEl.getBoundingClientRect();
      if (x >= stripRect.left && x <= stripRect.right && y >= stripRect.top && y <= stripRect.bottom) {
        var stripInfo = getBoundaryPositions(stripEl, currentRatios.stripCols, 'col');
        if (findNearBoundary(x, stripInfo.positions, threshold) !== -1) return true;
      }
      return false;
    }

    document.addEventListener('mousedown', function(e) {
      if (!document.body.classList.contains('edit-mode')) return;
      var panel = e.target.closest('.panel');
      if (!panel) return;
      // Let resize handler take priority near boundaries
      if (isNearAnyBoundary(e.clientX, e.clientY)) return;
      e.preventDefault();

      dragSource = panel;
      dragContainer = panel.parentElement;
      var label = panel.querySelector('.panel-label');

      dragGhost = document.createElement('div');
      dragGhost.className = 'drag-ghost';
      dragGhost.textContent = label ? label.textContent : panel.dataset.panel;
      dragGhost.style.left = e.clientX + 12 + 'px';
      dragGhost.style.top = e.clientY + 12 + 'px';
      document.body.appendChild(dragGhost);

      panel.style.opacity = '0.4';
    });

    document.addEventListener('mousemove', function(e) {
      if (!dragSource) return;
      if (dragGhost) {
        dragGhost.style.left = e.clientX + 12 + 'px';
        dragGhost.style.top = e.clientY + 12 + 'px';
      }
      // Highlight drop target
      document.querySelectorAll('.panel.drag-over').forEach(function(p) { p.classList.remove('drag-over'); });
      var target = document.elementFromPoint(e.clientX, e.clientY);
      if (target) {
        var targetPanel = target.closest('.panel');
        if (targetPanel && targetPanel !== dragSource && targetPanel.parentElement === dragContainer) {
          targetPanel.classList.add('drag-over');
        }
      }
    });

    document.addEventListener('mouseup', function(e) {
      if (!dragSource) return;
      document.querySelectorAll('.panel.drag-over').forEach(function(p) { p.classList.remove('drag-over'); });
      if (dragGhost) { dragGhost.remove(); dragGhost = null; }

      var target = document.elementFromPoint(e.clientX, e.clientY);
      if (target) {
        var targetPanel = target.closest('.panel');
        if (targetPanel && targetPanel !== dragSource && targetPanel.parentElement === dragContainer) {
          // Swap DOM positions
          var container = dragContainer;
          var allPanels = Array.from(container.querySelectorAll('.panel'));
          var srcIdx = allPanels.indexOf(dragSource);
          var tgtIdx = allPanels.indexOf(targetPanel);
          if (srcIdx !== -1 && tgtIdx !== -1) {
            if (srcIdx < tgtIdx) {
              container.insertBefore(targetPanel, dragSource);
              container.insertBefore(dragSource, allPanels[tgtIdx + 1] || null);
            } else {
              container.insertBefore(dragSource, targetPanel);
              container.insertBefore(targetPanel, allPanels[srcIdx + 1] || null);
            }
            updateGridAreas();
            saveLayout(getCurrentLayout());
          }
        }
      }

      if (dragSource) dragSource.style.opacity = '';
      dragSource = null;
      dragContainer = null;
    });

    /* ── Ratio Persistence (Task 6) ── */
    var defaultRatios = { cols: [5,2,2,1.5,1.5], rows: [3,2], stripCols: [1,2.5] };

    function loadRatios() {
      try {
        var stored = localStorage.getItem(RATIOS_KEY);
        if (stored) {
          var r = JSON.parse(stored);
          if (r && r.cols && r.rows && r.stripCols) return r;
        }
      } catch(e) {}
      return JSON.parse(JSON.stringify(defaultRatios));
    }

    function saveRatios(ratios) {
      localStorage.setItem(RATIOS_KEY, JSON.stringify(ratios));
    }

    function applyRatios(ratios) {
      gridEl.style.gridTemplateColumns = ratios.cols.map(function(v) { return v + 'fr'; }).join(' ');
      gridEl.style.gridTemplateRows = ratios.rows.map(function(v) { return v + 'fr'; }).join(' ');
      stripEl.style.gridTemplateColumns = ratios.stripCols.map(function(v) { return v + 'fr'; }).join(' ');
    }

    /* ── Edge Resize (Task 6) ── */
    var resizing = false;
    var resizeTarget = null; // 'grid-col', 'grid-row', 'strip-col'
    var resizeIndex = -1;
    var resizeStartX = 0;
    var resizeStartY = 0;
    var resizeStartRatios = null;
    var resizeTotalPx = 0;

    function getBoundaryPositions(container, ratios, axis) {
      var rect = container.getBoundingClientRect();
      var total = axis === 'col' ? rect.width : rect.height;
      var gap = 1; // 1px gap
      var numGaps = ratios.length - 1;
      var usable = total - numGaps * gap;
      var sum = ratios.reduce(function(a,b) { return a+b; }, 0);
      var positions = [];
      var offset = axis === 'col' ? rect.left : rect.top;
      for (var i = 0; i < ratios.length - 1; i++) {
        offset += (ratios[i] / sum) * usable + gap;
        positions.push(offset);
      }
      return { positions: positions, total: usable, sum: sum };
    }

    function findNearBoundary(mousePos, positions, threshold) {
      for (var i = 0; i < positions.length; i++) {
        if (Math.abs(mousePos - positions[i]) < threshold) return i;
      }
      return -1;
    }

    document.addEventListener('mousedown', function(e) {
      if (!document.body.classList.contains('edit-mode')) return;
      if (dragSource) return;
      if (e.target.closest('.reset-layout-btn') || e.target.closest('.edit-btn')) return;

      var currentRatios = loadRatios();
      var threshold = 6;

      // Check grid columns
      var gridRect = gridEl.getBoundingClientRect();
      if (e.clientX >= gridRect.left && e.clientX <= gridRect.right && e.clientY >= gridRect.top && e.clientY <= gridRect.bottom) {
        var colInfo = getBoundaryPositions(gridEl, currentRatios.cols, 'col');
        var colIdx = findNearBoundary(e.clientX, colInfo.positions, threshold);
        if (colIdx !== -1) {
          e.preventDefault();
          resizing = true;
          resizeTarget = 'grid-col';
          resizeIndex = colIdx;
          resizeStartX = e.clientX;
          resizeStartRatios = JSON.parse(JSON.stringify(currentRatios));
          resizeTotalPx = colInfo.total;
          document.body.classList.add('resizing');
          return;
        }
        var rowInfo = getBoundaryPositions(gridEl, currentRatios.rows, 'row');
        var rowIdx = findNearBoundary(e.clientY, rowInfo.positions, threshold);
        if (rowIdx !== -1) {
          e.preventDefault();
          resizing = true;
          resizeTarget = 'grid-row';
          resizeIndex = rowIdx;
          resizeStartY = e.clientY;
          resizeStartRatios = JSON.parse(JSON.stringify(currentRatios));
          resizeTotalPx = rowInfo.total;
          document.body.classList.add('resizing');
          return;
        }
      }

      // Check strip columns
      var stripRect = stripEl.getBoundingClientRect();
      if (e.clientX >= stripRect.left && e.clientX <= stripRect.right && e.clientY >= stripRect.top && e.clientY <= stripRect.bottom) {
        var stripInfo = getBoundaryPositions(stripEl, currentRatios.stripCols, 'col');
        var stripIdx = findNearBoundary(e.clientX, stripInfo.positions, threshold);
        if (stripIdx !== -1) {
          e.preventDefault();
          resizing = true;
          resizeTarget = 'strip-col';
          resizeIndex = stripIdx;
          resizeStartX = e.clientX;
          resizeStartRatios = JSON.parse(JSON.stringify(currentRatios));
          resizeTotalPx = stripInfo.total;
          document.body.classList.add('resizing');
          return;
        }
      }
    });

    document.addEventListener('mousemove', function(e) {
      // Cursor hints in edit mode
      if (document.body.classList.contains('edit-mode') && !resizing && !dragSource) {
        var currentRatios = loadRatios();
        var cursor = '';
        var gridRect = gridEl.getBoundingClientRect();
        if (e.clientX >= gridRect.left && e.clientX <= gridRect.right && e.clientY >= gridRect.top && e.clientY <= gridRect.bottom) {
          var colInfo = getBoundaryPositions(gridEl, currentRatios.cols, 'col');
          if (findNearBoundary(e.clientX, colInfo.positions, 6) !== -1) cursor = 'col-resize';
          else {
            var rowInfo = getBoundaryPositions(gridEl, currentRatios.rows, 'row');
            if (findNearBoundary(e.clientY, rowInfo.positions, 6) !== -1) cursor = 'row-resize';
          }
        }
        if (!cursor) {
          var stripRect = stripEl.getBoundingClientRect();
          if (e.clientX >= stripRect.left && e.clientX <= stripRect.right && e.clientY >= stripRect.top && e.clientY <= stripRect.bottom) {
            var stripInfo = getBoundaryPositions(stripEl, currentRatios.stripCols, 'col');
            if (findNearBoundary(e.clientX, stripInfo.positions, 6) !== -1) cursor = 'col-resize';
          }
        }
        document.body.style.cursor = cursor || '';
      }

      if (!resizing) return;
      e.preventDefault();

      var ratios = JSON.parse(JSON.stringify(resizeStartRatios));
      var MIN_RATIO = 0.5;

      if (resizeTarget === 'grid-col') {
        var dx = e.clientX - resizeStartX;
        var sum = ratios.cols.reduce(function(a,b) { return a+b; }, 0);
        var dRatio = (dx / resizeTotalPx) * sum;
        var newLeft = ratios.cols[resizeIndex] + dRatio;
        var newRight = ratios.cols[resizeIndex + 1] - dRatio;
        if (newLeft >= MIN_RATIO && newRight >= MIN_RATIO) {
          ratios.cols[resizeIndex] = Math.round(newLeft * 100) / 100;
          ratios.cols[resizeIndex + 1] = Math.round(newRight * 100) / 100;
        }
      } else if (resizeTarget === 'grid-row') {
        var dy = e.clientY - resizeStartY;
        var sum = ratios.rows.reduce(function(a,b) { return a+b; }, 0);
        var dRatio = (dy / resizeTotalPx) * sum;
        var newTop = ratios.rows[resizeIndex] + dRatio;
        var newBottom = ratios.rows[resizeIndex + 1] - dRatio;
        if (newTop >= MIN_RATIO && newBottom >= MIN_RATIO) {
          ratios.rows[resizeIndex] = Math.round(newTop * 100) / 100;
          ratios.rows[resizeIndex + 1] = Math.round(newBottom * 100) / 100;
        }
      } else if (resizeTarget === 'strip-col') {
        var dx = e.clientX - resizeStartX;
        var sum = ratios.stripCols.reduce(function(a,b) { return a+b; }, 0);
        var dRatio = (dx / resizeTotalPx) * sum;
        var newLeft = ratios.stripCols[resizeIndex] + dRatio;
        var newRight = ratios.stripCols[resizeIndex + 1] - dRatio;
        if (newLeft >= MIN_RATIO && newRight >= MIN_RATIO) {
          ratios.stripCols[resizeIndex] = Math.round(newLeft * 100) / 100;
          ratios.stripCols[resizeIndex + 1] = Math.round(newRight * 100) / 100;
        }
      }

      applyRatios(ratios);
    });

    document.addEventListener('mouseup', function() {
      if (!resizing) return;
      resizing = false;
      document.body.classList.remove('resizing');
      document.body.style.cursor = '';
      // Read current ratios from the grid styles and save
      var currentRatios = loadRatios();
      var gridCols = gridEl.style.gridTemplateColumns;
      var gridRows = gridEl.style.gridTemplateRows;
      var stripCols = stripEl.style.gridTemplateColumns;
      if (gridCols) currentRatios.cols = gridCols.split(' ').map(function(v) { return parseFloat(v); });
      if (gridRows) currentRatios.rows = gridRows.split(' ').map(function(v) { return parseFloat(v); });
      if (stripCols) currentRatios.stripCols = stripCols.split(' ').map(function(v) { return parseFloat(v); });
      saveRatios(currentRatios);
      resizeTarget = null;
      resizeIndex = -1;
      resizeStartRatios = null;
    });

    /* ── Toggle Edit Mode ── */
    window.toggleEditMode = function() {
      document.body.classList.toggle('edit-mode');
      document.getElementById('edit-btn').classList.toggle('active');
      if (!document.body.classList.contains('edit-mode')) {
        document.body.style.cursor = '';
      }
    };

    /* ── Reset Layout ── */
    window.resetLayout = function() {
      localStorage.removeItem(LAYOUT_KEY);
      localStorage.removeItem(RATIOS_KEY);
      applyLayout(getDefaultLayout());
      applyRatios(JSON.parse(JSON.stringify(defaultRatios)));
    };

    /* ── Apply saved layout + ratios on load ── */
    applyLayout(loadLayout());
    applyRatios(loadRatios());

    // ESC key handler
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (document.body.classList.contains('edit-mode')) {
          window.toggleEditMode();
        } else {
          window.location.href = '/racing/teams';
        }
      }
    });

    connect();
  })();
  </script>

  <script>lucide.createIcons();</script>
</body>
</html>
