<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pitwall — <%= team.team_name %> — Atleta</title>
  <link rel="icon" type="image/png" href="/app-icon/honest_graphic-running-athlete-9715727.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/gridstack@10/dist/gridstack.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/gridstack@10/dist/gridstack-all.js"></script>
  <style>
    :root {
      --bg-base: #0c0d14;
      --bg-surface: #141520;
      --bg-elevated: #1a1b2e;
      --bg-hover: #1f2037;
      --border: rgba(255,255,255,0.06);
      --border-focus: rgba(145,70,255,0.4);
      --text-primary: #e8e6f0;
      --text-secondary: #8b8a9e;
      --text-muted: #5c5b6e;
      --accent: #9146ff;
      --accent-glow: rgba(145,70,255,0.15);
      --accent-hover: #a56bff;
      --success: #3ecf8e;
      --danger: #f04438;
      --warning: #f79009;
      --font-display: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      --timing-bar-h: 48px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: var(--font-body);
      background: var(--bg-base);
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Timing Bar ── */
    .timing-bar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--timing-bar-h);
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 12px;
      gap: 10px;
      z-index: 100;
    }

    .timing-bar .back-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 6px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-secondary);
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      flex-shrink: 0;
    }
    .timing-bar .back-btn:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .live-badge {
      display: none;
      align-items: center;
      gap: 5px;
      background: #e10600;
      color: #fff;
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
      padding: 3px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      flex-shrink: 0;
    }
    .live-badge.active { display: flex; }
    .live-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #fff;
      animation: live-pulse 1.5s ease-in-out infinite;
    }
    @keyframes live-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .driver-info {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      min-width: 0;
    }
    .driver-info .driver-name {
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
      color: var(--text-secondary);
    }
    .driver-info .driver-name.has-driver { color: var(--text-primary); }
    .driver-info .lap-time {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .session-info {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .session-info span {
      font-size: 11px;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .timing-spacer { flex: 1; }

    .ws-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--text-muted);
      flex-shrink: 0;
      transition: background var(--transition);
    }

    .driver-dots {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }

    .driver-dot {
      position: relative;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--bg-elevated);
      border: 2px solid var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 9px;
      font-weight: 700;
      color: var(--text-secondary);
      cursor: pointer;
      transition: var(--transition);
      user-select: none;
    }
    .driver-dot:hover { border-color: var(--text-secondary); }
    .driver-dot.online { border-color: var(--success); }
    .driver-dot.selected {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .driver-dot.self {
      opacity: 0.7;
    }
    .driver-dot .tooltip {
      display: none;
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      color: var(--text-primary);
      font-size: 11px;
      font-weight: 500;
      padding: 4px 8px;
      border-radius: 4px;
      white-space: nowrap;
      pointer-events: none;
      z-index: 200;
    }
    .driver-dot:hover .tooltip { display: block; }

    .toolbar-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 6px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-muted);
      cursor: pointer;
      transition: var(--transition);
      flex-shrink: 0;
    }
    .toolbar-btn:hover { background: var(--bg-hover); color: var(--text-secondary); }
    .toolbar-btn.active { background: var(--accent-glow); border-color: var(--border-focus); color: var(--accent); }

    /* ── Toggle Panel ── */
    .toggle-panel {
      display: none;
      position: fixed;
      top: var(--timing-bar-h);
      right: 0;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-top: none;
      border-radius: 0 0 0 8px;
      padding: 8px 12px;
      z-index: 99;
      min-width: 160px;
    }
    .toggle-panel.open { display: block; }
    .toggle-panel label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--text-secondary);
      padding: 4px 0;
      cursor: pointer;
    }
    .toggle-panel input[type="checkbox"] { accent-color: var(--accent); }
    .toggle-panel .toggle-actions {
      display: flex;
      gap: 6px;
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px solid var(--border);
    }
    .toggle-panel .toggle-actions button {
      flex: 1;
      padding: 5px 8px;
      border-radius: 4px;
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      border: 1px solid var(--border);
    }
    .toggle-panel .reset-btn {
      background: rgba(240,68,56,0.12);
      color: #f04438;
      border-color: rgba(240,68,56,0.25);
    }
    .toggle-panel .reset-btn:hover { background: rgba(240,68,56,0.2); }

    /* ── Gridstack Overrides ── */
    .grid-stack {
      position: fixed;
      top: var(--timing-bar-h);
      left: 0; right: 0; bottom: 0;
      background: var(--bg-base);
    }

    .grid-stack-item-content {
      background: var(--bg-base);
      border: 1px solid var(--border);
      overflow: hidden;
      border-radius: 0;
      position: relative;
    }

    .grid-stack-item-content .panel-label {
      position: absolute;
      top: 4px; left: 6px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-muted);
      z-index: 2;
      pointer-events: none;
    }

    .grid-stack-item-content iframe {
      width: 100%;
      height: 100%;
      border: none;
      background: transparent;
      display: none;
    }

    .grid-stack-item-content .placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%; height: 100%;
      color: rgba(255,255,255,0.12);
      font-size: 12px;
    }

    /* Gridstack placeholder during drag */
    .grid-stack-placeholder > .placeholder-content {
      background: var(--accent-glow) !important;
      border: 1px dashed var(--accent) !important;
      border-radius: 0 !important;
    }

    /* Resize handle styling */
    .grid-stack-item > .ui-resizable-se {
      background: none;
      width: 14px; height: 14px;
      right: 2px; bottom: 2px;
    }
    .grid-stack-item > .ui-resizable-se::after {
      content: '';
      position: absolute;
      right: 3px; bottom: 3px;
      width: 8px; height: 8px;
      border-right: 2px solid var(--text-muted);
      border-bottom: 2px solid var(--text-muted);
      opacity: 0.5;
    }
  </style>
</head>
<body>

  <!-- Timing Bar -->
  <div class="timing-bar">
    <a href="/racing/teams" class="back-btn" title="Back to teams">
      <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
    </a>

    <div class="live-badge" id="live-badge">LIVE</div>

    <div class="driver-info">
      <span class="driver-name" id="driver-name">Select a driver</span>
      <span class="lap-time" id="lap-time"></span>
    </div>

    <div class="session-info">
      <span id="lap-count"></span>
      <span id="time-remaining"></span>
    </div>

    <div class="timing-spacer"></div>

    <div class="ws-dot" id="ws-dot" title="Disconnected"></div>

    <div class="driver-dots">
      <% members.forEach(function(m) { %>
        <div class="driver-dot<%= m.user_id === racingUser.id ? ' self' : '' %>"
             data-user-id="<%= m.user_id %>"
             data-name="<%= (m.display_name || m.username).replace(/"/g, '&quot;') %>"
             onclick="selectDriver(<%= m.user_id %>, this.dataset.name)">
          <%= (m.display_name || m.username).substring(0, 2).toUpperCase() %>
          <span class="tooltip"><%= m.display_name || m.username %><%= m.user_id === racingUser.id ? ' (You)' : '' %></span>
        </div>
      <% }); %>
    </div>

    <button class="toolbar-btn" id="settings-btn" onclick="toggleSettingsPanel()" title="Layout settings">
      <i data-lucide="settings" style="width:16px;height:16px;"></i>
    </button>
  </div>

  <!-- Toggle / Settings Panel -->
  <div class="toggle-panel" id="toggle-panel"></div>

  <!-- Gridstack Container -->
  <div class="grid-stack" id="pitwall-grid"></div>

  <script>
  (function() {
    var WS_URL = (location.protocol === 'https:' ? 'wss://' : 'ws://') + location.host + '/ws/pitwall';
    var OVERLAY_BASE = '/pitwall/overlays';
    var ALL_CHANNELS = ['standings', 'relative', 'fuel', 'wind', 'trackmap', 'inputs', 'session'];
    var OVERLAY_MAP = {
      standings:    'standings.html',
      relative:     'relative.html',
      fuel:         'fuel.html',
      inputs:       'inputs.html',
      trackmap:     'trackmap.html',
      weather:      'weather.html',
      wind:         'wind.html',
      stintlaps:    'stintlaps.html',
      raceduration: 'raceduration.html'
    };

    var PANEL_LABELS = {
      standings: 'Standings', relative: 'Relative', fuel: 'Fuel',
      inputs: 'Inputs', trackmap: 'Track Map', weather: 'Weather',
      wind: 'Wind', stintlaps: 'Session Laps', raceduration: 'Race Duration'
    };

    // Default layout: 12-column grid, row height auto-calculated
    var DEFAULT_LAYOUT = [
      { id: 'standings',    x: 0,  y: 0, w: 4, h: 8 },
      { id: 'relative',     x: 4,  y: 0, w: 4, h: 4 },
      { id: 'fuel',         x: 4,  y: 4, w: 2, h: 4 },
      { id: 'raceduration', x: 6,  y: 4, w: 2, h: 4 },
      { id: 'trackmap',     x: 8,  y: 0, w: 4, h: 4 },
      { id: 'weather',      x: 8,  y: 4, w: 2, h: 4 },
      { id: 'wind',         x: 10, y: 4, w: 2, h: 4 },
      { id: 'inputs',       x: 0,  y: 8, w: 4, h: 2 },
      { id: 'stintlaps',    x: 4,  y: 8, w: 8, h: 2 },
    ];

    var LAYOUT_KEY = 'pitwall-gridstack-v2';
    var HIDDEN_KEY = 'pitwall-hidden-v2';

    var grid = null;
    var ws = null;
    var reconnectTimer = null;
    var selectedDriverId = null;
    var onlineDrivers = new Set();
    var hiddenPanels = new Set();

    // ── Gridstack Init ──────────────────────────────────────────
    function initGrid() {
      // Load hidden panels
      try {
        var stored = localStorage.getItem(HIDDEN_KEY);
        if (stored) JSON.parse(stored).forEach(function(id) { hiddenPanels.add(id); });
      } catch(e) {}

      // Load saved layout or use defaults
      var layout = loadLayout();

      // Calculate row height based on viewport
      var availH = window.innerHeight - 48; // minus timing bar
      var cellH = Math.floor(availH / 10);

      grid = GridStack.init({
        column: 12,
        cellHeight: cellH,
        margin: 1,
        animate: true,
        float: true,
        disableOneColumnMode: true,
        removable: false,
        resizable: { handles: 'n,e,s,w,ne,nw,se,sw' },
      }, '#pitwall-grid');

      // Add widgets
      layout.forEach(function(item) {
        addWidget(item);
      });

      // Default: viewing mode — grid is present but drag/resize are off
      // until the user clicks Edit Layout (Task 2).
      grid.enableMove(false);
      grid.enableResize(false);

      // Save on change
      grid.on('change', function() { saveCurrentLayout(); });

      // Resize handler
      window.addEventListener('resize', function() {
        var newH = Math.floor((window.innerHeight - 48) / 10);
        grid.cellHeight(newH);
      });
    }

    function addWidget(item) {
      var isHidden = hiddenPanels.has(item.id);
      var el = grid.addWidget({
        id: item.id,
        x: item.x, y: item.y,
        w: item.w, h: item.h,
        minW: 1, minH: 1,
        content:
          '<div class="panel-label">' + (PANEL_LABELS[item.id] || item.id) + '</div>' +
          '<div class="placeholder" id="placeholder-' + item.id + '">Waiting for driver...</div>' +
          '<iframe id="iframe-' + item.id + '" loading="lazy"></iframe>',
      });
      if (isHidden && el) {
        el.style.display = 'none';
        grid.update(el, { noMove: true, noResize: true });
      }
    }

    function loadLayout() {
      try {
        var stored = localStorage.getItem(LAYOUT_KEY);
        if (stored) {
          var layout = JSON.parse(stored);
          if (Array.isArray(layout) && layout.length > 0) return layout;
        }
      } catch(e) {}
      return JSON.parse(JSON.stringify(DEFAULT_LAYOUT));
    }

    function saveCurrentLayout() {
      var items = grid.getGridItems();
      var layout = items.map(function(el) {
        var node = el.gridstackNode;
        return { id: node.id, x: node.x, y: node.y, w: node.w, h: node.h };
      });
      localStorage.setItem(LAYOUT_KEY, JSON.stringify(layout));
    }

    // ── Toggle / Settings Panel ─────────────────────────────────
    function buildSettingsPanel() {
      var panel = document.getElementById('toggle-panel');
      var html = '<div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);margin-bottom:6px;">Show / Hide Overlays</div>';
      Object.keys(OVERLAY_MAP).forEach(function(id) {
        var checked = !hiddenPanels.has(id) ? 'checked' : '';
        html += '<label><input type="checkbox" data-panel-id="' + id + '" ' + checked + ' onchange="toggleOverlay(\'' + id + '\', this.checked)"> ' + PANEL_LABELS[id] + '</label>';
      });
      html += '<div class="toggle-actions">';
      html += '<button class="reset-btn" onclick="resetLayout()">Reset</button>';
      html += '</div>';
      panel.innerHTML = html;
    }

    window.toggleSettingsPanel = function() {
      var panel = document.getElementById('toggle-panel');
      var btn = document.getElementById('settings-btn');
      panel.classList.toggle('open');
      btn.classList.toggle('active');
      if (panel.classList.contains('open')) buildSettingsPanel();
    };

    window.toggleOverlay = function(id, visible) {
      var items = grid.getGridItems();
      var widget = items.find(function(el) { return el.gridstackNode && el.gridstackNode.id === id; });

      if (visible) {
        hiddenPanels.delete(id);
        if (widget) {
          widget.style.display = '';
          grid.update(widget, { noMove: false, noResize: false });
        } else {
          // Re-add with default position
          var def = DEFAULT_LAYOUT.find(function(d) { return d.id === id; });
          if (def) addWidget(def);
        }
        // Reload iframe if driver is selected
        if (selectedDriverId) {
          var iframe = document.getElementById('iframe-' + id);
          var placeholder = document.getElementById('placeholder-' + id);
          if (iframe) {
            iframe.src = OVERLAY_BASE + '/' + OVERLAY_MAP[id] + '?pitwall=1&driver=' + selectedDriverId;
            iframe.style.display = 'block';
            iframe.onload = function() {
              if (iframe.contentWindow) {
                iframe.contentWindow.postMessage({ type: 'bridge-connected' }, '*');
                iframe.contentWindow.postMessage({ type: 'status', iracing: true }, '*');
              }
            };
          }
          if (placeholder) placeholder.style.display = 'none';
        }
      } else {
        hiddenPanels.add(id);
        if (widget) {
          widget.style.display = 'none';
          grid.update(widget, { noMove: true, noResize: true });
          var iframe = document.getElementById('iframe-' + id);
          if (iframe) { iframe.src = 'about:blank'; iframe.style.display = 'none'; }
        }
      }
      localStorage.setItem(HIDDEN_KEY, JSON.stringify([...hiddenPanels]));
      saveCurrentLayout();
    };

    window.resetLayout = function() {
      localStorage.removeItem(LAYOUT_KEY);
      localStorage.removeItem(HIDDEN_KEY);
      location.reload();
    };

    // ── WebSocket ───────────────────────────────────────────────
    function connect() {
      setStatus('connecting');
      ws = new WebSocket(WS_URL);

      ws.onopen = function() {
        setStatus('connected');
        ws.send(JSON.stringify({ type: 'select-team', teamId: <%= team.team_id %> }));
        if (selectedDriverId) {
          ws.send(JSON.stringify({ type: 'subscribe', channels: ALL_CHANNELS, driverId: selectedDriverId }));
        }
      };

      ws.onmessage = function(e) {
        var msg;
        try { msg = JSON.parse(e.data); } catch(err) { return; }

        if (msg.type === 'auth-ok') {
          ws.send(JSON.stringify({ type: 'select-team', teamId: <%= team.team_id %> }));
        } else if (msg.type === 'team-selected') {
          (msg.activeDrivers || []).forEach(function(d) {
            onlineDrivers.add(d.userId);
          });
          updateDriverDots();
          if (selectedDriverId) postToIframes({ type: 'status', iracing: true });
        } else if (msg.type === 'driver-online') {
          onlineDrivers.add(msg.userId);
          updateDriverDots();
        } else if (msg.type === 'driver-offline') {
          onlineDrivers.delete(msg.userId);
          updateDriverDots();
        } else if (msg.type === 'data') {
          postToIframes(msg);
        }
      };

      ws.onclose = function() {
        setStatus('disconnected');
        postToIframes({ type: 'status', iracing: false });
        scheduleReconnect();
      };

      ws.onerror = function() { ws.close(); };
    }

    function scheduleReconnect() {
      if (reconnectTimer) return;
      reconnectTimer = setTimeout(function() {
        reconnectTimer = null;
        connect();
      }, 3000);
    }

    function setStatus(state) {
      var dot = document.getElementById('ws-dot');
      var colors = { connected: 'var(--success)', connecting: 'var(--warning)', disconnected: 'var(--text-muted)', error: 'var(--danger)' };
      var titles = { connected: 'Connected', connecting: 'Connecting...', disconnected: 'Disconnected', error: 'Error' };
      dot.style.background = colors[state] || 'var(--text-muted)';
      dot.title = titles[state] || state;
    }

    function updateDriverDots() {
      document.querySelectorAll('.driver-dot').forEach(function(el) {
        var uid = parseInt(el.dataset.userId);
        el.classList.toggle('online', onlineDrivers.has(uid));
      });
    }

    // ── postMessage relay to iframes ────────────────────────────
    function postToIframes(msg) {
      for (var key in OVERLAY_MAP) {
        if (hiddenPanels.has(key)) continue;
        var iframe = document.getElementById('iframe-' + key);
        if (iframe && iframe.contentWindow && iframe.style.display !== 'none') {
          iframe.contentWindow.postMessage(msg, '*');
        }
      }
    }

    function loadOverlayIframes(driverId) {
      for (var key in OVERLAY_MAP) {
        if (hiddenPanels.has(key)) continue;
        var iframe = document.getElementById('iframe-' + key);
        var placeholder = document.getElementById('placeholder-' + key);
        if (iframe) {
          iframe.src = OVERLAY_BASE + '/' + OVERLAY_MAP[key] + '?pitwall=1&driver=' + driverId;
          iframe.style.display = 'block';
          var label = iframe.parentNode && iframe.parentNode.querySelector('.panel-label');
          if (label) label.style.display = 'none';
          iframe.onload = (function() {
            var iframeRef = iframe;
            return function() {
              if (iframeRef.contentWindow) {
                iframeRef.contentWindow.postMessage({ type: 'bridge-connected' }, '*');
                iframeRef.contentWindow.postMessage({ type: 'status', iracing: true }, '*');
              }
            };
          })();
        }
        if (placeholder) placeholder.style.display = 'none';
      }
    }

    function clearOverlayIframes() {
      for (var key in OVERLAY_MAP) {
        var iframe = document.getElementById('iframe-' + key);
        var placeholder = document.getElementById('placeholder-' + key);
        if (iframe) {
          iframe.src = 'about:blank';
          iframe.style.display = 'none';
          var label = iframe.parentNode && iframe.parentNode.querySelector('.panel-label');
          if (label) label.style.display = '';
        }
        if (placeholder) placeholder.style.display = 'flex';
      }
    }

    // ── Driver Selection ────────────────────────────────────────
    window.selectDriver = function(userId, name) {
      if (selectedDriverId === userId) {
        window.deselectDriver();
        return;
      }

      selectedDriverId = userId;

      var nameEl = document.getElementById('driver-name');
      nameEl.textContent = name;
      nameEl.classList.add('has-driver');
      document.getElementById('live-badge').classList.add('active');

      document.querySelectorAll('.driver-dot').forEach(function(el) {
        var uid = parseInt(el.dataset.userId);
        el.classList.toggle('selected', uid === userId);
      });

      loadOverlayIframes(userId);

      if (ws && ws.readyState === 1) {
        ws.send(JSON.stringify({ type: 'subscribe', channels: ALL_CHANNELS, driverId: userId }));
      }
    };

    window.deselectDriver = function() {
      selectedDriverId = null;

      var nameEl = document.getElementById('driver-name');
      nameEl.textContent = 'Select a driver';
      nameEl.classList.remove('has-driver');
      document.getElementById('live-badge').classList.remove('active');
      document.getElementById('lap-time').textContent = '';
      document.getElementById('lap-count').textContent = '';
      document.getElementById('time-remaining').textContent = '';

      document.querySelectorAll('.driver-dot').forEach(function(el) {
        el.classList.remove('selected');
      });

      clearOverlayIframes();
    };

    // ── ESC key ─────────────────────────────────────────────────
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        var panel = document.getElementById('toggle-panel');
        if (panel.classList.contains('open')) {
          window.toggleSettingsPanel();
        } else {
          window.location.href = '/racing/teams';
        }
      }
    });

    // ── Boot ────────────────────────────────────────────────────
    initGrid();
    connect();
  })();
  </script>

  <script>lucide.createIcons();</script>
</body>
</html>
