<%- include('header', { streamer, t, title: 'Track Database' }) %>

<style>
  .tracks-page { max-width: 1200px; margin: 0 auto; padding: 20px; }
  .tracks-header { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 24px; }
  .tracks-header h1 { font-size: 24px; font-weight: 700; flex: 1; min-width: 200px; }
  .tracks-search { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 8px 14px; color: #fff; font-size: 14px; width: 240px; outline: none; }
  .tracks-search:focus { border-color: var(--accent, #9146ff); }
  .view-toggle { display: flex; gap: 4px; background: rgba(255,255,255,0.06); border-radius: 8px; padding: 3px; }
  .view-toggle button { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 6px 10px; border-radius: 6px; display: flex; align-items: center; }
  .view-toggle button.active { background: var(--accent, #9146ff); color: #fff; }
  .view-toggle button svg { width: 16px; height: 16px; fill: currentColor; }
  .btn-upload-ibt { background: var(--accent, #9146ff); color: #fff; border: none; border-radius: 8px; padding: 8px 16px; font-size: 13px; font-weight: 600; cursor: pointer; white-space: nowrap; }
  .btn-upload-ibt:hover { filter: brightness(1.15); }

  /* Grid View */
  .tracks-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
  .track-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden; cursor: pointer; transition: border-color 0.2s, transform 0.15s; }
  .track-card:hover { border-color: var(--accent, #9146ff); transform: translateY(-2px); }
  .track-card.missing { border: 2px dashed rgba(255,80,80,0.4); opacity: 0.6; cursor: default; }
  .track-card.missing:hover { transform: none; border-color: rgba(255,80,80,0.4); }
  .track-card-canvas { width: 100%; height: 200px; background: rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; }
  .track-card-canvas canvas { width: 100%; height: 100%; }
  .track-card-body { padding: 12px; }
  .track-card-name { font-size: 13px; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 6px; }
  .track-card-meta { display: flex; gap: 10px; flex-wrap: wrap; font-size: 11px; color: rgba(255,255,255,0.45); }
  .track-card-meta span { display: flex; align-items: center; gap: 3px; }
  .live-badge { background: #3ecf8e; color: #000; font-size: 9px; font-weight: 800; padding: 2px 8px; border-radius: 10px; animation: live-pulse 1.5s ease-in-out infinite; display: inline-flex; align-items: center; gap: 4px; }
  .live-badge::before { content: ''; width: 6px; height: 6px; background: #000; border-radius: 50%; }
  @keyframes live-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.7; } }
  .live-detail { background: rgba(62,207,142,0.1); border: 1px solid rgba(62,207,142,0.2); border-radius: 8px; padding: 10px 14px; margin-bottom: 12px; display: flex; align-items: center; gap: 12px; font-size: 11px; }
  .live-detail .live-badge { font-size: 10px; }
  .track-card-missing { font-size: 11px; color: rgba(255,80,80,0.7); padding: 12px; text-align: center; }

  /* List View */
  .tracks-list { display: none; }
  .tracks-list table { width: 100%; border-collapse: collapse; }
  .tracks-list th { text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.4); border-bottom: 1px solid rgba(255,255,255,0.08); }
  .tracks-list td { padding: 8px 12px; font-size: 13px; color: rgba(255,255,255,0.75); border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle; }
  .tracks-list tr.clickable { cursor: pointer; }
  .tracks-list tr.clickable:hover { background: rgba(255,255,255,0.04); }
  .tracks-list tr.missing td { color: rgba(255,80,80,0.5); }
  .tracks-list tr.missing { border-left: 3px solid rgba(255,80,80,0.4); }
  .list-thumb { width: 60px; height: 36px; border-radius: 4px; background: rgba(0,0,0,0.3); }

  /* Detail Page */
  .track-detail { display: none; }
  .track-detail-header { display: flex; gap: 24px; align-items: flex-start; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 24px; margin-bottom: 24px; }
  .track-detail-canvas { width: 200px; height: 160px; flex-shrink: 0; background: rgba(0,0,0,0.2); border-radius: 10px; overflow: hidden; }
  .track-detail-canvas canvas { width: 100%; height: 100%; }
  .track-detail-info { flex: 1; min-width: 0; }
  .track-detail-info h2 { font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .track-detail-location { font-size: 14px; color: rgba(255,255,255,0.45); margin-bottom: 16px; }
  .track-detail-stats { display: flex; gap: 24px; flex-wrap: wrap; }
  .track-stat { text-align: center; }
  .track-stat-value { font-size: 20px; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; }
  .track-stat-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; }
  .btn-back { background: none; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; padding: 6px 14px; color: rgba(255,255,255,0.6); font-size: 13px; cursor: pointer; margin-bottom: 16px; display: inline-flex; align-items: center; gap: 6px; }
  .btn-back:hover { color: #fff; border-color: rgba(255,255,255,0.3); }

  /* Class Tabs */
  .class-tabs { display: flex; gap: 4px; margin-bottom: 16px; flex-wrap: wrap; }
  .class-tab { padding: 6px 16px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.5); font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .class-tab:hover { border-color: rgba(255,255,255,0.25); }
  .class-tab.active { color: #fff; }
  .class-tab .class-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; }

  /* Stats Table */
  .stats-table { width: 100%; border-collapse: collapse; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; overflow: hidden; table-layout: auto; }
  .stats-table th { text-align: left; padding: 10px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.06); white-space: nowrap; }
  .stats-table td { padding: 10px 12px; font-size: 13px; color: rgba(255,255,255,0.7); border-bottom: 1px solid rgba(255,255,255,0.04); font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .stats-table td.dimmed { color: rgba(255,255,255,0.15); }
  .stats-table tr:last-child td { border-bottom: none; }

  /* Section Tabs (Stats / Practice / Race) */
  .section-tabs { display: flex; gap: 2px; margin-bottom: 16px; }
  .section-tab { padding: 8px 20px; font-size: 13px; font-weight: 600; cursor: pointer; border-radius: 8px 8px 0 0; transition: all 0.15s; border: 1px solid transparent; border-bottom: none; }
  .section-tab.tab-stats { color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.03); }
  .section-tab.tab-stats.active { color: var(--accent); background: rgba(145,70,255,0.08); border-color: rgba(145,70,255,0.2); }
  .section-tab.tab-practice { color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.03); }
  .section-tab.tab-practice.active { color: #3ecf8e; background: rgba(62,207,142,0.08); border-color: rgba(62,207,142,0.2); }
  .section-tab.tab-race { color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.03); }
  .section-tab.tab-race.active { color: #f7c948; background: rgba(247,201,72,0.08); border-color: rgba(247,201,72,0.2); }
  .section-content { display: none; }
  .section-content.active { display: block; }

  /* Session list */
  .session-list { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; overflow: hidden; }
  .session-row { display: grid; grid-template-columns: 140px 1fr 100px 60px 60px; gap: 8px; padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 12px; color: rgba(255,255,255,0.6); cursor: pointer; transition: background 0.1s; }
  .session-row:hover { background: rgba(255,255,255,0.03); }
  .session-row:last-child { border-bottom: none; }
  .session-header { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.03); cursor: default; }
  .session-header:hover { background: rgba(255,255,255,0.03); }
  .session-best { font-family: 'JetBrains Mono', monospace; font-weight: 600; color: #f7c948; }
  .session-empty { padding: 24px; text-align: center; color: rgba(255,255,255,0.25); font-size: 13px; }

  /* Import Modal */
  .import-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center; }
  .import-modal-overlay.open { display: flex; }
  .import-modal { background: var(--bg-card, #13141c); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 24px; width: 90%; max-width: 600px; max-height: 85vh; overflow-y: auto; position: relative; }
  .import-modal-close { position: absolute; top: 12px; right: 16px; background: none; border: none; color: rgba(255,255,255,0.4); font-size: 20px; cursor: pointer; }
  .import-modal-close:hover { color: #fff; }

  /* Import button */
  .import-toggle { background: none; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; padding: 8px 16px; color: rgba(255,255,255,0.6); font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
  .import-toggle:hover { color: #fff; border-color: rgba(255,255,255,0.3); }
  .import-toggle svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2; }
  .import-controls { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; align-items: flex-end; }
  .import-field { display: flex; flex-direction: column; gap: 4px; }
  .import-field label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px; }
  .import-field select { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 8px 12px; color: #fff; font-size: 13px; min-width: 160px; }
  .import-dropzone { border: 2px dashed rgba(255,255,255,0.12); border-radius: 10px; padding: 32px; text-align: center; cursor: pointer; transition: all 0.2s; }
  .import-dropzone:hover, .import-dropzone.dragover { border-color: var(--accent, #9146ff); background: rgba(145,70,255,0.05); }
  .import-dropzone-text { font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.5); margin-bottom: 4px; }
  .import-dropzone-hint { font-size: 12px; color: rgba(255,255,255,0.25); }
  .import-spinner { display: none; text-align: center; padding: 24px; color: rgba(255,255,255,0.5); font-size: 13px; }
  .import-spinner.active { display: block; }
  .import-confirm { display: none; margin-top: 16px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 16px; }
  .import-confirm.active { display: block; }
  .import-confirm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; margin-bottom: 16px; }
  .import-confirm-item { text-align: center; padding: 8px; }
  .import-confirm-value { font-size: 18px; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; }
  .import-confirm-label { font-size: 10px; color: rgba(255,255,255,0.4); text-transform: uppercase; }
  .import-confirm-actions { display: flex; gap: 8px; }
  .btn-save-import { background: #3ecf8e; color: #000; border: none; border-radius: 8px; padding: 8px 20px; font-size: 13px; font-weight: 600; cursor: pointer; }
  .btn-save-import:hover { filter: brightness(1.1); }
  .btn-save-import:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-cancel-import { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.6); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 8px 20px; font-size: 13px; cursor: pointer; }
  .import-error { color: #f04438; font-size: 13px; margin-top: 8px; }
  .import-success { color: #3ecf8e; font-size: 13px; margin-top: 8px; }

  @media (max-width: 600px) {
    .tracks-header { flex-direction: column; align-items: stretch; }
    .tracks-search { width: 100%; }
    .track-detail-header { flex-direction: column; }
    .track-detail-canvas { width: 100%; height: 140px; }
  }
</style>

<div class="tracks-page">
  <!-- List View -->
  <div id="tracks-list-view">
    <a href="/racing" class="btn-back" style="text-decoration:none;margin-bottom:16px;">&#8592; Back</a>
    <div class="tracks-header">
      <h1>Track Database</h1>
      <div class="view-toggle">
        <button id="btn-grid" class="active" onclick="setView('grid')" title="Grid view">
          <svg viewBox="0 0 24 24"><path d="M3 3h8v8H3V3zm0 10h8v8H3v-8zm10-10h8v8h-8V3zm0 10h8v8h-8v-8z"/></svg>
        </button>
        <button id="btn-list" onclick="setView('list')" title="List view">
          <svg viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
        </button>
      </div>
      <input type="text" class="tracks-search" id="tracks-search" placeholder="Search tracks..." oninput="filterTracks()">
      <button class="btn-upload-ibt" onclick="window.location='/dashboard#iracing-tracks'">Upload IBT</button>
    </div>

    <div class="tracks-grid" id="tracks-grid"></div>
    <div class="tracks-list" id="tracks-list">
      <table>
        <thead><tr><th>Track</th><th>Location</th><th>Length</th><th>Turns</th><th>Classes</th><th>Races</th></tr></thead>
        <tbody id="tracks-list-body"></tbody>
      </table>
    </div>
  </div>

  <!-- Detail View -->
  <div class="track-detail" id="track-detail">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <button class="btn-back" onclick="goBack()">&#8592; Back</button>
      <button class="import-toggle" onclick="openImportModal()">
        <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Import Race Data
      </button>
    </div>
    <div class="live-detail" id="detail-live-info" style="display:none;"></div>
    <div class="track-detail-header">
      <div class="track-detail-canvas"><canvas id="detail-canvas" width="400" height="320"></canvas></div>
      <div class="track-detail-info">
        <h2 id="detail-name">--</h2>
        <div class="track-detail-location" id="detail-location">--</div>
        <div class="track-detail-stats" id="detail-stats"></div>
      </div>
    </div>

    <!-- Section Tabs: Stats / Practice / Race -->
    <div class="section-tabs">
      <div class="section-tab tab-stats active" onclick="switchSection('stats')">Stats</div>
      <div class="section-tab tab-practice" onclick="switchSection('practice')">Practice</div>
      <div class="section-tab tab-race" onclick="switchSection('race')">Race</div>
    </div>

    <!-- Stats Section (existing) -->
    <div class="section-content active" id="section-stats">
      <div class="class-tabs" id="class-tabs"></div>
      <div id="class-stats-content"></div>
    </div>

    <!-- Practice Section -->
    <div class="section-content" id="section-practice">
      <div class="session-list" id="practice-sessions">
        <div class="session-empty">Loading practice sessions...</div>
      </div>
    </div>

    <!-- Race Section -->
    <div class="section-content" id="section-race">
      <div class="session-list" id="race-sessions">
        <div class="session-empty">Loading race sessions...</div>
      </div>
    </div>
  </div>

  <!-- Import Modal -->
  <div class="import-modal-overlay" id="import-modal" onclick="if(event.target===this)closeImportModal()">
    <div class="import-modal">
      <button class="import-modal-close" onclick="closeImportModal()">&times;</button>
      <h3 style="margin-bottom:16px;font-size:16px;">Import Race Data</h3>
      <div class="import-panel" id="import-panel" style="display:block;margin-top:0;border:none;padding:0;background:none;">
        <div class="import-controls">
          <div class="import-field">
            <label>Category</label>
            <select id="import-category" onchange="updateImportOptions()">
              <option value="road">Road</option>
              <option value="formula">Formula</option>
              <option value="oval">Oval / NASCAR</option>
              <option value="dirt_oval">Dirt Oval</option>
              <option value="dirt_road">Dirt Road / Rallycross</option>
            </select>
          </div>
          <div class="import-field">
            <label>Car Class</label>
            <select id="import-class"></select>
          </div>
          <div class="import-field">
            <label>Race Type</label>
            <select id="import-race-type"></select>
          </div>
        </div>
        <div id="import-coming-soon" style="display:none;padding:20px;text-align:center;color:rgba(255,255,255,0.35);font-size:13px;font-weight:600;">Coming Soon</div>
        <div style="display:flex;gap:12px;margin-bottom:12px;" id="import-dropzones">
          <div class="import-dropzone" id="import-dropzone" style="flex:1;"
            ondragover="event.preventDefault(); this.classList.add('dragover');"
            ondragleave="this.classList.remove('dragover');"
            ondrop="event.preventDefault(); this.classList.remove('dragover'); handleImportDrop(event);"
            onclick="document.getElementById('import-file-input').click();">
            <input type="file" id="import-file-input" accept="image/*,.json,.csv" style="display:none" onchange="handleImportFile(this.files[0])">
            <div class="import-dropzone-text">Race Results</div>
            <div class="import-dropzone-hint">iRacing JSON · CSV · Screenshot</div>
          </div>
          <div class="import-dropzone" style="flex:1;"
            ondragover="event.preventDefault(); this.classList.add('dragover');"
            ondragleave="this.classList.remove('dragover');"
            ondrop="event.preventDefault(); this.classList.remove('dragover'); handleQualDrop(event);"
            onclick="document.getElementById('import-qual-input').click();">
            <input type="file" id="import-qual-input" accept=".json,.csv" style="display:none" onchange="handleQualFile(this.files[0])">
            <div class="import-dropzone-text">Qualifying (optional)</div>
            <div class="import-dropzone-hint">Separate qualify JSON/CSV if needed</div>
          </div>
        </div>
        <div class="import-spinner" id="import-spinner">Analyzing screenshot...</div>
        <div class="import-confirm" id="import-confirm">
          <div class="import-confirm-grid" id="import-confirm-grid"></div>
          <div class="import-confirm-actions">
            <button class="btn-save-import" id="btn-save-import" onclick="saveImport()">Save to Database</button>
            <button class="btn-cancel-import" onclick="cancelImport()">Cancel</button>
          </div>
          <div id="import-message"></div>
        </div>
        <div id="import-error" class="import-error"></div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  let allTracks = [];
