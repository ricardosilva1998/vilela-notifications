  // Parse JSON import — supports iRacing event result format + direct format
  function parseImportJSON(json, carClass, raceType) {
    // Direct format: { avgLapTime: 92.5, avgPitTime: 28.3, ... }
    if (json.avgLapTime !== undefined) return json;

    var data = { carClass: carClass, raceType: raceType };

    // iRacing event result format (type: "event_result")
    if (json.type === 'event_result' && json.data) {
      var d = json.data;
      // SOF from car_classes
      if (d.car_classes && d.car_classes.length) {
        data.avgSOF = d.car_classes[0].strength_of_field || d.event_strength_of_field;
        data.driverCount = d.car_classes[0].num_entries || d.num_drivers;
        // Auto-detect car class
        if (!carClass || carClass === 'auto') {
          var cls = d.car_classes[0].short_name || d.car_classes[0].name || '';
          if (cls.includes('GT3')) data.carClass = 'GT3';
          else if (cls.includes('GTP') || cls.includes('Hypercar')) data.carClass = 'GTP';
          else if (cls.includes('LMP2')) data.carClass = 'LMP2';
          else if (cls.includes('GT4')) data.carClass = 'GT4';
          else if (cls.includes('LMP3')) data.carClass = 'LMP3';
          else if (cls.includes('GTE')) data.carClass = 'GTE';
          else if (cls.includes('TCR')) data.carClass = 'TCR';
          else if (cls.includes('Porsche')) data.carClass = 'Porsche Cup';
          else if (cls.includes('BMW M2') || cls.includes('MX-5') || cls.includes('Mazda')) data.carClass = cls.includes('Mazda') || cls.includes('MX-5') ? 'Mazda' : 'BMW M2';
          else if (cls.includes('Toyota') || cls.includes('GR86')) data.carClass = 'Toyota';
          else data.carClass = cls;
        }
      }
      data.estLaps = d.event_laps_complete || 0;

      // Auto-detect race type from series name
      if ((!raceType || raceType === 'auto') && d.series_name) {
        var sn = d.series_name.toLowerCase();
        if (sn.includes('regional')) data.raceType = 'Regionals';
        else if (sn.includes('vrs') && sn.includes('sprint')) data.raceType = 'VRS Sprint';
        else if (sn.includes('vrs') && sn.includes('open')) data.raceType = 'VRS Open';
        else if (sn.includes('imsa') && sn.includes('sprint')) data.raceType = 'IMSA Sprint';
        else if (sn.includes('imsa') && sn.includes('open')) data.raceType = 'IMSA Open';
        else if (sn.includes('imsa') && sn.includes('endurance')) data.raceType = 'IMSA Endurance';
        else if (sn.includes('global') && sn.includes('endurance')) data.raceType = 'Global Endurance';
        else if (sn.includes('sprint')) data.raceType = 'Sprint';
        else if (sn.includes('open')) data.raceType = 'Open';
        else if (sn.includes('endurance')) data.raceType = 'Endurance';
      }

      // Find RACE session results
      var raceSession = (d.session_results || []).find(function(s) { return s.simsession_type === 6; });
      if (raceSession && raceSession.results && raceSession.results.length) {
        // Use average_lap (race pace) not best_lap_time — values in tenths of ms (÷10000 for seconds)
        var avgLaps = raceSession.results
          .map(function(r) { return r.average_lap; })
          .filter(function(t) { return t && t > 0; });
        if (avgLaps.length) {
          data.avgLapTime = (avgLaps.reduce(function(a,b){return a+b;},0) / avgLaps.length) / 10000;
        }
        // Max laps completed (leader)
        var maxLaps = 0;
        raceSession.results.forEach(function(r) { if (r.laps_complete > maxLaps) maxLaps = r.laps_complete; });
        if (maxLaps > 0) data.estLaps = maxLaps;
        data.driverCount = raceSession.results.length;
        // Most used car
        var carCounts = {};
        raceSession.results.forEach(function(r) { if (r.car_name) carCounts[r.car_name] = (carCounts[r.car_name] || 0) + 1; });
        var topCar = Object.keys(carCounts).sort(function(a,b) { return carCounts[b] - carCounts[a]; })[0];
        if (topCar) data.topCar = topCar;
      }

      // Find QUALIFY session (type 4 = Lone Qualifying, type 5 = Open Qualifying)
      var qualSession = (d.session_results || []).find(function(s) { return s.simsession_type === 4 || s.simsession_type === 5; });
      if (qualSession && qualSession.results && qualSession.results.length) {
        var qualLaps = qualSession.results
          .map(function(r) { return r.best_lap_time; })
          .filter(function(t) { return t && t > 0; });
        if (qualLaps.length) {
          data.avgQualifyTime = (qualLaps.reduce(function(a,b){return a+b;},0) / qualLaps.length) / 10000;
        }
      }

      if (d.series_name) data._seriesName = d.series_name;

      return data;
    }

    // Garage61 / generic format
    if (json.results && Array.isArray(json.results)) {
      var laps = json.results.map(function(r) { return r.bestLapTime || r.best_lap || r.fastestLap; }).filter(function(t) { return t && t > 0; });
      if (laps.length) data.avgLapTime = laps.reduce(function(a,b){return a+b;},0) / laps.length;
      data.driverCount = json.results.length;
    }
    if (json.sof || json.SOF || json.strengthOfField) data.avgSOF = json.sof || json.SOF || json.strengthOfField;
    if (json.laps && typeof json.laps === 'number') data.estLaps = json.laps;
    return data;
  }

  // Parse CSV import — expects header row with lap time columns
  function parseImportCSV(text, carClass, raceType) {
    var lines = text.trim().split('\n').filter(function(l) { return l.trim(); });
    if (lines.length < 2) throw new Error('CSV needs header + at least 1 data row');
    var data = { carClass: carClass, raceType: raceType };

    // iRacing CSV format has a summary header (row 0), summary data (row 1),
    // blank line, then results header + driver rows.
    // Detect by checking if row 0 has "Strength of Field" (summary header)
    var summaryHeader = lines[0].split(',').map(function(h) { return h.trim().replace(/"/g, ''); });
    var hasSummary = summaryHeader.some(function(h) { return h.toLowerCase().includes('strength of field'); });

    var resultsStartLine = 0;
    if (hasSummary) {
      // Parse summary row for SOF and series info
      var summaryHeaders = summaryHeader.map(function(h) { return h.toLowerCase(); });
      var summaryVals = lines[1].split(',').map(function(c) { return c.trim().replace(/"/g, ''); });
      var sofIdx = summaryHeaders.findIndex(function(h) { return h.includes('strength'); });
      var seriesIdx = summaryHeaders.findIndex(function(h) { return h.includes('series'); });
      if (sofIdx >= 0 && summaryVals[sofIdx]) data.avgSOF = parseFloat(summaryVals[sofIdx]) || 0;
      if (seriesIdx >= 0) data._seriesName = summaryVals[seriesIdx] || '';
      // Skip to results header (find line with "Fin Pos" or "Car")
      for (var i = 2; i < lines.length; i++) {
        if (lines[i].toLowerCase().includes('fin pos') || lines[i].toLowerCase().includes('car class')) {
          resultsStartLine = i;
          break;
        }
      }
    }

    var headers = lines[resultsStartLine].split(',').map(function(h) { return h.trim().toLowerCase().replace(/"/g, ''); });

    // Find column indices
    var fastLapCol = headers.findIndex(function(h) { return h.includes('fastest lap') || h.includes('fast lap'); });
    var avgLapCol = headers.findIndex(function(h) { return h.includes('average lap'); });
    var qualCol = headers.findIndex(function(h) { return h.includes('qualify time') || h.includes('qual time'); });
    var carCol = headers.findIndex(function(h) { return h === 'car'; });
    var carClassCol = headers.findIndex(function(h) { return h === 'car class'; });
    var lapsCol = headers.findIndex(function(h) { return h.includes('laps comp'); });
    var newIRCol = headers.findIndex(function(h) { return h.includes('new irating'); });

    var fastLaps = [], avgLaps = [], qualTimes = [], lapsArr = [], iRatings = [];
    var detectedCar = '', detectedClass = '', driverCount = 0;

    for (var i = resultsStartLine + 1; i < lines.length; i++) {
      var cols = lines[i].split(',').map(function(c) { return c.trim().replace(/"/g, ''); });
      if (cols.length < 3) continue;
      driverCount++;

      if (fastLapCol >= 0 && cols[fastLapCol]) { var t = parseLapTime(cols[fastLapCol]); if (t > 0) fastLaps.push(t); }
      if (avgLapCol >= 0 && cols[avgLapCol]) { var t = parseLapTime(cols[avgLapCol]); if (t > 0) avgLaps.push(t); }
      if (qualCol >= 0 && cols[qualCol]) { var t = parseLapTime(cols[qualCol]); if (t > 0) qualTimes.push(t); }
      if (lapsCol >= 0 && cols[lapsCol]) { var l = parseInt(cols[lapsCol]); if (l > 0) lapsArr.push(l); }
      if (newIRCol >= 0 && cols[newIRCol]) { var r = parseInt(cols[newIRCol]); if (r > 0) iRatings.push(r); }
      if (carCol >= 0 && cols[carCol] && !detectedCar) detectedCar = cols[carCol];
      if (carClassCol >= 0 && cols[carClassCol] && !detectedClass) detectedClass = cols[carClassCol];
    }

    // Use fastest laps for avg lap (most meaningful)
    if (fastLaps.length) data.avgLapTime = fastLaps.reduce(function(a,b){return a+b;},0) / fastLaps.length;
    else if (avgLaps.length) data.avgLapTime = avgLaps.reduce(function(a,b){return a+b;},0) / avgLaps.length;
    if (qualTimes.length) data.avgQualifyTime = qualTimes.reduce(function(a,b){return a+b;},0) / qualTimes.length;
    if (lapsArr.length) data.estLaps = Math.max.apply(null, lapsArr);
    if (iRatings.length && !data.avgSOF) data.avgSOF = Math.round(iRatings.reduce(function(a,b){return a+b;},0) / iRatings.length);
    data.driverCount = driverCount;
    if (detectedCar) data.topCar = detectedCar;
    // Auto-detect class from CSV if user chose 'auto'
    if ((!carClass || carClass === 'auto') && detectedCar) data.carClass = detectedCar;
    return data;
  }

  // Parse lap time string "1:32.456" → 92.456 seconds
  function parseLapTime(str) {
    if (!str) return 0;
    str = String(str).trim();
    var match = str.match(/^(\d+):(\d+\.\d+)$/);
    if (match) return parseInt(match[1]) * 60 + parseFloat(match[2]);
    var num = parseFloat(str);
    return isNaN(num) ? 0 : num;
  }

  function showImportConfirm(data) {
    // Merge pending qualify data (always override with separate qualify file if available)
    if (pendingQualData && pendingQualData.avgQualifyTime) {
      data.avgQualifyTime = pendingQualData.avgQualifyTime;
    }
    // Use the category/class/raceType the user already selected in the import panel
    var userCategory = document.getElementById('import-category').value;
    var userClass = document.getElementById('import-class').value;
    var userRaceType = document.getElementById('import-race-type').value;

    // Auto-detect category from car class if user left on auto
    var detectedClass = data.carClass || data.topCar || '';
    if (userClass === 'auto' && detectedClass) {
      // Search all categories for the detected class
      for (var cat in IMPORT_OPTIONS) {
        if (!IMPORT_OPTIONS[cat]) continue;
        var found = IMPORT_OPTIONS[cat].classes.find(function(c) {
          return c.toLowerCase() === detectedClass.toLowerCase() || detectedClass.toLowerCase().includes(c.toLowerCase());
        });
        if (found && found !== 'auto') {
          userCategory = cat;
          userClass = found;
          // Also update the import panel dropdowns
          document.getElementById('import-category').value = cat;
          updateImportOptions();
          document.getElementById('import-class').value = found;
          break;
        }
      }
    }

    // Confirm dropdowns removed — using top panel selections directly

    // Populate values grid
    var grid = document.getElementById('import-confirm-grid');
    grid.innerHTML = '';
    var fields = [
      { key: 'avgLapTime', label: 'Avg Lap', format: formatLapTime },
      { key: 'avgQualifyTime', label: 'Avg Qualify', format: formatLapTime },
      { key: 'avgPitTime', label: 'Avg Pit', format: function(v) { return v ? v.toFixed(1) + 's' : '--'; } },
      { key: 'avgSOF', label: 'SOF', format: function(v) { return v ? Math.round(v).toLocaleString() : '--'; } },
      { key: 'driverCount', label: 'Drivers', format: function(v) { return v || '--'; } },
      { key: 'estLaps', label: 'Laps', format: function(v) { return v || '--'; } },
      { key: 'topCar', label: 'Top Car', format: function(v) { return v || '--'; } },
    ];
    fields.forEach(function(f) {
      var val = data[f.key];
      grid.innerHTML += '<div class="import-confirm-item"><div class="import-confirm-value">' + f.format(val) + '</div><div class="import-confirm-label">' + f.label + '</div></div>';
    });

    document.getElementById('import-confirm').classList.add('active');
    document.getElementById('import-message').innerHTML = '';

    // Enable save button
    var btn = document.getElementById('btn-save-import');
    btn.disabled = false;
  }

  window.saveImport = function() {
    if (!importData) return;
    var trackName = document.getElementById('detail-name').textContent;
    var carClass = document.getElementById('import-class').value;
    var raceType = document.getElementById('import-race-type').value;
    // If still auto, use detected values
    if (carClass === 'auto') carClass = importData.carClass || importData.topCar || 'GT3';
    if (raceType === 'auto') raceType = importData.raceType || 'Sprint';
    var btn = document.getElementById('btn-save-import');
    btn.disabled = true;
    btn.textContent = 'Saving...';

    var stats = {};
    stats[carClass] = {
      avgLapTime: importData.avgLapTime || 0,
      avgPitTime: importData.avgPitTime || 0,
      avgQualifyTime: importData.avgQualifyTime || 0,
      avgSOF: importData.avgSOF || 0,
      estLaps: importData.estLaps || 0,
      samples: importData.driverCount || 0,
      topCar: importData.topCar || null,
    };

    fetch('/api/track-stats', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ trackName: trackName, raceType: raceType, stats: stats }),
    })
    .then(function(r) { return r.json(); })
    .then(function(result) {
      if (result.ok) {
        document.getElementById('import-message').innerHTML = '<div class="import-success">Data saved! Refreshing...</div>';
        setTimeout(function() {
          fetch('/api/track-stats').then(function(r) { return r.json(); }).then(function(s) {
            allStats = s;
            showDetail(trackName);
            cancelImport();
          });
        }, 1000);
      } else {
        document.getElementById('import-message').innerHTML = '<div class="import-error">Error: ' + (result.error || 'Save failed') + '</div>';
        btn.disabled = false;
        btn.textContent = 'Save to Database';
      }
    })
    .catch(function(e) {
      document.getElementById('import-message').innerHTML = '<div class="import-error">Request failed: ' + e.message + '</div>';
      btn.disabled = false;
      btn.textContent = 'Save to Database';
    });
  };

  window.cancelImport = function() {
    document.getElementById('import-confirm').classList.remove('active');
    document.getElementById('import-dropzone').style.display = '';
    document.getElementById('import-spinner').classList.remove('active');
    document.getElementById('import-error').textContent = '';
    document.getElementById('import-file-input').value = '';
    importData = null;
  };

  window._switchClassTab = function(btn, cls) {
    document.querySelectorAll('.class-tab').forEach(t => {
      t.classList.remove('active');
      t.style.background = 'rgba(255,255,255,0.04)';
      t.style.borderColor = 'rgba(255,255,255,0.1)';
    });
    btn.classList.add('active');
    const color = btn.dataset.color || '#ffffff';
    btn.style.background = color + '22';
    btn.style.borderColor = color;
    const trackName = document.getElementById('detail-name').textContent;
    renderClassStats(trackName, cls);
  };

  // Handle browser back
  window.addEventListener('popstate', () => {
    const pathMatch = window.location.pathname.match(/^\/tracks\/(.+)/);
    if (pathMatch) {
      showDetail(decodeURIComponent(pathMatch[1]));
    } else {
      showList();
    }
  });

  loadData();

  // ─── Live Session Polling ───
  let liveSession = null;
  async function pollLiveSession() {
    try {
      const res = await fetch('/api/live-session');
      liveSession = await res.json();
    } catch(e) { liveSession = null; }
    updateLiveBadges();
  }

  function updateLiveBadges() {
    // Update grid cards
    document.querySelectorAll('.track-card').forEach(card => {
      const name = card.querySelector('.track-card-name')?.textContent;
      const existing = card.querySelector('.live-badge');
      if (existing) existing.remove();
      if (liveSession && liveSession.trackName === name) {
        const badge = document.createElement('div');
        badge.className = 'live-badge';
        badge.textContent = 'LIVE';
        badge.style.position = 'absolute'; badge.style.top = '8px'; badge.style.right = '8px';
        const canvas = card.querySelector('.track-card-canvas');
        if (canvas) { canvas.style.position = 'relative'; canvas.appendChild(badge); }
      }
    });
    // Update detail page live indicator
    const detailLive = document.getElementById('detail-live-info');
    if (detailLive) {
      const detailName = document.getElementById('detail-name')?.textContent;
      if (liveSession && liveSession.trackName === detailName) {
        const classes = (liveSession.classes || []).join(', ');
        const type = liveSession.eventType || 'Unknown';
        const drivers = liveSession.driversCount || 0;
        const timeLeft = liveSession.timeRemain ? Math.round(liveSession.timeRemain / 60) + ' min left' : '';
        detailLive.innerHTML = '<span class="live-badge">LIVE</span> <span>' + type + '</span> <span style="color:rgba(255,255,255,0.5);">·</span> <span>' + classes + '</span> <span style="color:rgba(255,255,255,0.5);">·</span> <span>' + drivers + ' drivers</span>' + (timeLeft ? ' <span style="color:rgba(255,255,255,0.5);">·</span> <span>' + timeLeft + '</span>' : '');
        detailLive.style.display = 'flex';
      } else {
        detailLive.style.display = 'none';
      }
    }
  }

  pollLiveSession();
  setInterval(pollLiveSession, 10000);
})();
</script>

