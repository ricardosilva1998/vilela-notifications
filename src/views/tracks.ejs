  const RACE_TYPES_BY_CLASS = {
    'GT3':  ['VRS Sprint', 'VRS Open', 'VRS Endurance', 'IMSA Sprint', 'IMSA Open', 'IMSA Endurance', 'Global Endurance', 'Regionals'],
    'LMP2': ['LMP2 Sprint', 'IMSA Sprint', 'IMSA Open', 'IMSA Endurance', 'Global Endurance'],
    'GTP':  ['Proto Sprint', 'IMSA Sprint', 'IMSA Open', 'IMSA Endurance', 'Global Endurance'],
  };
  const DEFAULT_RACE_TYPES = ['Sprint', 'Open', 'Endurance'];

  // iRacing class colors (matching in-sim colors)
  const CLASS_COLORS = {
    'GTP':         '#c8a84e', // gold
    'LMP2':        '#3b82f6', // blue
    'GT3':         '#e63995', // pink/magenta
    'GT4':         '#4ade80', // green
    'LMP3':        '#f97316', // orange
    'TCR':         '#a78bfa', // purple
    'Porsche Cup': '#ef4444', // red
    'BMW M2':      '#06b6d4', // cyan
    'Toyota':      '#f43f5e', // rose
    'GTE':         '#eab308', // yellow
    'Mazda':       '#fb923c', // light orange
  };
  function getClassColor(cls) { return CLASS_COLORS[cls] || '#ffffff'; }

  function drawTrackPreview(canvas, points) {
    const ctx = canvas.getContext('2d');
    const w = canvas.width, h = canvas.height;
    ctx.clearRect(0, 0, w, h);
    if (!points || points.length < 10) return;
    let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
    points.forEach(p => { if (p.x < minX) minX = p.x; if (p.x > maxX) maxX = p.x; if (p.y < minY) minY = p.y; if (p.y > maxY) maxY = p.y; });
    const xR = maxX - minX || 1, yR = maxY - minY || 1;
    const pad = 0.08, aspect = xR / yR;
    let scX = 1, scY = 1;
    if (aspect > 1) scY = 1 / aspect; else scX = aspect;
    const u = 1 - 2 * pad;
    ctx.beginPath();
    ctx.strokeStyle = '#9146ff';
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    points.forEach((p, i) => {
      const x = (pad + u * scX * (p.x - minX) / xR + u * (1 - scX) / 2) * w;
      const y = (pad + u * scY * (1 - (p.y - minY) / yR) + u * (1 - scY) / 2) * h;
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    });
    ctx.closePath();
    ctx.stroke();
    // Start/finish dot
    const sf = points[0];
    const sfx = (pad + u * scX * (sf.x - minX) / xR + u * (1 - scX) / 2) * w;
    const sfy = (pad + u * scY * (1 - (sf.y - minY) / yR) + u * (1 - scY) / 2) * h;
    ctx.beginPath(); ctx.arc(sfx, sfy, 4, 0, Math.PI * 2); ctx.fillStyle = '#3ecf8e'; ctx.fill();
  }

  function formatLapTime(t) {
    if (!t || t <= 0) return '--';
    const m = Math.floor(t / 60);
    const s = (t % 60).toFixed(3);
    return m > 0 ? m + ':' + s.padStart(6, '0') : s;
  }

  function formatSOF(v) {
    if (!v || v <= 0) return '--';
    return v >= 1000 ? (v / 1000).toFixed(1) + 'k' : String(Math.round(v));
  }

  function isNamedTrack(name) {
    return !name.match(/^-?\d+\.\d+_-?\d+\.\d+$/);
  }

  // ─── Load data ───
  async function loadData() {
    try {
      const [tracksRes, statsRes] = await Promise.all([
        fetch('/api/track-maps'),
        fetch('/api/track-stats'),
      ]);
      allTracks = await tracksRes.json();
      allStats = await statsRes.json();
    } catch(e) { console.error('Failed to load track data:', e); }

    // Apply initial view
    setView(currentView);
    renderTracks();

    // Check URL for detail view
    const pathMatch = window.location.pathname.match(/^\/tracks\/(.+)/);
    if (pathMatch) {
      const trackName = decodeURIComponent(pathMatch[1]);
      showDetail(trackName);
    }
  }

  // ─── Render ───
  function renderTracks() {
    const search = (document.getElementById('tracks-search').value || '').toLowerCase();
    const named = allTracks.filter(t => isNamedTrack(t.track_name));

    // Build stats lookup: track -> { classes, totalRaces }
    const statsLookup = {};
    allStats.forEach(s => {
      if (!statsLookup[s.track_name]) statsLookup[s.track_name] = { classes: new Set(), totalRaces: 0 };
      statsLookup[s.track_name].classes.add(s.car_class);
      statsLookup[s.track_name].totalRaces += s.race_count || 0;
    });

    // Merge known tracks (missing ones)
    function cleanTrackName(n) {
      return n.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9 ]/g, ' ').replace(/\s+/g, ' ').trim();
    }
    var GENERIC_WORDS = ['circuit','speedway','international','motor','park','raceway','ring','grand','prix','motorsport','motorsports','track','road','national'];
    function getSignificantWords(s) {
      return cleanTrackName(s).split(' ').filter(function(w) { return w.length >= 4 && GENERIC_WORDS.indexOf(w) < 0; });
    }
    function tracksMatch(a, b) {
      var cleanA = cleanTrackName(a), cleanB = cleanTrackName(b);
      if (cleanA === cleanB) return true;
      if (cleanA.includes(cleanB) || cleanB.includes(cleanA)) return true;
      // Word overlap: need 1+ specific word (not generic) of 5+ chars matching
      var wordsA = getSignificantWords(a), wordsB = getSignificantWords(b);
      var overlap = wordsA.filter(function(w) { return wordsB.some(function(w2) { return w === w2; }); });
      return overlap.length >= 1 && overlap.some(function(w) { return w.length >= 5; });
    }
    const missing = KNOWN_IRACING_TRACKS.filter(function(known) {
      return !named.some(function(t) { return tracksMatch(t.track_name, known.name); });
    });

    const filtered = named.filter(t => t.track_name.toLowerCase().includes(search));
    const filteredMissing = missing.filter(t => t.name.toLowerCase().includes(search));

    // Grid view
    let gridHtml = '';
    filtered.forEach(t => {
      const s = statsLookup[t.track_name];
      const loc = [t.track_city, t.track_country].filter(Boolean).join(', ');
      gridHtml += `<div class="track-card" onclick="window._showDetail('${t.track_name.replace(/'/g, "\\'")}')">
        <div class="track-card-canvas"><canvas data-track="${t.track_name}" width="440" height="280"></canvas></div>
        <div class="track-card-body">
          <div class="track-card-name" title="${t.track_name}">${t.track_name}</div>
          <div class="track-card-meta">
            ${t.track_length ? '<span>' + t.track_length + '</span>' : ''}
            ${t.track_turns ? '<span>' + t.track_turns + ' turns</span>' : ''}
            ${s ? '<span>' + s.classes.size + ' class' + (s.classes.size !== 1 ? 'es' : '') + '</span>' : ''}
            ${s ? '<span>' + s.totalRaces + ' race' + (s.totalRaces !== 1 ? 's' : '') + '</span>' : ''}
          </div>
        </div>
      </div>`;
    });
    var catLabels = { road: 'Road', oval: 'Oval', dirt_oval: 'Dirt', dirt_road: 'Rallycross', formula: 'Formula' };
    var catColors = { road: '#9146ff', oval: '#f7c948', dirt_oval: '#f97316', dirt_road: '#4ade80', formula: '#38bdf8' };
    filteredMissing.forEach(n => {
      var catLabel = catLabels[n.cat] || 'Road';
      var catColor = catColors[n.cat] || '#9146ff';
      gridHtml += `<div class="track-card missing">
        <div class="track-card-canvas" style="display:flex;align-items:center;justify-content:center;color:rgba(255,80,80,0.35);font-size:11px;">No data</div>
        <div class="track-card-body">
          <div class="track-card-name" title="${n.name}">${n.name}</div>
          <div style="display:flex;gap:6px;align-items:center;">
            <span style="font-size:9px;font-weight:700;color:${catColor};background:${catColor}15;padding:1px 6px;border-radius:4px;">${catLabel}</span>
            <span class="track-card-missing">Upload IBT to add</span>
          </div>
        </div>
      </div>`;
    });
    document.getElementById('tracks-grid').innerHTML = gridHtml;

    // List view
    let listHtml = '';
    filtered.forEach(t => {
      const s = statsLookup[t.track_name];
      const loc = [t.track_city, t.track_country].filter(Boolean).join(', ') || '--';
      listHtml += `<tr class="clickable" onclick="window._showDetail('${t.track_name.replace(/'/g, "\\'")}')">
        <td><canvas class="list-thumb" data-track="${t.track_name}" width="120" height="72"></canvas> ${t.track_name}</td>
        <td>${loc}</td>
        <td>${t.track_length || '--'}</td>
        <td>${t.track_turns || '--'}</td>
        <td>${s ? s.classes.size : 0}</td>
        <td>${s ? s.totalRaces : 0}</td>
      </tr>`;
    });
    filteredMissing.forEach(n => {
      var catLabel = catLabels[n.cat] || 'Road';
      var catColor = catColors[n.cat] || '#9146ff';
      listHtml += `<tr class="missing"><td>${n.name} <span style="font-size:9px;font-weight:700;color:${catColor};margin-left:6px;">${catLabel}</span></td><td>--</td><td>--</td><td>--</td><td>0</td><td>0</td></tr>`;
    });
    document.getElementById('tracks-list-body').innerHTML = listHtml;

    // Draw canvases
    requestAnimationFrame(() => {
      document.querySelectorAll('canvas[data-track]').forEach(async (canvas) => {
        const name = canvas.dataset.track;
        try {
          const res = await fetch('/api/track-map/' + encodeURIComponent(name));
          if (res.ok) {
            const data = await res.json();
            drawTrackPreview(canvas, data.trackData);
          }
        } catch(e) {}
      });
    });
  }

  // ─── Detail ───
  async function showDetail(trackName) {
    document.getElementById('tracks-list-view').style.display = 'none';
    const detail = document.getElementById('track-detail');
    detail.style.display = 'block';
    history.pushState(null, '', '/tracks/' + encodeURIComponent(trackName));

    const track = allTracks.find(t => t.track_name === trackName);
    document.getElementById('detail-name').textContent = trackName;
    _currentDetailTrack = trackName;
    _sessionsLoaded = false;
    _currentSection = 'stats';
    document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
    document.querySelector('.tab-stats').classList.add('active');
    document.querySelectorAll('.section-content').forEach(c => c.classList.remove('active'));
    document.getElementById('section-stats').classList.add('active');
    document.getElementById('practice-sessions').innerHTML = '<div class="session-empty">Click to load practice sessions</div>';
    document.getElementById('race-sessions').innerHTML = '<div class="session-empty">Click to load race sessions</div>';
    const loc = track ? [track.track_city, track.track_country].filter(Boolean).join(', ') : '';
    document.getElementById('detail-location').textContent = loc || 'Location unknown';

    // Track stats from allStats
    const trackStats = allStats.filter(s => s.track_name === trackName);
    const CLASS_ORDER = ['GTP', 'LMP2', 'GT3', 'LMP3', 'GT4', 'GTE', 'TCR', 'Porsche Cup', 'BMW M2', 'Toyota', 'Mazda'];
    const classes = [...new Set(trackStats.map(s => s.car_class))].sort((a, b) => {
      const ai = CLASS_ORDER.indexOf(a), bi = CLASS_ORDER.indexOf(b);
      return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
    });
    const totalRaces = trackStats.reduce((sum, s) => sum + (s.race_count || 0), 0);

    // Header stats
    let statsHtml = '';
    if (track && track.track_length) statsHtml += `<div class="track-stat"><div class="track-stat-value">${track.track_length}</div><div class="track-stat-label">Length</div></div>`;
    if (track && track.track_turns) statsHtml += `<div class="track-stat"><div class="track-stat-value">${track.track_turns}</div><div class="track-stat-label">Turns</div></div>`;
    statsHtml += `<div class="track-stat"><div class="track-stat-value">${totalRaces}</div><div class="track-stat-label">Races</div></div>`;
    statsHtml += `<div class="track-stat"><div class="track-stat-value">${classes.length}</div><div class="track-stat-label">Classes</div></div>`;
    document.getElementById('detail-stats').innerHTML = statsHtml;

    // Canvas
    try {
      const res = await fetch('/api/track-map/' + encodeURIComponent(trackName));
      if (res.ok) {
        const data = await res.json();
        drawTrackPreview(document.getElementById('detail-canvas'), data.trackData);
      }
    } catch(e) {}

    // Class tabs
    if (classes.length === 0) {
      document.getElementById('class-tabs').innerHTML = '';
      document.getElementById('class-stats-content').innerHTML = '<p style="color:rgba(255,255,255,0.35);text-align:center;padding:40px 0;">No race data yet. Run races with Atleta Bridge to populate stats.</p>';
      return;
    }

    let tabsHtml = '';
    classes.forEach((cls, i) => {
      const color = getClassColor(cls);
      const activeStyle = i === 0 ? ' style="background:' + color + '22;border-color:' + color + ';"' : '';
      tabsHtml += '<button class="class-tab' + (i === 0 ? ' active' : '') + '"' + activeStyle + ' onclick="window._switchClassTab(this, \'' + cls.replace(/'/g, "\\'") + '\')" data-class="' + cls + '" data-color="' + color + '"><span class="class-dot" style="background:' + color + ';"></span>' + cls + '</button>';
    });
    document.getElementById('class-tabs').innerHTML = tabsHtml;
    renderClassStats(trackName, classes[0]);
  }

  function renderClassStats(trackName, className) {
    const trackStats = allStats.filter(s => s.track_name === trackName && s.car_class === className);
    const raceTypes = RACE_TYPES_BY_CLASS[className] || DEFAULT_RACE_TYPES;

    // Build lookup
    const lookup = {};
    trackStats.forEach(s => { lookup[s.race_type] = s; });

    let html = '<table class="stats-table"><thead><tr>';
    html += '<th>Race Type</th><th>Avg Lap</th><th>Avg Pit</th><th>Avg Qualify</th><th>Est. Laps</th><th>Avg SOF</th><th>Races</th><th>Avg Drivers</th><th>Top Car</th>';
    html += '</tr></thead><tbody>';

    raceTypes.forEach(rt => {
      const s = lookup[rt];
      if (s) {
        html += `<tr>
          <td style="color:#fff;font-family:inherit;font-weight:600;">${rt}</td>
          <td>${formatLapTime(s.avg_lap_time)}</td>
          <td>${s.avg_pit_time > 0 ? s.avg_pit_time.toFixed(1) + 's' : '--'}</td>
          <td>${formatLapTime(s.avg_qualify_time)}</td>
          <td>${s.est_laps > 0 ? Math.round(s.est_laps) : '--'}</td>
          <td>${formatSOF(s.avg_sof)}</td>
          <td>${s.race_count || 0}</td>
          <td>${s.avg_drivers > 0 ? Math.round(s.avg_drivers) : '--'}</td>
          <td>${s.top_car || '--'}</td>
        </tr>`;
      } else {
        html += `<tr>
          <td style="color:rgba(255,255,255,0.25);font-family:inherit;">${rt}</td>
          <td class="dimmed">--</td><td class="dimmed">--</td><td class="dimmed">--</td>
          <td class="dimmed">--</td><td class="dimmed">--</td><td class="dimmed">--</td><td class="dimmed">--</td><td class="dimmed">--</td>
        </tr>`;
      }
    });

    // Also show any race types in data not in the predefined list
    trackStats.forEach(s => {
      if (!raceTypes.includes(s.race_type)) {
        html += `<tr>
          <td style="color:#fff;font-family:inherit;font-weight:600;">${s.race_type}</td>
          <td>${formatLapTime(s.avg_lap_time)}</td>
          <td>${s.avg_pit_time > 0 ? s.avg_pit_time.toFixed(1) + 's' : '--'}</td>
          <td>${formatLapTime(s.avg_qualify_time)}</td>
          <td>${s.est_laps > 0 ? Math.round(s.est_laps) : '--'}</td>
          <td>${formatSOF(s.avg_sof)}</td>
          <td>${s.race_count || 0}</td>
          <td>${s.avg_drivers > 0 ? Math.round(s.avg_drivers) : '--'}</td>
          <td>${s.top_car || '--'}</td>
        </tr>`;
      }
    });

    html += '</tbody></table>';
    document.getElementById('class-stats-content').innerHTML = html;
  }

  function showList() {
    document.getElementById('track-detail').style.display = 'none';
    document.getElementById('tracks-list-view').style.display = 'block';
    history.pushState(null, '', '/tracks');
  }

  function goBack() {
    // If user came from dashboard, go back to it; otherwise show track list
    if (document.referrer && document.referrer.includes('/dashboard')) {
      window.location.href = document.referrer;
    } else if (history.length > 1) {
      history.back();
    } else {
      showList();
    }
  }
  window.goBack = goBack;

  // ─── Section tabs (Stats / Practice / Race) ───
  let _currentSection = 'stats';
  let _sessionsLoaded = false;
  let _currentDetailTrack = '';

  window.switchSection = function(section) {
    _currentSection = section;
    document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
    document.querySelector('.tab-' + section).classList.add('active');
    document.querySelectorAll('.section-content').forEach(c => c.classList.remove('active'));
    document.getElementById('section-' + section).classList.add('active');
    if ((section === 'practice' || section === 'race') && !_sessionsLoaded) {
      loadSessions(_currentDetailTrack);
    }
  };

  function loadSessions(trackName) {
    _sessionsLoaded = true;
    const bridgeId = '<%= (typeof racingUser !== "undefined" && racingUser && racingUser.bridge_id) ? racingUser.bridge_id : "" %>';
    fetch('/api/sessions/' + encodeURIComponent(trackName) + '?bridge_id=' + encodeURIComponent(bridgeId))
      .then(r => r.json())
      .then(sessions => {
        const practice = sessions.filter(s => s.session_type === 'practice');
        const race = sessions.filter(s => s.session_type === 'race' || s.session_type === 'qualify');
        renderSessionList('practice-sessions', practice, 'No practice sessions recorded yet');
        renderSessionList('race-sessions', race, 'No race sessions recorded yet');
      })
      .catch(() => {
        document.getElementById('practice-sessions').innerHTML = '<div class="session-empty">Failed to load sessions</div>';
        document.getElementById('race-sessions').innerHTML = '<div class="session-empty">Failed to load sessions</div>';
      });
  }

  function renderSessionList(containerId, sessions, emptyMsg) {
    const el = document.getElementById(containerId);
    if (!sessions.length) { el.innerHTML = '<div class="session-empty">' + emptyMsg + '</div>'; return; }
    let html = '<div class="session-row session-header"><span>Date</span><span>Car</span><span style="text-align:right;">Best Lap</span><span style="text-align:right;">Laps</span><span style="text-align:center;">Type</span></div>';
    sessions.forEach(s => {
      const d = new Date(s.created_at);
      const date = d.toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' });
      const best = s.best_lap_time > 0 ? formatLapTime(s.best_lap_time) : '--';
      const laps = s.actual_laps || s.lap_count || 0;
      const typeLabel = s.race_type || s.session_type;
      const typeColor = s.session_type === 'practice' ? '#3ecf8e' : s.session_type === 'qualify' ? '#f7c948' : '#b18cff';
      html += '<div class="session-row" onclick="window.open(\'/api/session/' + s.id + '?bridge_id=' + encodeURIComponent(s.bridge_id || '') + '\',\'_blank\')">';
      html += '<span>' + date + '</span>';
      html += '<span style="color:#e8e6f0;">' + (s.car_name || s.car_class) + '</span>';
      html += '<span class="session-best" style="text-align:right;">' + best + '</span>';
      html += '<span style="text-align:right;">' + laps + '</span>';
      html += '<span style="text-align:center;font-size:10px;color:' + typeColor + ';font-weight:600;">' + typeLabel + '</span>';
      html += '</div>';
    });
    el.innerHTML = html;
  }

  function formatLapTime(t) {
    if (!t || t <= 0) return '--';
    var m = Math.floor(t / 60);
    var s = (t % 60).toFixed(3);
    return m > 0 ? m + ':' + s.padStart(6, '0') : s;
  }

