      reader.readAsText(file);
    } else if (ext === 'csv') {
      // CSV import — send to server for iRacing format parsing
      var reader = new FileReader();
      reader.onload = function() {
        fetch('/api/track-stats/import-csv', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ csvData: reader.result, trackName: trackName, carClass: carClass, raceType: raceType }),
        })
        .then(function(r) { return r.json(); })
