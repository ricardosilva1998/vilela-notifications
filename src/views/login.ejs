<%- include('header', { title: 'Atleta — Streamers Helper', streamer: null }) %>

<div style="text-align: center; padding: 48px 0 32px;" class="animate-in">
  <div style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 20px; background: var(--accent-glow); border: 1px solid rgba(145,70,255,0.15); font-size: 12px; color: var(--accent-hover); font-family: var(--font-display); font-weight: 600; margin-bottom: 20px;">
    <%= t('landing.tagline') %>
  </div>
  <h1 style="font-size: 40px; font-weight: 800; margin-bottom: 12px; line-height: 1.1; letter-spacing: -0.03em;">
    <%= t('landing.title1') %><br>
    <span style="background: linear-gradient(135deg, var(--accent), #c026d3); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"><%= t('landing.title2') %></span>
  </h1>
  <p style="color: var(--text-secondary); max-width: 460px; margin: 0 auto; font-size: 16px; line-height: 1.6;">
    <%= t('landing.subtitle') %>
  </p>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 40px; max-width: 800px; margin-left: auto; margin-right: auto;">
  <!-- Streamer Card -->
  <a href="/streamer" class="card animate-in animate-in-delay-1" style="padding: 28px 24px; text-decoration: none; color: inherit; cursor: pointer; transition: all 0.2s; border: 1px solid rgba(145,70,255,0.15); position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--accent), #c026d3);"></div>
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
      <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(145,70,255,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
      </div>
      <div>
        <h3 style="font-size: 17px; margin-bottom: 2px; font-weight: 700;">Streamer</h3>
        <p style="color: var(--text-muted); font-size: 11px;">Twitch, YouTube & Discord tools</p>
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13px; color: var(--text-secondary); line-height: 1.4;">
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: var(--accent); font-size: 10px;">&#9679;</span> Live alerts & go-live notifications
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: var(--accent); font-size: 10px;">&#9679;</span> Clips, recaps & weekly highlights
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: var(--accent); font-size: 10px;">&#9679;</span> OBS overlay alerts with animations
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: var(--accent); font-size: 10px;">&#9679;</span> Twitch & YouTube chatbot
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: var(--accent); font-size: 10px;">&#9679;</span> PayPal donations & sponsor rotation
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: var(--accent); font-size: 10px;">&#9679;</span> Visual overlay builder
      </div>
    </div>
  </a>

  <!-- Racing Card -->
  <a href="/racing" class="card animate-in animate-in-delay-2" style="padding: 28px 24px; text-decoration: none; color: inherit; cursor: pointer; transition: all 0.2s; border: 1px solid rgba(62,207,142,0.15); position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #3ecf8e, #06b6d4);"></div>
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
      <div style="width: 44px; height: 44px; border-radius: 12px; background: rgba(62,207,142,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3ecf8e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2c4 4 6 8 6 14H6c0-6 2-10 6-14z"/><path d="M8 16h8"/><line x1="12" y1="2" x2="12" y2="8"/></svg>
      </div>
      <div>
        <h3 style="font-size: 17px; margin-bottom: 2px; font-weight: 700;">Racing</h3>
        <p style="color: var(--text-muted); font-size: 11px;">iRacing telemetry & analysis</p>
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13px; color: var(--text-secondary); line-height: 1.4;">
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: #3ecf8e; font-size: 10px;">&#9679;</span> Real-time telemetry overlays
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: #3ecf8e; font-size: 10px;">&#9679;</span> Standings, relative & fuel calculator
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: #3ecf8e; font-size: 10px;">&#9679;</span> Session history & lap recording
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: #3ecf8e; font-size: 10px;">&#9679;</span> Telemetry comparison tool
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: #3ecf8e; font-size: 10px;">&#9679;</span> Track database with statistics
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="color: #3ecf8e; font-size: 10px;">&#9679;</span> Voice chat & driver inputs overlay
      </div>
    </div>
  </a>
</div>

<div style="text-align: center; margin-bottom: 24px;" class="animate-in animate-in-delay-4">
  <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
    <a href="/tutorial" class="btn btn-secondary" style="padding: 12px 28px;"><%= t('landing.howItWorks') %></a>
  </div>
</div>

<%- include('footer') %>
