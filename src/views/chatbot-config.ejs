<%- include('header', { title: 'Chatbot Config', streamer: streamer }) %>

<style>
.pill-toggle { position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; }
.pill-toggle input { opacity: 0; width: 0; height: 0; }
.pill-toggle .slider { position: absolute; cursor: pointer; inset: 0; background: var(--bg-elevated); border-radius: 24px; border: 1px solid var(--border); transition: 0.3s; }
.pill-toggle .slider:before { content: ''; position: absolute; height: 18px; width: 18px; left: 2px; bottom: 2px; background: #fff; border-radius: 50%; transition: 0.3s; }
.pill-toggle input:checked + .slider { background: var(--accent); border-color: var(--accent); }
.pill-toggle input:checked + .slider:before { transform: translateX(20px); }

.tab-connection.active { background: #9146ff; }
.tab-events.active { background: #9146ff; }
.tab-commands.active { background: #9146ff; }
.tab-moderation.active { background: #ff4444; }
.mod-card { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; margin-bottom: 10px; transition: border-color 0.2s; }
.mod-card:hover { border-color: rgba(145,70,255,0.2); }
.mod-card-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
.mod-card-info { display: flex; align-items: center; gap: 12px; }
.mod-card-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; }
.mod-card-title { font-size: 14px; font-weight: 700; color: var(--text-primary); font-family: var(--font-display); }
.mod-card-desc { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
.mod-card-settings { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border); }
.mod-setting { display: flex; align-items: center; gap: 6px; }
.mod-setting label { font-size: 11px; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; font-family: var(--font-display); }
.mod-setting input[type=number] { width: 64px; padding: 8px 10px; background: var(--bg-base); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); font-size: 13px; font-family: var(--font-display); font-weight: 600; text-align: center; transition: all 0.2s; }
.mod-setting input[type=number]:focus { border-color: var(--accent); outline: none; box-shadow: 0 0 0 3px rgba(145,70,255,0.1); }
.mod-setting input[type=number]:hover { border-color: rgba(145,70,255,0.3); }
.mod-setting select { padding: 8px 12px; background: var(--bg-base); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); font-size: 13px; font-family: var(--font-display); font-weight: 500; transition: all 0.2s; cursor: pointer; -webkit-appearance: none; appearance: none; background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%238b8a9e' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 10px center; padding-right: 28px; }
.mod-setting select:focus { border-color: var(--accent); outline: none; box-shadow: 0 0 0 3px rgba(145,70,255,0.1); }
.mod-setting select:hover { border-color: rgba(145,70,255,0.3); }
.mod-setting .mod-unit { font-size: 12px; color: var(--text-muted); font-family: var(--font-display); font-weight: 500; }
.mod-note { background: rgba(145,70,255,0.08); border: 1px solid rgba(145,70,255,0.2); border-radius: var(--radius-sm); padding: 12px 16px; font-size: 12px; color: var(--text-secondary); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.banned-word-list { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
.banned-word-tag { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 14px; font-size: 12px; color: var(--text-primary); font-family: var(--font-display); font-weight: 500; }
.banned-word-tag.regex { border-color: rgba(255,68,68,0.3); background: rgba(255,68,68,0.08); }
.banned-word-tag button { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 14px; padding: 0 0 0 2px; line-height: 1; transition: color 0.15s; }
.banned-word-tag button:hover { color: var(--danger); }
.banned-word-add { display: flex; gap: 8px; margin-top: 14px; align-items: center; }
.banned-word-add input[type=text] { flex: 1; padding: 9px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); font-size: 13px; font-family: var(--font-body); transition: all 0.2s; }
.banned-word-add input[type=text]:focus { border-color: var(--accent); outline: none; box-shadow: 0 0 0 3px rgba(145,70,255,0.1); }
.banned-word-add input[type=text]:hover { border-color: rgba(145,70,255,0.3); }
.banned-word-add .mod-btn { padding: 9px 16px; font-size: 12px; font-weight: 600; font-family: var(--font-display); border: 1px solid var(--border); border-radius: 8px; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px; }
.banned-word-add .mod-btn-add { background: var(--accent); border-color: var(--accent); color: #fff; }
.banned-word-add .mod-btn-add:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
.mod-checkbox { display: flex; align-items: center; gap: 6px; cursor: pointer; font-size: 12px; color: var(--text-muted); font-family: var(--font-display); font-weight: 500; white-space: nowrap; user-select: none; }
.mod-checkbox input[type=checkbox] { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; border-radius: 4px; }
.mod-exempt-item { display: flex; align-items: center; gap: 10px; padding: 8px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: 8px; transition: border-color 0.2s; }
.mod-exempt-item:hover { border-color: rgba(145,70,255,0.2); }
.mod-exempt-label { font-size: 13px; font-weight: 600; color: var(--text-primary); font-family: var(--font-display); }
.mod-save-btn { padding: 12px 32px; font-size: 14px; font-weight: 700; font-family: var(--font-display); background: var(--accent); color: #fff; border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 2px 8px rgba(145,70,255,0.25); }
.mod-save-btn:hover { background: var(--accent-hover); box-shadow: 0 4px 16px rgba(145,70,255,0.35); transform: translateY(-1px); }
.mod-subtab { flex:1; padding:7px; font-size:11px; font-weight:600; font-family:var(--font-display); border:none; border-radius:6px; cursor:pointer; transition:all 0.15s; background:transparent; color:var(--text-secondary); }
.mod-subtab.active { background:var(--accent); color:#fff; }
.mod-tab-content { display:none; }
.mod-tab-content.active { display:block; }
</style>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<h2 style="margin: 16px 0 8px; font-size: 24px; font-weight: 700;" class="animate-in">Chatbot Configuration</h2>
<p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 24px;">Set up your chat bot to send automatic messages for follows, subscriptions, bits, donations, and raids.</p>

<!-- Tab Bar -->
<div class="tab-bar animate-in animate-in-delay-1">
  <button class="tab-btn tab-connection" data-tab="connection">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    Connection
  </button>
  <button class="tab-btn tab-events" data-tab="events">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    Event Messages
  </button>
  <button class="tab-btn tab-commands" data-tab="commands">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
    Custom Commands
  </button>
  <button class="tab-btn tab-moderation" data-tab="moderation">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    Moderation
  </button>
</div>

<!-- ==================== CONNECTION TAB ==================== -->
<div class="tab-content" id="tab-connection">

  <div class="card animate-in">
    <form method="POST" action="/dashboard/chatbot">
      <input type="hidden" name="chat_follow_enabled" value="<%= streamer.chat_follow_enabled ? '1' : '' %>">
      <input type="hidden" name="chat_sub_enabled" value="<%= streamer.chat_sub_enabled ? '1' : '' %>">
      <input type="hidden" name="chat_giftsub_enabled" value="<%= streamer.chat_giftsub_enabled ? '1' : '' %>">
      <input type="hidden" name="chat_bits_enabled" value="<%= streamer.chat_bits_enabled ? '1' : '' %>">
      <input type="hidden" name="chat_donation_enabled" value="<%= streamer.chat_donation_enabled ? '1' : '' %>">
      <input type="hidden" name="chat_raid_enabled" value="<%= streamer.chat_raid_enabled ? '1' : '' %>">
      <input type="hidden" name="chat_follow_template" value="<%= streamer.chat_follow_template || '' %>">
      <input type="hidden" name="chat_sub_template" value="<%= streamer.chat_sub_template || '' %>">
      <input type="hidden" name="chat_giftsub_template" value="<%= streamer.chat_giftsub_template || '' %>">
      <input type="hidden" name="chat_bits_template" value="<%= streamer.chat_bits_template || '' %>">
      <input type="hidden" name="chat_donation_template" value="<%= streamer.chat_donation_template || '' %>">
      <input type="hidden" name="chat_raid_template" value="<%= streamer.chat_raid_template || '' %>">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <h3>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Bot Status
      </h3>
      <div style="display: flex; align-items: center; gap: 10px;">
        <label for="chatbot_enabled" style="font-size: 13px; font-weight: 600; color: var(--text-secondary); font-family: var(--font-display);">Enable chatbot</label>
        <label class="pill-toggle">
          <input type="checkbox" id="chatbot_enabled" name="chatbot_enabled" value="1" <%= streamer.chatbot_enabled ? 'checked' : '' %> onchange="this.closest('form').submit()">
          <span class="slider"></span>
        </label>
      </div>
    </div>
    </form>
    <% if (botConnected && botUsername) { %>
      <p style="color: var(--success); font-size: 14px; display: flex; align-items: center; gap: 8px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Bot <strong><%= botUsername %></strong> is online
      </p>
      <% if (streamer.twitch_username) { %>
        <p style="color: var(--text-secondary); font-size: 13px; margin-top: 8px;">
          Channel: <strong style="color: var(--accent);">#<%= streamer.twitch_username %></strong>
        </p>
      <% } %>
    <% } else if (botUsername) { %>
      <p style="color: var(--warning, #f7c948); font-size: 14px; display: flex; align-items: center; gap: 8px;">
        ⚠️ Bot <strong><%= botUsername %></strong> is configured but not connected. Check server logs.
      </p>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 14px;">
        ⚠️ Bot not configured. The admin needs to set <code>BOT_TWITCH_USERNAME</code> and <code>BOT_TWITCH_TOKEN</code> environment variables.
      </p>
    <% } %>
    <% if (!streamer.twitch_username) { %>
      <p style="color: var(--warning, #f7c948); font-size: 13px; margin-top: 12px;">
        ⚠️ No Twitch account linked. <a href="/auth/twitch" style="color: var(--accent);">Link your Twitch account</a> so the bot knows which channel to join.
      </p>
    <% } %>
  </div>


</div>

<!-- ==================== EVENT MESSAGES TAB ==================== -->
<div class="tab-content" id="tab-events">

  <form method="POST" action="/dashboard/chatbot">

    <!-- Event Templates -->
    <div class="card animate-in animate-in-delay-1">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
        <h3 style="margin-bottom: 0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
          Event Messages
        </h3>
        <button type="submit" class="btn btn-primary" style="padding: 8px 20px; font-size: 13px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save Settings
        </button>
      </div>
      <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 20px;">
        Configure which events trigger a chat message and what that message says. Use variables to personalize each message.
      </p>

      <!-- Follow -->
      <div style="padding: 18px 0; border-bottom: 1px solid var(--border);">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
          <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(145,70,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="toggle" style="margin-bottom: 0;">
            <input type="checkbox" id="chat_follow_enabled" name="chat_follow_enabled" value="1" <%= streamer.chat_follow_enabled ? 'checked' : '' %>>
            <label for="chat_follow_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Follows</label>
          </div>
        </div>
        <div class="form-group" style="margin-bottom: 4px;">
          <textarea name="chat_follow_template" rows="2"
            placeholder="Thanks for the follow, {username}! Welcome to the stream!"
            style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
          ><%= streamer.chat_follow_template || '' %></textarea>
        </div>
        <p style="font-size: 12px; color: var(--text-muted);">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code></p>
        <div style="display: flex; justify-content: flex-end; margin-top: 8px;"><button type="button" onclick="testChat('follow', this)" class="btn btn-primary" style="font-size: 13px; padding: 8px 20px;">Test in chat</button></div>
      </div>

      <!-- Subscription -->
      <div style="padding: 18px 0; border-bottom: 1px solid var(--border);">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
          <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(145,70,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
          </div>
          <div class="toggle" style="margin-bottom: 0;">
            <input type="checkbox" id="chat_sub_enabled" name="chat_sub_enabled" value="1" <%= streamer.chat_sub_enabled ? 'checked' : '' %>>
            <label for="chat_sub_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Subscriptions</label>
          </div>
        </div>
        <div class="form-group" style="margin-bottom: 4px;">
          <textarea name="chat_sub_template" rows="2"
            placeholder="Thank you {username} for the Tier {tier} sub! ({months} months)"
            style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
          ><%= streamer.chat_sub_template || '' %></textarea>
        </div>
        <p style="font-size: 12px; color: var(--text-muted);">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{tier}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{months}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{message}</code></p>
        <div style="display: flex; justify-content: flex-end; margin-top: 8px;"><button type="button" onclick="testChat('sub', this)" class="btn btn-primary" style="font-size: 13px; padding: 8px 20px;">Test in chat</button></div>
      </div>

      <!-- Gift Sub -->
      <div style="padding: 18px 0; border-bottom: 1px solid var(--border);">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
          <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(145,70,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
          </div>
          <div class="toggle" style="margin-bottom: 0;">
            <input type="checkbox" id="chat_giftsub_enabled" name="chat_giftsub_enabled" value="1" <%= streamer.chat_giftsub_enabled ? 'checked' : '' %>>
            <label for="chat_giftsub_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Gift Subscriptions</label>
          </div>
        </div>
        <div class="form-group" style="margin-bottom: 4px;">
          <textarea name="chat_giftsub_template" rows="2"
            placeholder="Huge thanks to {username} for gifting {amount} Tier {tier} subs!"
            style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
          ><%= streamer.chat_giftsub_template || '' %></textarea>
        </div>
        <p style="font-size: 12px; color: var(--text-muted);">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{amount}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{tier}</code></p>
        <div style="display: flex; justify-content: flex-end; margin-top: 8px;"><button type="button" onclick="testChat('giftsub', this)" class="btn btn-primary" style="font-size: 13px; padding: 8px 20px;">Test in chat</button></div>
      </div>

      <!-- Bits -->
      <div style="padding: 18px 0; border-bottom: 1px solid var(--border);">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
          <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(145,70,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div class="toggle" style="margin-bottom: 0;">
            <input type="checkbox" id="chat_bits_enabled" name="chat_bits_enabled" value="1" <%= streamer.chat_bits_enabled ? 'checked' : '' %>>
            <label for="chat_bits_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Bits / Cheers</label>
          </div>
        </div>
        <div class="form-group" style="margin-bottom: 4px;">
          <textarea name="chat_bits_template" rows="2"
            placeholder="Thanks {username} for the {amount} bits! {message}"
            style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
          ><%= streamer.chat_bits_template || '' %></textarea>
        </div>
        <p style="font-size: 12px; color: var(--text-muted);">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{amount}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{message}</code></p>
        <div style="display: flex; justify-content: flex-end; margin-top: 8px;"><button type="button" onclick="testChat('bits', this)" class="btn btn-primary" style="font-size: 13px; padding: 8px 20px;">Test in chat</button></div>
      </div>

      <!-- Donation -->
      <div style="padding: 18px 0; border-bottom: 1px solid var(--border);">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
          <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(62,207,142,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div class="toggle" style="margin-bottom: 0;">
            <input type="checkbox" id="chat_donation_enabled" name="chat_donation_enabled" value="1" <%= streamer.chat_donation_enabled ? 'checked' : '' %>>
            <label for="chat_donation_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Donations</label>
          </div>
        </div>
        <div class="form-group" style="margin-bottom: 4px;">
          <textarea name="chat_donation_template" rows="2"
            placeholder="Thank you {username} for the {amount} {currency} donation! {message}"
            style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
          ><%= streamer.chat_donation_template || '' %></textarea>
        </div>
        <p style="font-size: 12px; color: var(--text-muted);">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{amount}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{currency}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{message}</code></p>
        <div style="display: flex; justify-content: flex-end; margin-top: 8px;"><button type="button" onclick="testChat('donation', this)" class="btn btn-primary" style="font-size: 13px; padding: 8px 20px;">Test in chat</button></div>
      </div>

      <!-- Raid -->
      <div style="padding: 18px 0;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
          <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(247,144,9,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div class="toggle" style="margin-bottom: 0;">
            <input type="checkbox" id="chat_raid_enabled" name="chat_raid_enabled" value="1" <%= streamer.chat_raid_enabled ? 'checked' : '' %>>
            <label for="chat_raid_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Raids</label>
          </div>
        </div>
        <div class="form-group" style="margin-bottom: 4px;">
          <textarea name="chat_raid_template" rows="2"
            placeholder="Welcome raiders! Thanks {username} for bringing {viewers} viewers!"
            style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
          ><%= streamer.chat_raid_template || '' %></textarea>
        </div>
        <p style="font-size: 12px; color: var(--text-muted);">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{viewers}</code></p>
        <div style="display: flex; justify-content: flex-end; margin-top: 8px;"><button type="button" onclick="testChat('raid', this)" class="btn btn-primary" style="font-size: 13px; padding: 8px 20px;">Test in chat</button></div>
      </div>
    </div>

    <!-- Save Button -->
    <div style="display: flex; justify-content: flex-end; margin-bottom: 24px;">
      <button type="submit" class="btn btn-primary" style="padding: 12px 32px; font-size: 14px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Save Settings
      </button>
    </div>

  </form>


</div>

<!-- ==================== CUSTOM COMMANDS TAB ==================== -->
<div class="tab-content" id="tab-commands">

  <!-- Add Command -->
  <div class="card animate-in">
    <h3>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Command
    </h3>
    <form method="POST" action="/dashboard/chatbot/commands" style="margin: 0;">
      <div style="display: grid; grid-template-columns: 1fr 2fr auto; gap: 12px; align-items: end;">
        <div class="form-group" style="margin-bottom: 0;">
          <label for="new-command" style="display: block; font-size: 12px; font-family: var(--font-display); font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">Command</label>
          <div style="display: flex; align-items: center; gap: 0;">
            <span style="padding: 10px 10px 10px 14px; background: var(--bg-elevated); border: 1px solid var(--border); border-right: none; border-radius: var(--radius-sm) 0 0 var(--radius-sm); color: var(--text-muted); font-size: 13px; font-family: var(--font-display); font-weight: 600; line-height: 1;">!</span>
            <input type="text" id="new-command" name="command" placeholder="socials"
              style="flex: 1; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-left: none; border-radius: 0 var(--radius-sm) var(--radius-sm) 0; color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; min-width: 0;"
              onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
              autocomplete="off" required>
          </div>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label for="new-response" style="display: block; font-size: 12px; font-family: var(--font-display); font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">Response</label>
          <input type="text" id="new-response" name="response" placeholder="Follow us on Discord at discord.gg/..."
            style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; box-sizing: border-box;"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
            autocomplete="off" required>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label for="new-cooldown" style="display: block; font-size: 12px; font-family: var(--font-display); font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">Cooldown (s)</label>
          <input type="number" id="new-cooldown" name="cooldown" value="5" min="1" max="3600"
            style="width: 90px; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; text-align: center;"
            onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'">
        </div>
      </div>
      <div style="margin-top: 16px; display: flex; justify-content: flex-end;">
        <button type="submit" class="btn btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Command
        </button>
      </div>
    </form>
  </div>

  <!-- Command List -->
  <div class="card animate-in animate-in-delay-1">
    <h3>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
      Commands (<%= commands.length %>)
    </h3>

    <% if (commands.length === 0) { %>
      <div style="text-align: center; padding: 40px 20px; color: var(--text-muted);">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 12px; opacity: 0.4;"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        <p style="font-size: 15px; font-weight: 600; margin: 0 0 6px;">No commands yet</p>
        <p style="font-size: 13px; margin: 0;">Add your first command above to get started.</p>
      </div>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 0;">
        <% commands.forEach((cmd, i) => { %>
          <div style="padding: 16px 0; border-bottom: <%= i < commands.length - 1 ? '1px solid var(--border)' : 'none' %>;" id="cmd-row-<%= cmd.id %>">

            <!-- View mode -->
            <div id="cmd-view-<%= cmd.id %>" style="display: flex; align-items: center; gap: 12px;">
              <div style="flex: 0 0 auto;">
                <span style="font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--accent);">!<%= cmd.command %></span>
              </div>
              <div style="flex: 1; min-width: 0;">
                <p style="margin: 0; font-size: 13px; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= cmd.response %></p>
                <p style="margin: 4px 0 0; font-size: 12px; color: var(--text-muted);">
                  Cooldown: <%= cmd.cooldown %>s &nbsp;&bull;&nbsp;
                  <% if (cmd.enabled) { %>
                    <span style="color: var(--success);">Enabled</span>
                  <% } else { %>
                    <span style="color: var(--text-muted);">Disabled</span>
                  <% } %>
                </p>
              </div>
              <div style="display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
                <button type="button" data-response="<%= cmd.response.replace(/"/g, '&quot;') %>" onclick="testCustomCommand(this.dataset.response, this)" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px; color: var(--success);">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  Test
                </button>
                <button type="button" onclick="showEdit(<%= cmd.id %>)" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px;">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Edit
                </button>
                <form method="POST" action="/dashboard/chatbot/commands/<%= cmd.id %>/delete" style="margin: 0;" onsubmit="return confirm('Delete !<%= cmd.command %>?');">
                  <button type="submit" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px; color: var(--danger); border-color: transparent;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Delete
                  </button>
                </form>
              </div>
            </div>

            <!-- Edit mode (hidden by default) -->
            <div id="cmd-edit-<%= cmd.id %>" style="display: none;">
              <form method="POST" action="/dashboard/chatbot/commands/<%= cmd.id %>/update" style="margin: 0;">
                <div style="display: grid; grid-template-columns: 1fr 2fr auto; gap: 12px; align-items: end; margin-bottom: 12px;">
                  <div class="form-group" style="margin-bottom: 0;">
                    <label style="display: block; font-size: 12px; font-family: var(--font-display); font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">Command</label>
                    <div style="display: flex; align-items: center;">
                      <span style="padding: 10px 10px 10px 14px; background: var(--bg-elevated); border: 1px solid var(--border); border-right: none; border-radius: var(--radius-sm) 0 0 var(--radius-sm); color: var(--text-muted); font-size: 13px; font-family: var(--font-display); font-weight: 600; line-height: 1;">!</span>
                      <input type="text" name="command" value="<%= cmd.command %>"
                        style="flex: 1; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-left: none; border-radius: 0 var(--radius-sm) var(--radius-sm) 0; color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; min-width: 0;"
                        onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
                        required>
                    </div>
                  </div>
                  <div class="form-group" style="margin-bottom: 0;">
                    <label style="display: block; font-size: 12px; font-family: var(--font-display); font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">Response</label>
                    <input type="text" name="response" value="<%= cmd.response %>"
                      style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; box-sizing: border-box;"
                      onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
                      required>
                  </div>
                  <div class="form-group" style="margin-bottom: 0;">
                    <label style="display: block; font-size: 12px; font-family: var(--font-display); font-weight: 500; color: var(--text-secondary); margin-bottom: 6px;">Cooldown (s)</label>
                    <input type="number" name="cooldown" value="<%= cmd.cooldown %>" min="1" max="3600"
                      style="width: 90px; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; text-align: center;"
                      onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'">
                  </div>
                </div>
                <div style="display: flex; align-items: center; justify-content: space-between;">
                  <div class="toggle" style="margin-bottom: 0;">
                    <input type="checkbox" id="enabled-<%= cmd.id %>" name="enabled" value="1" <%= cmd.enabled ? 'checked' : '' %>>
                    <label for="enabled-<%= cmd.id %>" style="font-size: 13px;">Enabled</label>
                  </div>
                  <div style="display: flex; gap: 8px;">
                    <button type="button" onclick="hideEdit(<%= cmd.id %>)" class="btn btn-secondary" style="padding: 6px 14px; font-size: 12px;">Cancel</button>
                    <button type="submit" class="btn btn-primary" style="padding: 6px 14px; font-size: 12px;">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                      Save
                    </button>
                  </div>
                </div>
              </form>
            </div>

          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<div class="tab-content" id="tab-moderation">
  <form method="POST" action="/dashboard/chatbot/moderation">
    <div class="mod-note">
      <strong>Note:</strong> The bot must be a moderator in your channel for moderation to work. Type <code>/mod Atleta</code> in your Twitch chat.
    </div>

    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; gap: 12px;">
      <a href="/dashboard/chatbot/mod-log" class="btn btn-secondary" style="font-size: 12px; padding: 7px 14px; display: inline-flex; align-items: center; gap: 6px; text-decoration: none;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        View Moderation Log
      </a>
      <button type="submit" class="mod-save-btn" style="padding: 8px 20px; font-size: 13px; box-shadow: none;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Save Settings
      </button>
    </div>

    <div style="display:flex;gap:4px;margin-bottom:14px;background:var(--bg-base);padding:3px;border-radius:8px;">
      <button type="button" class="mod-subtab active" data-mod-tab="filters" onclick="switchModTab('filters')">Message Filters</button>
      <button type="button" class="mod-subtab" data-mod-tab="users" onclick="switchModTab('users')">User Management</button>
      <button type="button" class="mod-subtab" data-mod-tab="protection" onclick="switchModTab('protection')">Protection</button>
      <button type="button" class="mod-subtab" data-mod-tab="actions" onclick="switchModTab('actions')">Actions</button>
    </div>

    <div class="mod-tab-content active" id="mod-tab-filters">
    <div class="card" style="margin-bottom: 16px;">
    <h3 style="font-size: 14px; margin-bottom: 4px; display: flex; align-items: center; gap: 8px;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
      Message Filters
    </h3>
    <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">Filter unwanted messages from chat</p>

    <div class="mod-card">
      <div class="mod-card-header">
        <div class="mod-card-info">
          <div class="mod-card-icon" style="background:rgba(240,68,56,0.12);"><span>🚫</span></div>
          <div>
            <div class="mod-card-title">Banned Words</div>
            <div class="mod-card-desc">Block messages containing specific words or patterns</div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" id="mod_banned_words_enabled" name="mod_banned_words_enabled" value="1" <%= streamer.mod_banned_words_enabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="banned-word-list" id="banned-word-list">
        <% bannedWords.forEach(w => { %>
          <span class="banned-word-tag <%= w.is_regex ? 'regex' : '' %>">
            <% if (w.is_regex) { %><small style="opacity:0.5">regex:</small><% } %>
            <%= w.word %>
            <button type="button" onclick="removeBannedWord(<%= w.id %>)">×</button>
          </span>
        <% }) %>
      </div>
      <div class="banned-word-add">
        <input type="text" id="new-banned-word" placeholder="Add word or phrase...">
        <label class="mod-checkbox">
          <input type="checkbox" id="new-banned-regex"> Regex
        </label>
        <button type="button" class="mod-btn mod-btn-add" onclick="addBannedWord()">+ Add</button>
      </div>
    </div>

    <div class="mod-card">
      <div class="mod-card-header">
        <div class="mod-card-info">
          <div class="mod-card-icon" style="background:rgba(66,133,244,0.12);"><span>🔗</span></div>
          <div>
            <div class="mod-card-title">Link Protection</div>
            <div class="mod-card-desc">Block URLs from non-mods/VIPs. Mods can use <code>!permit username</code></div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" id="mod_link_protection_enabled" name="mod_link_protection_enabled" value="1" <%= streamer.mod_link_protection_enabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="mod-card-settings">
        <div class="mod-setting">
          <label>Permit duration</label>
          <input type="number" name="mod_link_permit_seconds" value="<%= streamer.mod_link_permit_seconds || 60 %>" min="10" max="600">
          <span class="mod-unit">s</span>
        </div>
      </div>
    </div>

    <div class="mod-card">
      <div class="mod-card-header">
        <div class="mod-card-info">
          <div class="mod-card-icon" style="background:rgba(247,144,9,0.12);"><span>🔠</span></div>
          <div>
            <div class="mod-card-title">Caps Filter</div>
            <div class="mod-card-desc">Block messages with excessive uppercase letters</div>
          </div>
        </div>
        <label class="pill-toggle">
          <input type="checkbox" id="mod_caps_enabled" name="mod_caps_enabled" value="1" <%= streamer.mod_caps_enabled ? 'checked' : '' %>>
          <span class="slider"></span>
        </label>
      </div>
      <div class="mod-card-settings">
        <div class="mod-setting">
          <label>Min length</label>
          <input type="number" name="mod_caps_min_length" value="<%= streamer.mod_caps_min_length || 10 %>" min="3" max="100">
        </div>
