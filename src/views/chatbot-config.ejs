<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panes = document.querySelectorAll('.tab-content');
  function switchTab(tabName) {
    tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tabName));
    panes.forEach(p => p.classList.toggle('active', p.id === 'tab-' + tabName));
  }
  tabs.forEach(t => t.addEventListener('click', () => {
    switchTab(t.dataset.tab);
    localStorage.setItem('chatbot_tab', t.dataset.tab);
  }));
  const urlTab = new URLSearchParams(window.location.search).get('tab');
  const savedTab = localStorage.getItem('chatbot_tab');
  switchTab(urlTab || savedTab || 'connection');

  function showEdit(id) {
    document.getElementById('cmd-view-' + id).style.display = 'none';
    document.getElementById('cmd-edit-' + id).style.display = 'block';
  }
  function hideEdit(id) {
    document.getElementById('cmd-edit-' + id).style.display = 'none';
    document.getElementById('cmd-view-' + id).style.display = 'flex';
  }

  async function testChat(type, btn) {
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Sending...';
    try {
      const res = await fetch('/dashboard/chatbot/test/' + type, { method: 'POST' });
      const data = await res.json();
      btn.textContent = data.ok ? 'Sent!' : 'Failed';
    } catch (e) {
      btn.textContent = 'Error';
    }
    setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 2000);
  }

  async function testCustomCommand(response, btn) {
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Sending...';
    try {
      const res = await fetch('/dashboard/chatbot/test/custom?response=' + encodeURIComponent(response), { method: 'POST' });
      const data = await res.json();
      btn.textContent = data.ok ? 'Sent!' : 'Failed';
    } catch (e) {
      btn.textContent = 'Error';
    }
    setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 2000);
  }

  function switchModTab(tab) {
    document.querySelectorAll('.mod-subtab').forEach(b => {
      b.classList.toggle('active', b.dataset.modTab === tab);
      b.style.background = b.dataset.modTab === tab ? 'var(--accent)' : 'transparent';
      b.style.color = b.dataset.modTab === tab ? '#fff' : 'var(--text-secondary)';
    });
    document.querySelectorAll('.mod-tab-content').forEach(c => c.classList.toggle('active', c.id === 'mod-tab-' + tab));
    localStorage.setItem('chatbot_mod_tab', tab);
  }

  const savedModTab = localStorage.getItem('chatbot_mod_tab');
  switchModTab(savedModTab || 'filters');
</script>

<script>
function addBannedWord() {
  const input = document.getElementById('new-banned-word');
  const word = input.value.trim();
  if (!word) return;
  const isRegex = document.getElementById('new-banned-regex').checked;
  fetch('/dashboard/chatbot/banned-words', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ word, is_regex: isRegex })
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      input.value = '';
      document.getElementById('new-banned-regex').checked = false;
      renderBannedWords(data.words);
    }
  });
}

function removeBannedWord(id) {
  fetch('/dashboard/chatbot/banned-words/' + id, { method: 'DELETE' })
    .then(r => r.json())
    .then(data => { if (data.ok) renderBannedWords(data.words); });
}

function renderBannedWords(words) {
  const list = document.getElementById('banned-word-list');
  list.innerHTML = words.map(w =>
    '<span class="banned-word-tag ' + (w.is_regex ? 'regex' : '') + '">' +
    (w.is_regex ? '<small style="opacity:0.5">regex:</small>' : '') +
    w.word.replace(/</g,'&lt;') + ' <button type="button" onclick="removeBannedWord(' + w.id + ')">×</button></span>'
  ).join('');
}

document.getElementById('new-banned-word').addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); addBannedWord(); }
});
</script>

