<%- include('header', { title: 'Pricing', streamer: streamer }) %>

<div style="text-align: center; margin-bottom: 32px;">
  <h2 style="font-size: 28px; margin-bottom: 8px;">Choose Your Plan</h2>
  <p style="color: #adadb8;">All plans are billed annually. Cancel anytime.</p>
</div>

<% if (typeof msg !== 'undefined') { %>
  <% if (msg === 'payment_error') { %><div class="alert" style="background: #e74c3c33; border: 1px solid #e74c3c;">Payment failed. Please try again.</div><% } %>
  <% if (msg === 'cancelled') { %><div class="alert alert-info">Payment cancelled.</div><% } %>
<% } %>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px;">

  <!-- Free -->
  <div class="card" style="text-align: center; padding: 24px; <%= currentTier === 'free' ? 'border-color: #9146ff;' : '' %>">
    <h3 style="margin-bottom: 4px;">Free</h3>
    <div style="font-size: 28px; font-weight: 700; margin: 12px 0;">0 EUR</div>
    <p style="color: #adadb8; font-size: 13px; margin-bottom: 16px;">per year</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; color: #adadb8; line-height: 2;">
      <li>&#10003; 1 Twitch live channel</li>
      <li>&#10003; 1 Discord server</li>
      <li style="color: #666;">&#10007; Clip notifications</li>
      <li style="color: #666;">&#10007; YouTube</li>
      <li style="color: #666;">&#10007; Welcome messages</li>
      <li style="color: #666;">&#10007; Sub sync</li>
    </ul>
    <% if (currentTier === 'free') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 12px; cursor: default;">Current Plan</div>
    <% } %>
  </div>

  <!-- Starter -->
  <div class="card" style="text-align: center; padding: 24px; <%= currentTier === 'starter' ? 'border-color: #9146ff;' : '' %>">
    <h3 style="margin-bottom: 4px;">Starter</h3>
    <div style="font-size: 28px; font-weight: 700; margin: 12px 0;">10 EUR</div>
    <p style="color: #adadb8; font-size: 13px; margin-bottom: 16px;">per year</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; color: #adadb8; line-height: 2;">
      <li>&#10003; Unlimited Twitch live</li>
      <li>&#10003; Clip notifications</li>
      <li>&#10003; 2 Discord servers</li>
      <li style="color: #666;">&#10007; YouTube</li>
      <li style="color: #666;">&#10007; Welcome messages</li>
      <li style="color: #666;">&#10007; Sub sync</li>
    </ul>
    <% if (currentTier === 'starter') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 12px; cursor: default;">Current Plan</div>
    <% } else if (streamer) { %>
      <form method="POST" action="/payment/create" style="margin-top: 12px;">
        <input type="hidden" name="tier" value="starter">
        <div style="margin-bottom: 8px;"><input type="text" name="discount_code" placeholder="Discount code" style="width: 100%; padding: 6px; background: #0e0e10; border: 1px solid #303032; border-radius: 4px; color: #efeff1; font-size: 12px; text-align: center;"></div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary" style="width: 100%; margin-top: 12px;">Log in to Subscribe</a>
    <% } %>
  </div>

  <!-- Pro -->
  <div class="card" style="text-align: center; padding: 24px; border-color: #9146ff; <%= currentTier === 'pro' ? '' : 'border-color: #9146ff44;' %>">
    <div style="background: #9146ff; color: white; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px; display: inline-block; margin-bottom: 8px;">POPULAR</div>
    <h3 style="margin-bottom: 4px;">Pro</h3>
    <div style="font-size: 28px; font-weight: 700; margin: 12px 0;">20 EUR</div>
    <p style="color: #adadb8; font-size: 13px; margin-bottom: 16px;">per year</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; color: #adadb8; line-height: 2;">
      <li>&#10003; Unlimited Twitch live</li>
      <li>&#10003; Clip notifications</li>
      <li>&#10003; YouTube notifications</li>
      <li>&#10003; Welcome messages</li>
      <li>&#10003; Sub sync (/link)</li>
      <li>&#10003; 5 Discord servers</li>
    </ul>
    <% if (currentTier === 'pro') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 12px; cursor: default;">Current Plan</div>
    <% } else if (streamer) { %>
      <form method="POST" action="/payment/create" style="margin-top: 12px;">
        <input type="hidden" name="tier" value="pro">
        <div style="margin-bottom: 8px;"><input type="text" name="discount_code" placeholder="Discount code" style="width: 100%; padding: 6px; background: #0e0e10; border: 1px solid #303032; border-radius: 4px; color: #efeff1; font-size: 12px; text-align: center;"></div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary" style="width: 100%; margin-top: 12px;">Log in to Subscribe</a>
    <% } %>
  </div>

  <!-- Unlimited -->
  <div class="card" style="text-align: center; padding: 24px; <%= currentTier === 'unlimited' ? 'border-color: #9146ff;' : '' %>">
    <h3 style="margin-bottom: 4px;">Unlimited</h3>
    <div style="font-size: 28px; font-weight: 700; margin: 12px 0;">50 EUR</div>
    <p style="color: #adadb8; font-size: 13px; margin-bottom: 16px;">per year</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; color: #adadb8; line-height: 2;">
      <li>&#10003; Everything in Pro</li>
      <li>&#10003; Unlimited Discord servers</li>
      <li>&#10003; Unlimited channels</li>
      <li>&#10003; Priority support</li>
    </ul>
    <% if (currentTier === 'unlimited') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 12px; cursor: default;">Current Plan</div>
    <% } else if (streamer) { %>
      <form method="POST" action="/payment/create" style="margin-top: 12px;">
        <input type="hidden" name="tier" value="unlimited">
        <div style="margin-bottom: 8px;"><input type="text" name="discount_code" placeholder="Discount code" style="width: 100%; padding: 6px; background: #0e0e10; border: 1px solid #303032; border-radius: 4px; color: #efeff1; font-size: 12px; text-align: center;"></div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary" style="width: 100%; margin-top: 12px;">Log in to Subscribe</a>
    <% } %>
  </div>

</div>

<%- include('footer') %>
