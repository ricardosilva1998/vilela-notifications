<%- include('header', { title: 'Pricing', streamer: streamer }) %>

<div style="text-align: center; margin-bottom: 36px;" class="animate-in">
  <h2 style="font-size: 28px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.03em;">Choose Your Plan</h2>
  <p style="color: var(--text-secondary); font-size: 15px;">All plans billed annually. Cancel anytime.</p>
</div>

<% if (typeof msg !== 'undefined' && msg) { %>
  <% if (msg === 'payment_error') { %><div class="alert alert-danger">Payment failed. Please try again.</div><% } %>
  <% if (msg === 'cancelled') { %><div class="alert alert-info">Payment cancelled.</div><% } %>
<% } %>

<div class="pricing-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px;">

  <!-- Free -->
  <div class="card animate-in animate-in-delay-1" style="text-align: center; padding: 28px 20px; <%= currentTier === 'free' ? 'border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), 0 4px 24px rgba(145,70,255,0.1);' : '' %>">
    <h3 style="margin-bottom: 4px; justify-content: center; font-size: 17px;">Free</h3>
    <div style="font-size: 32px; font-weight: 800; margin: 16px 0 4px; font-family: var(--font-display); letter-spacing: -0.03em;">0 EUR</div>
    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 20px;">forever</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; line-height: 2.2;">
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 1 Discord server</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 2 Twitch live channels</li>
      <li style="color: var(--text-secondary);"><%- '&#9203;' %> 5 min notification delay</li>
      <li style="color: var(--text-muted);"><%- '&#10007;' %> Clip notifications</li>
      <li style="color: var(--text-muted);"><%- '&#10007;' %> YouTube</li>
      <li style="color: var(--text-muted);"><%- '&#10007;' %> Welcome messages</li>
      <li style="color: var(--text-muted);"><%- '&#10007;' %> Sub sync</li>
    </ul>
    <% if (currentTier === 'free') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 16px; cursor: default; opacity: 0.7;">Current Plan</div>
    <% } %>
  </div>

  <!-- Starter -->
  <div class="card animate-in animate-in-delay-2" style="text-align: center; padding: 28px 20px; <%= currentTier === 'starter' ? 'border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), 0 4px 24px rgba(145,70,255,0.1);' : '' %>">
    <h3 style="margin-bottom: 4px; justify-content: center; font-size: 17px;">Starter</h3>
    <div style="font-size: 32px; font-weight: 800; margin: 16px 0 4px; font-family: var(--font-display); letter-spacing: -0.03em;">5 EUR</div>
    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 20px;">per year</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; line-height: 2.2;">
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 3 Discord servers</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 10 Twitch channels</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 3 YouTube channels</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Clip notifications</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Instant notifications</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Welcome messages</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Sub sync (/link)</li>
    </ul>
    <% if (currentTier === 'starter') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 16px; cursor: default; opacity: 0.7;">Current Plan</div>
    <% } else if (streamer) { %>
      <form method="POST" action="/payment/create" style="margin-top: 16px;">
        <input type="hidden" name="tier" value="starter">
        <div style="margin-bottom: 8px;"><input type="text" name="discount_code" placeholder="Discount code" style="width: 100%; padding: 8px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-size: 12px; text-align: center; font-family: var(--font-body);"></div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary" style="width: 100%; margin-top: 16px;">Log in to Subscribe</a>
    <% } %>
  </div>

  <!-- Pro -->
  <div class="card animate-in animate-in-delay-3" style="text-align: center; padding: 28px 20px; border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), 0 4px 24px rgba(145,70,255,0.1); position: relative;">
    <div class="badge badge-popular" style="margin-bottom: 12px;">Most Popular</div>
    <h3 style="margin-bottom: 4px; justify-content: center; font-size: 17px;">Pro</h3>
    <div style="font-size: 32px; font-weight: 800; margin: 16px 0 4px; font-family: var(--font-display); letter-spacing: -0.03em;">10 EUR</div>
    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 20px;">per year</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; line-height: 2.2;">
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 10 Discord servers</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 50 Twitch channels</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> 20 YouTube channels</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Everything in Starter</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Custom embed colors</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Stream summaries</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Go-live threads</li>
    </ul>
    <% if (currentTier === 'pro') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 16px; cursor: default; opacity: 0.7;">Current Plan</div>
    <% } else if (streamer) { %>
      <form method="POST" action="/payment/create" style="margin-top: 16px;">
        <input type="hidden" name="tier" value="pro">
        <div style="margin-bottom: 8px;"><input type="text" name="discount_code" placeholder="Discount code" style="width: 100%; padding: 8px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-size: 12px; text-align: center; font-family: var(--font-body);"></div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary" style="width: 100%; margin-top: 16px;">Log in to Subscribe</a>
    <% } %>
  </div>

  <!-- Enterprise -->
  <div class="card animate-in animate-in-delay-4" style="text-align: center; padding: 28px 20px; <%= currentTier === 'enterprise' ? 'border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), 0 4px 24px rgba(145,70,255,0.1);' : '' %>">
    <h3 style="margin-bottom: 4px; justify-content: center; font-size: 17px;">Enterprise</h3>
    <div style="font-size: 32px; font-weight: 800; margin: 16px 0 4px; font-family: var(--font-display); letter-spacing: -0.03em;">25 EUR</div>
    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 20px;">per year</p>
    <ul style="text-align: left; list-style: none; padding: 0; font-size: 13px; line-height: 2.2;">
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Unlimited servers</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Unlimited channels</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Everything in Pro</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Custom webhooks</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> White-label (no branding)</li>
      <li style="color: var(--text-primary);"><%- '&#10003;' %> Priority support</li>
    </ul>
    <% if (currentTier === 'enterprise') { %>
      <div class="btn btn-secondary" style="width: 100%; margin-top: 16px; cursor: default; opacity: 0.7;">Current Plan</div>
    <% } else if (streamer) { %>
      <form method="POST" action="/payment/create" style="margin-top: 16px;">
        <input type="hidden" name="tier" value="enterprise">
        <div style="margin-bottom: 8px;"><input type="text" name="discount_code" placeholder="Discount code" style="width: 100%; padding: 8px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-size: 12px; text-align: center; font-family: var(--font-body);"></div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary" style="width: 100%; margin-top: 16px;">Log in to Subscribe</a>
    <% } %>
  </div>

</div>

<%- include('footer') %>
