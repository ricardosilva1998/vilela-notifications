<%- include('header', { title: 'Racing Account', streamer: streamer }) %>
<div style="padding:24px 0;">
  <a href="/racing" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:6px 14px;color:rgba(255,255,255,0.6);font-size:13px;margin-bottom:16px;">&#8592; Back</a>
  <h1 style="font-size:28px;font-weight:800;margin-bottom:24px;">Account Settings</h1>
  <% if (msg) { %><div style="color:#3ecf8e;background:rgba(62,207,142,0.1);padding:10px 16px;border-radius:8px;margin-bottom:16px;font-size:13px;"><%= msg %></div><% } %>
  <% if (error) { %><div style="color:#f04438;background:rgba(240,68,56,0.1);padding:10px 16px;border-radius:8px;margin-bottom:16px;font-size:13px;"><%= error %></div><% } %>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <!-- Left: Profile + Avatar -->
    <div class="card" style="padding:20px;">
      <h3 style="font-size:14px;margin-bottom:16px;">Profile</h3>
      <!-- Avatar -->
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
        <div id="avatar-preview" style="width:72px;height:72px;border-radius:50%;background:rgba(62,207,142,0.15);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;cursor:pointer;border:2px solid rgba(255,255,255,0.1);" onclick="document.getElementById('avatar-input').click();" title="Click to change">
          <% if (racingUser.avatar) { %>
            <img src="<%= racingUser.avatar %>" style="width:100%;height:100%;object-fit:cover;">
          <% } else { %>
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3ecf8e" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <% } %>
        </div>
        <div>
          <div style="font-size:16px;font-weight:700;"><%= racingUser.display_name || racingUser.username %></div>
          <div style="font-size:12px;color:var(--text-muted);">@<%= racingUser.username %></div>
          <button onclick="document.getElementById('avatar-input').click();" style="margin-top:6px;background:none;border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:4px 10px;color:rgba(255,255,255,0.5);font-size:11px;cursor:pointer;">Change Photo</button>
          <input type="file" id="avatar-input" accept="image/*" style="display:none;" onchange="uploadAvatar(this)">
        </div>
      </div>
      <!-- Profile form -->
      <form method="POST" action="/racing/account/profile" style="display:flex;flex-direction:column;gap:10px;">
        <label style="font-size:12px;color:var(--text-secondary);">Display Name</label>
        <input name="display_name" type="text" placeholder="<%= racingUser.username %>" value="<%= racingUser.display_name || '' %>" maxlength="32" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;margin-top:-6px;">
        <label style="font-size:12px;color:var(--text-secondary);">iRacing Name</label>
        <input name="iracing_name" type="text" placeholder="Your iRacing name" value="<%= racingUser.iracing_name || '' %>" maxlength="64" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;margin-top:-6px;">
        <label style="font-size:12px;color:var(--text-secondary);">Email <span style="color:var(--text-muted);font-size:11px;">(for password recovery)</span></label>
        <input name="email" type="email" placeholder="your@email.com" value="<%= racingUser.email || '' %>" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;margin-top:-6px;">
        <button type="submit" class="btn btn-secondary" style="padding:8px;font-size:13px;">Save Profile</button>
      </form>
    </div>

    <!-- Right: Password + Discord -->
    <div style="display:flex;flex-direction:column;gap:16px;">
      <div class="card" style="padding:20px;">
        <h3 style="font-size:14px;margin-bottom:12px;">Change Password</h3>
        <form method="POST" action="/racing/account/password" style="display:flex;flex-direction:column;gap:10px;">
          <input name="current_password" type="password" placeholder="Current Password" required style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;">
          <input name="new_password" type="password" placeholder="New Password" required minlength="6" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;">
          <input name="confirm_password" type="password" placeholder="Confirm New Password" required style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;">
          <button type="submit" class="btn btn-secondary" style="padding:8px;font-size:13px;">Update Password</button>
        </form>
      </div>
      <div class="card" style="padding:20px;">
        <h3 style="font-size:14px;margin-bottom:12px;">Discord Link</h3>
        <% if (streamer) { %>
          <div style="display:flex;align-items:center;gap:10px;">
            <% if (streamer.discord_avatar) { %>
              <img src="<%= streamer.discord_avatar %>" style="width:32px;height:32px;border-radius:50%;">
            <% } %>
            <div>
              <p style="font-size:13px;color:#3ecf8e;font-weight:600;"><%= streamer.discord_display_name || streamer.discord_username %></p>
              <p style="font-size:11px;color:var(--text-muted);">Linked</p>
            </div>
          </div>
        <% } else { %>
          <p style="font-size:13px;color:var(--text-secondary);margin-bottom:10px;">Link your Discord account to access Streamer features too.</p>
          <a href="/auth/login" class="btn btn-discord" style="padding:8px 16px;font-size:13px;">Link Discord</a>
        <% } %>
      </div>
      <div class="card" style="padding:20px;">
        <h3 style="font-size:14px;margin-bottom:12px;">Twitch Link</h3>
        <% if (streamer && streamer.twitch_username) { %>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:32px;height:32px;border-radius:50%;background:rgba(145,70,255,0.15);display:flex;align-items:center;justify-content:center;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#9146ff"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
            </div>
            <div>
              <p style="font-size:13px;color:#9146ff;font-weight:600;"><%= streamer.twitch_display_name || streamer.twitch_username %></p>
              <p style="font-size:11px;color:var(--text-muted);">Linked</p>
            </div>
          </div>
        <% } else { %>
          <p style="font-size:13px;color:var(--text-secondary);margin-bottom:10px;">Connect your Twitch account.</p>
          <a href="/auth/twitch" style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;background:#9146ff;color:#fff;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
            Connect Twitch
          </a>
        <% } %>
      </div>
      <div class="card" style="padding:20px;">
        <h3 style="font-size:14px;margin-bottom:12px;">Spotify Link</h3>
        <% if (streamer && streamer.spotify_access_token) { %>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:32px;height:32px;border-radius:50%;background:rgba(29,185,84,0.15);display:flex;align-items:center;justify-content:center;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            </div>
            <div style="flex:1;">
              <p style="font-size:13px;color:#1DB954;font-weight:600;">Connected</p>
              <p style="font-size:11px;color:var(--text-muted);">Now Playing overlay ready</p>
            </div>
            <a href="/auth/spotify" style="font-size:11px;color:rgba(255,255,255,0.4);text-decoration:none;border:1px solid rgba(255,255,255,0.1);padding:4px 10px;border-radius:5px;">Reconnect</a>
          </div>
        <% } else if (streamer) { %>
          <p style="font-size:13px;color:var(--text-secondary);margin-bottom:10px;">Connect Spotify for the Now Playing overlay.</p>
          <a href="/auth/spotify" style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;background:#1DB954;color:#fff;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            Connect Spotify
          </a>
        <% } else { %>
          <p style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Link your Discord account first, then connect Spotify.</p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- My Sessions -->
  <div style="margin-top:32px;">
    <div style="margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;">
      <h2 style="font-size:18px;font-weight:700;">My Sessions</h2>
      <% if (racingUser.bridge_id) { %>
        <span style="font-size:11px;color:var(--text-muted);background:rgba(62,207,142,0.1);padding:3px 8px;border-radius:4px;color:#3ecf8e;">Bridge linked</span>
      <% } else { %>
        <span style="font-size:11px;color:var(--text-muted);">Link Bridge to see session data</span>
      <% } %>
    </div>

    <% if (typeof sessions !== 'undefined' && sessions && sessions.length > 0) { %>
      <div class="card" style="overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
              <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Date</th>
              <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Track</th>
              <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Type</th>
              <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Car</th>
              <th style="padding:10px 14px;text-align:right;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Best Lap</th>
              <th style="padding:10px 14px;text-align:right;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Laps</th>
              <th style="padding:10px 14px;text-align:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Status</th>
            </tr>
          </thead>
          <tbody>
            <% sessions.forEach(function(s) { %>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.03);cursor:pointer;" onclick="window.location='/api/session/<%= s.id %>?bridge_id=<%= racingUser.bridge_id || '' %>'">
                <td style="padding:10px 14px;color:var(--text-secondary);font-size:12px;"><%= new Date(s.created_at).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></td>
                <td style="padding:10px 14px;font-weight:600;"><%= s.track_name %></td>
                <td style="padding:10px 14px;">
                  <span style="padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;
                    <% if (s.session_type === 'practice') { %>background:rgba(62,207,142,0.1);color:#3ecf8e;<% } else if (s.session_type === 'qualify') { %>background:rgba(247,201,72,0.1);color:#f7c948;<% } else { %>background:rgba(145,70,255,0.1);color:#b18cff;<% } %>
                  "><%= s.session_type.charAt(0).toUpperCase() + s.session_type.slice(1) %></span>
                  <% if (s.race_type) { %><span style="font-size:10px;color:var(--text-muted);margin-left:4px;"><%= s.race_type %></span><% } %>
                </td>
                <td style="padding:10px 14px;color:var(--text-secondary);font-size:12px;"><%= s.car_name || s.car_class %></td>
                <td style="padding:10px 14px;text-align:right;font-family:'JetBrains Mono',monospace;font-weight:600;color:#f7c948;">
                  <% if (s.best_lap_time && s.best_lap_time > 0) { %>
                    <% var m = Math.floor(s.best_lap_time / 60); var sec = (s.best_lap_time % 60).toFixed(3); %>
                    <%= m > 0 ? m + ':' + sec.padStart(6, '0') : sec %>
                  <% } else { %>--<% } %>
                </td>
                <td style="padding:10px 14px;text-align:right;color:var(--text-secondary);"><%= s.actual_laps || s.lap_count || 0 %></td>
                <td style="padding:10px 14px;text-align:center;">
                  <% if (s.is_public) { %>
                    <span style="font-size:10px;color:#3ecf8e;" title="Public">&#127760;</span>
                  <% } else { %>
                    <span style="font-size:10px;color:var(--text-muted);" title="Private">&#128274;</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="card" style="padding:40px;text-align:center;">
        <p style="color:var(--text-muted);font-size:14px;margin-bottom:8px;">No sessions recorded yet</p>
        <p style="color:var(--text-secondary);font-size:12px;">Sessions are automatically captured when you race with Atleta Bridge</p>
      </div>
    <% } %>
  </div>

  <!-- Crop Avatar Modal -->
  <div id="crop-modal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;align-items:center;justify-content:center;background:rgba(0,0,0,0.7);" onclick="if(event.target===this)closeCropModal()">
    <div style="background:#1a1b23;border-radius:12px;border:1px solid rgba(255,255,255,0.08);padding:24px;width:480px;max-width:95vw;" onclick="event.stopPropagation()">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
        <h3 style="font-size:16px;font-weight:700;margin:0;">Crop Avatar</h3>
        <button onclick="closeCropModal()" style="background:none;border:none;color:rgba(255,255,255,0.5);font-size:20px;cursor:pointer;padding:0 4px;line-height:1;">&times;</button>
      </div>
      <div style="display:flex;gap:20px;align-items:flex-start;">
        <canvas id="crop-canvas" width="240" height="240" style="border-radius:8px;cursor:grab;flex-shrink:0;background:#0c0d14;"></canvas>
        <div style="display:flex;flex-direction:column;align-items:center;gap:8px;padding-top:8px;">
          <span style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">Preview</span>
          <canvas id="crop-preview-72" width="72" height="72" style="border-radius:50%;border:2px solid rgba(255,255,255,0.1);"></canvas>
          <canvas id="crop-preview-36" width="36" height="36" style="border-radius:50%;border:2px solid rgba(255,255,255,0.1);"></canvas>
          <div style="display:flex;gap:12px;font-size:10px;color:var(--text-muted);margin-top:-2px;">
            <span>72px</span>
            <span>36px</span>
          </div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:14px;">
        <span style="font-size:12px;color:var(--text-muted);">&minus;</span>
        <input type="range" id="crop-zoom-slider" min="0" max="100" value="0" style="flex:1;accent-color:#3ecf8e;">
        <span style="font-size:12px;color:var(--text-muted);">+</span>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:18px;">
        <button onclick="closeCropModal()" style="background:none;border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:8px 18px;color:rgba(255,255,255,0.6);font-size:13px;cursor:pointer;">Cancel</button>
        <button onclick="saveCrop()" style="background:#3ecf8e;border:none;border-radius:8px;padding:8px 22px;color:#0c0d14;font-size:13px;font-weight:700;cursor:pointer;">Save</button>
      </div>
    </div>
  </div>
</div>

<script>
var cropImg = null, cropZoom = 1, cropMinZoom = 1, cropMaxZoom = 3;
var cropX = 0, cropY = 0, cropDragging = false, cropDragStart = null;
var CANVAS_SIZE = 240, CIRCLE_D = 200, CIRCLE_R = CIRCLE_D / 2;
var CANVAS_CX = CANVAS_SIZE / 2, CANVAS_CY = CANVAS_SIZE / 2;

function uploadAvatar(input) {
  if (!input.files || !input.files[0]) return;
  var file = input.files[0];
  if (file.size > 5 * 1024 * 1024) { alert('Image too large (max 5MB)'); return; }

  var reader = new FileReader();
  reader.onload = function(e) {
    var img = new Image();
    img.onload = function() {
      cropImg = img;
      cropMinZoom = CIRCLE_D / Math.min(img.width, img.height);
      cropMaxZoom = cropMinZoom * 3;
      cropZoom = cropMinZoom;
      cropX = CANVAS_CX - (img.width * cropZoom) / 2;
      cropY = CANVAS_CY - (img.height * cropZoom) / 2;
      openCropModal();
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function openCropModal() {
  document.getElementById('crop-modal').style.display = 'flex';
  var slider = document.getElementById('crop-zoom-slider');
  slider.value = 0;
  setupCropEvents();
  renderCrop();
}

function closeCropModal() {
  document.getElementById('crop-modal').style.display = 'none';
  window.onmousemove = null;
  window.onmouseup = null;
  document.getElementById('avatar-input').value = '';
}

function clampCropPosition() {
  var sw = cropImg.width * cropZoom, sh = cropImg.height * cropZoom;
  var minX = CANVAS_CX + CIRCLE_R - sw;
  var maxX = CANVAS_CX - CIRCLE_R;
  var minY = CANVAS_CY + CIRCLE_R - sh;
  var maxY = CANVAS_CY - CIRCLE_R;
  cropX = Math.min(maxX, Math.max(minX, cropX));
  cropY = Math.min(maxY, Math.max(minY, cropY));
}

function renderCrop() {
  var canvas = document.getElementById('crop-canvas');
  var ctx = canvas.getContext('2d');
  var sw = cropImg.width * cropZoom, sh = cropImg.height * cropZoom;

  ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
  ctx.drawImage(cropImg, cropX, cropY, sw, sh);

  // Dark overlay outside circle
  ctx.save();
  ctx.beginPath();
  ctx.rect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
  ctx.arc(CANVAS_CX, CANVAS_CY, CIRCLE_R, 0, Math.PI * 2, true);
  ctx.fillStyle = 'rgba(0,0,0,0.55)';
  ctx.fill();
  ctx.restore();

  // Circle border
  ctx.beginPath();
  ctx.arc(CANVAS_CX, CANVAS_CY, CIRCLE_R, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(255,255,255,0.4)';
  ctx.lineWidth = 2;
  ctx.stroke();

  renderPreview('crop-preview-72', 72);
  renderPreview('crop-preview-36', 36);
}

function renderPreview(canvasId, size) {
  var canvas = document.getElementById(canvasId);
  var ctx = canvas.getContext('2d');
  var srcCx = (CANVAS_CX - cropX) / cropZoom;
  var srcCy = (CANVAS_CY - cropY) / cropZoom;
  var srcR = CIRCLE_R / cropZoom;

  ctx.clearRect(0, 0, size, size);
  ctx.save();
  ctx.beginPath();
  ctx.arc(size / 2, size / 2, size / 2, 0, Math.PI * 2);
  ctx.clip();
  ctx.drawImage(cropImg, srcCx - srcR, srcCy - srcR, srcR * 2, srcR * 2, 0, 0, size, size);
  ctx.restore();
}

function setupCropEvents() {
  var canvas = document.getElementById('crop-canvas');
  var slider = document.getElementById('crop-zoom-slider');

  canvas.onmousedown = function(e) {
    cropDragging = true;
    cropDragStart = { x: e.clientX - cropX, y: e.clientY - cropY };
    canvas.style.cursor = 'grabbing';
  };
  window.onmousemove = function(e) {
    if (!cropDragging) return;
    cropX = e.clientX - cropDragStart.x;
    cropY = e.clientY - cropDragStart.y;
    clampCropPosition();
    renderCrop();
  };
  window.onmouseup = function() {
    cropDragging = false;
    canvas.style.cursor = 'grab';
  };

  canvas.ontouchstart = function(e) {
    e.preventDefault();
    var t = e.touches[0];
    cropDragging = true;
    cropDragStart = { x: t.clientX - cropX, y: t.clientY - cropY };
  };
  canvas.ontouchmove = function(e) {
    e.preventDefault();
    if (!cropDragging) return;
    var t = e.touches[0];
    cropX = t.clientX - cropDragStart.x;
    cropY = t.clientY - cropDragStart.y;
    clampCropPosition();
    renderCrop();
  };
  canvas.ontouchend = function() { cropDragging = false; };

  canvas.onwheel = function(e) {
    e.preventDefault();
    var oldZoom = cropZoom;
    var delta = e.deltaY > 0 ? -0.02 : 0.02;
    cropZoom = Math.min(cropMaxZoom, Math.max(cropMinZoom, cropZoom + delta * (cropMaxZoom - cropMinZoom)));
    // Zoom toward center
    var ratio = cropZoom / oldZoom;
    cropX = CANVAS_CX - (CANVAS_CX - cropX) * ratio;
    cropY = CANVAS_CY - (CANVAS_CY - cropY) * ratio;
    clampCropPosition();
    slider.value = ((cropZoom - cropMinZoom) / (cropMaxZoom - cropMinZoom)) * 100;
    renderCrop();
  };

  slider.oninput = function() {
    var oldZoom = cropZoom;
    cropZoom = cropMinZoom + (parseFloat(this.value) / 100) * (cropMaxZoom - cropMinZoom);
    var ratio = cropZoom / oldZoom;
    cropX = CANVAS_CX - (CANVAS_CX - cropX) * ratio;
    cropY = CANVAS_CY - (CANVAS_CY - cropY) * ratio;
    clampCropPosition();
    renderCrop();
  };
}

function saveCrop() {
  var outCanvas = document.createElement('canvas');
  outCanvas.width = 128; outCanvas.height = 128;
  var ctx = outCanvas.getContext('2d');
  var srcCx = (CANVAS_CX - cropX) / cropZoom;
  var srcCy = (CANVAS_CY - cropY) / cropZoom;
  var srcR = CIRCLE_R / cropZoom;

  ctx.beginPath();
  ctx.arc(64, 64, 64, 0, Math.PI * 2);
  ctx.clip();
  ctx.drawImage(cropImg, srcCx - srcR, srcCy - srcR, srcR * 2, srcR * 2, 0, 0, 128, 128);

  var dataUrl = outCanvas.toDataURL('image/jpeg', 0.8);

  fetch('/racing/account/avatar', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ avatar: dataUrl }),
  }).then(function(r) { return r.json(); }).then(function(d) {
    if (d.ok) {
      document.getElementById('avatar-preview').innerHTML = '<img src="' + dataUrl + '" style="width:100%;height:100%;object-fit:cover;">';
      // Update nav avatar if present
      var navAvatar = document.querySelector('.nav-avatar-img, nav img[style*="border-radius:50%"]');
      if (navAvatar) navAvatar.src = dataUrl;
      closeCropModal();
    } else {
      alert(d.error || 'Upload failed');
    }
  }).catch(function() { alert('Upload failed'); });
}
</script>
