<%- include('header', { title: 'Racing Admin', streamer: streamer }) %>
<div style="padding:24px 0;">
  <a href="/racing" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:6px 14px;color:rgba(255,255,255,0.6);font-size:13px;margin-bottom:16px;">&#8592; Back</a>
  <h1 style="font-size:24px;font-weight:800;margin-bottom:24px;">Racing Admin</h1>

  <!-- Racing Accounts -->
  <div style="margin-bottom:32px;">
    <% var onlineCount = 0; racingUsers.forEach(function(u) { var bd = u.bridge_id ? bridgeUsers.find(function(b){return b.bridge_id===u.bridge_id;}) : null; if (bd && (Date.now() - new Date(bd.last_seen+'Z').getTime()) < 2*60*1000) onlineCount++; }); %>
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Racing Accounts (<%= racingUsers.length %>) <% if (onlineCount) { %><span style="font-size:12px;font-weight:600;color:#3ecf8e;margin-left:8px;"><%= onlineCount %> online</span><% } %></h2>
    <div class="card" style="overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Status</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Username</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">iRacing Name</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Last Seen</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Bridge ID</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Discord</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Created</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Security</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);"></th>
          </tr>
        </thead>
        <tbody>
          <% racingUsers.forEach(function(u) { %>
            <% var bridgeData = u.bridge_id ? bridgeUsers.find(function(b) { return b.bridge_id === u.bridge_id; }) : null; %>
            <% var userOnline = bridgeData && (Date.now() - new Date(bridgeData.last_seen + 'Z').getTime()) < 2 * 60 * 1000; %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:10px 14px;text-align:center;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:<%= userOnline ? '#3ecf8e' : 'rgba(255,255,255,0.1)' %>;<%= userOnline ? 'box-shadow:0 0 6px rgba(62,207,142,0.4);' : '' %>"></span>
                <span style="font-size:10px;font-weight:600;margin-left:4px;color:<%= userOnline ? '#3ecf8e' : 'var(--text-muted)' %>;"><%= userOnline ? 'Online' : 'Offline' %></span>
              </td>
              <td style="padding:10px 14px;font-weight:600;"><%= u.username %></td>
              <td style="padding:10px 14px;color:var(--text-secondary);"><%= u.iracing_name || (bridgeData ? bridgeData.iracing_name : null) || '—' %></td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;">
                <% if (userOnline) { %><span style="color:#3ecf8e;">Now</span>
                <% } else if (bridgeData) { %><%= new Date(bridgeData.last_seen).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                <% } else { %>Never<% } %>
              </td>
              <td style="padding:10px 14px;font-family:monospace;font-size:11px;color:var(--text-muted);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= u.bridge_id || '' %>"><%= u.bridge_id ? u.bridge_id.substring(0, 12) + '...' : '—' %></td>
              <td style="padding:10px 14px;">
                <% if (u.streamer_id) { %>
                  <span style="color:#3ecf8e;font-size:11px;">Linked</span>
                <% } else { %>
                  <span style="color:var(--text-muted);font-size:11px;">—</span>
                <% } %>
              </td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;"><%= new Date(u.created_at).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) %></td>
              <td style="padding:10px 14px;">
                <% var isLocked = u.locked_until && u.locked_until > Date.now(); %>
                <form method="POST" action="/racing/admin/<%= isLocked ? 'unlock' : 'lock' %>/<%= u.id %>" style="display:inline;" title="<%= isLocked ? 'Account locked — click to unlock' : (u.login_attempts > 0 ? u.login_attempts + ' failed attempts' : 'Account OK') %>">
                  <label style="position:relative;display:inline-block;width:28px;height:16px;cursor:pointer;">
                    <input type="checkbox" <%= isLocked ? 'checked' : '' %> onchange="this.form.submit()" style="display:none;">
                    <span style="position:absolute;inset:0;border-radius:8px;background:<%= isLocked ? '#f04438' : 'rgba(255,255,255,0.1)' %>;transition:background 0.2s;"></span>
                    <span style="position:absolute;top:2px;left:<%= isLocked ? '14px' : '2px' %>;width:12px;height:12px;border-radius:50%;background:white;transition:left 0.2s;"></span>
                  </label>
                </form>
              </td>
              <td style="padding:10px 14px;">
                <form method="POST" action="/racing/admin/delete/<%= u.id %>" style="display:inline;" onsubmit="return confirm('Delete account @<%= u.username %>? This cannot be undone.');">
                  <button type="submit" style="background:none;border:1px solid rgba(240,68,56,0.3);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:600;color:#f04438;cursor:pointer;">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Unregistered Bridge Users -->
  <div>
    <% var unregistered = bridgeUsers.filter(function(b) { return !racingUsers.find(function(u) { return u.bridge_id === b.bridge_id; }); }); %>
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Unregistered Bridges (<%= unregistered.length %>)</h2>
    <div class="card" style="overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Status</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Bridge ID</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">iRacing Name</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Last Seen</th>
          </tr>
        </thead>
        <tbody>
          <% unregistered.forEach(function(b) { %>
            <% var isOnline = (Date.now() - new Date(b.last_seen + 'Z').getTime()) < 2 * 60 * 1000; %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:10px 14px;text-align:center;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:<%= isOnline ? '#3ecf8e' : 'rgba(255,255,255,0.1)' %>;<%= isOnline ? 'box-shadow:0 0 6px rgba(62,207,142,0.4);' : '' %>"></span>
                <span style="font-size:10px;font-weight:600;margin-left:4px;color:<%= isOnline ? '#3ecf8e' : 'var(--text-muted)' %>;"><%= isOnline ? 'Online' : 'Offline' %></span>
              </td>
              <td style="padding:10px 14px;font-family:monospace;font-size:11px;color:var(--text-muted);max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= b.bridge_id %>"><%= b.bridge_id.substring(0, 16) %>...</td>
              <td style="padding:10px 14px;font-weight:600;"><%= b.iracing_name || '—' %></td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;">
                <% if (isOnline) { %><span style="color:#3ecf8e;">Now</span><% } else { %><%= new Date(b.last_seen).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %><% } %>
              </td>
            </tr>
          <% }); %>
          <% if (!unregistered.length) { %>
            <tr><td colspan="4" style="padding:16px;text-align:center;color:var(--text-muted);font-size:12px;">All Bridge users have registered accounts</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('footer') %>
