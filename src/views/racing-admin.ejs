<%- include('header', { title: 'Racing Admin', streamer: streamer }) %>
<div style="padding:24px 0;">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
    <a href="/racing" style="color:var(--accent);font-size:13px;text-decoration:none;">&larr; Back</a>
    <h1 style="font-size:24px;font-weight:800;">Racing Admin</h1>
  </div>

  <!-- Racing Accounts -->
  <div style="margin-bottom:32px;">
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Racing Accounts (<%= racingUsers.length %>)</h2>
    <div class="card" style="overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">ID</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Username</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">iRacing Name</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Bridge ID</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Discord Link</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Created</th>
          </tr>
        </thead>
        <tbody>
          <% racingUsers.forEach(function(u) { %>
            <% var bridgeData = u.bridge_id ? bridgeUsers.find(function(b) { return b.bridge_id === u.bridge_id; }) : null; %>
            <% var userOnline = bridgeData && (Date.now() - new Date(bridgeData.last_seen + 'Z').getTime()) < 2 * 60 * 1000; %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;"><%= u.id %></td>
              <td style="padding:10px 14px;font-weight:600;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;background:<%= userOnline ? '#3ecf8e' : 'rgba(255,255,255,0.1)' %>;vertical-align:middle;<%= userOnline ? 'box-shadow:0 0 6px rgba(62,207,142,0.4);' : '' %>"></span><%= u.username %>
              </td>
              <td style="padding:10px 14px;color:var(--text-secondary);"><%= u.iracing_name || '—' %></td>
              <td style="padding:10px 14px;font-family:monospace;font-size:11px;color:var(--text-muted);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= u.bridge_id || '' %>"><%= u.bridge_id ? u.bridge_id.substring(0, 12) + '...' : '—' %></td>
              <td style="padding:10px 14px;">
                <% if (u.streamer_id) { %>
                  <span style="color:#3ecf8e;font-size:11px;">Linked (#<%= u.streamer_id %>)</span>
                <% } else { %>
                  <span style="color:var(--text-muted);font-size:11px;">—</span>
                <% } %>
              </td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;"><%= new Date(u.created_at).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Bridge Users (from logs) -->
  <div>
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Bridge Activity (<%= bridgeUsers.length %> bridges)</h2>
    <div class="card" style="overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Bridge ID</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">iRacing Name</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Last Seen</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Racing Account</th>
          </tr>
        </thead>
        <tbody>
          <% bridgeUsers.forEach(function(b) { %>
            <% var isOnline = (Date.now() - new Date(b.last_seen + 'Z').getTime()) < 2 * 60 * 1000; %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:10px 14px;font-family:monospace;font-size:11px;color:var(--text-muted);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= b.bridge_id %>"><%= b.bridge_id.substring(0, 12) %>...</td>
              <td style="padding:10px 14px;font-weight:600;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;background:<%= isOnline ? '#3ecf8e' : 'rgba(255,255,255,0.1)' %>;vertical-align:middle;<%= isOnline ? 'box-shadow:0 0 6px rgba(62,207,142,0.4);' : '' %>"></span><%= b.iracing_name || '—' %>
              </td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;">
                <% if (isOnline) { %><span style="color:#3ecf8e;font-weight:600;">Online</span><% } else { %><%= new Date(b.last_seen).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %><% } %>
              </td>
              <td style="padding:10px 14px;">
                <% var linked = racingUsers.find(function(u) { return u.bridge_id === b.bridge_id; }); %>
                <% if (linked) { %>
                  <span style="color:#3ecf8e;font-size:11px;"><%= linked.username %></span>
                <% } else { %>
                  <span style="color:var(--text-muted);font-size:11px;">Not registered</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('footer') %>
