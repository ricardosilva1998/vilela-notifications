<%- include('header', { title: 'Racing Admin', streamer: streamer }) %>
<style>.container { max-width: 1200px !important; } .admin-table td, .admin-table th { white-space: nowrap; }</style>
<div style="padding:24px 0;">
  <a href="/racing" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:6px 14px;color:rgba(255,255,255,0.6);font-size:13px;margin-bottom:16px;">&#8592; Back</a>
  <h1 style="font-size:24px;font-weight:800;margin-bottom:24px;">Racing Admin</h1>

  <% if (typeof msg !== 'undefined' && msg) { %><div style="color:#3ecf8e;background:rgba(62,207,142,0.1);padding:10px 16px;border-radius:8px;margin-bottom:16px;font-size:13px;"><%= msg %></div><% } %>
  <% if (typeof error !== 'undefined' && error) { %><div style="color:#f04438;background:rgba(240,68,56,0.1);padding:10px 16px;border-radius:8px;margin-bottom:16px;font-size:13px;"><%= error %></div><% } %>

  <!-- Notifications -->
  <div style="margin-bottom:32px;">
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Notifications</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div class="card" style="padding:20px;">
        <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;">Send Announcement</h3>
        <form method="POST" action="/racing/admin/announcement" style="display:flex;flex-direction:column;gap:10px;">
          <input name="title" type="text" placeholder="Title" required maxlength="100" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;">
          <textarea name="message" placeholder="Message" required maxlength="500" rows="3" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;resize:vertical;"></textarea>
          <input name="link" type="text" placeholder="Link (optional)" maxlength="200" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;">
          <button type="submit" class="btn btn-secondary" style="padding:8px;font-size:13px;" onclick="return confirm('Send announcement to all racing users?')">Send to all users</button>
        </form>
      </div>
      <div class="card" style="padding:20px;">
        <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;">Bridge Update Notification</h3>
        <form method="POST" action="/racing/admin/bridge-update" style="display:flex;flex-direction:column;gap:10px;">
          <input name="version" type="text" placeholder="Version (e.g. 3.16)" required maxlength="20" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;">
          <input name="message" type="text" placeholder="Custom message (optional)" maxlength="200" style="padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-primary);font-size:13px;">
          <button type="submit" class="btn btn-secondary" style="padding:8px;font-size:13px;" onclick="return confirm('Notify all Bridge users about this update?')">Notify Bridge users</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Racing Accounts -->
  <div style="margin-bottom:32px;">
    <% var onlineCount = 0; racingUsers.forEach(function(u) { var bd = u.bridge_id ? bridgeUsers.find(function(b){return b.bridge_id===u.bridge_id;}) : null; if (bd && (Date.now() - new Date(bd.last_seen+'Z').getTime()) < 2*60*1000) onlineCount++; }); %>
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Racing Accounts (<%= racingUsers.length %>) <% if (onlineCount) { %><span style="font-size:12px;font-weight:600;color:#3ecf8e;margin-left:8px;"><%= onlineCount %> online</span><% } %></h2>
    <div class="card" style="overflow:hidden;">
      <table class="admin-table" style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Status</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Username</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">iRacing Name</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Last Seen</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Bridge ID</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Discord</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Created</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Security</th>
            <th style="padding:10px 14px;text-align:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Reset</th>
            <th style="padding:10px 14px;text-align:center;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Delete</th>
          </tr>
        </thead>
        <tbody>
          <% racingUsers.forEach(function(u) { %>
            <% var bridgeData = u.bridge_id ? bridgeUsers.find(function(b) { return b.bridge_id === u.bridge_id; }) : null; %>
            <% var userOnline = bridgeData && (Date.now() - new Date(bridgeData.last_seen + 'Z').getTime()) < 2 * 60 * 1000; %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:10px 14px;text-align:center;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:<%= userOnline ? '#3ecf8e' : 'rgba(255,255,255,0.1)' %>;<%= userOnline ? 'box-shadow:0 0 6px rgba(62,207,142,0.4);' : '' %>"></span>
                <span style="font-size:10px;font-weight:600;margin-left:4px;color:<%= userOnline ? '#3ecf8e' : 'var(--text-muted)' %>;"><%= userOnline ? 'Online' : 'Offline' %></span>
              </td>
              <td style="padding:10px 14px;font-weight:600;"><%= u.username %></td>
              <td style="padding:10px 14px;color:var(--text-secondary);"><%= u.iracing_name || (bridgeData ? bridgeData.iracing_name : null) || '—' %></td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;">
                <% if (userOnline) { %><span style="color:#3ecf8e;">Now</span>
                <% } else if (bridgeData) { %><%= new Date(bridgeData.last_seen).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                <% } else { %>Never<% } %>
              </td>
              <td style="padding:10px 14px;font-family:monospace;font-size:11px;color:var(--text-muted);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= u.bridge_id || '' %>"><%= u.bridge_id ? u.bridge_id.substring(0, 12) + '...' : '—' %></td>
              <td style="padding:10px 14px;">
                <% if (u.streamer_id) { %>
                  <span style="color:#3ecf8e;font-size:11px;">Linked</span>
                <% } else { %>
                  <span style="color:var(--text-muted);font-size:11px;">—</span>
                <% } %>
              </td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;"><%= new Date(u.created_at).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) %></td>
              <td style="padding:10px 14px;">
                <% var isLocked = u.locked_until && u.locked_until > Date.now(); %>
                <form method="POST" action="/racing/admin/<%= isLocked ? 'unlock' : 'lock' %>/<%= u.id %>" style="display:inline;" title="<%= isLocked ? 'Account locked — click to unlock' : (u.login_attempts > 0 ? u.login_attempts + ' failed attempts' : 'Account OK') %>">
                  <label style="position:relative;display:inline-block;width:28px;height:16px;cursor:pointer;">
                    <input type="checkbox" <%= isLocked ? 'checked' : '' %> onchange="this.form.submit()" style="display:none;">
                    <span style="position:absolute;inset:0;border-radius:8px;background:<%= isLocked ? '#f04438' : 'rgba(255,255,255,0.1)' %>;transition:background 0.2s;"></span>
                    <span style="position:absolute;top:2px;left:<%= isLocked ? '14px' : '2px' %>;width:12px;height:12px;border-radius:50%;background:white;transition:left 0.2s;"></span>
                  </label>
                </form>
              </td>
              <td style="padding:10px 14px;text-align:center;">
                <form method="POST" action="/racing/admin/reset-password/<%= u.id %>" style="display:inline;">
                  <button type="submit" style="background:none;border:1px solid rgba(62,207,142,0.3);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:600;color:#3ecf8e;cursor:pointer;">Reset PW</button>
                </form>
              </td>
              <td style="padding:10px 14px;text-align:center;">
                <form method="POST" action="/racing/admin/delete/<%= u.id %>" style="display:inline;" onsubmit="return confirm('Delete account @<%= u.username %>? This cannot be undone.');">
                  <button type="submit" style="background:none;border:1px solid rgba(240,68,56,0.3);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:600;color:#f04438;cursor:pointer;">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Unregistered Bridge Users -->
  <div>
    <% var unregistered = bridgeUsers.filter(function(b) { return !racingUsers.find(function(u) { return u.bridge_id === b.bridge_id; }); }); %>
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Unregistered Bridges (<%= unregistered.length %>)</h2>
    <div class="card" style="overflow:hidden;">
      <table class="admin-table" style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Status</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Bridge ID</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">iRacing Name</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Last Seen</th>
          </tr>
        </thead>
        <tbody>
          <% unregistered.forEach(function(b) { %>
            <% var isOnline = (Date.now() - new Date(b.last_seen + 'Z').getTime()) < 2 * 60 * 1000; %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:10px 14px;text-align:center;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:<%= isOnline ? '#3ecf8e' : 'rgba(255,255,255,0.1)' %>;<%= isOnline ? 'box-shadow:0 0 6px rgba(62,207,142,0.4);' : '' %>"></span>
                <span style="font-size:10px;font-weight:600;margin-left:4px;color:<%= isOnline ? '#3ecf8e' : 'var(--text-muted)' %>;"><%= isOnline ? 'Online' : 'Offline' %></span>
              </td>
              <td style="padding:10px 14px;font-family:monospace;font-size:11px;color:var(--text-muted);max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= b.bridge_id %>"><%= b.bridge_id.substring(0, 16) %>...</td>
              <td style="padding:10px 14px;font-weight:600;"><%= b.iracing_name || '—' %></td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;">
                <% if (isOnline) { %><span style="color:#3ecf8e;">Now</span><% } else { %><%= new Date(b.last_seen).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %><% } %>
              </td>
            </tr>
          <% }); %>
          <% if (!unregistered.length) { %>
            <tr><td colspan="4" style="padding:16px;text-align:center;color:var(--text-muted);font-size:12px;">All Bridge users have registered accounts</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Suspicious Activity -->
  <div style="margin-top:32px;">
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Suspicious Activity (last 24h)</h2>
    <% if (suspicious && suspicious.length > 0) { %>
    <div class="card" style="overflow:hidden;">
      <table class="admin-table" style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">IP</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Username</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Action</th>
            <th style="padding:10px 14px;text-align:right;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Failures</th>
            <th style="padding:10px 14px;text-align:right;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Successes</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Last Attempt</th>
            <th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">First Attempt</th>
          </tr>
        </thead>
        <tbody>
          <% suspicious.forEach(function(s) { %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:10px 14px;font-family:monospace;font-size:11px;color:var(--text-muted);"><%= s.ip || '—' %></td>
              <td style="padding:10px 14px;font-weight:600;<%= s.failures >= 5 ? 'color:#f04438;' : '' %>"><%= s.username || '—' %></td>
              <td style="padding:10px 14px;font-size:11px;"><%= s.action %></td>
              <td style="padding:10px 14px;text-align:right;font-weight:700;color:<%= s.failures >= 5 ? '#f04438' : (s.failures >= 3 ? '#f79009' : 'var(--text-secondary)') %>;"><%= s.failures %></td>
              <td style="padding:10px 14px;text-align:right;color:var(--text-muted);"><%= s.successes %></td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;"><%= new Date(s.last_attempt).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></td>
              <td style="padding:10px 14px;color:var(--text-muted);font-size:11px;"><%= new Date(s.first_attempt).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="card" style="padding:20px;text-align:center;">
      <p style="color:var(--text-muted);font-size:13px;">No suspicious activity in the last 24 hours</p>
    </div>
    <% } %>
  </div>

  <!-- Recent Auth Log -->
  <div style="margin-top:32px;">
    <h2 style="font-size:16px;font-weight:700;margin-bottom:12px;">Recent Auth Log</h2>
    <div class="card" style="overflow:hidden;">
      <table class="admin-table" style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead>
          <tr style="background:rgba(255,255,255,0.03);border-bottom:1px solid var(--border);">
            <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Time</th>
            <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Action</th>
            <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Username</th>
            <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">IP</th>
            <th style="padding:8px 12px;text-align:center;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Result</th>
            <th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">Reason</th>
          </tr>
        </thead>
        <tbody>
          <% authLog.forEach(function(l) { %>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
              <td style="padding:8px 12px;color:var(--text-muted);font-size:11px;"><%= new Date(l.created_at).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit', second:'2-digit' }) %></td>
              <td style="padding:8px 12px;font-size:11px;"><%= l.action %></td>
              <td style="padding:8px 12px;font-weight:600;"><%= l.username || '—' %></td>
              <td style="padding:8px 12px;font-family:monospace;font-size:10px;color:var(--text-muted);"><%= l.ip || '—' %></td>
              <td style="padding:8px 12px;text-align:center;">
                <% if (l.success) { %>
                  <span style="color:#3ecf8e;font-size:10px;font-weight:600;">OK</span>
                <% } else { %>
                  <span style="color:#f04438;font-size:10px;font-weight:600;">FAIL</span>
                <% } %>
              </td>
              <td style="padding:8px 12px;font-size:10px;color:var(--text-muted);"><%= l.reason || '—' %></td>
            </tr>
          <% }); %>
          <% if (!authLog.length) { %>
            <tr><td colspan="6" style="padding:16px;text-align:center;color:var(--text-muted);font-size:12px;">No auth activity logged yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('footer') %>
