<%- include('header', { title: 'YouTube Chatbot Config', streamer: streamer }) %>

<style>
.yt-accent { color: #ff0000; }
</style>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<h2 style="margin: 16px 0 8px; font-size: 24px; font-weight: 700;" class="animate-in">YouTube Chatbot Configuration</h2>
<p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 24px;">Set up your YouTube live chat bot to respond to Super Chats, new Members, and Gift events.</p>

<% if (connected) { %>
  <div style="background: rgba(62,207,142,0.1); border: 1px solid rgba(62,207,142,0.2); border-radius: var(--radius-md); padding: 14px 16px; margin-bottom: 20px; font-size: 14px; color: var(--success); display: flex; align-items: center; gap: 8px;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    Connected to YouTube live chat! Bot is now polling for events.
  </div>
<% } %>
<% if (disconnected) { %>
  <div style="background: rgba(247,144,9,0.1); border: 1px solid rgba(247,144,9,0.2); border-radius: var(--radius-md); padding: 14px 16px; margin-bottom: 20px; font-size: 14px; color: var(--warning);">
    Disconnected from YouTube live chat.
  </div>
<% } %>
<% if (error) { %>
  <div style="background: rgba(240,68,56,0.1); border: 1px solid rgba(240,68,56,0.2); border-radius: var(--radius-md); padding: 14px 16px; margin-bottom: 20px; font-size: 14px; color: var(--danger);">
    <%= error %>
  </div>
<% } %>

<!-- Live Stream Connection -->
<div class="card animate-in" style="margin-bottom: 16px;">
  <h3 style="margin-bottom: 16px;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    Live Stream Connection
  </h3>
  <% if (streamer.yt_access_token) { %>
    <p style="color: var(--success); font-size: 14px; display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      YouTube account connected<%= streamer.yt_channel_name ? ': <strong>' + streamer.yt_channel_name + '</strong>' : '' %>
    </p>
    <p style="color: var(--text-muted); font-size: 12px; margin-bottom: 12px;">
      <a href="/auth/youtube" style="color: var(--accent);">Reconnect with a different account</a>
    </p>
  <% } else { %>
    <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px; line-height: 1.5;">
      Connect your YouTube account so we can detect your live streams and join your chat.
    </p>
    <a href="/auth/youtube" class="btn btn-primary" style="font-size: 13px; padding: 10px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 12px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.5 7.7a2.8 2.8 0 0 0-2-2C18.9 5 12 5 12 5s-6.9 0-8.5.7a2.8 2.8 0 0 0-2 2A29 29 0 0 0 1 12a29 29 0 0 0 .5 4.3 2.8 2.8 0 0 0 2 2c1.6.7 8.5.7 8.5.7s6.9 0 8.5-.7a2.8 2.8 0 0 0 2-2A29 29 0 0 0 23 12a29 29 0 0 0-.5-4.3z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
      Connect YouTube Account
    </a>
  <% } %>

  <% if (ytPolling) { %>
    <div style="margin-top: 12px; padding: 12px 16px; background: rgba(62,207,142,0.08); border: 1px solid rgba(62,207,142,0.2); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: space-between;">
      <span style="color: var(--success); font-size: 13px; font-weight: 600;">● Bot is polling live chat</span>
      <form method="POST" action="/dashboard/youtube-chatbot/disconnect" style="margin: 0;">
        <button type="submit" class="btn btn-secondary" style="font-size: 12px; padding: 6px 14px;">Disconnect</button>
      </form>
    </div>
  <% } else if (streamer.yt_access_token) { %>
    <form method="POST" action="/dashboard/youtube-chatbot/connect" style="margin-top: 12px;">
      <button type="submit" class="btn btn-primary" style="font-size: 13px; padding: 10px 20px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        Connect to My Live Stream
      </button>
    </form>
  <% } %>
</div>

<form method="POST" action="/dashboard/youtube-chatbot">

  <!-- Enable/Disable Toggle -->
  <div class="card animate-in" style="margin-bottom: 16px;">
    <h3 style="margin-bottom: 16px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Bot Settings
    </h3>
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
      <input type="checkbox" id="yt_chatbot_enabled" name="yt_chatbot_enabled" value="1" <%= streamer.yt_chatbot_enabled ? 'checked' : '' %> style="width: 18px; height: 18px; accent-color: #ff0000;">
      <label for="yt_chatbot_enabled" style="font-weight: 600; font-size: 15px;">Enable YouTube chatbot on my channel</label>
    </div>
    <p style="color: var(--text-muted); font-size: 13px; line-height: 1.5;">
      The chatbot will automatically respond to Super Chats, new Members, and Gift Memberships during your live streams.
    </p>
  </div>

  <!-- Event Sections -->
  <div class="card animate-in animate-in-delay-1" style="margin-bottom: 16px;">
    <h3 style="margin-bottom: 4px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
      Event Messages &amp; Overlay
    </h3>
    <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 20px;">
      Configure chat responses and overlay notifications for each YouTube live event type.
    </p>

    <!-- Super Chat -->
    <div style="padding: 18px 0; border-bottom: 1px solid var(--border);">
      <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 14px;">
        <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(255,0,0,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h4 style="font-size: 15px; font-weight: 700; color: #ff4444;">Super Chat</h4>
      </div>

      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
        <div class="toggle" style="margin-bottom: 0;">
          <input type="checkbox" id="yt_chat_superchat_enabled" name="yt_chat_superchat_enabled" value="1" <%= streamer.yt_chat_superchat_enabled ? 'checked' : '' %>>
          <label for="yt_chat_superchat_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Send chat message</label>
        </div>
      </div>
      <div class="form-group" style="margin-bottom: 4px;">
        <textarea name="yt_chat_superchat_template" rows="2"
          placeholder="{username} sent a Super Chat of {amount}! {message}"
          style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
          onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
        ><%= streamer.yt_chat_superchat_template || '' %></textarea>
      </div>
      <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{amount}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{message}</code></p>

      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
        <div class="toggle" style="margin-bottom: 0;">
          <input type="checkbox" id="yt_overlay_superchat_enabled" name="yt_overlay_superchat_enabled" value="1" <%= streamer.yt_overlay_superchat_enabled ? 'checked' : '' %>>
          <label for="yt_overlay_superchat_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Show overlay banner</label>
        </div>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 8px;">
        <button type="button" onclick="testEvent('yt_superchat', this)" class="btn btn-secondary" style="font-size: 13px; padding: 8px 16px;">Test Event</button>
        <button type="button" onclick="previewMessage('superchat')" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px;">Preview Message</button>
      </div>
    </div>

    <!-- New Member -->
    <div style="padding: 18px 0; border-bottom: 1px solid var(--border);">
      <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 14px;">
        <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(15,157,88,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0f9d58" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <h4 style="font-size: 15px; font-weight: 700; color: #0f9d58;">New Member</h4>
      </div>

      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
        <div class="toggle" style="margin-bottom: 0;">
          <input type="checkbox" id="yt_chat_member_enabled" name="yt_chat_member_enabled" value="1" <%= streamer.yt_chat_member_enabled ? 'checked' : '' %>>
          <label for="yt_chat_member_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Send chat message</label>
        </div>
      </div>
      <div class="form-group" style="margin-bottom: 4px;">
        <textarea name="yt_chat_member_template" rows="2"
          placeholder="Welcome to the team, {username}! Thanks for becoming a member!"
          style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
          onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
        ><%= streamer.yt_chat_member_template || '' %></textarea>
      </div>
      <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{level}</code></p>

      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
        <div class="toggle" style="margin-bottom: 0;">
          <input type="checkbox" id="yt_overlay_member_enabled" name="yt_overlay_member_enabled" value="1" <%= streamer.yt_overlay_member_enabled ? 'checked' : '' %>>
          <label for="yt_overlay_member_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Show overlay banner</label>
        </div>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 8px;">
        <button type="button" onclick="testEvent('yt_member', this)" class="btn btn-secondary" style="font-size: 13px; padding: 8px 16px;">Test Event</button>
        <button type="button" onclick="previewMessage('member')" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px;">Preview Message</button>
      </div>
    </div>

    <!-- Gifted Memberships -->
    <div style="padding: 18px 0;">
      <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 14px;">
        <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(66,133,244,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4285f4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
        </div>
        <h4 style="font-size: 15px; font-weight: 700; color: #4285f4;">Gifted Memberships</h4>
      </div>

      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
        <div class="toggle" style="margin-bottom: 0;">
          <input type="checkbox" id="yt_chat_giftmember_enabled" name="yt_chat_giftmember_enabled" value="1" <%= streamer.yt_chat_giftmember_enabled ? 'checked' : '' %>>
          <label for="yt_chat_giftmember_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Send chat message</label>
        </div>
      </div>
      <div class="form-group" style="margin-bottom: 4px;">
        <textarea name="yt_chat_giftmember_template" rows="2"
          placeholder="{username} gifted {amount} memberships! What a legend!"
          style="width: 100%; padding: 10px 14px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-body); font-size: 13px; outline: none; resize: vertical; transition: border-color var(--transition);"
          onfocus="this.style.borderColor='var(--border-focus)'" onblur="this.style.borderColor='var(--border)'"
        ><%= streamer.yt_chat_giftmember_template || '' %></textarea>
      </div>
      <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Variables: <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{username}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{amount}</code> <code style="background: var(--bg-elevated); padding: 1px 5px; border-radius: 4px;">{level}</code></p>

      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
        <div class="toggle" style="margin-bottom: 0;">
          <input type="checkbox" id="yt_overlay_giftmember_enabled" name="yt_overlay_giftmember_enabled" value="1" <%= streamer.yt_overlay_giftmember_enabled ? 'checked' : '' %>>
          <label for="yt_overlay_giftmember_enabled" style="font-size: 14px; font-weight: 600; color: var(--text-primary);">Show overlay banner</label>
        </div>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 8px;">
        <button type="button" onclick="testEvent('yt_giftmember', this)" class="btn btn-secondary" style="font-size: 13px; padding: 8px 16px;">Test Event</button>
        <button type="button" onclick="previewMessage('giftmember')" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px;">Preview Message</button>
      </div>
    </div>

  </div>

  <!-- Save Button -->
  <div style="display: flex; justify-content: flex-end; margin-bottom: 24px;">
    <button type="submit" class="btn btn-primary" style="padding: 12px 32px; font-size: 14px; background: #ff0000; border-color: #ff0000;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      Save Settings
    </button>
  </div>

</form>

<script>
async function testEvent(eventType, btn) {
  const orig = btn.textContent;
  btn.textContent = 'Sending...';
  btn.disabled = true;
  try {
    const res = await fetch(`/dashboard/youtube-chatbot/test/${eventType}`, { method: 'POST' });
    const data = await res.json();
    if (data.ok && data.chatSent) {
      btn.textContent = 'Overlay + Chat sent!';
    } else if (data.ok) {
      btn.textContent = 'Overlay sent!';
    } else {
      btn.textContent = 'Error';
    }
  } catch (e) {
    btn.textContent = 'Error';
  }
  setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2500);
}

const sampleData = {
  superchat: { username: 'TestViewer', amount: '$10.00', message: 'Great stream!' },
  member: { username: 'NewFan', level: 'Member' },
  giftmember: { username: 'GenerousViewer', amount: '5', level: 'Member' },
};

function previewMessage(type) {
  const textarea = document.querySelector(`textarea[name="yt_chat_${type}_template"]`);
  if (!textarea) return;

  let message = textarea.value || '(empty template)';
  const data = sampleData[type];
  for (const [key, value] of Object.entries(data)) {
    message = message.replace(new RegExp(`\\{${key}\\}`, 'g'), value);
  }

  // Remove existing preview if any
  const existing = textarea.parentElement.parentElement.querySelector('.chat-preview');
  if (existing) existing.remove();

  const preview = document.createElement('div');
  preview.className = 'chat-preview';
  preview.style.cssText = 'margin-top: 10px; padding: 10px 14px; background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 13px; color: var(--text-primary); display: flex; align-items: flex-start; gap: 8px;';
  preview.innerHTML = `<span style="color: var(--text-muted); font-size: 12px; flex-shrink: 0;">Preview:</span><span>${message.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</span>`;

  // Insert after the test buttons row
  const buttonsRow = textarea.closest('[style*="padding: 18px"]') || textarea.closest('.card');
  const targetRow = buttonsRow.querySelector('[style*="justify-content: flex-end"]');
  if (targetRow) targetRow.after(preview);
}
</script>
