<%- include('header', { title: guildName + ' - Statistics', streamer: streamer }) %>

<a href="/dashboard/guild/<%= guildId %>" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Server
</a>
<h2 style="margin: 16px 0 24px; font-size: 24px; font-weight: 700;" class="animate-in"><%= guildName %> — Statistics</h2>

<!-- Period Selector -->
<div class="tab-bar animate-in animate-in-delay-1" style="max-width: 500px; margin-bottom: 28px;">
  <a href="?period=24h" class="tab-btn <%= period === '24h' ? 'active' : '' %>" style="text-decoration: none; text-align: center;">24h</a>
  <a href="?period=7d" class="tab-btn <%= period === '7d' ? 'active' : '' %>" style="text-decoration: none; text-align: center;">7 Days</a>
  <a href="?period=30d" class="tab-btn <%= period === '30d' ? 'active' : '' %>" style="text-decoration: none; text-align: center;">30 Days</a>
  <a href="?period=1y" class="tab-btn <%= period === '1y' ? 'active' : '' %>" style="text-decoration: none; text-align: center;">Year</a>
  <a href="?period=lifetime" class="tab-btn <%= period === 'lifetime' ? 'active' : '' %>" style="text-decoration: none; text-align: center;">Lifetime</a>
</div>

<!-- Overview Cards -->
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px;" class="animate-in animate-in-delay-1">
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 32px; font-weight: 800; font-family: var(--font-display); color: var(--accent);"><%= stats.total %></div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Total Sent</div>
  </div>
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 32px; font-weight: 800; font-family: var(--font-display); color: var(--success);"><%= stats.success_count %></div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Delivered</div>
  </div>
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 32px; font-weight: 800; font-family: var(--font-display); color: var(--danger);"><%= stats.fail_count %></div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Failed</div>
  </div>
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 32px; font-weight: 800; font-family: var(--font-display); color: var(--text-primary);"><%= stats.total > 0 ? Math.round(stats.success_count / stats.total * 100) : 0 %>%</div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Success Rate</div>
  </div>
</div>

<!-- Chart -->
<div class="card animate-in animate-in-delay-2" style="padding: 24px; margin-bottom: 24px;">
  <h3 style="font-size: 15px; margin-bottom: 20px;">Notifications Over Time</h3>
  <% if (chartData.length === 0) { %>
    <div style="text-align: center; padding: 40px 0; color: var(--text-muted); font-size: 14px;">
      No notifications in this period
    </div>
  <% } else { %>
    <div style="display: flex; align-items: flex-end; gap: <%= chartData.length > 30 ? '1' : '3' %>px; height: 160px;">
      <% const maxCount = Math.max(...chartData.map(d => d.count), 1); %>
      <% chartData.forEach(function(d) { %>
        <div style="flex: 1; display: flex; flex-direction: column; align-items: center; position: relative;" title="<%= d.period %>: <%= d.count %> notifications">
          <div style="width: 100%; background: var(--accent); border-radius: 3px 3px 0 0; min-height: 2px; height: <%= Math.max((d.count / maxCount) * 100, 2) %>%; opacity: <%= d.count > 0 ? 1 : 0.15 %>; transition: all 0.3s ease;"></div>
        </div>
      <% }); %>
    </div>
    <div style="display: flex; justify-content: space-between; margin-top: 8px;">
      <span style="font-size: 10px; color: var(--text-muted);"><%= chartData[0].period %></span>
      <span style="font-size: 10px; color: var(--text-muted);">Max: <%= maxCount %></span>
      <span style="font-size: 10px; color: var(--text-muted);"><%= chartData[chartData.length - 1].period %></span>
    </div>
  <% } %>
</div>

<!-- Breakdown by Feature -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;" class="animate-in animate-in-delay-3">
  <!-- Twitch Stats -->
  <div class="card" style="padding: 24px;">
    <h3 style="font-size: 15px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
      Twitch
    </h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 24px; font-weight: 700; font-family: var(--font-display); color: var(--accent);"><%= stats.live_count %></div>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">Live Alerts</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 24px; font-weight: 700; font-family: var(--font-display); color: #bf94ff;"><%= stats.clip_count %></div>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">Clips</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 24px; font-weight: 700; font-family: var(--font-display); color: #6d28d9;"><%= stats.recap_count %></div>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">Recaps</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 24px; font-weight: 700; font-family: var(--font-display); color: #f1c40f;"><%= stats.milestone_count %></div>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">Milestones</div>
      </div>
    </div>
    <div style="margin-top: 12px; font-size: 12px; color: var(--text-muted);">
      Watching <strong style="color: var(--text-primary);"><%= twitchCount %></strong> channel<%= twitchCount !== 1 ? 's' : '' %>
    </div>
  </div>

  <!-- YouTube Stats -->
  <div class="card" style="padding: 24px;">
    <h3 style="font-size: 15px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#f04438"/></svg>
      YouTube
    </h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 24px; font-weight: 700; font-family: var(--font-display); color: #f04438;"><%= stats.youtube_video_count %></div>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">Videos</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 24px; font-weight: 700; font-family: var(--font-display); color: #ff6b6b;"><%= stats.youtube_live_count %></div>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">Live</div>
      </div>
    </div>
    <div style="margin-top: 12px; font-size: 12px; color: var(--text-muted);">
      Watching <strong style="color: var(--text-primary);"><%= youtubeCount %></strong> channel<%= youtubeCount !== 1 ? 's' : '' %>
    </div>
  </div>
</div>

<!-- Community Features -->
<div class="card animate-in animate-in-delay-4" style="padding: 24px; margin-bottom: 24px;">
  <h3 style="font-size: 15px; margin-bottom: 16px;">Community Features</h3>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
    <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border); display: flex; align-items: center; gap: 12px;">
      <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(52,152,219,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3498db" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </div>
      <div>
        <div style="font-size: 20px; font-weight: 700; font-family: var(--font-display); color: #3498db;"><%= stats.digest_count %></div>
        <div style="font-size: 11px; color: var(--text-muted);">Weekly Digests</div>
      </div>
    </div>
    <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border); display: flex; align-items: center; gap: 12px;">
      <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(241,196,15,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f1c40f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      </div>
      <div>
        <div style="font-size: 20px; font-weight: 700; font-family: var(--font-display); color: #f1c40f;"><%= stats.milestone_count %></div>
        <div style="font-size: 11px; color: var(--text-muted);">Milestones</div>
      </div>
    </div>
  </div>
</div>

<style>
  @media (max-width: 640px) {
    div[style*="grid-template-columns: repeat(4, 1fr)"] { grid-template-columns: repeat(2, 1fr) !important; }
    div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>

<%- include('footer') %>
