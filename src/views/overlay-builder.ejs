<script>
// ─── Theme Popup ─────────────────────────────────────────────
let themeBackup = {};
function openThemePopup() {
  const d = workingDesigns[currentType];
  themeBackup = {
    bg: document.getElementById('ctrl-bg-color').value,
    accent: document.getElementById('ctrl-accent-color').value,
    border: document.getElementById('ctrl-border-color').value,
    text: document.getElementById('ctrl-text-color').value,
    bg_opacity: d.bg_opacity != null ? d.bg_opacity : 1.0,
    gradient_direction: d.gradient_direction || '160deg',
    border_thickness: d.border_thickness != null ? d.border_thickness : 2,
    border_opacity: d.border_opacity != null ? d.border_opacity : 0.5,
    glow_intensity: d.glow_intensity != null ? d.glow_intensity : 0.25,
    shadow_opacity: d.shadow_opacity != null ? d.shadow_opacity : 0.6,
    shadow_blur: d.shadow_blur != null ? d.shadow_blur : 32,
    shadow_spread: d.shadow_spread != null ? d.shadow_spread : 0,
  };
  document.getElementById('modal-bg-color').value = themeBackup.bg;
  document.getElementById('modal-bg-hex').value = themeBackup.bg;
  document.getElementById('modal-accent-color').value = themeBackup.accent;
  document.getElementById('modal-accent-hex').value = themeBackup.accent;
  document.getElementById('modal-border-color').value = themeBackup.border;
  document.getElementById('modal-border-hex').value = themeBackup.border;
  document.getElementById('modal-text-color').value = themeBackup.text;
  document.getElementById('modal-text-hex').value = themeBackup.text;
  // Advanced controls
  document.getElementById('modal-bg-opacity').value = themeBackup.bg_opacity;
  document.getElementById('modal-val-bg-opacity').textContent = Math.round(themeBackup.bg_opacity * 100) + '%';
  document.getElementById('modal-gradient-direction').value = themeBackup.gradient_direction;
  document.getElementById('modal-border-thickness').value = themeBackup.border_thickness;
  document.getElementById('modal-val-border-thickness').textContent = themeBackup.border_thickness + 'px';
  document.getElementById('modal-border-opacity').value = themeBackup.border_opacity;
  document.getElementById('modal-val-border-opacity').textContent = Math.round(themeBackup.border_opacity * 100) + '%';
  document.getElementById('modal-glow-intensity').value = themeBackup.glow_intensity;
  document.getElementById('modal-val-glow-intensity').textContent = Math.round(themeBackup.glow_intensity * 100) + '%';
  document.getElementById('modal-shadow-opacity').value = themeBackup.shadow_opacity;
  document.getElementById('modal-val-shadow-opacity').textContent = Math.round(themeBackup.shadow_opacity * 100) + '%';
  document.getElementById('modal-shadow-blur').value = themeBackup.shadow_blur;
  document.getElementById('modal-val-shadow-blur').textContent = themeBackup.shadow_blur + 'px';
  document.getElementById('modal-shadow-spread').value = themeBackup.shadow_spread;
  document.getElementById('modal-val-shadow-spread').textContent = themeBackup.shadow_spread + 'px';
  updateThemePreview();
  document.getElementById('theme-modal').classList.add('visible');
}
function closeThemePopup() {
  document.getElementById('theme-modal').classList.remove('visible');
}
function updateThemePreview() {
  const bg = document.getElementById('modal-bg-color').value;
  const accent = document.getElementById('modal-accent-color').value;
  const border = document.getElementById('modal-border-color').value;
  const text = document.getElementById('modal-text-color').value;
  const bgOpacity = parseFloat(document.getElementById('modal-bg-opacity').value);
  const gradDir = document.getElementById('modal-gradient-direction').value;
  const borderThick = parseInt(document.getElementById('modal-border-thickness').value);
  const borderOpacity = parseFloat(document.getElementById('modal-border-opacity').value);
  const glowIntensity = parseFloat(document.getElementById('modal-glow-intensity').value);
  const shadowOpacity = parseFloat(document.getElementById('modal-shadow-opacity').value);
  const shadowBlur = parseInt(document.getElementById('modal-shadow-blur').value);
  const shadowSpread = parseInt(document.getElementById('modal-shadow-spread').value);

  const card = document.getElementById('theme-preview-card');
  const dark = darken(bg);
  const [r,g,b] = hexToRgb(bg);

  // Background
  if (gradDir) {
    card.style.background = `linear-gradient(${gradDir}, rgba(${Math.round(r*0.35)},${Math.round(g*0.35)},${Math.round(b*0.35)},${bgOpacity}), rgba(${r},${g},${b},${bgOpacity}) 40%, rgba(${Math.round(r*0.35)},${Math.round(g*0.35)},${Math.round(b*0.35)},${bgOpacity}))`;
  } else {
    card.style.background = `rgba(${r},${g},${b},${bgOpacity})`;
  }

  // Border
  const [br,bg2,bb] = hexToRgb(border);
  card.style.border = `${borderThick}px solid rgba(${br},${bg2},${bb},${borderOpacity})`;

  // Shadow
  const [gr,gg,gb] = hexToRgb(border);
  card.style.boxShadow = glowIntensity > 0
    ? `0 ${shadowBlur/4}px ${shadowBlur}px ${shadowSpread}px rgba(${gr},${gg},${gb},${glowIntensity}), 0 4px 24px rgba(0,0,0,${shadowOpacity})`
    : `0 4px ${shadowBlur}px ${shadowSpread}px rgba(0,0,0,${shadowOpacity})`;

  // Text
  card.querySelector('div:first-child').style.color = accent;
  document.getElementById('theme-preview-username').style.color = text;
  card.querySelector('div:last-child').style.color = text;
}
function applyTheme() {
  const d = workingDesigns[currentType];
  document.getElementById('ctrl-bg-color').value = document.getElementById('modal-bg-color').value;
  document.getElementById('ctrl-accent-color').value = document.getElementById('modal-accent-color').value;
  document.getElementById('ctrl-border-color').value = document.getElementById('modal-border-color').value;
  document.getElementById('ctrl-text-color').value = document.getElementById('modal-text-color').value;
  // Advanced properties
  d.bg_opacity = parseFloat(document.getElementById('modal-bg-opacity').value);
  d.gradient_direction = document.getElementById('modal-gradient-direction').value;
  d.border_thickness = parseInt(document.getElementById('modal-border-thickness').value);
  d.border_opacity = parseFloat(document.getElementById('modal-border-opacity').value);
  d.glow_intensity = parseFloat(document.getElementById('modal-glow-intensity').value);
  d.shadow_opacity = parseFloat(document.getElementById('modal-shadow-opacity').value);
  d.shadow_blur = parseInt(document.getElementById('modal-shadow-blur').value);
  d.shadow_spread = parseInt(document.getElementById('modal-shadow-spread').value);
  // Update swatches
  document.getElementById('swatch-bg').style.background = document.getElementById('modal-bg-color').value;
  document.getElementById('swatch-accent').style.background = document.getElementById('modal-accent-color').value;
  unsavedChanges = true;
  updatePreview();
  closeThemePopup();
}

// Sync color pickers with hex inputs in theme modal
['bg', 'accent', 'border', 'text'].forEach(key => {
  document.getElementById('modal-' + key + '-color').addEventListener('input', function() {
    document.getElementById('modal-' + key + '-hex').value = this.value;
    updateThemePreview();
  });
});

// Theme presets in modal
document.querySelectorAll('#theme-modal .theme-preset').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('modal-bg-color').value = btn.dataset.bg;
    document.getElementById('modal-bg-hex').value = btn.dataset.bg;
    document.getElementById('modal-accent-color').value = btn.dataset.accent;
    document.getElementById('modal-accent-hex').value = btn.dataset.accent;
    document.getElementById('modal-border-color').value = btn.dataset.border;
    document.getElementById('modal-border-hex').value = btn.dataset.border;
    document.getElementById('modal-text-color').value = btn.dataset.text;
    document.getElementById('modal-text-hex').value = btn.dataset.text;
    updateThemePreview();
  });
});

// ─── Text & Font Popup (Tabbed) ──────────────────────────────
let textBackup = {};
const FONT_LIST = [
  { name: 'System Default', family: '-apple-system, BlinkMacSystemFont, sans-serif' },
  { name: 'Outfit', family: "'Outfit', sans-serif" },
  { name: 'Inter', family: "'Inter', sans-serif" },
  { name: 'Poppins', family: "'Poppins', sans-serif" },
  { name: 'Roboto Mono', family: "'Roboto Mono', monospace" },
  { name: 'Press Start 2P', family: "'Press Start 2P', cursive", sampleSize: '12px' },
  { name: 'Permanent Marker', family: "'Permanent Marker', cursive" },
  { name: 'Bangers', family: "'Bangers', cursive" },
];

// Per-tab selected fonts
const modalFonts = { label: 'System Default', username: 'System Default', detail: 'System Default' };

function buildFontGallery(containerId, tabKey) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  FONT_LIST.forEach(f => {
    const div = document.createElement('div');
    div.className = 'font-gallery-item' + (modalFonts[tabKey] === f.name ? ' selected' : '');
    div.dataset.font = f.name;
    div.innerHTML = `<div class="font-name">${f.name}</div><div class="font-sample" style="font-family:${f.family};${f.sampleSize ? 'font-size:'+f.sampleSize+';' : ''}">The quick brown fox</div>`;
    div.addEventListener('click', () => {
      container.querySelectorAll('.font-gallery-item').forEach(i => i.classList.remove('selected'));
      div.classList.add('selected');
      modalFonts[tabKey] = f.name;
      if (f.name !== 'System Default') loadGoogleFont(f.name);
      updateTextPreview();
    });
    container.appendChild(div);
  });
}

function switchTextTab(tab) {
  document.querySelectorAll('.text-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
  ['label', 'username', 'detail'].forEach(t => {
    document.getElementById('tab-' + t).style.display = t === tab ? '' : 'none';
  });
}

function setTextAlign(align) {
  document.querySelectorAll('.text-align-btn').forEach(b => b.classList.toggle('active', b.dataset.align === align));
  modalTextAlign = align;
  updateTextPreview();
}

let modalTextAlign = 'center';

function openTextPopup() {
  const d = workingDesigns[currentType];
  // Backup for cancel
  textBackup = JSON.parse(JSON.stringify({
    event_label: d.event_label, detail_text: d.detail_text, font_family: d.font_family, username_size: d.username_size,
    label_font_family: d.label_font_family, label_font_size: d.label_font_size, label_font_weight: d.label_font_weight, label_color: d.label_color,
    username_font_family: d.username_font_family, username_font_weight: d.username_font_weight, username_color: d.username_color,
    detail_font_family: d.detail_font_family, detail_font_size: d.detail_font_size, detail_font_weight: d.detail_font_weight, detail_color: d.detail_color,
    text_align: d.text_align,
  }));

  // Populate label tab
  document.getElementById('modal-event-label').value = d.event_label || '';
  document.getElementById('modal-label-color').value = d.label_color || d.accent_color || '#8888cc';
  document.getElementById('modal-label-weight').value = d.label_font_weight || 700;
  document.getElementById('modal-label-size').value = d.label_font_size || 10;
  document.getElementById('modal-val-label-size').textContent = (d.label_font_size || 10) + 'px';
  modalFonts.label = d.label_font_family || d.font_family || 'System Default';

  // Populate username tab
  document.getElementById('modal-username-color').value = d.username_color || d.text_color || '#ffffff';
  document.getElementById('modal-username-weight').value = d.username_font_weight || 800;
  document.getElementById('modal-username-size').value = d.username_size || 24;
  document.getElementById('modal-val-username-size').textContent = (d.username_size || 24) + 'px';
  modalFonts.username = d.username_font_family || d.font_family || 'System Default';

  // Populate detail tab
  document.getElementById('modal-detail-text').value = d.detail_text || '';
  document.getElementById('modal-detail-color').value = d.detail_color || d.text_color || '#ffffff';
  document.getElementById('modal-detail-weight').value = d.detail_font_weight || 400;
  document.getElementById('modal-detail-size').value = d.detail_font_size || 13;
  document.getElementById('modal-val-detail-size').textContent = (d.detail_font_size || 13) + 'px';
  modalFonts.detail = d.detail_font_family || d.font_family || 'System Default';

  // Alignment
  modalTextAlign = d.text_align || 'center';
  document.querySelectorAll('.text-align-btn').forEach(b => b.classList.toggle('active', b.dataset.align === modalTextAlign));

  // Build font galleries
  buildFontGallery('font-gallery-label', 'label');
  buildFontGallery('font-gallery-username', 'username');
  buildFontGallery('font-gallery-detail', 'detail');

  // Reset to first tab
  switchTextTab('label');

  updateTextPreview();
  document.getElementById('text-modal').classList.add('visible');
}

function closeTextPopup() {
  document.getElementById('text-modal').classList.remove('visible');
}

function updateTextPreview() {
  const card = document.getElementById('text-preview-card');
  const d = workingDesigns[currentType];
  card.style.background = d.bg_color;
  card.style.borderColor = d.border_color;
  card.style.textAlign = modalTextAlign;

  // Label
  const labelEl = document.getElementById('text-preview-label');
  const labelText = document.getElementById('modal-event-label').value || d.event_label || EVENT_DEFAULTS[currentType]?.event_label || 'New Follower';
  labelEl.textContent = labelText;
  labelEl.style.color = document.getElementById('modal-label-color').value;
  labelEl.style.fontWeight = document.getElementById('modal-label-weight').value;
  labelEl.style.fontSize = document.getElementById('modal-label-size').value + 'px';
  labelEl.style.fontFamily = resolveFont(modalFonts.label);

  // Username
  const un = document.getElementById('text-preview-username');
  un.style.color = document.getElementById('modal-username-color').value;
  un.style.fontWeight = document.getElementById('modal-username-weight').value;
  un.style.fontSize = document.getElementById('modal-username-size').value + 'px';
  un.style.fontFamily = resolveFont(modalFonts.username);

  // Detail
  const detailEl = document.getElementById('text-preview-detail');
  const detailText = document.getElementById('modal-detail-text').value || d.detail_text || 'just joined the race';
  detailEl.textContent = detailText;
  detailEl.style.color = document.getElementById('modal-detail-color').value;
  detailEl.style.fontWeight = document.getElementById('modal-detail-weight').value;
  detailEl.style.fontSize = document.getElementById('modal-detail-size').value + 'px';
  detailEl.style.fontFamily = resolveFont(modalFonts.detail);
}

function applyText() {
  const d = workingDesigns[currentType];

  // Text content
  d.event_label = document.getElementById('modal-event-label').value;
  document.getElementById('ctrl-event-label').value = d.event_label;
  d.detail_text = document.getElementById('modal-detail-text').value;
  document.getElementById('ctrl-detail-text').value = d.detail_text;

  // Label styling
  d.label_font_family = modalFonts.label === 'System Default' ? null : modalFonts.label;
  d.label_font_size = parseInt(document.getElementById('modal-label-size').value);
  d.label_font_weight = parseInt(document.getElementById('modal-label-weight').value);
  d.label_color = document.getElementById('modal-label-color').value;

  // Username styling
  d.username_size = parseInt(document.getElementById('modal-username-size').value);
  document.getElementById('ctrl-username-size').value = d.username_size;
  d.username_font_family = modalFonts.username === 'System Default' ? null : modalFonts.username;
  d.username_font_weight = parseInt(document.getElementById('modal-username-weight').value);
  d.username_color = document.getElementById('modal-username-color').value;

  // Detail styling
  d.detail_font_family = modalFonts.detail === 'System Default' ? null : modalFonts.detail;
  d.detail_font_size = parseInt(document.getElementById('modal-detail-size').value);
  d.detail_font_weight = parseInt(document.getElementById('modal-detail-weight').value);
  d.detail_color = document.getElementById('modal-detail-color').value;

  // Alignment
  d.text_align = modalTextAlign;

  // Legacy font_family = username font for backward compat
  d.font_family = modalFonts.username === 'System Default' ? 'System Default' : modalFonts.username;
  const fontSpan = document.getElementById('font-picker-selected').querySelector('span');
  fontSpan.textContent = d.font_family;
  fontSpan.style.fontFamily = resolveFont(d.font_family);

  unsavedChanges = true;
  updatePreview();
  updateTextSectionPreview(d);
  closeTextPopup();
}

// Update the inline preview in the Text & Font section
function updateTextSectionPreview(d) {
  const preview = document.getElementById('text-section-preview');
  if (!preview) return;
  preview.style.textAlign = d.text_align || 'center';

  const labelEl = document.getElementById('tsp-label');
  labelEl.textContent = d.event_label || EVENT_DEFAULTS[currentType]?.event_label || 'Label';
  labelEl.style.color = d.label_color || d.accent_color;
  labelEl.style.fontFamily = resolveFont(d.label_font_family || d.font_family);
  labelEl.style.fontSize = (d.label_font_size || 10) + 'px';
  labelEl.style.fontWeight = d.label_font_weight || 700;

  const usernameEl = document.getElementById('tsp-username');
  usernameEl.style.color = d.username_color || d.text_color;
  usernameEl.style.fontFamily = resolveFont(d.username_font_family || d.font_family);
  usernameEl.style.fontSize = (d.username_size || 24) + 'px';
  usernameEl.style.fontWeight = d.username_font_weight || 800;

  const detailEl = document.getElementById('tsp-detail');
  detailEl.textContent = d.detail_text || getDetailPreviewText(currentType) || 'detail text';
  detailEl.style.color = d.detail_color || d.text_color;
  detailEl.style.fontFamily = resolveFont(d.detail_font_family || d.font_family);
  detailEl.style.fontSize = (d.detail_font_size || 13) + 'px';
  detailEl.style.fontWeight = d.detail_font_weight || 400;
}

// Run initial text section preview now that this function is defined
updateTextSectionPreview(workingDesigns[currentType]);

// ─── Animation Popup ─────────────────────────────────────────
const ENTRANCE_LABELS = { slideDown:'Slide Down', slideUp:'Slide Up', slideLeft:'Slide Left', slideRight:'Slide Right', zoomIn:'Zoom In', fadeIn:'Fade In' };
const CAR_LABELS = { zoomLR:'🏎️ Car L→R', zoomRL:'🏎️ Car R→L', checkered:'🏁 Checkered', flames:'🔥 Flames', sparkles:'✨ Sparkles', lightning:'⚡ Lightning', neonSweep:'💡 Neon Sweep', equalizer:'🎵 Equalizer', pulse:'💓 Pulse', none:'None' };
const EFFECT_LABELS = { default:'Default', none:'None', confetti:'Confetti', gold:'Gold Rain', money:'Money Rain', robots:'Robots', tiremarks:'Tire Marks' };

let animBackup = {};

function openAnimPopup() {
  const d = workingDesigns[currentType];
  animBackup = {
    entrance_animation: d.entrance_animation,
    car_animation: d.car_animation,
    screen_effect: d.screen_effect,
    animation_speed: d.animation_speed,
    effect_amount: d.effect_amount,
    effect_size: d.effect_size,
  };
  document.getElementById('modal-entrance-animation').value = d.entrance_animation || 'slideDown';
  document.getElementById('modal-car-animation').value = d.car_animation || 'zoomLR';
  document.getElementById('modal-screen-effect').value = d.screen_effect || 'default';
  document.getElementById('modal-animation-speed').value = d.animation_speed || 1.0;
  document.getElementById('modal-val-speed').textContent = parseFloat(d.animation_speed || 1.0).toFixed(1) + '×';
  document.getElementById('modal-effect-amount').value = d.effect_amount || 1.0;
  document.getElementById('modal-val-amount').textContent = parseFloat(d.effect_amount || 1.0).toFixed(1) + '×';
  document.getElementById('modal-effect-size').value = d.effect_size || 1.0;
  document.getElementById('modal-val-size').textContent = parseFloat(d.effect_size || 1.0).toFixed(1) + '×';
  document.getElementById('modal-effect-direction').value = d.effect_direction || 'down';

  // Update popup card to match current event type
  const label = d.event_label || EVENT_DEFAULTS[currentType]?.event_label || 'Alert';
  const username = PREVIEW_USERNAMES[currentType] || 'RacerName';
  const detail = getDetailPreviewText(currentType) || '';
  document.getElementById('anim-card-label').textContent = label;
  document.getElementById('anim-card-label').style.color = d.accent_color || '#8888cc';
  document.getElementById('anim-card-username').textContent = username;
  document.getElementById('anim-card-detail').textContent = detail;
  // Update card colors
  const cardEl = document.getElementById('anim-preview-card');
  const dark = darken(d.bg_color || '#1a1a3e');
  cardEl.style.background = `linear-gradient(160deg, ${dark}, ${d.bg_color || '#1a1a3e'} 40%, ${dark})`;
  cardEl.style.borderColor = hexToRgba(d.border_color || '#8888cc', 0.5);

  updateAnimPreview();
  updateAnimPopupBottomPreview();
  document.getElementById('anim-modal').classList.add('visible');
  switchAnimTab('card');
  // Auto-play entrance on open
  setTimeout(() => playAnimPreviewEntrance(), 200);
}

function closeAnimPopup() {
  document.getElementById('anim-modal').classList.remove('visible');
}

function switchAnimTab(tab) {
  document.querySelectorAll('.anim-tab').forEach(b => {
    const isActive = b.dataset.animTab === tab;
    b.style.background = isActive ? 'var(--accent)' : 'transparent';
    b.style.color = isActive ? '#fff' : 'var(--text-secondary)';
    b.classList.toggle('active', isActive);
  });
  document.getElementById('anim-tab-card').style.display = tab === 'card' ? '' : 'none';
  document.getElementById('anim-tab-canvas').style.display = tab === 'canvas' ? '' : 'none';
}

function updateAnimPopupBottomPreview() {
  const track = document.getElementById('anim-preview-track');
  const popupCard = document.getElementById('anim-preview-card');
  if (!track) return;
  const anim = document.getElementById('modal-car-animation').value;
  const speed = parseFloat(document.getElementById('modal-animation-speed').value) || 1.0;
  const d = workingDesigns[currentType] || {};
  const accent = d.accent_color || '#8888cc';
  if (anim === 'none') {
    track.style.display = 'none';
    if (popupCard) popupCard.querySelectorAll('.card-anim-overlay').forEach(e => e.remove());
  } else {
    buildPreviewBottomAnimation(track, anim, speed, accent, popupCard);
  }
}

function updateAnimPreview() {
  // Update the mini effect preview
  const box = document.getElementById('anim-preview-box');
  box.querySelectorAll('.anim-fx').forEach(e => e.remove());

  const effect = document.getElementById('modal-screen-effect').value;
  const speed = parseFloat(document.getElementById('modal-animation-speed').value) || 1.0;
  const amount = parseFloat(document.getElementById('modal-effect-amount').value) || 1.0;
  const size = parseFloat(document.getElementById('modal-effect-size').value) || 1.0;
  const dir = document.getElementById('modal-effect-direction').value || 'down';
  const aName = 'fxFall' + dir.charAt(0).toUpperCase() + dir.slice(1);

  let resolved = effect;
  if (resolved === 'default') {
    const defaults = { follow:'tiremarks', subscription:'confetti', bits:'gold', donation:'money', raid:'robots', yt_superchat:'gold', yt_member:'confetti', yt_giftmember:'money' };
    resolved = defaults[currentType] || 'none';
  }
  if (resolved === 'none') return;

  // Ensure keyframes exist
  ensureFxKeyframes();

  function mfxPos() {
    if (dir === 'down') return `left:${Math.random()*100}%;top:-5%;`;
    if (dir === 'up') return `left:${Math.random()*100}%;bottom:-5%;`;
    if (dir === 'left') return `top:${Math.random()*100}%;right:-5%;`;
    if (dir === 'right') return `top:${Math.random()*100}%;left:-5%;`;
    return `left:${Math.random()*100}%;top:-5%;`;
  }

  const fxContainer = document.createElement('div');
  fxContainer.className = 'anim-fx';
  fxContainer.style.cssText = 'position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:5;';

  const colors = ['#f7c948','#ff6b35','#00ff88','#9146ff','#ff4444','#4285f4','#fff'];
  const goldIcons = ['🪙','💎','⭐','🏆','✨'];
  const moneyIcons = ['💵','💰','💲','🪙','💸'];

  if (resolved === 'confetti') {
    const count = Math.round(20 * amount);
    for (let i = 0; i < count; i++) {
      const c = document.createElement('div');
      const w = (4 + Math.random()*4) * size;
      c.style.cssText = `position:absolute;width:${w}px;height:${w*1.3}px;border-radius:${Math.random()>0.5?'50%':'1px'};background:${colors[Math.floor(Math.random()*colors.length)]};${mfxPos()}opacity:0;animation:${aName} ${(1.5+Math.random()*2)/speed}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(c);
    }
  } else if (resolved === 'gold') {
    const count = Math.round(12 * amount);
    for (let i = 0; i < count; i++) {
      const g = document.createElement('div');
      g.textContent = goldIcons[Math.floor(Math.random()*goldIcons.length)];
      g.style.cssText = `position:absolute;font-size:${10*size}px;${mfxPos()}opacity:0;animation:${aName} ${(2+Math.random()*2)/speed}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(g);
    }
  } else if (resolved === 'money') {
    const count = Math.round(12 * amount);
    for (let i = 0; i < count; i++) {
      const m = document.createElement('div');
      m.textContent = moneyIcons[Math.floor(Math.random()*moneyIcons.length)];
      m.style.cssText = `position:absolute;font-size:${10*size}px;${mfxPos()}opacity:0;animation:${aName} ${(2+Math.random()*2)/speed}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(m);
    }
  } else if (resolved === 'robots') {
    const count = Math.round(8 * amount);
    for (let i = 0; i < count; i++) {
      const r = document.createElement('div');
      r.textContent = '🤖';
      r.style.cssText = `position:absolute;font-size:${(8+Math.random()*6)*size}px;${mfxPos()}opacity:0;animation:${aName} ${(2+Math.random()*2)/speed}s linear ${Math.random()*3}s infinite;`;
      fxContainer.appendChild(r);
    }
  } else if (resolved === 'tiremarks') {
    for (let i = 0; i < 2; i++) {
      const t = document.createElement('div');
      t.style.cssText = `position:absolute;height:${2*size}px;left:0;right:0;top:${48+i*3}%;background:linear-gradient(90deg,transparent,rgba(136,136,204,0.2),transparent);animation:fxTire ${2.5/speed}s ease-in-out infinite;`;
      fxContainer.appendChild(t);
    }
  }

  box.appendChild(fxContainer);
}

function playAnimPreviewEntrance() {
  const card = document.getElementById('anim-preview-card');
  const entrance = document.getElementById('modal-entrance-animation').value;
  const speed = parseFloat(document.getElementById('modal-animation-speed').value) || 1.0;
  const dur = (0.5 / speed).toFixed(2) + 's';

  card.style.opacity = '0';
  card.style.animation = 'none';
  setTimeout(() => {
    card.style.animation = `anim-${entrance} ${dur} ease-out forwards`;
    card.style.opacity = '';
  }, 50);
}

function applyAnim() {
  const d = workingDesigns[currentType];
  d.entrance_animation = document.getElementById('modal-entrance-animation').value;
  d.car_animation = document.getElementById('modal-car-animation').value;
  d.screen_effect = document.getElementById('modal-screen-effect').value;
  d.animation_speed = parseFloat(document.getElementById('modal-animation-speed').value);
  d.effect_amount = parseFloat(document.getElementById('modal-effect-amount').value);
  d.effect_size = parseFloat(document.getElementById('modal-effect-size').value);
  d.effect_direction = document.getElementById('modal-effect-direction').value;

  // Sync to hidden controls
  document.getElementById('ctrl-entrance-animation').value = d.entrance_animation;
  document.getElementById('ctrl-car-animation').value = d.car_animation;
  document.getElementById('ctrl-screen-effect').value = d.screen_effect;
  document.getElementById('ctrl-animation-speed').value = d.animation_speed;
  document.getElementById('ctrl-effect-amount').value = d.effect_amount;
  document.getElementById('ctrl-effect-size').value = d.effect_size;
  document.getElementById('ctrl-effect-direction').value = d.effect_direction;

  unsavedChanges = true;
  updateAnimSectionPreview(d);
  updatePreview();
  closeAnimPopup();
}

const DIR_LABELS = { down:'Down', up:'Up', left:'Left', right:'Right' };

function updateAnimSectionPreview(d) {
  document.getElementById('asp-entrance').textContent = ENTRANCE_LABELS[d.entrance_animation] || 'Slide Down';
  document.getElementById('asp-car').textContent = CAR_LABELS[d.car_animation] || 'L→R';
  document.getElementById('asp-effect').textContent = EFFECT_LABELS[d.screen_effect] || 'Default';
  document.getElementById('asp-speed').textContent = parseFloat(d.animation_speed || 1.0).toFixed(1) + '×';
  document.getElementById('asp-amount').textContent = parseFloat(d.effect_amount || 1.0).toFixed(1) + '×';
  document.getElementById('asp-size').textContent = parseFloat(d.effect_size || 1.0).toFixed(1) + '×';
  document.getElementById('asp-direction').textContent = DIR_LABELS[d.effect_direction] || 'Down';
}

// Initial animation section preview
updateAnimSectionPreview(workingDesigns[currentType]);
</script>

</body>
</html>
