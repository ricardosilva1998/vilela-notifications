<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Overlay Builder — Atleta</title>
  <link rel="icon" type="image/png" href="/app-icon/honest_graphic-running-athlete-9715727.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link id="google-fonts-base" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <link id="google-fonts-custom" href="" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Outfit&family=Inter&family=Poppins&family=Roboto+Mono&family=Press+Start+2P&family=Permanent+Marker&family=Bangers&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-base: #0c0d14;
      --bg-surface: #141520;
      --bg-elevated: #1a1b2e;
      --bg-hover: #1f2037;
      --border: rgba(255,255,255,0.06);
      --border-focus: rgba(145,70,255,0.4);
      --text-primary: #e8e6f0;
      --text-secondary: #8b8a9e;
      --text-muted: #5c5b6e;
      --accent: #9146ff;
      --accent-glow: rgba(145,70,255,0.15);
      --accent-hover: #a56bff;
      --discord: #5865F2;
      --success: #3ecf8e;
      --danger: #f04438;
      --warning: #f79009;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --font-display: 'Outfit', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --panel-width: 340px;
      --header-height: 56px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: var(--font-body);
      background: var(--bg-base);
      color: var(--text-primary);
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }
    h1,h2,h3,h4,h5,h6 { font-family: var(--font-display); letter-spacing: -0.02em; }

    /* ── Top nav ── */
    .top-nav {
      height: var(--header-height);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 20px;
      gap: 16px;
      background: var(--bg-surface);
      flex-shrink: 0;
      z-index: 100;
    }
    .top-nav .back-link {
      display: flex; align-items: center; gap: 6px;
      color: var(--text-secondary); text-decoration: none;
      font-size: 13px; font-family: var(--font-display); font-weight: 500;
      transition: color 0.2s;
    }
    .top-nav .back-link:hover { color: var(--text-primary); }
    .top-nav .sep { color: var(--text-muted); }
    .top-nav h1 { font-size: 15px; font-weight: 700; color: var(--text-primary); }
    .top-nav .spacer { flex: 1; }
    .top-nav .overlay-url-row { display: flex; align-items: center; gap: 8px; }
    .top-nav .overlay-url-row input {
      width: 280px; padding: 6px 10px; font-size: 11px; font-family: monospace;
      background: var(--bg-elevated); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text-secondary);
    }
    .top-nav .overlay-url-row .copy-btn {
      padding: 6px 12px; font-size: 12px; font-family: var(--font-display);
      font-weight: 600; background: var(--bg-elevated); border: 1px solid var(--border);
      color: var(--text-secondary); border-radius: var(--radius-sm); cursor: pointer;
      transition: all 0.2s;
    }
    .top-nav .overlay-url-row .copy-btn:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Layout ── */
    .builder-layout {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* ── Left panel ── */
    .left-panel {
      width: var(--panel-width);
      flex-shrink: 0;
      background: var(--bg-surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Event tabs */
    .event-tabs {
      flex-shrink: 0;
    }
    .event-tabs-section { padding: 14px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); background: rgba(0,0,0,0.2); }
    .event-tabs-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: #666; margin-bottom: 6px; margin-top: 10px; font-family: var(--font-display); }
    .event-tabs-label:first-child { margin-top: 0; }
    .event-tabs-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-bottom: 4px; }
    .event-tab {
      padding: 6px 4px; font-size: 11px; font-weight: 600;
      font-family: var(--font-display); cursor: pointer;
      background: var(--bg-elevated); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text-secondary);
      text-align: center; transition: all 0.15s; user-select: none;
      display: flex; flex-direction: column; align-items: center; gap: 2px;
    }
    .event-tab:hover { border-color: rgba(145,70,255,0.3); color: var(--text-primary); }
    .event-tab.active {
      background: rgba(145,70,255,0.15); border-color: rgba(145,70,255,0.5);
      color: var(--accent);
    }

    /* Panel scrollable area */
    .panel-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 0 12px 12px;
    }
    .panel-scroll::-webkit-scrollbar { width: 4px; }
    .panel-scroll::-webkit-scrollbar-track { background: transparent; }
    .panel-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    /* Sections */
    .section {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      margin-bottom: 8px;
      overflow: hidden;
    }
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 12px; cursor: pointer; user-select: none;
      background: var(--bg-elevated); transition: background 0.15s;
    }
    .section-header:hover { background: var(--bg-hover); }
    .section-title {
      font-size: 12px; font-weight: 700; font-family: var(--font-display);
      color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.5px;
    }
    .section-chevron {
      color: var(--text-muted); transition: transform 0.2s; font-size: 10px;
    }
    .section.collapsed .section-chevron { transform: rotate(-90deg); }
    .section-body {
      padding: 12px;
      background: var(--bg-surface);
      border-top: 1px solid var(--border);
    }
    .section.collapsed .section-body { display: none; }

    /* Controls */
    .ctrl-row {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 10px;
    }
    .ctrl-row:last-child { margin-bottom: 0; }
    .ctrl-label {
      font-size: 11px; font-weight: 600; color: var(--text-secondary);
      font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.3px;
    }
    .ctrl-label small { display: block; font-size: 10px; color: var(--text-muted); text-transform: none; letter-spacing: 0; font-weight: 400; }

    input[type="color"] {
      width: 32px; height: 32px; border-radius: 6px; border: 1px solid var(--border);
      cursor: pointer; background: none; padding: 2px;
    }
    input[type="range"] {
      accent-color: var(--accent); cursor: pointer; width: 100%;
    }
    input[type="text"], select {
      background: var(--bg-elevated); border: 1px solid var(--border);
      color: var(--text-primary); border-radius: var(--radius-sm);
      padding: 6px 8px; font-size: 12px; outline: none;
      transition: border-color 0.2s; font-family: var(--font-body);
    }
    input[type="text"]:focus, select:focus { border-color: var(--border-focus); }
    select { cursor: pointer; }

    .range-row { margin-bottom: 10px; }
    .range-row:last-child { margin-bottom: 0; }
    .range-header {
      display: flex; justify-content: space-between; margin-bottom: 4px;
    }
    .range-val {
      font-size: 11px; font-family: var(--font-display); font-weight: 700;
      color: var(--accent);
    }

    /* Color swatch row */
    .color-row {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 8px; margin-bottom: 0;
    }
    .color-item {
      display: flex; align-items: center; gap: 8px;
    }
    .color-item-label {
      font-size: 11px; color: var(--text-muted); font-family: var(--font-display);
    }

    /* Position grid */
    .position-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 4px;
    }
    .pos-cell {
      aspect-ratio: 1.5; border-radius: 4px; cursor: pointer;
      background: var(--bg-elevated); border: 1px solid var(--border);
      transition: all 0.15s; display: flex; align-items: center; justify-content: center;
    }
    .pos-cell:hover { border-color: rgba(145,70,255,0.4); }
    .pos-cell.active {
      background: rgba(145,70,255,0.2); border-color: rgba(145,70,255,0.7);
    }
    .pos-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--text-muted);
    }
    .pos-cell.active .pos-dot { background: var(--accent); }

    /* ── Right preview ── */
    .right-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: var(--bg-base);
    }

    /* Toolbar */
    .preview-toolbar {
      height: 48px;
      border-bottom: 1px solid var(--border);
      background: var(--bg-surface);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 8px;
      flex-shrink: 0;
    }
    .toolbar-btn {
      padding: 6px 14px; font-size: 12px; font-weight: 600;
      font-family: var(--font-display); border-radius: var(--radius-sm);
      cursor: pointer; border: 1px solid var(--border);
      background: var(--bg-elevated); color: var(--text-secondary);
      transition: all 0.15s; display: flex; align-items: center; gap: 6px;
    }
    .toolbar-btn:hover { border-color: rgba(145,70,255,0.4); color: var(--accent); }
    .toolbar-btn.primary {
      background: var(--accent); border-color: var(--accent); color: #fff;
    }
    .toolbar-btn.primary:hover { background: var(--accent-hover); }
    .toolbar-spacer { flex: 1; }
    .toolbar-hint {
      font-size: 11px; color: var(--text-muted); font-family: var(--font-display);
    }

    /* Preview canvas */
    .preview-canvas-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      overflow: hidden;
    }
    .preview-screen {
      width: 100%;
      max-width: 960px;
      aspect-ratio: 16/9;
      background: #080a10;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
      position: relative;
      overflow: hidden;
      box-shadow: 0 8px 48px rgba(0,0,0,0.6);
    }

    /* Fake stream elements */
    .fake-webcam {
      position: absolute; bottom: 0; left: 0;
      width: 22%; aspect-ratio: 16/9;
      background: linear-gradient(135deg, #1a1a2e, #16213e);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 4px 0 0 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; color: rgba(255,255,255,0.15);
    }
    .fake-game-bg {
      position: absolute; inset: 0;
      background: linear-gradient(160deg, #0a0e1a 0%, #0d1220 50%, #080b15 100%);
    }
    .stream-bg {
      background-size: cover;
      background-position: center;
    }
    .fake-hud-tl {
      display: none;
    }
    .fake-chat {
      position: absolute; right: 0; bottom: 0;
      width: 22%; height: 40%; background: rgba(0,0,0,0.45); padding: 8px;
      display: flex; flex-direction: column; gap: 4px; overflow: hidden;
      justify-content: flex-end; border-radius: 6px 0 0 0;
    }
    .fake-chat-msg {
      font-size: 8px; color: rgba(255,255,255,0.5);
      background: rgba(255,255,255,0.04); border-radius: 3px;
      padding: 3px 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .fake-chat-msg .chat-user { font-weight: 700; }
    .fake-chat-msg.c1 .chat-user { color: #9146ff; }
    .fake-chat-msg.c2 .chat-user { color: #00ff88; }
    .fake-chat-msg.c3 .chat-user { color: #f7c948; }
    .fake-chat-msg.c4 .chat-user { color: #ff8800; }
    .fake-chat-msg.c5 .chat-user { color: #4285f4; }
    .fake-stream-label {
      position: absolute; bottom: 8px; left: 12px;
      font-size: 8px; color: rgba(255,255,255,0.2);
      font-family: var(--font-display);
    }
    .fake-live-badge {
      position: absolute; top: 10px; right: 10px;
      background: #e00; border-radius: 3px;
      font-size: 8px; font-weight: 800; color: #fff;
      padding: 2px 5px; font-family: var(--font-display); letter-spacing: 1px;
    }

    /* The preview card container — positions it in the screen */
    .preview-card-container {
      position: absolute;
      pointer-events: auto;
      transition: all 0.3s ease;
    }
    #preview-card-container { cursor: grab; }
    #preview-card-container:active { cursor: grabbing; }
    #preview-card-container:hover .preview-alert-card,
    #preview-card-container:hover #preview-card {
      outline: 2px dashed rgba(145,71,255,0.4);
      outline-offset: 4px;
    }

    /* Preview alert card (mirrors overlay.css structure) */
    .preview-alert-card {
      width: 420px;
      border-radius: 16px;
      border: 1px solid;
      overflow: visible;
      box-shadow: 0 8px 32px rgba(136,136,204,0.25);
      transform-origin: top center;
    }
    .preview-alert-card .top-accent {
      height: 3px; border-radius: 16px 16px 0 0;
    }
    .preview-alert-card .card-body {
      padding: 14px 20px 12px;
    }
    .preview-alert-card .event-label {
      font-size: 10px; text-transform: uppercase; letter-spacing: 2px;
      font-weight: 700; margin-bottom: 4px;
    }
    .preview-alert-card .username {
      font-size: 22px; font-weight: 800; color: #fff; line-height: 1.1;
    }
    .preview-alert-card .detail {
      font-size: 13px; color: #ccc; margin-top: 4px;
    }
    .preview-alert-card .detail b { color: #fff; font-weight: 700; }
    .preview-alert-card .car-track {
      height: 44px; position: relative; overflow: hidden;
      border-top: 1px solid rgba(255,255,255,0.07);
      border-radius: 0 0 16px 16px;
    }
    .preview-alert-card .race-line {
      position: absolute; top: 50%; left: 0; right: 0;
      height: 1px; background: rgba(255,255,255,0.08); transform: translateY(-50%);
    }
    .preview-alert-card .track-car {
      position: absolute; top: 50%;
      transform: translateY(-50%) scaleX(-1); font-size: 22px;
      animation: previewCarZoom 2.8s linear infinite; z-index: 5;
    }
    @keyframes previewCarZoom {
      0%   { left: -40px; opacity: 1; }
      80%  { left: 105%;  opacity: 1; }
      81%  { opacity: 0; left: -40px; }
      100% { opacity: 0; left: -40px; }
    }
    .preview-alert-card .cup-row {
      display: flex; align-items: center; gap: 12px;
    }
    .preview-alert-card .cup {
      font-size: 26px;
      animation: cupBounce 0.6s ease-in-out infinite alternate;
    }
    @keyframes cupBounce {
      from { transform: translateY(0) scale(1); }
      to   { transform: translateY(-4px) scale(1.08); }
    }
    .preview-alert-card .card-inner { flex: 1; min-width: 0; }

    /* Entrance animations */
    @keyframes anim-slideDown {
      from { transform: translateY(-120%) scale(0.95); opacity: 0; }
      to   { transform: translateY(0) scale(1); opacity: 1; }
    }
    @keyframes anim-slideUp {
      from { transform: translateY(120%) scale(0.95); opacity: 0; }
      to   { transform: translateY(0) scale(1); opacity: 1; }
    }
    @keyframes anim-slideLeft {
      from { transform: translateX(120%) scale(0.95); opacity: 0; }
      to   { transform: translateX(0) scale(1); opacity: 1; }
    }
    @keyframes anim-slideRight {
      from { transform: translateX(-120%) scale(0.95); opacity: 0; }
      to   { transform: translateX(0) scale(1); opacity: 1; }
    }
    @keyframes anim-zoomIn {
      from { transform: scale(0.3); opacity: 0; }
      to   { transform: scale(1); opacity: 1; }
    }
    @keyframes anim-fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    .anim-playing { animation-fill-mode: both; animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1); }

    /* ── Save bar ── */
    .save-bar {
      height: 56px;
      border-top: 1px solid var(--border);
      background: var(--bg-surface);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 8px;
      flex-shrink: 0;
    }
    .save-bar .event-badge {
      font-size: 12px; font-family: var(--font-display); font-weight: 700;
      color: var(--text-secondary); background: var(--bg-elevated);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      padding: 4px 10px;
    }
    .save-bar .spacer { flex: 1; }
    .save-status {
      font-size: 12px; color: var(--success); font-family: var(--font-display);
      font-weight: 600; opacity: 0; transition: opacity 0.3s;
    }
    .save-status.visible { opacity: 1; }
    .btn {
      padding: 8px 18px; font-size: 13px; font-weight: 600;
      font-family: var(--font-display); border-radius: var(--radius-sm);
      cursor: pointer; border: 1px solid var(--border);
      transition: all 0.15s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-secondary {
      background: var(--bg-elevated); color: var(--text-secondary);
    }
    .btn-secondary:hover { border-color: rgba(145,70,255,0.4); color: var(--accent); }
    .btn-primary {
      background: var(--accent); border-color: var(--accent); color: #fff;
    }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-danger {
      background: rgba(240,68,56,0.1); border-color: rgba(240,68,56,0.3); color: var(--danger);
    }
    .btn-danger:hover { background: rgba(240,68,56,0.2); border-color: var(--danger); }

    /* Font picker */
    .font-picker { position: relative; min-width: 150px; width: 100%; }
    .font-picker-selected {
      padding: 6px 10px; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;
      color: #ccc; font-size: 12px; cursor: pointer;
      display: flex; justify-content: space-between; align-items: center;
    }
    .font-picker-selected:hover { border-color: var(--border-focus); }
    .font-picker-arrow { font-size: 10px; color: #666; }
    .font-picker-dropdown {
      display: none; position: absolute; top: 100%; left: 0; right: 0;
      background: #1a1a1e; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px; margin-top: 4px; z-index: 100;
      max-height: 200px; overflow-y: auto; box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }
    .font-picker-dropdown.open { display: block; }
    .font-option {
      padding: 8px 12px; cursor: pointer; font-size: 14px; color: #ccc;
      transition: background 0.15s;
    }
    .font-option:hover { background: rgba(145,71,255,0.1); }
  </style>
</head>
<body>

<!-- Top nav -->
<nav class="top-nav">
  <a href="/dashboard" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Dashboard
  </a>
  <span class="sep">/</span>
  <h1>Overlay Builder</h1>
  <span class="sep">/</span>
  <a href="/dashboard/overlay" style="font-size:13px;color:var(--text-secondary);font-family:var(--font-display);font-weight:500;">Settings &amp; Sounds</a>
  <div class="spacer"></div>
  <% if (overlayUrl) { %>
  <div class="overlay-url-row">
    <input type="text" value="<%= overlayUrl %>" readonly id="overlay-url-input">
    <button class="copy-btn" onclick="navigator.clipboard.writeText(document.getElementById('overlay-url-input').value); this.textContent='Copied!'; setTimeout(()=>this.textContent='Copy URL',1500);">Copy URL</button>
  </div>
  <% } %>
</nav>

<!-- Main layout -->
<div class="builder-layout">

  <!-- LEFT PANEL -->
  <div class="left-panel">
    <div class="event-tabs">
      <div class="event-tabs-section">
        <div class="event-tabs-label">Twitch</div>
        <div class="event-tabs-row">
          <div class="event-tab active" data-type="follow"><span style="font-size:16px;">🏁</span><span style="font-size:10px;">Follow</span></div>
          <div class="event-tab" data-type="subscription"><span style="font-size:16px;">🏆</span><span style="font-size:10px;">Sub</span></div>
          <div class="event-tab" data-type="bits"><span style="font-size:16px;">⛽</span><span style="font-size:10px;">Bits</span></div>
          <div class="event-tab" data-type="donation"><span style="font-size:16px;">💰</span><span style="font-size:10px;">Donation</span></div>
          <div class="event-tab" data-type="raid"><span style="font-size:16px;">🤖</span><span style="font-size:10px;">Raid</span></div>
        </div>
        <div class="event-tabs-label">YouTube</div>
        <div class="event-tabs-row">
          <div class="event-tab" data-type="yt_superchat"><span style="font-size:16px;">💬</span><span style="font-size:10px;">Super Chat</span></div>
          <div class="event-tab" data-type="yt_member"><span style="font-size:16px;">⭐</span><span style="font-size:10px;">Member</span></div>
          <div class="event-tab" data-type="yt_giftmember"><span style="font-size:16px;">🎁</span><span style="font-size:10px;">Gift</span></div>
        </div>
        <div class="event-tabs-label" style="color: #555;">Kick (coming soon)</div>
        <div class="event-tabs-label">General</div>
        <div class="event-tabs-row">
          <div class="event-tab" data-type="timed"><span style="font-size:16px;">⏰</span><span style="font-size:10px;">Timed</span></div>
        </div>
