<script>
// ─── Data setup ───────────────────────────────────────────────────────────────
const SAVED_DESIGNS = {};
const SERVER_DESIGNS = <%- designs %>;
SERVER_DESIGNS.forEach(d => { SAVED_DESIGNS[d.event_type] = d; });

const EVENT_DEFAULTS = {
  follow:        { bg_color:'#1a1a3e', accent_color:'#8888cc', border_color:'#8888cc', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'New Pit Crew Member', detail_text:'just joined the race 🏁', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  subscription:  { bg_color:'#061a10', accent_color:'#00ff88', border_color:'#00ff88', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Podium Finish',        detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  bits:          { bg_color:'#1c1200', accent_color:'#f7c948', border_color:'#f7c948', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Nitro Boost',          detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  donation:      { bg_color:'#110022', accent_color:'#bf00ff', border_color:'#bf00ff', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Sponsor Alert',        detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  raid:          { bg_color:'#1c0505', accent_color:'#ff4444', border_color:'#ff4444', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Incoming Raid',        detail_text:'', entrance_animation:'slideDown', car_animation:'none',   screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  yt_superchat:  { bg_color:'#200808', accent_color:'#ff4444', border_color:'#ff4444', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Super Chat',           detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  yt_member:     { bg_color:'#041a0c', accent_color:'#0f9d58', border_color:'#0f9d58', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'New Member',           detail_text:'', entrance_animation:'slideDown', car_animation:'none',   screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  yt_giftmember: { bg_color:'#060e20', accent_color:'#4285f4', border_color:'#4285f4', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Gift Alert',           detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  timed:         { bg_color:'#1a1a2e', accent_color:'#f79009', border_color:'#f79009', text_color:'#ffffff', font_family:'System Default', username_size:18, event_label:'', detail_text:'', entrance_animation:'slideDown', car_animation:'none', screen_effect:'none', animation_speed:1.0, card_width:500, card_position:'bot-center', border_radius:12 },
};

const EVENT_NAMES = {
  follow:'Follow', subscription:'Subscription', bits:'Bits', donation:'Donation',
  raid:'Raid', yt_superchat:'YT Super Chat', yt_member:'YT Member', yt_giftmember:'YT Gift Member',
  timed:'Timed',
};

const PREVIEW_USERNAMES = {
  follow:'StreamerFan99', subscription:'ProRacer_24', bits:'NitroQueen',
  donation:'SpeedSponsor', raid:'RaidLeader', yt_superchat:'YoutubeViewer',
  yt_member:'NewMember42', yt_giftmember:'GenerousGifter',
  timed:'TimedMessage',
};

// In-memory designs (working copy for current session)
const workingDesigns = {};
Object.keys(EVENT_DEFAULTS).forEach(t => {
  workingDesigns[t] = Object.assign({}, EVENT_DEFAULTS[t], SAVED_DESIGNS[t] || {});
});

let currentType = 'follow';
let unsavedChanges = false;

// ─── Section collapse ─────────────────────────────────────────────────────────
function toggleSection(id) {
  const sec = document.getElementById('section-' + id);
  sec.classList.toggle('collapsed');
}

// ─── Google Fonts loader ──────────────────────────────────────────────────────
const FONT_URLS = {
  'Inter': 'Inter:wght@400;600;700;800',
  'Poppins': 'Poppins:wght@400;600;700;800',
  'Roboto Mono': 'Roboto+Mono:wght@400;700',
  'Press Start 2P': 'Press+Start+2P',
  'Outfit': 'Outfit:wght@400;600;700;800',
};
function loadGoogleFont(name) {
  const key = FONT_URLS[name];
  if (!key) return;
  const el = document.getElementById('google-fonts-custom');
  el.href = `https://fonts.googleapis.com/css2?family=${key}&display=swap`;
}

// ─── Controls → design ───────────────────────────────────────────────────────
function getControlValues() {
  return {
    bg_color: document.getElementById('ctrl-bg-color').value,
    accent_color: document.getElementById('ctrl-accent-color').value,
    border_color: document.getElementById('ctrl-border-color').value,
    text_color: document.getElementById('ctrl-text-color').value,
    font_family: document.getElementById('font-picker-selected').querySelector('span').textContent,
    username_size: parseInt(document.getElementById('ctrl-username-size').value),
    event_label: document.getElementById('ctrl-event-label').value,
    detail_text: document.getElementById('ctrl-detail-text').value,
    entrance_animation: document.getElementById('ctrl-entrance-animation').value,
    car_animation: document.getElementById('ctrl-car-animation').value,
    screen_effect: document.getElementById('ctrl-screen-effect').value,
    animation_speed: parseFloat(document.getElementById('ctrl-animation-speed').value),
    card_width: parseInt(document.getElementById('ctrl-card-width').value),
    card_position: document.querySelector('.pos-cell.active')?.dataset.pos || 'top-center',
    card_custom_x: workingDesigns[currentType]?.card_custom_x || null,
    card_custom_y: workingDesigns[currentType]?.card_custom_y || null,
    border_radius: parseInt(document.getElementById('ctrl-border-radius').value),
  };
}

function setControlValues(d) {
  document.getElementById('ctrl-bg-color').value = d.bg_color;
  document.getElementById('ctrl-accent-color').value = d.accent_color;
  document.getElementById('ctrl-border-color').value = d.border_color;
  document.getElementById('ctrl-text-color').value = d.text_color;
  const fontSpan = document.getElementById('font-picker-selected').querySelector('span');
  fontSpan.textContent = d.font_family;
  if (d.font_family !== 'System Default') {
    fontSpan.style.fontFamily = d.font_family;
    loadGoogleFont(d.font_family);
  } else {
    fontSpan.style.fontFamily = '-apple-system, BlinkMacSystemFont, sans-serif';
  }
  document.getElementById('ctrl-username-size').value = d.username_size;
  document.getElementById('val-username-size').textContent = d.username_size + 'px';
  document.getElementById('ctrl-event-label').value = d.event_label || '';
  document.getElementById('ctrl-detail-text').value = d.detail_text || '';
  document.getElementById('ctrl-entrance-animation').value = d.entrance_animation;
  document.getElementById('ctrl-car-animation').value = d.car_animation;
  document.getElementById('ctrl-screen-effect').value = d.screen_effect;
  document.getElementById('ctrl-animation-speed').value = d.animation_speed;
  document.getElementById('val-animation-speed').textContent = parseFloat(d.animation_speed).toFixed(1) + '×';
  document.getElementById('ctrl-card-width').value = d.card_width;
  document.getElementById('val-card-width').textContent = d.card_width + 'px';
  document.getElementById('ctrl-border-radius').value = d.border_radius;
  document.getElementById('val-border-radius').textContent = d.border_radius + 'px';

  // Position grid
  document.querySelectorAll('.pos-cell').forEach(c => c.classList.remove('active'));
  const cell = document.querySelector(`.pos-cell[data-pos="${d.card_position}"]`);
  if (cell) cell.classList.add('active');
}

// ─── Darken helper ────────────────────────────────────────────────────────────
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return [r,g,b];
}
function darken(hex, factor=0.35) {
  const [r,g,b] = hexToRgb(hex);
  return `rgb(${Math.round(r*factor)},${Math.round(g*factor)},${Math.round(b*factor)})`;
}

// ─── Update preview card ──────────────────────────────────────────────────────
function updatePreview() {
  const d = getControlValues();
  workingDesigns[currentType] = Object.assign({}, workingDesigns[currentType], d);

  const card = document.getElementById('preview-card');
  const accent = document.getElementById('preview-top-accent');
  const track = document.getElementById('preview-car-track');
  const labelEl = document.getElementById('preview-event-label');
  const usernameEl = document.getElementById('preview-username');
  const detailEl = document.getElementById('preview-detail');

  // Background gradient
  const dark = darken(d.bg_color);
  card.style.background = `linear-gradient(160deg, ${dark}, ${d.bg_color} 40%, ${dark})`;

  // Border
  card.style.borderColor = hexToRgba(d.border_color, 0.5);
  card.style.boxShadow = `0 8px 32px ${hexToRgba(d.border_color, 0.25)}, 0 4px 24px rgba(0,0,0,0.6)`;
  card.style.borderRadius = d.border_radius + 'px';
  card.style.width = d.card_width + 'px';

  // Top accent
  const accentDark = darken(d.accent_color, 0.6);
  accent.style.background = `linear-gradient(90deg, ${accentDark}, ${d.accent_color}, ${accentDark})`;
  accent.style.borderRadius = d.border_radius + 'px ' + d.border_radius + 'px 0 0';

  // Car track background
  track.style.background = hexToRgba(d.accent_color, 0.06);

  // Label color = accent
  labelEl.style.color = d.accent_color;
  labelEl.textContent = d.event_label || EVENT_DEFAULTS[currentType].event_label;

  // Username
  const ff = d.font_family === 'System Default' ? '-apple-system, BlinkMacSystemFont, sans-serif' : d.font_family;
  usernameEl.style.fontFamily = ff;
  usernameEl.style.fontSize = d.username_size + 'px';
  usernameEl.style.color = d.text_color;
  card.style.fontFamily = ff;

  // Detail
  const detailDefault = getDetailPreviewText(currentType);
  detailEl.textContent = d.detail_text || detailDefault;

  // Car animation
  const carEl = document.getElementById('preview-car');
  if (d.car_animation === 'none') {
    carEl.style.animation = 'none';
    carEl.style.left = '50%';
    carEl.style.transform = 'translateY(-50%) scaleX(-1)';
  } else if (d.car_animation === 'zoomRL') {
    carEl.style.animation = `previewCarZoomRL ${2.8 / d.animation_speed}s linear infinite`;
  } else if (d.car_animation === 'bounce') {
    carEl.style.animation = `previewCarBounce ${1.2 / d.animation_speed}s ease-in-out infinite`;
  } else {
    carEl.style.animation = `previewCarZoom ${2.8 / d.animation_speed}s linear infinite`;
  }

  // Position card in the preview screen
  positionCard(d.card_position, d.card_width);

  // Load font if needed
  if (d.font_family !== 'System Default') loadGoogleFont(d.font_family);

  // Show screen effect preview
  renderScreenEffect(d.screen_effect);
}

function renderScreenEffect(effect) {
  const screen = document.getElementById('preview-screen');
  // Remove old effects
  screen.querySelectorAll('.preview-fx').forEach(e => e.remove());

  // Resolve 'default' to the natural effect for the current event type
  if (effect === 'default') {
    const defaultEffects = {
      follow: 'tiremarks', subscription: 'confetti', bits: 'gold',
      donation: 'money', raid: 'robots',
      yt_superchat: 'gold', yt_member: 'confetti', yt_giftmember: 'money'
    };
    effect = defaultEffects[currentType] || 'none';
  }

  if (!effect || effect === 'none') return;

  const fxContainer = document.createElement('div');
  fxContainer.className = 'preview-fx';
  fxContainer.style.cssText = 'position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:5;';

  const colors = {
    confetti: ['#f7c948','#ff6b35','#00ff88','#9146ff','#ff4444','#4285f4','#fff'],
    gold: ['🪙','💎','⭐','🏆','✨','💰'],
    money: ['💵','💰','💲','🪙','💸'],
    robots: ['🤖'],
    tiremarks: null,
  };

  if (effect === 'confetti') {
    for (let i = 0; i < 30; i++) {
      const c = document.createElement('div');
      c.style.cssText = `position:absolute;width:5px;height:5px;border-radius:${Math.random()>0.5?'50%':'1px'};background:${colors.confetti[Math.floor(Math.random()*colors.confetti.length)]};left:${Math.random()*100}%;top:-5%;opacity:0;animation:fxFall ${1.5+Math.random()*2}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(c);
    }
  } else if (effect === 'gold') {
    for (let i = 0; i < 20; i++) {
      const g = document.createElement('div');
      g.textContent = colors.gold[Math.floor(Math.random()*colors.gold.length)];
      g.style.cssText = `position:absolute;font-size:14px;left:${Math.random()*100}%;top:-5%;opacity:0;animation:fxFall ${2+Math.random()*2}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(g);
    }
  } else if (effect === 'money') {
    for (let i = 0; i < 20; i++) {
      const m = document.createElement('div');
      m.textContent = colors.money[Math.floor(Math.random()*colors.money.length)];
      m.style.cssText = `position:absolute;font-size:14px;left:${Math.random()*100}%;top:-5%;opacity:0;animation:fxFall ${2+Math.random()*2}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(m);
    }
  } else if (effect === 'robots') {
    for (let i = 0; i < 15; i++) {
      const r = document.createElement('div');
      r.textContent = '🤖';
      r.style.cssText = `position:absolute;font-size:${12+Math.random()*8}px;left:${Math.random()*95}%;top:-5%;opacity:0;animation:fxFall ${2+Math.random()*2}s linear ${Math.random()*3}s infinite;`;
      fxContainer.appendChild(r);
    }
  } else if (effect === 'tiremarks') {
    for (let i = 0; i < 2; i++) {
      const t = document.createElement('div');
      t.style.cssText = `position:absolute;height:2px;left:0;right:0;top:${48+i*3}%;background:linear-gradient(90deg,transparent,rgba(136,136,204,0.15),transparent);animation:fxTire 2.5s ease-in-out infinite;`;
      fxContainer.appendChild(t);
    }
  }

  screen.appendChild(fxContainer);

  // Inject keyframes if not already there
  if (!document.getElementById('fx-keyframes')) {
    const style = document.createElement('style');
    style.id = 'fx-keyframes';
    style.textContent = `
      @keyframes fxFall { 0% { opacity:0; transform:translateY(0) rotate(0); } 5% { opacity:1; } 90% { opacity:0.8; } 100% { opacity:0; transform:translateY(400px) rotate(720deg); } }
      @keyframes fxTire { 0%,25% { width:0; opacity:0; } 30% { opacity:0.6; } 70% { width:100%; opacity:0.2; } 100% { width:100%; opacity:0; } }
    `;
    document.head.appendChild(style);
  }
}

function hexToRgba(hex, alpha) {
  const [r,g,b] = hexToRgb(hex);
  return `rgba(${r},${g},${b},${alpha})`;
}

function getDetailPreviewText(type) {
  const map = {
    follow: 'just joined the race 🏁',
    subscription: 'Subscribed for 3 months — Tier 1 🥇',
    bits: 'fueled up 500 bits of nitro! 🔥',
    donation: 'sponsored the team with $10 💸',
    raid: 'raiding with 42 viewers! 🏁',
    yt_superchat: 'sent $5.00 — Love the stream! 🔥',
    yt_member: 'just became a member! 🥇',
    yt_giftmember: 'gifted 5 memberships! 🎁',
    timed: 'Your timed message appears here...',
  };
  return map[type] || '';
}

// Position card in screen based on card_position
function positionCard(pos, cardWidth) {
  const container = document.getElementById('preview-card-container');
  const screen = document.getElementById('preview-screen');
  const screenW = screen.offsetWidth;
  const screenH = screen.offsetHeight;

  // If custom x/y from drag, use those
  const d = workingDesigns[currentType];
  if (d && d.card_custom_x != null && d.card_custom_y != null) {
    const scale = screenW / 1920;
    container.style.transform = `scale(${scale})`;
    container.style.transformOrigin = 'top left';
    container.style.left = (d.card_custom_x * screenW) + 'px';
    container.style.top = (d.card_custom_y * screenH) + 'px';
    return;
  }

  // Scale the card to fit the preview screen (designed for 1920px)
  const scale = screenW / 1920;
  container.style.transform = `scale(${scale})`;
  container.style.transformOrigin = 'top left';

  const [vPos, hPos] = pos.split('-');
  const margin = 20;

  // Reset
  container.style.left = '';
  container.style.top = '';
  container.style.right = '';
  container.style.bottom = '';

  // Work in unscaled coordinates (since transform-origin is top-left and we set left/top)
  // The container is positioned in screen pixels, then scaled

  // Horizontal position
  if (hPos === 'left') {
    container.style.left = margin + 'px';
    container.style.transformOrigin = 'top left';
  } else if (hPos === 'right') {
    container.style.left = (screenW - cardWidth * scale - margin) + 'px';
    container.style.transformOrigin = 'top left';
  } else {
    container.style.left = (screenW / 2 - (cardWidth * scale) / 2) + 'px';
    container.style.transformOrigin = 'top left';
  }

  // Vertical position (estimate card height ~140px unscaled)
  const cardH = 140 * scale;
  if (vPos === 'top') {
    container.style.top = margin + 'px';
  } else if (vPos === 'bot') {
    container.style.top = (screenH - cardH - margin) + 'px';
  } else {
    container.style.top = (screenH / 2 - cardH / 2) + 'px';
  }
}

// ─── Play animation ───────────────────────────────────────────────────────────
function playPreviewAnimation() {
  const d = workingDesigns[currentType];
  const card = document.getElementById('preview-card');
  const speed = d.animation_speed || 1.0;
  const animName = `anim-${d.entrance_animation || 'slideDown'}`;
  const dur = (0.5 / speed).toFixed(2) + 's';

  card.style.opacity = '0';
  card.style.animation = 'none';

  setTimeout(() => {
    card.style.opacity = '';
    card.style.animation = `${animName} ${dur} cubic-bezier(0.34, 1.56, 0.64, 1) both`;
    setTimeout(() => { card.style.animation = 'none'; }, parseFloat(dur) * 1000 + 100);
  }, 50);
}

// ─── Tab switching ────────────────────────────────────────────────────────────
function switchTab(type) {
  // Save current working values before switching
  workingDesigns[currentType] = getControlValues();

  currentType = type;

  // Update tab UI
  document.querySelectorAll('.event-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.type === type);
  });

  // Update badges
  const name = EVENT_NAMES[type] || type;
  document.getElementById('toolbar-event-name').textContent = name;
  document.getElementById('save-event-badge').textContent = name;

  // Update preview username text
  document.getElementById('preview-username').textContent = PREVIEW_USERNAMES[type] || 'StreamerFan99';

  // Load controls for this type
  setControlValues(workingDesigns[type]);
  updatePreview();
}

// ─── Position grid ────────────────────────────────────────────────────────────
document.getElementById('position-grid').addEventListener('click', e => {
  const cell = e.target.closest('.pos-cell');
  if (!cell) return;
  document.querySelectorAll('.pos-cell').forEach(c => c.classList.remove('active'));
  cell.classList.add('active');
  // Clear custom drag position when grid is clicked
  if (workingDesigns[currentType]) {
    workingDesigns[currentType].card_custom_x = null;
    workingDesigns[currentType].card_custom_y = null;
  }
  updatePreview();
});

// ─── Event tabs ──────────────────────────────────────────────────────────────
document.querySelector('.event-tabs-section').addEventListener('click', e => {
  const tab = e.target.closest('.event-tab');
  if (!tab) return;
  switchTab(tab.dataset.type);
});

// ─── Range display updates ────────────────────────────────────────────────────
document.getElementById('ctrl-username-size').addEventListener('input', function() {
  document.getElementById('val-username-size').textContent = this.value + 'px';
  updatePreview();
});
document.getElementById('ctrl-animation-speed').addEventListener('input', function() {
  document.getElementById('val-animation-speed').textContent = parseFloat(this.value).toFixed(1) + '×';
  updatePreview();
});
document.getElementById('ctrl-card-width').addEventListener('input', function() {
  document.getElementById('val-card-width').textContent = this.value + 'px';
  updatePreview();
});
document.getElementById('ctrl-border-radius').addEventListener('input', function() {
  document.getElementById('val-border-radius').textContent = this.value + 'px';
  updatePreview();
});

// ─── All other controls: attach change listeners ──────────────────────────────
['ctrl-bg-color','ctrl-accent-color','ctrl-border-color','ctrl-text-color',
 'ctrl-event-label','ctrl-detail-text',
 'ctrl-entrance-animation','ctrl-car-animation','ctrl-screen-effect'].forEach(id => {
  const el = document.getElementById(id);
  if (!el) return;
  el.addEventListener('input', updatePreview);
  el.addEventListener('change', updatePreview);
});

// ─── Save ────────────────────────────────────────────────────────────────────
async function saveCurrentDesign() {
  const design = getControlValues();
  workingDesigns[currentType] = design;

  try {
    const resp = await fetch('/dashboard/overlay-builder/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ eventType: currentType, design }),
    });
    const data = await resp.json();
    if (data.ok) {
      SAVED_DESIGNS[currentType] = Object.assign({}, design);
      const status = document.getElementById('save-status');
      status.textContent = 'Saved!';
      status.classList.add('visible');
      setTimeout(() => status.classList.remove('visible'), 2000);
    }
  } catch(e) {
    alert('Save failed: ' + e.message);
  }
}

// ─── Discard ──────────────────────────────────────────────────────────────────
function discardChanges() {
  const saved = Object.assign({}, EVENT_DEFAULTS[currentType], SAVED_DESIGNS[currentType] || {});
  workingDesigns[currentType] = saved;
  setControlValues(saved);
  updatePreview();
}

// ─── Reset to default ─────────────────────────────────────────────────────────
async function resetCurrentDesign() {
  if (!confirm('Reset "' + EVENT_NAMES[currentType] + '" to default settings?')) return;
  try {
    await fetch('/dashboard/overlay-builder/reset', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ eventType: currentType }),
    });
  } catch(e) {}

  delete SAVED_DESIGNS[currentType];
  workingDesigns[currentType] = Object.assign({}, EVENT_DEFAULTS[currentType]);
  setControlValues(workingDesigns[currentType]);
  updatePreview();

  const status = document.getElementById('save-status');
  status.textContent = 'Reset to default';
  status.classList.add('visible');
  setTimeout(() => status.classList.remove('visible'), 2000);
}

// ─── Theme presets ────────────────────────────────────────────────────────────
document.querySelectorAll('.theme-preset').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('ctrl-bg-color').value = btn.dataset.bg;
    document.getElementById('ctrl-accent-color').value = btn.dataset.accent;
    document.getElementById('ctrl-border-color').value = btn.dataset.border;
    document.getElementById('ctrl-text-color').value = btn.dataset.text;
    updatePreview();
  });
});

// ─── Font picker ──────────────────────────────────────────────────────────────
function toggleFontPicker() {
  document.getElementById('font-picker-dropdown').classList.toggle('open');
}
document.querySelectorAll('.font-option').forEach(opt => {
  opt.addEventListener('click', () => {
    const font = opt.dataset.font;
    const selectedSpan = document.getElementById('font-picker-selected').querySelector('span');
    selectedSpan.textContent = font;
    selectedSpan.style.fontFamily = opt.style.fontFamily;
    document.getElementById('font-picker-dropdown').classList.remove('open');
    if (font !== 'System Default') loadGoogleFont(font);
    updatePreview();
  });
});
document.addEventListener('click', e => {
  if (!e.target.closest('.font-picker')) {
    document.getElementById('font-picker-dropdown').classList.remove('open');
  }
});

// ─── Initial render ───────────────────────────────────────────────────────────
setControlValues(workingDesigns['follow']);
updatePreview();

// Re-position card on window resize
window.addEventListener('resize', () => {
  const d = workingDesigns[currentType];
  positionCard(d.card_position, d.card_width);
});

// ─── Drag overlay card ──────────────────────────────────────────
let isDragging = false;
let dragOffsetX = 0;
let dragOffsetY = 0;

const dragTarget = document.getElementById('preview-card-container');
const dragScreen = document.getElementById('preview-screen');

dragTarget.style.cursor = 'grab';

dragTarget.addEventListener('mousedown', e => {
  isDragging = true;
  dragTarget.style.cursor = 'grabbing';
  const rect = dragTarget.getBoundingClientRect();
  dragOffsetX = e.clientX - rect.left;
  dragOffsetY = e.clientY - rect.top;
  e.preventDefault();
});

document.addEventListener('mousemove', e => {
  if (!isDragging) return;
  const screenRect = dragScreen.getBoundingClientRect();
  let x = e.clientX - screenRect.left - dragOffsetX;
  let y = e.clientY - screenRect.top - dragOffsetY;

  // Clamp within screen bounds
  x = Math.max(0, Math.min(x, screenRect.width - 50));
  y = Math.max(0, Math.min(y, screenRect.height - 30));

  dragTarget.style.left = x + 'px';
  dragTarget.style.top = y + 'px';
  dragTarget.style.transform = `scale(${dragScreen.offsetWidth / 1920})`;
  dragTarget.style.transformOrigin = 'top left';

  // Deselect position grid since user is custom-positioning
  document.querySelectorAll('.pos-cell, .pos-dot').forEach(c => c.classList.remove('active'));
});

document.addEventListener('mouseup', e => {
  if (!isDragging) return;
  isDragging = false;
  dragTarget.style.cursor = 'grab';

  // Calculate which grid position is closest and update
  const screenRect = dragScreen.getBoundingClientRect();
  const x = parseInt(dragTarget.style.left) || 0;
  const y = parseInt(dragTarget.style.top) || 0;
  const xRatio = x / screenRect.width;
  const yRatio = y / screenRect.height;

  // Map to 3x3 grid
  let hPos = xRatio < 0.33 ? 'left' : xRatio > 0.66 ? 'right' : 'center';
  let vPos = yRatio < 0.33 ? 'top' : yRatio > 0.66 ? 'bot' : 'mid';
  const newPos = `${vPos}-${hPos}`;

  // Update position grid UI
  document.querySelectorAll('.pos-cell, .pos-dot').forEach(c => c.classList.remove('active'));
  const matchCell = document.querySelector(`.pos-cell[data-pos="${newPos}"], .pos-dot[data-pos="${newPos}"]`);
  if (matchCell) matchCell.classList.add('active');

  // Update working design with grid position AND exact x/y percentages
  workingDesigns[currentType].card_position = newPos;
  workingDesigns[currentType].card_custom_x = x / screenRect.width;
  workingDesigns[currentType].card_custom_y = y / screenRect.height;
});
</script>

