<script>
// ─── Data setup ───────────────────────────────────────────────────────────────
const SAVED_DESIGNS = {};
const SERVER_DESIGNS = <%- designs %>;
SERVER_DESIGNS.forEach(d => { SAVED_DESIGNS[d.event_type] = d; });

// Per-text defaults shared across all events
const TEXT_STYLE_DEFAULTS = {
  label_font_family: null, label_font_size: 10, label_font_weight: 700, label_color: null,
  username_font_family: null, username_font_weight: 800, username_color: null,
  detail_font_family: null, detail_font_size: 13, detail_font_weight: 400, detail_color: null,
  text_align: 'center', card_side_icon: null, effect_amount: 1.0, effect_size: 1.0, effect_direction: 'down',
};

// Default side icons per event type (null = no icon)
const DEFAULT_SIDE_ICONS = {
  follow: null, subscription: '🏆', bits: null, donation: null, raid: null,
  yt_superchat: null, yt_member: '⭐', yt_giftmember: null, timed: null,
};

const EVENT_DEFAULTS = {
  follow:        { ...TEXT_STYLE_DEFAULTS, bg_color:'#1a1a3e', accent_color:'#8888cc', border_color:'#8888cc', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'New Pit Crew Member', detail_text:'just joined the race 🏁', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  subscription:  { ...TEXT_STYLE_DEFAULTS, bg_color:'#061a10', accent_color:'#00ff88', border_color:'#00ff88', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Podium Finish',        detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  bits:          { ...TEXT_STYLE_DEFAULTS, bg_color:'#1c1200', accent_color:'#f7c948', border_color:'#f7c948', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Nitro Boost',          detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  donation:      { ...TEXT_STYLE_DEFAULTS, bg_color:'#110022', accent_color:'#bf00ff', border_color:'#bf00ff', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Sponsor Alert',        detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  raid:          { ...TEXT_STYLE_DEFAULTS, bg_color:'#1c0505', accent_color:'#ff4444', border_color:'#ff4444', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Incoming Raid',        detail_text:'', entrance_animation:'slideDown', car_animation:'none',   screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  yt_superchat:  { ...TEXT_STYLE_DEFAULTS, bg_color:'#200808', accent_color:'#ff4444', border_color:'#ff4444', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Super Chat',           detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  yt_member:     { ...TEXT_STYLE_DEFAULTS, bg_color:'#041a0c', accent_color:'#0f9d58', border_color:'#0f9d58', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'New Member',           detail_text:'', entrance_animation:'slideDown', car_animation:'none',   screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  yt_giftmember: { ...TEXT_STYLE_DEFAULTS, bg_color:'#060e20', accent_color:'#4285f4', border_color:'#4285f4', text_color:'#ffffff', font_family:'System Default', username_size:24, event_label:'Gift Alert',           detail_text:'', entrance_animation:'slideDown', car_animation:'zoomLR', screen_effect:'default', animation_speed:1.0, card_width:420, card_position:'top-center', border_radius:16 },
  timed:         { ...TEXT_STYLE_DEFAULTS, bg_color:'#1a1a2e', accent_color:'#f79009', border_color:'#f79009', text_color:'#ffffff', font_family:'System Default', username_size:18, event_label:'', detail_text:'', entrance_animation:'slideDown', car_animation:'none', screen_effect:'none', animation_speed:1.0, card_width:500, card_position:'bot-center', border_radius:12 },
};

const EVENT_NAMES = {
  follow:'Follow', subscription:'Subscription', bits:'Bits', donation:'Donation',
  raid:'Raid', yt_superchat:'YT Super Chat', yt_member:'YT Member', yt_giftmember:'YT Gift Member',
  timed:'Timed',
};

const PREVIEW_USERNAMES = {
  follow:'StreamerFan99', subscription:'ProRacer_24', bits:'NitroQueen',
  donation:'SpeedSponsor', raid:'RaidLeader', yt_superchat:'YoutubeViewer',
  yt_member:'NewMember42', yt_giftmember:'GenerousGifter',
  timed:'TimedMessage',
};

// In-memory designs (working copy for current session)
const workingDesigns = {};
Object.keys(EVENT_DEFAULTS).forEach(t => {
  workingDesigns[t] = Object.assign({}, EVENT_DEFAULTS[t], SAVED_DESIGNS[t] || {});
});

let currentType = 'follow';
let unsavedChanges = false;

// ─── Sponsor data ─────────────────────────────────────────────────────────────
let sponsorImages = <%- sponsors %>;
const STREAMER_ID = <%= streamer.id %>;
let sponsorRotationEnabled = <%= streamer.sponsor_rotation_enabled ? 'true' : 'false' %>;

// ─── Section collapse ─────────────────────────────────────────────────────────
function toggleSection(id) {
  const sec = document.getElementById('section-' + id);
  sec.classList.toggle('collapsed');
}

// ─── Google Fonts loader ──────────────────────────────────────────────────────
const FONT_URLS = {
  'Inter': 'Inter:wght@400;600;700;800',
  'Poppins': 'Poppins:wght@400;600;700;800',
  'Roboto Mono': 'Roboto+Mono:wght@400;700',
  'Press Start 2P': 'Press+Start+2P',
  'Outfit': 'Outfit:wght@400;600;700;800',
};
function loadGoogleFont(name) {
  const key = FONT_URLS[name];
  if (!key) return;
  const el = document.getElementById('google-fonts-custom');
  el.href = `https://fonts.googleapis.com/css2?family=${key}&display=swap`;
}

// ─── Controls → design ───────────────────────────────────────────────────────
function getControlValues() {
  const wd = workingDesigns[currentType] || {};
  return {
    bg_color: document.getElementById('ctrl-bg-color').value,
    accent_color: document.getElementById('ctrl-accent-color').value,
    border_color: document.getElementById('ctrl-border-color').value,
    text_color: document.getElementById('ctrl-text-color').value,
    font_family: document.getElementById('font-picker-selected').querySelector('span').textContent,
    username_size: parseInt(document.getElementById('ctrl-username-size').value),
    event_label: document.getElementById('ctrl-event-label').value,
    detail_text: document.getElementById('ctrl-detail-text').value,
    entrance_animation: document.getElementById('ctrl-entrance-animation').value,
    car_animation: document.getElementById('ctrl-car-animation').value,
    screen_effect: document.getElementById('ctrl-screen-effect').value,
    animation_speed: parseFloat(document.getElementById('ctrl-animation-speed').value) || 1.0,
    card_width: parseInt(document.getElementById('ctrl-card-width').value) || 420,
    card_position: document.querySelector('.pos-cell.active')?.dataset.pos || 'top-center',
    card_custom_x: wd.card_custom_x != null ? wd.card_custom_x : null,
    card_custom_y: wd.card_custom_y != null ? wd.card_custom_y : null,
    border_radius: parseInt(document.getElementById('ctrl-border-radius').value),
    sponsor_animation: document.getElementById('ctrl-sponsor-animation').value,
    // Per-text styling (read from workingDesigns, set via popup)
    label_font_family: wd.label_font_family || null,
    label_font_size: wd.label_font_size != null ? wd.label_font_size : 10,
    label_font_weight: wd.label_font_weight != null ? wd.label_font_weight : 700,
    label_color: wd.label_color || null,
    username_font_family: wd.username_font_family || null,
    username_font_weight: wd.username_font_weight != null ? wd.username_font_weight : 800,
    username_color: wd.username_color || null,
    detail_font_family: wd.detail_font_family || null,
    detail_font_size: wd.detail_font_size != null ? wd.detail_font_size : 13,
    detail_font_weight: wd.detail_font_weight != null ? wd.detail_font_weight : 400,
    detail_color: wd.detail_color || null,
    text_align: wd.text_align || 'center',
    card_side_icon: wd.card_side_icon !== undefined ? wd.card_side_icon : null,
    effect_amount: parseFloat(document.getElementById('ctrl-effect-amount').value) || 1.0,
    effect_size: parseFloat(document.getElementById('ctrl-effect-size').value) || 1.0,
    effect_direction: document.getElementById('ctrl-effect-direction').value,
    // Advanced theme (read from workingDesigns, set via popup)
    bg_opacity: wd.bg_opacity != null ? wd.bg_opacity : 1.0,
    gradient_direction: wd.gradient_direction || '160deg',
    border_thickness: wd.border_thickness != null ? wd.border_thickness : 2,
    border_opacity: wd.border_opacity != null ? wd.border_opacity : 0.5,
    glow_intensity: wd.glow_intensity != null ? wd.glow_intensity : 0.25,
    shadow_opacity: wd.shadow_opacity != null ? wd.shadow_opacity : 0.6,
    shadow_blur: wd.shadow_blur != null ? wd.shadow_blur : 32,
    shadow_spread: wd.shadow_spread != null ? wd.shadow_spread : 0,
  };
}

function setControlValues(d) {
  document.getElementById('ctrl-bg-color').value = d.bg_color;
  document.getElementById('ctrl-accent-color').value = d.accent_color;
  document.getElementById('ctrl-border-color').value = d.border_color;
  document.getElementById('ctrl-text-color').value = d.text_color;
  const fontSpan = document.getElementById('font-picker-selected').querySelector('span');
  fontSpan.textContent = d.font_family;
  if (d.font_family !== 'System Default') {
    fontSpan.style.fontFamily = d.font_family;
    loadGoogleFont(d.font_family);
  } else {
    fontSpan.style.fontFamily = '-apple-system, BlinkMacSystemFont, sans-serif';
  }
  document.getElementById('ctrl-username-size').value = d.username_size;
  document.getElementById('val-username-size').textContent = d.username_size + 'px';
  document.getElementById('ctrl-event-label').value = d.event_label || '';
  document.getElementById('ctrl-detail-text').value = d.detail_text || '';
  document.getElementById('ctrl-entrance-animation').value = d.entrance_animation;
  document.getElementById('ctrl-car-animation').value = d.car_animation;
  document.getElementById('ctrl-screen-effect').value = d.screen_effect;
  document.getElementById('ctrl-animation-speed').value = d.animation_speed || 1.0;
  document.getElementById('ctrl-card-width').value = d.card_width || 420;
  document.getElementById('val-card-width').textContent = d.card_width + 'px';
  document.getElementById('ctrl-border-radius').value = d.border_radius || 16;
  document.getElementById('val-border-radius').textContent = d.border_radius + 'px';
  document.getElementById('ctrl-sponsor-animation').value = d.sponsor_animation || 'fade';
  document.getElementById('ctrl-effect-amount').value = d.effect_amount || 1.0;
  document.getElementById('ctrl-effect-size').value = d.effect_size || 1.0;
  document.getElementById('ctrl-effect-direction').value = d.effect_direction || 'down';
  // Update theme button swatches
  document.getElementById('swatch-bg').style.background = d.bg_color;
  document.getElementById('swatch-accent').style.background = d.accent_color;
  // Update text section inline preview (defined in second script block, safe-guard initial load)
  if (typeof updateTextSectionPreview === 'function') updateTextSectionPreview(d);

  // Position grid
  document.querySelectorAll('.pos-cell').forEach(c => c.classList.remove('active'));
  const cell = document.querySelector(`.pos-cell[data-pos="${d.card_position}"]`);
  if (cell) cell.classList.add('active');
}

// ─── Font resolver ────────────────────────────────────────────────────────────
function resolveFont(name) {
  if (!name || name === 'System Default') return '-apple-system, BlinkMacSystemFont, sans-serif';
  return `'${name}', sans-serif`;
}

// ─── Side icon helpers ────────────────────────────────────────────────────────
function setSideIcon(icon) {
  workingDesigns[currentType].card_side_icon = icon === 'none' ? 'none' : icon;
  unsavedChanges = true;
  updateSideIconGrid(workingDesigns[currentType]);
  updatePreview();
}

function updateSideIconGrid(d) {
  const activeIcon = d.card_side_icon;
  const defaultIcon = DEFAULT_SIDE_ICONS[currentType];
  const hint = document.getElementById('side-icon-hint');
  document.querySelectorAll('.side-icon-btn').forEach(btn => {
    if (activeIcon != null) {
      btn.classList.toggle('active', btn.dataset.icon === activeIcon);
    } else {
      // No custom set — highlight default or 'none'
      btn.classList.toggle('active', defaultIcon ? btn.dataset.icon === defaultIcon : btn.dataset.icon === 'none');
    }
  });
  if (hint) {
    if (activeIcon != null) {
      hint.textContent = activeIcon === 'none' ? 'No side icons' : `Custom: ${activeIcon}`;
    } else {
      hint.textContent = defaultIcon ? `Default: ${defaultIcon} (from event type)` : 'Default: no icons';
    }
  }
}

// ─── Darken helper ────────────────────────────────────────────────────────────
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return [r,g,b];
}
function darken(hex, factor=0.35) {
  const [r,g,b] = hexToRgb(hex);
  return `rgb(${Math.round(r*factor)},${Math.round(g*factor)},${Math.round(b*factor)})`;
}

// ─── Update preview card ──────────────────────────────────────────────────────
function updatePreview() {
  const d = getControlValues();
  workingDesigns[currentType] = Object.assign({}, workingDesigns[currentType], d);

  const card = document.getElementById('preview-card');
  const accent = document.getElementById('preview-top-accent');
  const track = document.getElementById('preview-car-track');

  // Determine side icon: custom > default per event type > none
  const sideIcon = d.card_side_icon !== null && d.card_side_icon !== undefined
    ? d.card_side_icon
    : (DEFAULT_SIDE_ICONS[currentType] || null);
  const hasIcon = sideIcon && sideIcon !== 'none';

  // Toggle icon vs flat layout
  const cupRow = document.getElementById('preview-cup-row');
  const flatWrap = document.getElementById('preview-no-icon-wrap');
  cupRow.style.display = hasIcon ? 'flex' : 'none';
  flatWrap.style.display = hasIcon ? 'none' : '';

  if (hasIcon) {
    document.getElementById('preview-icon-left').textContent = sideIcon;
    document.getElementById('preview-icon-right').textContent = sideIcon;
  }

  // Use the correct set of elements based on layout
  const labelEl = hasIcon ? document.getElementById('preview-event-label') : document.getElementById('preview-event-label-flat');
  const usernameEl = hasIcon ? document.getElementById('preview-username') : document.getElementById('preview-username-flat');
  const detailEl = hasIcon ? document.getElementById('preview-detail') : document.getElementById('preview-detail-flat');

  // Background gradient (with advanced theme)
  const bgOpacity = d.bg_opacity != null ? d.bg_opacity : 1.0;
  const gradDir = d.gradient_direction || '160deg';
  const [bgR,bgG,bgB] = hexToRgb(d.bg_color);
  const darkR = Math.round(bgR * 0.35), darkG = Math.round(bgG * 0.35), darkB = Math.round(bgB * 0.35);
  if (gradDir) {
    card.style.background = `linear-gradient(${gradDir}, rgba(${darkR},${darkG},${darkB},${bgOpacity}), rgba(${bgR},${bgG},${bgB},${bgOpacity}) 40%, rgba(${darkR},${darkG},${darkB},${bgOpacity}))`;
  } else {
    card.style.background = `rgba(${bgR},${bgG},${bgB},${bgOpacity})`;
  }

  // Border (with advanced theme)
  const borderThick = d.border_thickness != null ? d.border_thickness : 2;
  const borderOpacity = d.border_opacity != null ? d.border_opacity : 0.5;
  card.style.border = `${borderThick}px solid ${hexToRgba(d.border_color, borderOpacity)}`;
  card.style.borderRadius = d.border_radius + 'px';
  card.style.width = d.card_width + 'px';

  // Shadow & glow (with advanced theme)
  const glowIntensity = d.glow_intensity != null ? d.glow_intensity : 0.25;
  const shadowOpacity = d.shadow_opacity != null ? d.shadow_opacity : 0.6;
  const shadowBlur = d.shadow_blur != null ? d.shadow_blur : 32;
  const shadowSpread = d.shadow_spread != null ? d.shadow_spread : 0;
  if (glowIntensity > 0) {
    card.style.boxShadow = `0 ${Math.round(shadowBlur/4)}px ${shadowBlur}px ${shadowSpread}px ${hexToRgba(d.border_color, glowIntensity)}, 0 4px 24px rgba(0,0,0,${shadowOpacity})`;
  } else {
    card.style.boxShadow = `0 4px ${shadowBlur}px ${shadowSpread}px rgba(0,0,0,${shadowOpacity})`;
  }

  // Top accent
  const accentDark = darken(d.accent_color, 0.6);
  accent.style.background = `linear-gradient(90deg, ${accentDark}, ${d.accent_color}, ${accentDark})`;
  accent.style.borderRadius = d.border_radius + 'px ' + d.border_radius + 'px 0 0';

  // Car track background
  track.style.background = hexToRgba(d.accent_color, 0.06);

  // Text alignment
  const cardBody = card.querySelector('.card-body');
  if (cardBody) cardBody.style.textAlign = d.text_align || 'center';

  // Label — per-text styling with fallbacks
  const labelFont = resolveFont(d.label_font_family || d.font_family);
  labelEl.style.fontFamily = labelFont;
  labelEl.style.fontSize = (d.label_font_size || 10) + 'px';
  labelEl.style.fontWeight = d.label_font_weight || 700;
  labelEl.style.color = d.label_color || d.accent_color;
  labelEl.textContent = d.event_label || EVENT_DEFAULTS[currentType].event_label;

  // Username — per-text styling with fallbacks
  const usernameFont = resolveFont(d.username_font_family || d.font_family);
  usernameEl.style.fontFamily = usernameFont;
  usernameEl.style.fontSize = d.username_size + 'px';
  usernameEl.style.fontWeight = d.username_font_weight || 800;
  usernameEl.style.color = d.username_color || d.text_color;

  // Detail — per-text styling with fallbacks
  const detailFont = resolveFont(d.detail_font_family || d.font_family);
  detailEl.style.fontFamily = detailFont;
  detailEl.style.fontSize = (d.detail_font_size || 13) + 'px';
  detailEl.style.fontWeight = d.detail_font_weight || 400;
  detailEl.style.color = d.detail_color || d.text_color;
  const detailDefault = getDetailPreviewText(currentType);
  detailEl.textContent = d.detail_text || detailDefault;

  // Bottom bar animation (dynamic)
  const bottomAnim = d.car_animation || 'zoomLR';
  const animSpeed = d.animation_speed || 1.0;
  // Remove previous full-card overlays
  card.querySelectorAll('.card-anim-overlay').forEach(e => e.remove());
  if (bottomAnim === 'none') {
    track.style.display = 'none';
  } else {
    buildPreviewBottomAnimation(track, bottomAnim, animSpeed, d.accent_color || '#8888cc', card);
  }

  // Position card in the preview screen
  positionCard(d.card_position, d.card_width);

  // Update overlay guide border
  updateOverlayGuide();

  // Load fonts if needed
  [d.font_family, d.label_font_family, d.username_font_family, d.detail_font_family].forEach(f => {
    if (f && f !== 'System Default') loadGoogleFont(f);
  });

  // Show screen effect preview
  renderScreenEffect(d.screen_effect);
}

function updateOverlayGuide() {
  const container = document.getElementById('preview-card-container');
  const guide = document.getElementById('overlay-guide');
  const card = document.getElementById('preview-card');
  const sponsorWrap = container.querySelector('.preview-sponsor-wrap');
  const target = (sponsorWrap && sponsorWrap.style.display !== 'none') ? sponsorWrap : card;

  // Wait a frame so layout is computed
  requestAnimationFrame(() => {
    const w = target.offsetWidth || parseInt(target.style.width) || 420;
    const h = target.offsetHeight || 140;
    guide.style.width = w + 'px';
    guide.style.height = h + 'px';
    guide.style.top = '0';
    guide.style.left = '0';
    guide.style.borderRadius = (workingDesigns[currentType]?.border_radius || 16) + 'px';
  });
}

function ensureFxKeyframes() {
  if (document.getElementById('fx-keyframes')) return;
  const style = document.createElement('style');
  style.id = 'fx-keyframes';
  style.textContent = `
    @keyframes fxFallDown { 0% { opacity:0; transform:translateY(0) rotate(0); } 5% { opacity:1; } 90% { opacity:0.8; } 100% { opacity:0; transform:translateY(400px) rotate(720deg); } }
    @keyframes fxFallUp { 0% { opacity:0; transform:translateY(0) rotate(0); } 5% { opacity:1; } 90% { opacity:0.8; } 100% { opacity:0; transform:translateY(-400px) rotate(720deg); } }
    @keyframes fxFallLeft { 0% { opacity:0; transform:translateX(0) rotate(0); } 5% { opacity:1; } 90% { opacity:0.8; } 100% { opacity:0; transform:translateX(-400px) rotate(720deg); } }
    @keyframes fxFallRight { 0% { opacity:0; transform:translateX(0) rotate(0); } 5% { opacity:1; } 90% { opacity:0.8; } 100% { opacity:0; transform:translateX(400px) rotate(720deg); } }
    @keyframes fxFall { 0% { opacity:0; transform:translateY(0) rotate(0); } 5% { opacity:1; } 90% { opacity:0.8; } 100% { opacity:0; transform:translateY(400px) rotate(720deg); } }
    @keyframes fxTire { 0%,25% { width:0; opacity:0; } 30% { opacity:0.6; } 70% { width:100%; opacity:0.2; } 100% { width:100%; opacity:0; } }
  `;
  document.head.appendChild(style);
}
ensureFxKeyframes();

// ─── Build bottom bar animation for builder preview ──────────────────────────
const FULL_CARD_ANIMS_PREVIEW = new Set(['flames','sparkles','lightning','neonSweep','pulse']);

function buildPreviewBottomAnimation(track, type, speed, accent, card) {
  const [ar,ag,ab] = hexToRgb(accent);
  const dur = 2.8 / speed;

  // Remove previous full-card overlays
  if (card) card.querySelectorAll('.card-anim-overlay').forEach(e => e.remove());

  // Full-card animations
  if (FULL_CARD_ANIMS_PREVIEW.has(type) && card) {
    track.style.display = 'none';
    const overlay = document.createElement('div');
    overlay.className = 'card-anim-overlay';
    overlay.style.cssText = 'position:absolute;inset:0;pointer-events:none;overflow:hidden;border-radius:inherit;z-index:6;';

    if (type === 'flames') {
      let h = '';
      for (let i = 0; i < 10; i++) {
        const x = Math.random() * 100;
        const w = 15 + Math.random() * 25;
        const d = (0.6 + Math.random() * 0.8) / speed;
        const hue = Math.floor(Math.random() * 40);
        h += `<div style="position:absolute;bottom:-10%;left:${x}%;width:${w}%;height:60%;border-radius:50% 50% 20% 20%;background:radial-gradient(ellipse at bottom, hsla(${hue},100%,55%,0.7), hsla(${hue+15},100%,45%,0.3) 50%, transparent 70%);filter:blur(2px);animation:flameRise ${d}s ease-in-out ${Math.random()}s infinite;"></div>`;
      }
      h += `<div style="position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(to top,rgba(255,80,0,0.4),rgba(255,150,0,0.15),transparent);animation:flameGlow ${1.5/speed}s ease-in-out infinite;"></div>`;
      overlay.innerHTML = h;
    }
    else if (type === 'sparkles') {
      let h = '';
      const colors = ['#fff', accent, '#f7c948', '#ff88cc', '#00ffcc'];
      for (let i = 0; i < 15; i++) {
        const x = Math.random() * 100, y = Math.random() * 100;
        const sz = 1 + Math.random() * 3;
        const d = (1.5 + Math.random() * 2) / speed;
        const sx = (Math.random()-0.5)*30, sy = (Math.random()-0.5)*30;
        const c = colors[Math.floor(Math.random()*colors.length)];
        h += `<div style="position:absolute;left:${x}%;top:${y}%;width:${sz}px;height:${sz}px;border-radius:50%;background:${c};box-shadow:0 0 ${sz*3}px ${c};--sx:${sx}px;--sy:${sy}px;animation:sparkFloat ${d}s ease-in-out ${Math.random()*3}s infinite;"></div>`;
      }
      for (let i = 0; i < 4; i++) {
        const x = 10+Math.random()*80, y = 10+Math.random()*80;
        const c = colors[Math.floor(Math.random()*colors.length)];
        h += `<div style="position:absolute;left:${x}%;top:${y}%;font-size:${6+Math.random()*6}px;--sx:${(Math.random()-0.5)*20}px;--sy:${(Math.random()-0.5)*20}px;animation:sparkFloat ${(2+Math.random()*2)/speed}s ease-in-out ${Math.random()*3}s infinite;filter:drop-shadow(0 0 2px ${c});">✦</div>`;
      }
      overlay.innerHTML = h;
    }
    else if (type === 'lightning') {
      let h = '';
      for (let i = 0; i < 4; i++) {
        const x = 5+Math.random()*90;
        const d = (1.5+Math.random()*2.5)/speed;
        let pts = `M ${Math.random()*20+40} 0`;
        let py = 0;
        for (let s = 0; s < 5; s++) { py += 12+Math.random()*8; pts += ` L ${20+Math.random()*60} ${py}`; }
        h += `<svg style="position:absolute;left:${x}%;top:0;width:30px;height:100%;animation:boltStrike ${d}s ease-out ${Math.random()*3}s infinite;" viewBox="0 0 100 100" preserveAspectRatio="none"><path d="${pts}" stroke="rgba(${ar},${ag},${ab},0.9)" stroke-width="2" fill="none" style="filter:drop-shadow(0 0 3px rgba(${ar},${ag},${ab},0.6))"/></svg>`;
      }
      h += `<div style="position:absolute;inset:0;background:rgba(${ar},${ag},${ab},0.05);animation:ecgPulse ${1.5/speed}s ease-in-out infinite;"></div>`;
      overlay.innerHTML = h;
    }
    else if (type === 'neonSweep') {
      let h = '';
      h += `<div style="position:absolute;top:0;bottom:0;width:30%;background:linear-gradient(90deg,transparent,rgba(${ar},${ag},${ab},0.15),rgba(${ar},${ag},${ab},0.3),rgba(${ar},${ag},${ab},0.15),transparent);animation:neonSweepFull ${2.5/speed}s linear infinite;"></div>`;
      h += `<div style="position:absolute;top:0;bottom:0;width:10%;background:linear-gradient(90deg,transparent,rgba(${ar},${ag},${ab},0.1),transparent);animation:neonSweepFull ${3/speed}s linear ${0.8/speed}s infinite;"></div>`;
      h += `<div style="position:absolute;inset:0;border:1px solid rgba(${ar},${ag},${ab},0.2);border-radius:inherit;animation:ecgPulse ${2/speed}s ease-in-out infinite;"></div>`;
      overlay.innerHTML = h;
    }
    else if (type === 'pulse') {
      let h = '';
      h += `<div style="position:absolute;top:50%;left:0;right:0;height:1px;background:rgba(${ar},${ag},${ab},0.15);transform:translateY(-50%);"></div>`;
      const ecg = 'M 0 50 L 15 50 L 18 50 L 20 30 L 22 70 L 24 20 L 26 80 L 28 45 L 32 50 L 50 50 L 53 50 L 55 35 L 57 65 L 59 50 L 75 50 L 100 50';
      for (let i = 0; i < 2; i++) {
        const d = (3+i*0.5)/speed;
        h += `<svg style="position:absolute;top:20%;height:60%;width:50%;animation:ecgSweep ${d}s linear ${i*(1.5/speed)}s infinite;" viewBox="0 0 100 100" preserveAspectRatio="none"><path d="${ecg}" stroke="rgba(${ar},${ag},${ab},0.8)" stroke-width="2" fill="none"/></svg>`;
      }
      h += `<div style="position:absolute;top:50%;left:50%;width:3px;height:3px;border-radius:50%;background:rgba(${ar},${ag},${ab},0.8);box-shadow:0 0 6px rgba(${ar},${ag},${ab},0.6);transform:translate(-50%,-50%);animation:ecgPulse ${1/speed}s ease-in-out infinite;"></div>`;
      overlay.innerHTML = h;
    }

    card.style.position = card.style.position || 'relative';
    card.appendChild(overlay);
    return;
  }

  // Bottom-track animations
  track.style.display = '';
  track.innerHTML = '';

  if (type === 'zoomLR') {
    track.innerHTML = '<div class="race-line"></div><div class="track-car" id="preview-car" style="animation:previewCarZoom '+dur+'s linear infinite">🏎️</div>';
  } else if (type === 'zoomRL') {
    track.innerHTML = '<div class="race-line"></div><div class="track-car" id="preview-car" style="transform:translateY(-50%);animation:previewCarZoomRL '+dur+'s linear infinite">🏎️</div>';
  } else if (type === 'checkered') {
    let cells = '';
    const rows = 4, cellH = 10;
    for (let r = 0; r < rows; r++)
      for (let c = 0; c < 30; c++)
        cells += `<div style="width:${cellH}px;height:${cellH}px;background:${(r+c)%2===0?'rgba(255,255,255,0.85)':'rgba(0,0,0,0.85)'}"></div>`;
    track.innerHTML = `<div style="position:absolute;inset:0;overflow:hidden;"><div style="position:absolute;top:0;bottom:0;width:${30*cellH}px;display:flex;flex-wrap:wrap;animation:checkerScroll ${3/speed}s linear infinite;">${cells}</div></div>`;
  } else if (type === 'equalizer') {
    let h = '<div style="position:absolute;bottom:0;left:0;right:0;height:100%;display:flex;align-items:flex-end;justify-content:center;gap:2px;padding:3px 6px;">';
    for (let i = 0; i < 16; i++) {
      const d = (0.4+Math.random()*0.6)/speed;
      h += `<div style="flex:1;height:${20+Math.random()*60}%;background:rgba(${ar},${ag},${ab},0.7);border-radius:2px 2px 0 0;animation:eqBounce ${d}s ease-in-out ${Math.random()*0.5}s infinite;"></div>`;
    }
    h += '</div>';
    track.innerHTML = h;
  } else {
    track.innerHTML = '<div class="race-line"></div><div class="track-car" id="preview-car" style="animation:previewCarZoom '+dur+'s linear infinite">🏎️</div>';
  }
}

function renderScreenEffect(effect) {
  const screen = document.getElementById('preview-screen');
  screen.querySelectorAll('.preview-fx').forEach(e => e.remove());

  if (effect === 'default') {
    const defaultEffects = {
      follow: 'tiremarks', subscription: 'confetti', bits: 'gold',
      donation: 'money', raid: 'robots',
      yt_superchat: 'gold', yt_member: 'confetti', yt_giftmember: 'money'
    };
    effect = defaultEffects[currentType] || 'none';
  }
  if (!effect || effect === 'none') return;

  const d = workingDesigns[currentType] || {};
  const speed = d.animation_speed || 1.0;
  const amount = d.effect_amount || 1.0;
  const size = d.effect_size || 1.0;
  const dir = d.effect_direction || 'down';
  const animName = 'fxFall' + dir.charAt(0).toUpperCase() + dir.slice(1);
  const startProp = (dir === 'left' || dir === 'right') ? 'top' : 'left';
  const edgeProp = dir === 'up' ? 'bottom' : dir === 'left' ? 'right' : dir === 'right' ? 'left' : 'top';

  const fxContainer = document.createElement('div');
  fxContainer.className = 'preview-fx';
  fxContainer.style.cssText = 'position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:5;';

  const colors = {
    confetti: ['#f7c948','#ff6b35','#00ff88','#9146ff','#ff4444','#4285f4','#fff'],
    gold: ['🪙','💎','⭐','🏆','✨','💰'],
    money: ['💵','💰','💲','🪙','💸'],
  };

  const baseSizePx = 5 * size;
  const baseFontPx = 14 * size;

  function fxPos() {
    // Spawn from the correct edge based on direction
    if (dir === 'down') return `left:${Math.random()*100}%;top:-5%;`;
    if (dir === 'up') return `left:${Math.random()*100}%;bottom:-5%;`;
    if (dir === 'left') return `top:${Math.random()*100}%;right:-5%;`;
    if (dir === 'right') return `top:${Math.random()*100}%;left:-5%;`;
    return `left:${Math.random()*100}%;top:-5%;`;
  }

  if (effect === 'confetti') {
    const count = Math.round(30 * amount);
    for (let i = 0; i < count; i++) {
      const c = document.createElement('div');
      const w = baseSizePx + Math.random() * baseSizePx * 0.6;
      const h = w * 1.3;
      c.style.cssText = `position:absolute;width:${w}px;height:${h}px;border-radius:${Math.random()>0.5?'50%':'1px'};background:${colors.confetti[Math.floor(Math.random()*colors.confetti.length)]};${fxPos()}opacity:0;animation:${animName} ${(1.5+Math.random()*2)/speed}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(c);
    }
  } else if (effect === 'gold') {
    const count = Math.round(20 * amount);
    for (let i = 0; i < count; i++) {
      const g = document.createElement('div');
      g.textContent = colors.gold[Math.floor(Math.random()*colors.gold.length)];
      g.style.cssText = `position:absolute;font-size:${baseFontPx}px;${fxPos()}opacity:0;animation:${animName} ${(2+Math.random()*2)/speed}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(g);
    }
  } else if (effect === 'money') {
    const count = Math.round(20 * amount);
    for (let i = 0; i < count; i++) {
      const m = document.createElement('div');
      m.textContent = colors.money[Math.floor(Math.random()*colors.money.length)];
      m.style.cssText = `position:absolute;font-size:${baseFontPx}px;${fxPos()}opacity:0;animation:${animName} ${(2+Math.random()*2)/speed}s linear ${Math.random()*2}s infinite;`;
      fxContainer.appendChild(m);
    }
  } else if (effect === 'robots') {
    const count = Math.round(15 * amount);
    for (let i = 0; i < count; i++) {
      const r = document.createElement('div');
      r.textContent = '🤖';
      const fs = (12 + Math.random()*8) * size;
      r.style.cssText = `position:absolute;font-size:${fs}px;${fxPos()}opacity:0;animation:${animName} ${(2+Math.random()*2)/speed}s linear ${Math.random()*3}s infinite;`;
      fxContainer.appendChild(r);
    }
  } else if (effect === 'tiremarks') {
    const count = Math.round(2 * amount);
    for (let i = 0; i < count; i++) {
      const t = document.createElement('div');
      const h = 2 * size;
      t.style.cssText = `position:absolute;height:${h}px;left:0;right:0;top:${48+i*3}%;background:linear-gradient(90deg,transparent,rgba(136,136,204,0.15),transparent);animation:fxTire ${2.5/speed}s ease-in-out infinite;`;
      fxContainer.appendChild(t);
    }
  }

  screen.appendChild(fxContainer);

  ensureFxKeyframes();
}

function hexToRgba(hex, alpha) {
  const [r,g,b] = hexToRgb(hex);
  return `rgba(${r},${g},${b},${alpha})`;
}

function getDetailPreviewText(type) {
  const map = {
    follow: 'just joined the race 🏁',
    subscription: 'Subscribed for 3 months — Tier 1 🥇',
    bits: 'fueled up 500 bits of nitro! 🔥',
    donation: 'sponsored the team with $10 💸',
    raid: 'raiding with 42 viewers! 🏁',
    yt_superchat: 'sent $5.00 — Love the stream! 🔥',
    yt_member: 'just became a member! 🥇',
    yt_giftmember: 'gifted 5 memberships! 🎁',
    timed: 'Your timed message appears here...',
  };
  return map[type] || '';
}

// Position card in screen based on card_position
function positionCard(pos, cardWidth) {
  const container = document.getElementById('preview-card-container');
  const screen = document.getElementById('preview-screen');
  const screenW = screen.offsetWidth;
  const screenH = screen.offsetHeight;

  // If custom x/y from drag, use those
  const d = workingDesigns[currentType];
  if (d && d.card_custom_x != null && d.card_custom_y != null) {
    const scale = screenW / 1920;
    container.style.transform = `scale(${scale})`;
    container.style.transformOrigin = 'top left';
    container.style.left = (d.card_custom_x * screenW) + 'px';
    container.style.top = (d.card_custom_y * screenH) + 'px';
    return;
  }

  // Scale the card to fit the preview screen (designed for 1920px)
  const scale = screenW / 1920;
  container.style.transform = `scale(${scale})`;
  container.style.transformOrigin = 'top left';

  const [vPos, hPos] = pos.split('-');
  const margin = 20;

  // Reset
  container.style.left = '';
  container.style.top = '';
  container.style.right = '';
  container.style.bottom = '';

  // Work in unscaled coordinates (since transform-origin is top-left and we set left/top)
  // The container is positioned in screen pixels, then scaled

  // Horizontal position
  if (hPos === 'left') {
    container.style.left = margin + 'px';
    container.style.transformOrigin = 'top left';
  } else if (hPos === 'right') {
    container.style.left = (screenW - cardWidth * scale - margin) + 'px';
    container.style.transformOrigin = 'top left';
  } else {
    container.style.left = (screenW / 2 - (cardWidth * scale) / 2) + 'px';
    container.style.transformOrigin = 'top left';
  }

  // Vertical position (estimate card height ~140px unscaled)
  const cardH = 140 * scale;
  if (vPos === 'top') {
    container.style.top = margin + 'px';
  } else if (vPos === 'bot') {
    container.style.top = (screenH - cardH - margin) + 'px';
  } else {
    container.style.top = (screenH / 2 - cardH / 2) + 'px';
  }
}

// ─── Play animation ───────────────────────────────────────────────────────────
function playPreviewAnimation() {
  const d = workingDesigns[currentType];
  const card = document.getElementById('preview-card');
  const speed = d.animation_speed || 1.0;
  const animName = `anim-${d.entrance_animation || 'slideDown'}`;
  const dur = (0.5 / speed).toFixed(2) + 's';

  card.style.opacity = '0';
  card.style.animation = 'none';

  setTimeout(() => {
    card.style.opacity = '';
    card.style.animation = `${animName} ${dur} cubic-bezier(0.34, 1.56, 0.64, 1) both`;
    setTimeout(() => { card.style.animation = 'none'; }, parseFloat(dur) * 1000 + 100);
  }, 50);
}

// ─── Tab switching ────────────────────────────────────────────────────────────
function switchTab(type) {
  // Save current working values before switching
  workingDesigns[currentType] = getControlValues();

  // Stop sponsor preview if leaving timed tab
  if (currentType === 'timed' && type !== 'timed') {
    stopSponsorPreview();
  }

  currentType = type;

  // Update tab UI
  document.querySelectorAll('.event-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.type === type);
  });

  // Show/hide sponsor section
  const sponsorSection = document.getElementById('sponsor-section');
  if (type === 'timed') {
    sponsorSection.classList.add('visible');
    updateSponsorPreview();
  } else {
    sponsorSection.classList.remove('visible');
  }

  // Update badges
  const name = EVENT_NAMES[type] || type;
  const topBadge = document.getElementById('save-event-badge-top');
  if (topBadge) topBadge.textContent = name;

  // Update preview username text in both layouts
  const uname = PREVIEW_USERNAMES[type] || 'StreamerFan99';
  document.getElementById('preview-username').textContent = uname;
  document.getElementById('preview-username-flat').textContent = uname;

  // Load controls for this type
  setControlValues(workingDesigns[type]);
  updateSideIconGrid(workingDesigns[type]);
  if (typeof updateAnimSectionPreview === 'function') updateAnimSectionPreview(workingDesigns[type]);
  updatePreview();

  // Update URL and sounds link to preserve tab context
  const url = new URL(window.location);
  url.searchParams.set('tab', type);
  window.history.replaceState({}, '', url);
  document.getElementById('sounds-link').href = '/dashboard/overlay?tab=' + type;
}

