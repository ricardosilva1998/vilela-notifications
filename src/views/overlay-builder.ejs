// ─── Sponsor management ──────────────────────────────────────────────────────

function renderSponsorList() {
  const list = document.getElementById('sponsor-list');
  if (sponsorImages.length === 0) {
    list.innerHTML = '<div style="font-size:11px;color:var(--text-muted);text-align:center;padding:8px;">No sponsors yet</div>';
    return;
  }
  list.innerHTML = sponsorImages.map((s, i) => `
    <div class="sp-item" draggable="true" data-id="${s.id}" data-index="${i}">
      <span class="sp-grip">&#x2807;</span>
      <div class="sp-thumb">
        <img src="/sponsors/${STREAMER_ID}/${s.filename}" alt="${s.display_name || ''}" onerror="this.style.display='none'">
      </div>
      <span class="sp-name" title="${s.display_name || 'Sponsor'}">${s.display_name || 'Sponsor'}</span>
      <input type="number" class="sp-dur" value="${s.display_duration || 30}" min="5" max="300" step="5"
             title="Display duration (seconds)"
             onchange="updateSponsorDuration(${s.id}, this.value)">
      <span class="sp-dur-label">s</span>
      <label class="sp-toggle sp-enable">
        <input type="checkbox" ${s.enabled ? 'checked' : ''} onchange="updateSponsorEnabled(${s.id}, this.checked)">
        <span class="sp-toggle-slider"></span>
      </label>
      <button class="sp-del" onclick="deleteSponsor(${s.id})" title="Delete">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="sp-scale-row" onmousedown="event.stopPropagation()" ondragstart="event.preventDefault(); event.stopPropagation();">
        <span>Scale</span>
        <input type="range" min="0.3" max="1" step="0.05" value="${s.image_scale != null ? s.image_scale : 1.0}"
               draggable="false"
               oninput="this.nextElementSibling.textContent=Math.round(this.value*100)+'%'; updateSponsorScale(${s.id}, this.value)">
        <span>${Math.round((s.image_scale != null ? s.image_scale : 1.0) * 100)}%</span>
      </div>
    </div>
  `).join('');
  attachSponsorDragHandlers();
}

function attachSponsorDragHandlers() {
  const items = document.querySelectorAll('.sp-item[draggable]');
  let draggedEl = null;
  items.forEach(item => {
    item.addEventListener('dragstart', e => {
      draggedEl = item;
      item.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    item.addEventListener('dragend', () => {
      item.classList.remove('dragging');
      document.querySelectorAll('.sp-item.drag-over').forEach(el => el.classList.remove('drag-over'));
      draggedEl = null;
    });
    item.addEventListener('dragover', e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      if (draggedEl && draggedEl !== item) item.classList.add('drag-over');
    });
    item.addEventListener('dragleave', () => item.classList.remove('drag-over'));
    item.addEventListener('drop', e => {
      e.preventDefault();
      item.classList.remove('drag-over');
      if (!draggedEl || draggedEl === item) return;
      const fromIdx = parseInt(draggedEl.dataset.index);
      const toIdx = parseInt(item.dataset.index);
      const moved = sponsorImages.splice(fromIdx, 1)[0];
      sponsorImages.splice(toIdx, 0, moved);
      fetch('/dashboard/sponsors/reorder', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: sponsorImages.map(s => s.id) }),
      });
      renderSponsorList();
      updateSponsorPreview();
    });
  });
}

async function toggleSponsorRotation(enabled) {
  sponsorRotationEnabled = enabled;
  if (!enabled) {
    // Stop preview cycling and show the regular card preview
    stopSponsorPreview();
  } else {
    updateSponsorPreview();
  }
  await fetch('/dashboard/sponsors/toggle-rotation', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ enabled: enabled ? '1' : '' }),
  });
}

async function updateSponsorDuration(id, duration) {
  duration = Math.max(5, Math.min(300, parseInt(duration) || 30));
  const img = sponsorImages.find(s => s.id === id);
  if (img) img.display_duration = duration;
  await fetch(`/dashboard/sponsors/${id}/update`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ display_name: img?.display_name || 'Sponsor', chat_message: img?.chat_message || '', enabled: img?.enabled ? '1' : '', display_duration: duration, image_scale: img?.image_scale != null ? img.image_scale : 1.0 }),
  });
}

async function updateSponsorEnabled(id, enabled) {
  const img = sponsorImages.find(s => s.id === id);
  if (img) img.enabled = enabled ? 1 : 0;
  await fetch(`/dashboard/sponsors/${id}/update`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ display_name: img?.display_name || 'Sponsor', chat_message: img?.chat_message || '', enabled: enabled ? '1' : '', display_duration: img?.display_duration || 30, image_scale: img?.image_scale != null ? img.image_scale : 1.0 }),
  });
  updateSponsorPreview();
}

async function updateSponsorScale(id, scale) {
  scale = Math.max(0.3, Math.min(1, parseFloat(scale) || 1.0));
  const img = sponsorImages.find(s => s.id === id);
  if (img) img.image_scale = scale;
  updateSponsorPreview();
  await fetch(`/dashboard/sponsors/${id}/update`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ display_name: img?.display_name || 'Sponsor', chat_message: img?.chat_message || '', enabled: img?.enabled ? '1' : '', display_duration: img?.display_duration || 30, image_scale: scale }),
  });
}

async function deleteSponsor(id) {
  if (!confirm('Delete this sponsor image?')) return;
  await fetch(`/dashboard/sponsors/${id}/delete`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
  sponsorImages = sponsorImages.filter(s => s.id !== id);
  renderSponsorList();
  updateSponsorPreview();
}

// Upload
let spSelectedFile = null;
const spFileInput = document.getElementById('sp-file-input');
const spUploadZone = document.getElementById('sp-upload-zone');
const spUploadBtn = document.getElementById('sp-upload-btn');

spFileInput.addEventListener('change', function() {
  if (this.files[0]) { spSelectedFile = this.files[0]; spUploadBtn.disabled = false; }
});
spUploadZone.addEventListener('dragover', e => { e.preventDefault(); spUploadZone.classList.add('drag-over'); });
spUploadZone.addEventListener('dragleave', () => spUploadZone.classList.remove('drag-over'));
spUploadZone.addEventListener('drop', e => {
  e.preventDefault(); e.stopPropagation();
  spUploadZone.classList.remove('drag-over');
  const f = e.dataTransfer.files[0];
  if (f && f.type.startsWith('image/')) { spSelectedFile = f; spUploadBtn.disabled = false; }
});

async function uploadSponsor() {
  if (!spSelectedFile) return;
  spUploadBtn.disabled = true;
  spUploadBtn.textContent = '...';
  const name = document.getElementById('sp-upload-name').value || 'Sponsor';
  const ext = spSelectedFile.name.split('.').pop() || 'png';
  const dur = parseInt(document.getElementById('sp-upload-dur').value) || 30;
  try {
    const res = await fetch(`/dashboard/sponsors/upload?name=${encodeURIComponent(name)}&ext=${encodeURIComponent(ext)}&dur=${dur}`, {
      method: 'POST', headers: { 'Content-Type': 'application/octet-stream' }, body: spSelectedFile,
    });
    const data = await res.json();
    if (data.ok && data.image) {
      data.image.display_duration = dur;
      sponsorImages.push(data.image);
      renderSponsorList();
      updateSponsorPreview();
    }
  } catch(e) {}
  spSelectedFile = null;
  spFileInput.value = '';
  spUploadBtn.textContent = 'Upload';
  spUploadBtn.disabled = true;
  document.getElementById('sp-upload-name').value = 'Sponsor';
  document.getElementById('sp-upload-dur').value = '30';
}

// Sponsor preview cycling
let sponsorPreviewInterval = null;
let sponsorPreviewIndex = 0;

function updateSponsorPreview() {
  if (currentType !== 'timed') return;
  clearInterval(sponsorPreviewInterval);
  const container = document.getElementById('preview-card-container');
  const card = document.getElementById('preview-card');
  const enabled = sponsorImages.filter(s => s.enabled);
  if (!sponsorRotationEnabled || enabled.length === 0) {
    card.style.display = '';
    container.querySelector('.preview-sponsor-wrap')?.remove();
    return;
  }
  card.style.display = 'none';
  showSponsorInPreview(enabled[0]);
  sponsorPreviewIndex = 0;
  if (enabled.length > 1) {
    sponsorPreviewInterval = setInterval(() => {
      sponsorPreviewIndex = (sponsorPreviewIndex + 1) % enabled.length;
      showSponsorInPreview(enabled[sponsorPreviewIndex]);
    }, 3000);
  }
}

function showSponsorInPreview(sponsor) {
  const container = document.getElementById('preview-card-container');
  const d = workingDesigns['timed'];
  const anim = d.sponsor_animation || 'fade';

  // Remove old image immediately to avoid two showing at once
  container.querySelectorAll('.preview-sponsor-wrap').forEach(el => el.remove());

  // Create wrapper div (acts like the banner — fixed size, clips content)
  const wrap = document.createElement('div');
  wrap.className = 'preview-sponsor-wrap';
  const containerWidth = d.card_width || 500;
  wrap.style.width = containerWidth + 'px';
  wrap.style.height = '180px';
  wrap.style.borderRadius = (d.border_radius || 12) + 'px';
  wrap.style.overflow = 'hidden';
  wrap.style.display = 'flex';
  wrap.style.alignItems = 'center';
  wrap.style.justifyContent = 'center';
  wrap.style.background = 'rgba(0,0,0,0.2)';

  // Create image inside wrapper
  const img = document.createElement('img');
  img.className = 'preview-sponsor-img';
  img.src = `/sponsors/${STREAMER_ID}/${sponsor.filename}`;
  img.alt = sponsor.display_name || 'Sponsor';
  img.style.objectFit = 'contain';
  img.style.maxWidth = '100%';
  img.style.maxHeight = '100%';

  // Per-image scale — scales the image within the fixed-size container
  const scale = sponsor.image_scale != null ? sponsor.image_scale : 1.0;
  if (scale < 1) {
    img.style.maxWidth = (scale * 100) + '%';
    img.style.maxHeight = (scale * 100) + '%';
  }

  // Apply entrance animation to the img (not the wrapper, so position isn't affected)
  const animMap = {
    'fade': 'sponsorPreviewFadeIn 0.4s ease-out',
    'slide-left': 'sponsorPreviewSlideLeft 0.4s ease-out',
    'slide-right': 'sponsorPreviewSlideRight 0.4s ease-out',
    'slide-up': 'sponsorPreviewSlideUp 0.4s ease-out',
    'drop-down': 'sponsorPreviewDropDown 0.4s ease-out',
    'zoom': 'sponsorPreviewZoomIn 0.4s ease-out',
    'none': 'none',
  };
  img.style.animation = animMap[anim] || animMap['fade'];

  wrap.appendChild(img);
  container.appendChild(wrap);
  setTimeout(() => updateOverlayGuide(), 100);
}

function replaySponsorAnimation() {
  if (currentType !== 'timed') return;
  const enabled = sponsorImages.filter(s => s.enabled);
  if (enabled.length === 0) return;
  const idx = sponsorPreviewIndex % enabled.length;
  showSponsorInPreview(enabled[idx]);
}

function stopSponsorPreview() {
  clearInterval(sponsorPreviewInterval);
  const container = document.getElementById('preview-card-container');
  const card = document.getElementById('preview-card');
  card.style.display = '';
  container.querySelector('.preview-sponsor-img')?.remove();
}

