<%- include('header', { title: guildName + ' - YouTube Channels', streamer: streamer }) %>

<a href="/dashboard/guild/<%= guildId %>" style="color: #adadb8; font-size: 14px;">&larr; Back to Server Settings</a>
<h2 style="margin: 12px 0 20px;"><%= guildName %> — YouTube Channels</h2>

<% if (msg === 'added') { %>
  <div class="alert alert-success">YouTube channel added! Notifications will start within 5 minutes.</div>
<% } %>
<% if (msg === 'removed') { %>
  <div class="alert alert-success">YouTube channel removed.</div>
<% } %>
<% if (msg === 'missing_fields') { %>
  <div class="alert" style="background: #e74c3c33; border: 1px solid #e74c3c;">Please enter a Channel ID and select at least one notification channel.</div>
<% } %>
<% if (msg === 'upgrade_youtube') { %>
  <div class="alert" style="background: #f39c1233; border: 1px solid #f39c12;">YouTube notifications require a <a href="/pricing">Starter plan or higher</a>.</div>
<% } %>
<% if (msg === 'channel_limit') { %>
  <div class="alert" style="background: #f39c1233; border: 1px solid #f39c12;">You've reached the YouTube channel limit for your plan. <a href="/pricing">Upgrade</a> to add more.</div>
<% } %>

<div class="card">
  <h3>Add a YouTube Channel</h3>
  <p style="color: #adadb8; font-size: 14px; margin-bottom: 16px;">
    Enter a YouTube Channel ID (starts with <code>UC</code>) to get notified about new videos, shorts, and live streams.
    Find any channel ID at <a href="https://commentpicker.com/youtube-channel-id.php" target="_blank">commentpicker.com</a>.
  </p>
  <form method="POST" action="/dashboard/guild/<%= guildId %>/youtube">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
      <div class="form-group">
        <label>YouTube Channel ID</label>
        <input type="text" name="youtube_channel_id" placeholder="UCxxxxxxxxxxxxxxxxxxxxxxxx" required>
      </div>
      <div class="form-group">
        <label>Channel Name (optional, for display)</label>
        <input type="text" name="youtube_channel_name" placeholder="e.g. PewDiePie">
      </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
      <div class="form-group">
        <label>🎬 Videos/Shorts Notifications Channel</label>
        <select name="videos_channel_id">
          <option value="">-- Disabled --</option>
          <% for (const c of channels) { %>
            <option value="<%= c.id %>">#<%= c.name %></option>
          <% } %>
        </select>
      </div>
      <div class="form-group">
        <label>🔴 Live Notifications Channel</label>
        <select name="live_channel_id">
          <option value="">-- Disabled --</option>
          <% for (const c of channels) { %>
            <option value="<%= c.id %>">#<%= c.name %></option>
          <% } %>
        </select>
      </div>
    </div>
    <button type="submit" class="btn btn-primary">Add Channel</button>
  </form>
</div>

<h3 class="section-title" style="margin-top: 24px;">Watched YouTube Channels (<%= watchedChannels.length %>)</h3>

<% if (watchedChannels.length === 0) { %>
  <div class="card" style="text-align: center; padding: 32px; color: #adadb8;">
    <p style="font-size: 24px; margin-bottom: 8px;">🎬</p>
    <p>No YouTube channels being watched yet. Add one above!</p>
  </div>
<% } else { %>
  <% for (const wc of watchedChannels) { %>
    <div class="card" style="display: flex; align-items: center; gap: 16px;">
      <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%; background: #ff000033; display: flex; align-items: center; justify-content: center;">
        <span style="color: #ff0000; font-weight: 700; font-size: 16px;">Y</span>
      </div>
      <div style="flex: 1;">
        <div style="font-weight: 600; color: #efeff1;">
          <%= wc.youtube_channel_name || wc.youtube_channel_id %>
        </div>
        <div style="font-size: 12px; color: #adadb8;">
          <% if (wc.videos_channel_id) { %>🎬 Videos<% } %>
          <% if (wc.videos_channel_id && wc.live_channel_id) { %> &middot; <% } %>
          <% if (wc.live_channel_id) { %>🔴 Live<% } %>
          <% if (!wc.videos_channel_id && !wc.live_channel_id) { %>No notifications configured<% } %>
        </div>
      </div>
      <form method="POST" action="/dashboard/guild/<%= guildId %>/youtube/<%= wc.id %>/remove" style="margin: 0;">
        <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px;">Remove</button>
      </form>
    </div>
  <% } %>
<% } %>

<%- include('footer') %>
