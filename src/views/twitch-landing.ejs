<%- include('header', { title: 'Twitch', streamer: streamer }) %>

<h2 style="margin: 0 0 8px; font-size: 24px; font-weight: 700;" class="animate-in">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="#9146ff" style="vertical-align: middle; margin-right: 8px; margin-top: -3px;">
    <path d="M4.265 3L3 6.236v13.223h4.502V21l2.531.001 2.196-2.196h3.325l4.411-4.411V3H4.265zm14.462 10.715l-2.564 2.564H12l-2.196 2.196v-2.196H5.502V4.502h13.225v9.213zm-2.564-5.862v4.567h-1.502V7.853h1.502zm-4.011 0v4.567H10.65V7.853h1.502z"/>
  </svg>
  Twitch
</h2>
<p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 32px;">Manage your Twitch integrations — overlay notifications and chatbot.</p>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;" class="animate-in animate-in-delay-1">

  <!-- Overlay Card -->
  <a href="/dashboard/twitch/overlay" style="text-decoration: none;">
    <div class="card" style="cursor: pointer; transition: border-color 0.15s, transform 0.15s; border: 1px solid var(--border);"
      onmouseover="this.style.borderColor='#9146ff'; this.style.transform='translateY(-2px)'"
      onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'">
      <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 14px;">
        <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(145,70,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9146ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 3v2M12 19v2M3 12h2M19 12h2"/>
          </svg>
        </div>
        <div>
          <div style="font-size: 16px; font-weight: 700; color: var(--text-primary); font-family: var(--font-display);">Overlay</div>
          <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">OBS Browser Source</div>
        </div>
      </div>
      <p style="color: var(--text-secondary); font-size: 14px; margin: 0 0 16px;">Configure your OBS overlay notifications</p>
      <div style="display: flex; align-items: center; gap: 6px; color: #9146ff; font-size: 13px; font-weight: 600; font-family: var(--font-display);">
        Configure
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </div>
    </div>
  </a>

  <!-- Chatbot Card -->
  <a href="/dashboard/twitch/chatbot" style="text-decoration: none;">
    <div class="card" style="cursor: pointer; transition: border-color 0.15s, transform 0.15s; border: 1px solid var(--border);"
      onmouseover="this.style.borderColor='#9146ff'; this.style.transform='translateY(-2px)'"
      onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'">
      <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 14px;">
        <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(145,70,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9146ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <div>
          <div style="font-size: 16px; font-weight: 700; color: var(--text-primary); font-family: var(--font-display);">Chatbot</div>
          <% if (botConnected) { %>
            <div style="font-size: 12px; color: var(--success); margin-top: 2px; display: flex; align-items: center; gap: 4px;">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--success); display: inline-block;"></span>
              Connected<% if (botUsername) { %> as <%= botUsername %><% } %>
            </div>
          <% } else { %>
            <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">Not connected</div>
          <% } %>
        </div>
      </div>
      <p style="color: var(--text-secondary); font-size: 14px; margin: 0 0 16px;">Manage your Twitch chatbot and commands</p>
      <div style="display: flex; align-items: center; gap: 6px; color: #9146ff; font-size: 13px; font-weight: 600; font-family: var(--font-display);">
        Configure
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </div>
    </div>
  </a>

</div>

<%- include('footer') %>
