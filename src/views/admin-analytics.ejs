<%- include('header', { title: 'Analytics', streamer: null }) %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h2>Analytics</h2>
  <div>
    <a href="/admin/dashboard" class="btn btn-secondary">Dashboard</a>
    <a href="/admin/revenue" class="btn btn-secondary" style="margin-left: 8px;">Revenue</a>
    <a href="/admin/discounts" class="btn btn-secondary" style="margin-left: 8px;">Discounts</a>
    <a href="/admin/logout" class="btn btn-secondary" style="margin-left: 8px;">Logout</a>
  </div>
</div>

<!-- Subscription breakdown -->
<div class="features-grid" style="margin-bottom: 24px;">
  <% for (const t of tierBreakdown) { %>
    <div class="card" style="text-align: center;">
      <div style="font-size: 28px; font-weight: 700; color: #9146ff;"><%= t.count %></div>
      <p style="color: #adadb8; font-size: 14px;"><%= t.tier.charAt(0).toUpperCase() + t.tier.slice(1) %></p>
    </div>
  <% } %>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
  <div class="card">
    <h3>New Users</h3>
    <canvas id="usersChart" height="200"></canvas>
  </div>
  <div class="card">
    <h3>Notifications Sent</h3>
    <canvas id="notificationsChart" height="200"></canvas>
  </div>
  <div class="card">
    <h3>Servers Added</h3>
    <canvas id="serversChart" height="200"></canvas>
  </div>
  <div class="card">
    <h3>Monthly Revenue</h3>
    <canvas id="revenueChart" height="200"></canvas>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
  const chartOpts = { responsive: true, plugins: { legend: { display: false } }, scales: { x: { ticks: { color: '#adadb8' }, grid: { color: '#303032' } }, y: { ticks: { color: '#adadb8' }, grid: { color: '#303032' }, beginAtZero: true } } };

  new Chart(document.getElementById('usersChart'), {
    type: 'line', data: { labels: <%- JSON.stringify(users.map(u => u.period)) %>, datasets: [{ data: <%- JSON.stringify(users.map(u => u.count)) %>, borderColor: '#9146ff', tension: 0.3 }] }, options: chartOpts
  });

  new Chart(document.getElementById('notificationsChart'), {
    type: 'line', data: { labels: <%- JSON.stringify(notifications.map(n => n.period)) %>, datasets: [{ data: <%- JSON.stringify(notifications.map(n => n.count)) %>, borderColor: '#00b894', tension: 0.3 }] }, options: chartOpts
  });

  new Chart(document.getElementById('serversChart'), {
    type: 'line', data: { labels: <%- JSON.stringify(servers.map(s => s.period)) %>, datasets: [{ data: <%- JSON.stringify(servers.map(s => s.count)) %>, borderColor: '#5865F2', tension: 0.3 }] }, options: chartOpts
  });

  new Chart(document.getElementById('revenueChart'), {
    type: 'bar', data: { labels: <%- JSON.stringify(revenue.map(r => r.month)) %>, datasets: [{ data: <%- JSON.stringify(revenue.map(r => r.total)) %>, backgroundColor: '#9146ff88' }] }, options: chartOpts
  });
</script>

<%- include('footer') %>
