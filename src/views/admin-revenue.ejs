<%- include('header', { title: 'Revenue', streamer: null }) %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h2>Revenue</h2>
  <div>
    <a href="/admin/dashboard" class="btn btn-secondary">Dashboard</a>
    <a href="/admin/analytics" class="btn btn-secondary" style="margin-left: 8px;">Analytics</a>
    <a href="/admin/logout" class="btn btn-secondary" style="margin-left: 8px;">Logout</a>
  </div>
</div>

<div class="features-grid" style="margin-bottom: 24px;">
  <div class="card" style="text-align: center;">
    <div style="font-size: 28px; font-weight: 700; color: #00b894;"><%= revenueStats.revenue_today.toFixed(2) %> EUR</div>
    <p style="color: #adadb8; font-size: 14px;">Today</p>
  </div>
  <div class="card" style="text-align: center;">
    <div style="font-size: 28px; font-weight: 700; color: #00b894;"><%= revenueStats.revenue_month.toFixed(2) %> EUR</div>
    <p style="color: #adadb8; font-size: 14px;">This Month</p>
  </div>
  <div class="card" style="text-align: center;">
    <div style="font-size: 28px; font-weight: 700; color: #00b894;"><%= revenueStats.revenue_year.toFixed(2) %> EUR</div>
    <p style="color: #adadb8; font-size: 14px;">This Year</p>
  </div>
  <div class="card" style="text-align: center;">
    <div style="font-size: 28px; font-weight: 700; color: #efeff1;"><%= revenueStats.total_revenue.toFixed(2) %> EUR</div>
    <p style="color: #adadb8; font-size: 14px;">Lifetime (<%= revenueStats.total_transactions %> transactions)</p>
  </div>
</div>

<h3 class="section-title">Recent Transactions</h3>
<% if (transactions.length === 0) { %>
  <p style="color: #adadb8;">No transactions yet.</p>
<% } else { %>
  <div class="card" style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
      <thead>
        <tr style="border-bottom: 1px solid #303032; text-align: left;">
          <th style="padding: 8px; color: #adadb8;">Date</th>
          <th style="padding: 8px; color: #adadb8;">User</th>
          <th style="padding: 8px; color: #adadb8;">Amount</th>
          <th style="padding: 8px; color: #adadb8;">Discount</th>
          <th style="padding: 8px; color: #adadb8;">Status</th>
        </tr>
      </thead>
      <tbody>
        <% for (const t of transactions) { %>
          <tr style="border-bottom: 1px solid #1a1a1d;">
            <td style="padding: 8px; color: #adadb8;"><%= t.created_at %></td>
            <td style="padding: 8px;"><%= t.discord_username %></td>
            <td style="padding: 8px; color: #00b894;"><%= t.amount.toFixed(2) %> <%= t.currency %></td>
            <td style="padding: 8px;"><%= t.discount_code ? t.discount_code + ' (' + t.discount_percent + '%)' : '-' %></td>
            <td style="padding: 8px;"><%= t.status %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('footer') %>
