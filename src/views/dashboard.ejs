      <a href="/dashboard/overlay" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px; text-decoration: none;"><%= streamer.overlay_enabled ? 'Overlay Settings' : 'Configure Overlay' %></a>
    </div>

    <!-- YouTube Chatbot Card -->
    <div class="card animate-in animate-in-delay-1" style="padding: 24px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
