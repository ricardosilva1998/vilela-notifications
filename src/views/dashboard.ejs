        </p>
      <% } %>
      <a href="/dashboard/donations" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px; text-decoration: none; margin-top: auto;">Donation Settings</a>
    </div>

    <!-- Custom Overlays Card — DISABLED for now
    <a href="/dashboard/custom-overlays" class="card" style="text-decoration:none;">
      <div class="card-icon">🎨</div>
      <div class="card-title">Custom Overlays</div>
      <div class="card-desc">Scene banners, info bars, and custom alerts</div>
    </a>
    -->

  </div>
</div>

