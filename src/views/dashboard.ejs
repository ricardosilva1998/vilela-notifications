        <div style="line-height: 1.2;">
          <h3 style="font-size: 16px; font-weight: 700; margin: 0;">YouTube Chatbot</h3>
          <% if (streamer.yt_chatbot_enabled) { %>
            <span style="color: var(--success); font-size: 12px; font-weight: 600;">● Enabled</span>
