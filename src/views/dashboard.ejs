<%- include('header', { title: 'Dashboard', streamer: streamer }) %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
  <div style="display: flex; align-items: center; gap: 12px;">
    <h2>Dashboard</h2>
    <span style="background: #9146ff; color: white; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px;"><%= (tier || 'free').toUpperCase() %></span>
  </div>
  <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord">+ Add Bot to Server</a>
</div>

<% if (msg === 'guild_removed') { %>
  <div class="alert alert-success">Server removed from your account.</div>
<% } %>
<% if (msg === 'twitch_linked') { %>
  <div class="alert alert-success">Twitch account linked successfully!</div>
<% } %>
<% if (msg === 'broadcaster_authorized') { %>
  <div class="alert alert-success">Broadcaster authorized! Sub sync is now available.</div>
<% } %>
<% if (msg === 'youtube_saved') { %>
  <div class="alert alert-success">YouTube settings saved.</div>
<% } %>
<% if (msg === 'guild_limit') { %>
  <div class="alert" style="background: #f39c1233; border: 1px solid #f39c12;">You've reached the server limit for your plan. <a href="/pricing">Upgrade</a> to add more servers.</div>
<% } %>
<% if (msg === 'already_claimed') { %>
  <div class="alert" style="background: #e74c3c33; border: 1px solid #e74c3c;">This server is already configured by another user.</div>
<% } %>

<!-- Quick Links -->
<div style="display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap;">
  <% if (!streamer.twitch_user_id) { %>
    <a href="/auth/twitch" class="btn btn-primary">Link Twitch Account</a>
  <% } else { %>
    <span class="btn btn-secondary" style="cursor: default; opacity: 0.8;">Twitch: <%= streamer.twitch_username %></span>
  <% } %>
  <% if (streamer.twitch_user_id && !streamer.broadcaster_access_token) { %>
    <a href="/auth/broadcaster" class="btn btn-secondary">Enable Sub Sync</a>
  <% } %>
</div>

<!-- Servers -->
<h3 class="section-title">Your Servers</h3>

<% if (guilds.length === 0 && unclaimedGuilds.length === 0) { %>
  <div class="card" style="text-align: center; padding: 40px;">
    <p style="font-size: 28px; margin-bottom: 8px;">🖥️</p>
    <p style="color: #adadb8; margin-bottom: 12px;">No servers yet. Add the bot to a Discord server to get started.</p>
    <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord">Add Bot to Server</a>
  </div>
<% } %>

<div class="guild-list">
  <% for (const g of guilds) { %>
    <div class="card guild-card">
      <div class="guild-icon">
        <% if (g.icon) { %>
          <img src="<%= g.icon %>" alt="">
        <% } else { %>
          <%= g.name.charAt(0) %>
        <% } %>
      </div>
      <div class="guild-info">
        <h4><%= g.name %></h4>
        <p>
          <% if (g.botPresent) { %>
            <span style="color: #00b894;">● Active</span>
          <% } else { %>
            <span style="color: #e74c3c;">● Offline</span>
          <% } %>
        </p>
      </div>
      <div style="display: flex; gap: 8px;">
        <a href="/dashboard/guild/<%= g.guild_id %>/channels" class="btn btn-primary" style="padding: 8px 14px; font-size: 13px;">Channels</a>
        <a href="/dashboard/guild/<%= g.guild_id %>" class="btn btn-secondary" style="padding: 8px 14px; font-size: 13px;">Settings</a>
      </div>
    </div>
  <% } %>
</div>

<% if (unclaimedGuilds.length > 0) { %>
  <h3 class="section-title" style="margin-top: 24px;">Available Servers</h3>
  <p style="color: #adadb8; margin-bottom: 12px; font-size: 14px;">The bot is in these servers. Claim one to start configuring.</p>
  <div class="guild-list">
    <% for (const g of unclaimedGuilds) { %>
      <div class="card guild-card">
        <div class="guild-icon">
          <% if (g.icon) { %>
            <img src="<%= g.icon %>" alt="">
          <% } else { %>
            <%= g.name.charAt(0) %>
          <% } %>
        </div>
        <div class="guild-info">
          <h4><%= g.name %></h4>
          <p style="color: #adadb8;">Ready to configure</p>
        </div>
        <form method="POST" action="/dashboard/claim/<%= g.id %>" style="margin: 0;">
          <button type="submit" class="btn btn-primary" style="padding: 8px 14px; font-size: 13px;">Claim</button>
        </form>
      </div>
    <% } %>
  </div>
<% } %>

<%- include('footer') %>
