<%- include('header', { title: 'Dashboard', streamer: streamer }) %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;" class="animate-in">
  <div style="display: flex; align-items: center; gap: 12px;">
    <h2 style="font-size: 24px; font-weight: 700;"><%= t('dashboard.title') %></h2>
    <span class="badge badge-tier"><%= (tier || 'free').toUpperCase() %></span>
  </div>
</div>

<% if (msg === 'guild_removed') { %><div class="alert alert-success"><%= t('dashboard.guildRemoved') %></div><% } %>
<% if (msg === 'twitch_linked') { %><div class="alert alert-success"><%= t('dashboard.twitchLinked') %></div><% } %>
<% if (msg === 'broadcaster_authorized') { %><div class="alert alert-success"><%= t('dashboard.broadcasterAuthorized') %></div><% } %>
<% if (msg === 'youtube_saved') { %><div class="alert alert-success"><%= t('dashboard.youtubeSaved') %></div><% } %>
<% if (msg === 'guild_limit') { %><div class="alert alert-warning"><%= t('dashboard.guildLimit') %></div><% } %>
<% if (msg === 'already_claimed') { %><div class="alert alert-danger"><%= t('dashboard.alreadyClaimed') %></div><% } %>

<!-- Quick Links -->
<div style="display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap;" class="animate-in animate-in-delay-1">
  <% if (!streamer.twitch_user_id) { %>
    <a href="/auth/twitch" class="btn btn-primary" style="padding: 8px 16px; font-size: 13px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
      <%= t('dashboard.linkTwitch') %>
    </a>
  <% } else { %>
    <span class="btn btn-secondary" style="cursor: default; padding: 8px 16px; font-size: 13px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      Twitch: <%= streamer.twitch_username %>
    </span>
  <% } %>
  <% if (streamer.twitch_user_id && !streamer.broadcaster_access_token) { %>
    <a href="/auth/broadcaster" class="btn btn-secondary" style="padding: 8px 16px; font-size: 13px;"><%= t('dashboard.enableSubSync') %></a>
  <% } %>
  <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord" style="padding: 8px 16px; font-size: 13px;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    <%= t('dashboard.addBot') %>
  </a>
</div>

<h3 class="section-title animate-in animate-in-delay-2" style="display: flex; align-items: center; gap: 10px;">
  <%= t('dashboard.yourServers') %>
  <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 26px; height: 26px; padding: 0 8px; border-radius: 6px; background: var(--accent); color: white; font-size: 12px; font-weight: 700; font-family: var(--font-display);"><%= guilds.length %></span>
</h3>

<% if (guilds.length === 0 && unclaimedGuilds.length === 0) { %>
  <div class="card animate-in animate-in-delay-3" style="text-align: center; padding: 48px 24px;">
    <div style="width: 56px; height: 56px; border-radius: 16px; background: var(--bg-elevated); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </div>
    <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 14px;"><%= t('dashboard.noServers') %></p>
    <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord"><%= t('dashboard.addBot') %></a>
  </div>
<% } %>

<div style="display: grid; gap: 16px;">
  <% guilds.forEach(function(g, i) { %>
    <div class="card animate-in" style="animation-delay: <%= 0.1 + i * 0.05 %>s; padding: 20px;">
      <!-- Server Header -->
      <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 16px;">
        <div class="guild-icon">
          <% if (g.icon) { %><img src="<%= g.icon %>" alt=""><% } else { %><%= g.name.charAt(0) %><% } %>
        </div>
        <div style="flex: 1; min-width: 0;">
          <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= g.name %></h4>
          <div style="display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 12px; color: var(--text-secondary);">
              <% if (g.botPresent) { %><span class="status-dot online"></span><%= t('dashboard.active') %><% } else { %><span class="status-dot offline"></span><%= t('dashboard.offline') %><% } %>
            </span>
            <span style="font-size: 11px; color: var(--text-muted);"><%= g.twitchCount %> Twitch &middot; <%= g.youtubeCount %> YouTube</span>
          </div>
        </div>
        <div style="display: flex; gap: 6px; flex-shrink: 0;">
          <button onclick="toggleStats('<%= g.guild_id %>')" class="btn btn-secondary" style="padding: 7px 12px; font-size: 12px;" id="stats-btn-<%= g.guild_id %>">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Stats
          </button>
          <a href="/dashboard/guild/<%= g.guild_id %>" class="btn btn-primary" style="padding: 7px 12px; font-size: 12px;"><%= t('dashboard.configure') %></a>
        </div>
      </div>

      <!-- Summary (always visible) -->
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
        <div class="stat-card">
          <div class="stat-tooltip">Notifications sent when a Twitch channel goes live</div>
          <div class="stat-value" style="color: var(--accent);"><%= g.stats.live_count %></div>
          <div class="stat-label">Live Alerts</div>
        </div>
        <div class="stat-card">
          <div class="stat-tooltip">Clip notifications shared to Discord from Twitch</div>
          <div class="stat-value" style="color: #bf94ff;"><%= g.stats.clip_count %></div>
          <div class="stat-label">Clips Shared</div>
        </div>
        <div class="stat-card">
          <div class="stat-tooltip">YouTube video and livestream notifications combined</div>
          <div class="stat-value" style="color: #f04438;"><%= g.stats.youtube_video_count + g.stats.youtube_live_count %></div>
          <div class="stat-label">YouTube Alerts</div>
        </div>
        <div class="stat-card">
          <div class="stat-tooltip">Total notifications of all types sent to this server</div>
          <div class="stat-value" style="color: var(--text-primary);"><%= g.stats.total %></div>
          <div class="stat-label">All Notifications</div>
        </div>
      </div>

      <!-- Expandable Stats -->
      <div id="stats-<%= g.guild_id %>" style="display: none; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">

        <!-- Individual charts per notification type -->
        <%
          const typeKeys = ['twitch_live', 'twitch_clip', 'twitch_recap', 'twitch_milestone', 'youtube_video', 'youtube_live', 'weekly_digest'];
          const typeColors = { twitch_live: '#9146ff', twitch_clip: '#bf94ff', twitch_recap: '#6d28d9', twitch_milestone: '#f1c40f', youtube_video: '#f04438', youtube_live: '#ff6b6b', weekly_digest: '#3498db' };
          const typeNames = { twitch_live: 'Go-Live Alerts', twitch_clip: 'Clip Notifications', twitch_recap: 'Stream Recaps', twitch_milestone: 'Milestones', youtube_video: 'YouTube Video Alerts', youtube_live: 'YouTube Live Alerts', weekly_digest: 'Weekly Digests' };
          const activeTypes = typeKeys.filter(function(tk) { return g.chartData.some(function(d) { return (d[tk] || 0) > 0; }); });
        %>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;">
          <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">Last 30 days by type</div>
          <div style="font-size: 11px; color: var(--text-muted);"><%= g.stats.total %> total all time</div>
        </div>

        <% if (g.chartData.length === 0 || activeTypes.length === 0) { %>
          <div style="text-align: center; padding: 24px 0; color: var(--text-muted); font-size: 13px; background: var(--bg-base); border-radius: var(--radius-sm); border: 1px solid var(--border); margin-bottom: 20px;">No notifications in the last 30 days</div>
        <% } else { %>
          <div style="display: grid; grid-template-columns: repeat(<%= activeTypes.length <= 3 ? activeTypes.length : Math.ceil(activeTypes.length / 2) %>, 1fr); gap: 10px; margin-bottom: 20px;">
            <% activeTypes.forEach(function(tk) {
              const typeTotal = g.chartData.reduce(function(s, d) { return s + (d[tk] || 0); }, 0);
              const maxV = Math.max(...g.chartData.map(function(d) { return d[tk] || 0; }), 1);
            %>
              <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 12px; border: 1px solid var(--border);">
                <!-- Header -->
                <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
                  <div style="width: 8px; height: 8px; border-radius: 2px; background: <%= typeColors[tk] %>; flex-shrink: 0;"></div>
                  <span style="font-size: 11px; color: var(--text-secondary); font-family: var(--font-display); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= typeNames[tk] %></span>
                  <span style="font-size: 11px; color: var(--text-muted); margin-left: auto; font-weight: 700;"><%= typeTotal %></span>
                </div>
                <!-- Mini bar chart -->
                <div style="display: flex; align-items: flex-end; gap: 1px; height: 40px;">
                  <% g.chartData.forEach(function(d) {
                    const val = d[tk] || 0;
                    const barH = Math.round(Math.max((val / maxV) * 40, val > 0 ? 2 : 1));
                  %>
                    <div style="flex: 1; height: 100%; display: flex; flex-direction: column; justify-content: flex-end;" title="<%= d.period %>: <%= val %>">
                      <div style="width: 100%; background: <%= typeColors[tk] %>; border-radius: 1px 1px 0 0; height: <%= barH %>px; opacity: <%= val > 0 ? 0.9 : 0.08 %>;"></div>
                    </div>
                  <% }); %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>

        <!-- === TWITCH === -->
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border); margin-bottom: 12px;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
            <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">Twitch</div>
            <span style="font-size: 11px; color: var(--text-muted); margin-left: auto;"><%= g.twitchCount %> channel<%= g.twitchCount !== 1 ? 's' : '' %> watched</span>
          </div>
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Posted when a monitored Twitch channel starts streaming</div>
              <div class="stat-value" style="color: var(--accent);"><%= g.stats.live_count %></div>
              <div class="stat-label">Go-Live Alerts</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Shared when a new clip is created on a watched channel</div>
              <div class="stat-value" style="color: #bf94ff;"><%= g.stats.clip_count %></div>
              <div class="stat-label">Clip Notifications</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Summary posted after a stream ends with duration, category, and top clips</div>
              <div class="stat-value" style="color: #6d28d9;"><%= g.stats.recap_count %></div>
              <div class="stat-label">Stream Recaps</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Celebration posted when a channel hits a follower or subscriber milestone</div>
              <div class="stat-value" style="color: #f1c40f;"><%= g.stats.milestone_count %></div>
              <div class="stat-label">Milestones</div>
            </div>
          </div>
        </div>

        <!-- === YOUTUBE === -->
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border); margin-bottom: 12px;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#f04438"/></svg>
            <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">YouTube</div>
            <span style="font-size: 11px; color: var(--text-muted); margin-left: auto;"><%= g.youtubeCount %> channel<%= g.youtubeCount !== 1 ? 's' : '' %> watched</span>
          </div>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Sent when a watched YouTube channel uploads a new video or short</div>
              <div class="stat-value" style="color: #f04438;"><%= g.stats.youtube_video_count %></div>
              <div class="stat-label">New Video Alerts</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Sent when a watched YouTube channel starts a live stream</div>
              <div class="stat-value" style="color: #ff6b6b;"><%= g.stats.youtube_live_count %></div>
              <div class="stat-label">YouTube Live Alerts</div>
            </div>
          </div>
        </div>

        <!-- === DISCORD / COMMUNITY === -->
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border);">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5865F2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">Discord & Community</div>
          </div>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;">
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Automatic weekly summary posted every Monday with stream stats and top clips</div>
              <div class="stat-value" style="color: #3498db;"><%= g.stats.digest_count %></div>
              <div class="stat-label">Weekly Digests</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">All notifications sent to this server in the past 7 days</div>
              <div class="stat-value" style="color: var(--success);"><%= g.stats.week_total %></div>
              <div class="stat-label">Sent This Week</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Total notifications ever sent to this server across all features</div>
              <div class="stat-value" style="color: var(--text-primary);"><%= g.stats.total %></div>
              <div class="stat-label">All Time Total</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  <% }); %>
</div>

<% if (unclaimedGuilds.length > 0) { %>
  <h3 class="section-title" style="margin-top: 28px; display: flex; align-items: center; gap: 10px;">
    <%= t('dashboard.availableServers') %>
    <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 26px; height: 26px; padding: 0 8px; border-radius: 6px; background: var(--bg-elevated); color: var(--text-secondary); font-size: 12px; font-weight: 700; font-family: var(--font-display); border: 1px solid var(--border);"><%= unclaimedGuilds.length %></span>
  </h3>
  <p style="color: var(--text-secondary); margin-bottom: 12px; font-size: 14px;"><%= t('dashboard.availableServersDesc') %></p>
  <div class="guild-list">
    <% unclaimedGuilds.forEach(function(g, i) { %>
      <div class="card guild-card animate-in" style="animation-delay: <%= 0.05 + i * 0.05 %>s;">
        <div class="guild-icon">
          <% if (g.icon) { %><img src="<%= g.icon %>" alt=""><% } else { %><%= g.name.charAt(0) %><% } %>
        </div>
        <div class="guild-info">
          <h4><%= g.name %></h4>
          <p style="color: var(--text-muted);"><%= t('dashboard.readyToConfigure') %></p>
        </div>
        <form method="POST" action="/dashboard/claim/<%= g.id %>" style="margin: 0;">
          <button type="submit" class="btn btn-primary" style="padding: 7px 14px; font-size: 12px;"><%= t('dashboard.claim') %></button>
        </form>
      </div>
    <% }); %>
  </div>
<% } %>

<script>
function toggleStats(guildId) {
  var panel = document.getElementById('stats-' + guildId);
  var btn = document.getElementById('stats-btn-' + guildId);
  var isOpen = panel.style.display !== 'none';
  panel.style.display = isOpen ? 'none' : 'block';
  btn.style.background = isOpen ? '' : 'var(--accent)';
  btn.style.color = isOpen ? '' : 'white';
}
</script>

<style>
  @media (max-width: 640px) {
    .stat-tooltip { display: none !important; }
  }
  @media (max-width: 520px) {
    div[style*="grid-template-columns: repeat(4, 1fr)"] { grid-template-columns: repeat(2, 1fr) !important; }
    div[style*="grid-template-columns: repeat(3, 1fr)"] { grid-template-columns: 1fr 1fr !important; }
    div[style*="grid-template-columns: repeat(2, 1fr)"] { grid-template-columns: 1fr !important; }
  }
</style>

<%- include('footer') %>
