<%- include('header', { title: 'Dashboard', streamer: streamer }) %>

<style>
  .tab-discord.active { background: #5865F2; }
  .tab-twitch.active { background: #9146ff; }
  .tab-youtube.active { background: #ff0000; }
  .tab-kick.active { background: #53fc18; color: #000; }
  .tab-iracing.active { background: linear-gradient(135deg, #1a1a2e, #16213e); border: 1px solid #8888cc; }
  .tab-experimental.active { background: linear-gradient(135deg, #667eea, #764ba2); }
  .tab-admin.active { background: #e74c3c; }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;" class="animate-in">
  <div style="display: flex; align-items: center; gap: 12px;">
    <h2 style="font-size: 24px; font-weight: 700;"><%= t('dashboard.title') %></h2>
  </div>
</div>

<% if (msg === 'guild_removed') { %><div class="alert alert-success"><%= t('dashboard.guildRemoved') %></div><% } %>
<% if (msg === 'twitch_linked') { %><div class="alert alert-success"><%= t('dashboard.twitchLinked') %></div><% } %>
<% if (msg === 'broadcaster_authorized') { %><div class="alert alert-success"><%= t('dashboard.broadcasterAuthorized') %></div><% } %>
<% if (msg === 'youtube_saved') { %><div class="alert alert-success"><%= t('dashboard.youtubeSaved') %></div><% } %>
<% if (msg === 'guild_limit') { %><div class="alert alert-warning"><%= t('dashboard.guildLimit') %></div><% } %>
<% if (msg === 'already_claimed') { %><div class="alert alert-danger"><%= t('dashboard.alreadyClaimed') %></div><% } %>
<% if (msg === 'spotify_connected') { %><div class="alert alert-success">Spotify account connected! Viewers can now use !song.</div><% } %>
<% if (msg === 'spotify_error') { %><div class="alert alert-danger">Failed to connect Spotify. Please try again.</div><% } %>

<!-- Platform Tabs -->
<div class="tab-bar animate-in animate-in-delay-1">
  <button class="tab-btn tab-discord" data-tab="discord">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.9 5a19.5 19.5 0 0 0-4.8-1.5 14.6 14.6 0 0 0-.6 1.3 18 18 0 0 0-5 0A14 14 0 0 0 7.9 3.5 19.5 19.5 0 0 0 3.1 5 20.6 20.6 0 0 0 .5 17.6a19.6 19.6 0 0 0 6 3 14.8 14.8 0 0 0 1.3-2 12.7 12.7 0 0 1-2-.9l.5-.4a14 14 0 0 0 11.9 0l.5.4a12.7 12.7 0 0 1-2 .9 14.8 14.8 0 0 0 1.3 2 19.6 19.6 0 0 0 6-3A20.6 20.6 0 0 0 21 5z"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/></svg>
    Discord
  </button>
  <button class="tab-btn tab-twitch" data-tab="twitch">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
    Twitch
  </button>
  <button class="tab-btn tab-youtube" data-tab="youtube">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.5 7.7a2.8 2.8 0 0 0-2-2C18.9 5 12 5 12 5s-6.9 0-8.5.7a2.8 2.8 0 0 0-2 2A29 29 0 0 0 1 12a29 29 0 0 0 .5 4.3 2.8 2.8 0 0 0 2 2c1.6.7 8.5.7 8.5.7s6.9 0 8.5-.7a2.8 2.8 0 0 0 2-2A29 29 0 0 0 23 12a29 29 0 0 0-.5-4.3z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
    YouTube
  </button>
  <button class="tab-btn tab-kick" data-tab="kick">
    <svg width="30" height="10" viewBox="0 0 78 26" fill="currentColor"><path fill-rule="evenodd" clip-rule="evenodd" d="M0 0.0307312H8.34073V5.79423H11.1163V2.91248H13.8919V0.0307312H22.2326V8.69274H19.457V11.5745H16.6815V14.4562H19.457V17.338H22.2326V26H13.8919V23.1182H11.1163V20.2365H8.34073V26H0V0.0307312ZM55.6444 0.0307312H63.9852V5.79423H66.7608V2.91248H69.5363V0.0307312H77.8771V8.69274H75.1015V11.5745H72.3259V14.4562H75.1015V17.338H77.8771V26H69.5363V23.1182H66.7608V20.2365H63.9852V26H55.6444V0.0307312ZM25.039 0.0307312H33.3797V26H25.039V0.0307312ZM38.9462 0.0307312V2.91248H36.1706V23.1029H38.9462V25.9846H52.8535V17.3226H44.5128V8.66061H52.8535V0H38.9462V0.0307312Z"/></svg>
  </button>
  <button class="tab-btn tab-iracing" data-tab="iracing">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
    iRacing
  </button>
  <button class="tab-btn tab-experimental" data-tab="experimental">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v8l4 9H5l4-9V3z"/><path d="M9 3h6"/></svg>
    Experimental
  </button>
  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
  <button class="tab-btn tab-admin" data-tab="admin">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
    Admin
  </button>
  <% } %>
</div>

<div class="tab-content active" id="tab-discord">

<div class="animate-in animate-in-delay-2" style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
  <h3 class="section-title" style="margin: 0; line-height: 1;">
    <%= t('dashboard.yourServers') %>
  </h3>
  <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 26px; height: 26px; padding: 0 8px; border-radius: 6px; background: var(--accent); color: white; font-size: 12px; font-weight: 700; font-family: var(--font-display); vertical-align: middle;"><%= guilds.length %></span>
  <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord" style="padding: 8px 16px; font-size: 13px; margin-left: auto;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    <%= t('dashboard.addBot') %>
  </a>
</div>

<% if (guilds.length === 0 && unclaimedGuilds.length === 0) { %>
  <div class="card animate-in animate-in-delay-3" style="text-align: center; padding: 48px 24px;">
    <div style="width: 56px; height: 56px; border-radius: 16px; background: var(--bg-elevated); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </div>
    <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 14px;"><%= t('dashboard.noServers') %></p>
    <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord"><%= t('dashboard.addBot') %></a>
  </div>
<% } %>

<div style="display: grid; gap: 16px;">
  <% guilds.forEach(function(g, i) { %>
    <div class="card animate-in" style="animation-delay: <%= 0.1 + i * 0.05 %>s; padding: 20px;">
      <!-- Server Header -->
      <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 16px;">
        <div class="guild-icon">
          <% if (g.icon) { %><img src="<%= g.icon %>" alt=""><% } else { %><%= g.name.charAt(0) %><% } %>
        </div>
        <div style="flex: 1; min-width: 0;">
          <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= g.name %></h4>
          <div style="display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 12px; color: var(--text-secondary);">
              <% if (g.botPresent) { %><span class="status-dot online"></span><%= t('dashboard.active') %><% } else { %><span class="status-dot offline"></span><%= t('dashboard.offline') %><% } %>
            </span>
            <span style="font-size: 11px; color: var(--text-muted);"><%= g.twitchCount %> Twitch &middot; <%= g.youtubeCount %> YouTube</span>
          </div>
        </div>
        <div style="display: flex; gap: 6px; flex-shrink: 0;">
          <button onclick="toggleStats('<%= g.guild_id %>')" class="btn btn-secondary" style="padding: 7px 12px; font-size: 12px;" id="stats-btn-<%= g.guild_id %>">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Stats
          </button>
          <a href="/dashboard/guild/<%= g.guild_id %>" class="btn btn-primary" style="padding: 7px 12px; font-size: 12px;"><%= t('dashboard.configure') %></a>
        </div>
      </div>

      <!-- Summary (always visible) -->
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
        <div class="stat-card">
          <div class="stat-tooltip">Notifications sent when a Twitch channel goes live</div>
          <div class="stat-value" style="color: var(--accent);"><%= g.stats.live_count %></div>
          <div class="stat-label">Live Alerts</div>
        </div>
        <div class="stat-card">
          <div class="stat-tooltip">Clip notifications shared to Discord from Twitch</div>
          <div class="stat-value" style="color: #bf94ff;"><%= g.stats.clip_count %></div>
          <div class="stat-label">Clips Shared</div>
        </div>
        <div class="stat-card">
          <div class="stat-tooltip">YouTube video and livestream notifications combined</div>
          <div class="stat-value" style="color: #f04438;"><%= g.stats.youtube_video_count + g.stats.youtube_live_count %></div>
          <div class="stat-label">YouTube Alerts</div>
        </div>
        <div class="stat-card">
          <div class="stat-tooltip">Total notifications of all types sent to this server</div>
          <div class="stat-value" style="color: var(--text-primary);"><%= g.stats.total %></div>
          <div class="stat-label">All Notifications</div>
        </div>
      </div>

      <!-- Expandable Stats -->
      <div id="stats-<%= g.guild_id %>" style="display: none; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">

        <!-- Individual charts per notification type -->
        <%
          const typeKeys = ['twitch_live', 'twitch_clip', 'twitch_recap', 'twitch_milestone', 'youtube_video', 'youtube_short', 'youtube_live', 'weekly_digest', 'instagram_post', 'tiktok_video', 'twitter_tweet', 'iracing_result'];
          const typeColors = { twitch_live: '#9146ff', twitch_clip: '#bf94ff', twitch_recap: '#6d28d9', twitch_milestone: '#f1c40f', youtube_video: '#f04438', youtube_short: '#ff6b6b', youtube_live: '#ff4444', weekly_digest: '#3498db', instagram_post: '#E1306C', tiktok_video: '#010101', twitter_tweet: '#1DA1F2', iracing_result: '#1a1a2e' };
          const typeNames = { twitch_live: 'Go-Live Alerts', twitch_clip: 'Clip Notifications', twitch_recap: 'Stream Recaps', twitch_milestone: 'Milestones', youtube_video: 'YouTube Video Alerts', youtube_short: 'YouTube Shorts', youtube_live: 'YouTube Live Alerts', weekly_digest: 'Weekly Digests', instagram_post: 'Instagram Posts', tiktok_video: 'TikTok Videos', twitter_tweet: 'Tweets', iracing_result: 'iRacing Results' };
          const activeTypes = typeKeys.filter(function(tk) { return g.chartData.some(function(d) { return (d[tk] || 0) > 0; }); });
        %>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;">
          <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">Last 30 days by type</div>
          <div style="font-size: 11px; color: var(--text-muted);"><%= g.stats.total %> total all time</div>
        </div>

        <% if (g.chartData.length === 0 || activeTypes.length === 0) { %>
          <div style="text-align: center; padding: 24px 0; color: var(--text-muted); font-size: 13px; background: var(--bg-base); border-radius: var(--radius-sm); border: 1px solid var(--border); margin-bottom: 20px;">No notifications in the last 30 days</div>
        <% } else { %>
          <div style="display: grid; grid-template-columns: repeat(<%= activeTypes.length <= 3 ? activeTypes.length : Math.ceil(activeTypes.length / 2) %>, 1fr); gap: 10px; margin-bottom: 20px;">
            <% activeTypes.forEach(function(tk) {
              const typeTotal = g.chartData.reduce(function(s, d) { return s + (d[tk] || 0); }, 0);
              const maxV = Math.max(...g.chartData.map(function(d) { return d[tk] || 0; }), 1);
            %>
              <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 12px; border: 1px solid var(--border);">
                <!-- Header -->
                <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
                  <div style="width: 8px; height: 8px; border-radius: 2px; background: <%= typeColors[tk] %>; flex-shrink: 0;"></div>
                  <span style="font-size: 11px; color: var(--text-secondary); font-family: var(--font-display); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= typeNames[tk] %></span>
                  <span style="font-size: 11px; color: var(--text-muted); margin-left: auto; font-weight: 700;"><%= typeTotal %></span>
                </div>
                <!-- Mini bar chart -->
                <div style="display: flex; align-items: flex-end; gap: 1px; height: 40px;">
                  <% g.chartData.forEach(function(d) {
                    const val = d[tk] || 0;
                    const barH = Math.round(Math.max((val / maxV) * 40, val > 0 ? 2 : 1));
                  %>
                    <div style="flex: 1; height: 100%; display: flex; flex-direction: column; justify-content: flex-end;" title="<%= d.period %>: <%= val %>">
                      <div style="width: 100%; background: <%= typeColors[tk] %>; border-radius: 1px 1px 0 0; height: <%= barH %>px; opacity: <%= val > 0 ? 0.9 : 0.08 %>;"></div>
                    </div>
                  <% }); %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>

        <!-- === TWITCH === -->
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border); margin-bottom: 12px;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
            <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">Twitch</div>
            <span style="font-size: 11px; color: var(--text-muted); margin-left: auto;"><%= g.twitchCount %> channel<%= g.twitchCount !== 1 ? 's' : '' %> watched</span>
          </div>
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Posted when a monitored Twitch channel starts streaming</div>
              <div class="stat-value" style="color: var(--accent);"><%= g.stats.live_count %></div>
              <div class="stat-label">Go-Live Alerts</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Shared when a new clip is created on a watched channel</div>
              <div class="stat-value" style="color: #bf94ff;"><%= g.stats.clip_count %></div>
              <div class="stat-label">Clip Notifications</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Summary posted after a stream ends with duration, category, and top clips</div>
              <div class="stat-value" style="color: #6d28d9;"><%= g.stats.recap_count %></div>
              <div class="stat-label">Stream Recaps</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Celebration posted when a channel hits a follower or subscriber milestone</div>
              <div class="stat-value" style="color: #f1c40f;"><%= g.stats.milestone_count %></div>
              <div class="stat-label">Milestones</div>
            </div>
          </div>
        </div>

        <!-- === YOUTUBE === -->
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border); margin-bottom: 12px;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#f04438"/></svg>
            <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">YouTube</div>
            <span style="font-size: 11px; color: var(--text-muted); margin-left: auto;"><%= g.youtubeCount %> channel<%= g.youtubeCount !== 1 ? 's' : '' %> watched</span>
          </div>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Sent when a watched YouTube channel uploads a new video or short</div>
              <div class="stat-value" style="color: #f04438;"><%= g.stats.youtube_video_count %></div>
              <div class="stat-label">New Video Alerts</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Sent when a watched YouTube channel starts a live stream</div>
              <div class="stat-value" style="color: #ff6b6b;"><%= g.stats.youtube_live_count %></div>
              <div class="stat-label">YouTube Live Alerts</div>
            </div>
          </div>
        </div>

        <!-- === DISCORD / COMMUNITY === -->
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border);">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5865F2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <div style="font-size: 13px; color: var(--text-primary); font-family: var(--font-display); font-weight: 600;">Discord & Community</div>
          </div>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;">
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Automatic weekly summary posted every Monday with stream stats and top clips</div>
              <div class="stat-value" style="color: #3498db;"><%= g.stats.digest_count %></div>
              <div class="stat-label">Weekly Digests</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">All notifications sent to this server in the past 7 days</div>
              <div class="stat-value" style="color: var(--success);"><%= g.stats.week_total %></div>
              <div class="stat-label">Sent This Week</div>
            </div>
            <div class="stat-card" style="padding: 12px;">
              <div class="stat-tooltip">Total notifications ever sent to this server across all features</div>
              <div class="stat-value" style="color: var(--text-primary);"><%= g.stats.total %></div>
              <div class="stat-label">All Time Total</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  <% }); %>
</div>

<% if (unclaimedGuilds.length > 0) { %>
  <h3 class="section-title" style="margin-top: 28px; display: flex; align-items: center; gap: 10px;">
    <%= t('dashboard.availableServers') %>
    <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 26px; height: 26px; padding: 0 8px; border-radius: 6px; background: var(--bg-elevated); color: var(--text-secondary); font-size: 12px; font-weight: 700; font-family: var(--font-display); border: 1px solid var(--border);"><%= unclaimedGuilds.length %></span>
  </h3>
  <p style="color: var(--text-secondary); margin-bottom: 12px; font-size: 14px;"><%= t('dashboard.availableServersDesc') %></p>
  <div class="guild-list">
    <% unclaimedGuilds.forEach(function(g, i) { %>
      <div class="card guild-card animate-in" style="animation-delay: <%= 0.05 + i * 0.05 %>s;">
        <div class="guild-icon">
          <% if (g.icon) { %><img src="<%= g.icon %>" alt=""><% } else { %><%= g.name.charAt(0) %><% } %>
        </div>
        <div class="guild-info">
          <h4><%= g.name %></h4>
          <p style="color: var(--text-muted);"><%= t('dashboard.readyToConfigure') %></p>
        </div>
        <form method="POST" action="/dashboard/claim/<%= g.id %>" style="margin: 0;">
          <button type="submit" class="btn btn-primary" style="padding: 7px 14px; font-size: 12px;"><%= t('dashboard.claim') %></button>
        </form>
      </div>
    <% }); %>
  </div>
<% } %>

</div><!-- end tab-discord -->

<div class="tab-content" id="tab-twitch">

  <!-- Twitch Account -->
  <div style="display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;">
    <% if (!streamer.twitch_user_id) { %>
      <a href="/auth/twitch" class="btn btn-primary" style="padding: 8px 16px; font-size: 13px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
        <%= t('dashboard.linkTwitch') %>
      </a>
    <% } else { %>
      <span class="btn btn-secondary" style="cursor: default; padding: 8px 16px; font-size: 13px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Twitch: <%= streamer.twitch_username %>
      </span>
    <% } %>
    <% if (streamer.twitch_user_id && !streamer.broadcaster_access_token) { %>
      <a href="/auth/broadcaster" class="btn btn-secondary" style="padding: 8px 16px; font-size: 13px;"><%= t('dashboard.enableSubSync') %></a>
    <% } %>
  </div>

  <!-- 7-Day Stream Activity -->
  <% if (typeof overlayStats !== 'undefined' && overlayStats) { %>
  <div class="card animate-in" style="margin-bottom: 16px; padding: 20px 24px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
      <div style="display: flex; align-items: center; gap: 10px;">
        <div style="width: 36px; height: 36px; border-radius: 10px; background: rgba(145,70,255,0.15); display: flex; align-items: center; justify-content: center;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        </div>
        <div>
          <h3 style="font-size: 15px; font-weight: 700; margin: 0;">Last 7 Days</h3>
          <span style="color: var(--text-muted); font-size: 11px;">Stream activity overview</span>
        </div>
      </div>
      <span style="font-size: 12px; color: var(--text-muted); font-family: var(--font-display);"><%= overlayStats.total %> events total</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px;">
      <div style="background: var(--bg-elevated); border-radius: 10px; padding: 12px; text-align: center;">
        <div style="font-size: 22px; font-weight: 800; color: #8888cc; font-family: var(--font-display);"><%= overlayStats.follows %></div>
        <div style="font-size: 10px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px;">Follows</div>
      </div>
      <div style="background: var(--bg-elevated); border-radius: 10px; padding: 12px; text-align: center;">
        <div style="font-size: 22px; font-weight: 800; color: #00ff88; font-family: var(--font-display);"><%= overlayStats.subs %></div>
        <div style="font-size: 10px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px;">Subs</div>
      </div>
      <div style="background: var(--bg-elevated); border-radius: 10px; padding: 12px; text-align: center;">
        <div style="font-size: 22px; font-weight: 800; color: #f7c948; font-family: var(--font-display);"><%= overlayStats.bits_events %></div>
        <div style="font-size: 10px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px;">Bits</div>
      </div>
      <div style="background: var(--bg-elevated); border-radius: 10px; padding: 12px; text-align: center;">
        <div style="font-size: 22px; font-weight: 800; color: #bf00ff; font-family: var(--font-display);"><%= overlayStats.donations %></div>
        <div style="font-size: 10px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px;">Donations</div>
      </div>
      <div style="background: var(--bg-elevated); border-radius: 10px; padding: 12px; text-align: center;">
        <div style="font-size: 22px; font-weight: 800; color: #ff4444; font-family: var(--font-display);"><%= overlayStats.raids %></div>
        <div style="font-size: 10px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px;">Raids</div>
      </div>
      <div style="background: var(--bg-elevated); border-radius: 10px; padding: 12px; text-align: center;">
        <div style="font-size: 22px; font-weight: 800; color: #00ff88; font-family: var(--font-display);"><%= overlayStats.giftsubs %></div>
        <div style="font-size: 10px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px;">Gift Subs</div>
      </div>
    </div>
  </div>
  <% } %>

  <div class="twitch-cards-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; align-items: stretch;">

    <!-- Overlay Card -->
    <div class="card animate-in" style="padding: 24px; display: flex; flex-direction: column;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
        <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(145,71,255,0.15); display: flex; align-items: center; justify-content: center;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9146ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div>
          <h3 style="font-size: 16px; font-weight: 700;">OBS Overlay</h3>
          <% if (streamer.overlay_enabled) { %>
            <span style="color: var(--success); font-size: 12px; font-weight: 600;">● Enabled</span>
          <% } else { %>
            <span style="color: var(--text-muted); font-size: 12px;">● Not configured</span>
          <% } %>
        </div>
      </div>
      <% if (overlayUrl) { %>
        <div style="margin-bottom: 8px;">
          <label style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 4px;">Alerts Overlay</label>
          <div style="display: flex; gap: 6px;">
            <input type="text" value="<%= overlayUrl %>" readonly id="overlay-url-copy" style="flex: 1; background: var(--bg-surface); border: 1px solid var(--border); color: var(--text-primary); padding: 6px 8px; border-radius: var(--radius-sm); font-size: 11px; font-family: monospace;">
            <button onclick="navigator.clipboard.writeText(document.getElementById('overlay-url-copy').value); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 1500);" class="btn btn-secondary" style="font-size: 11px; padding: 6px 10px; white-space: nowrap;">Copy</button>
          </div>
        </div>
        <div style="margin-bottom: 12px;">
          <label style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 4px;">Sponsors Overlay</label>
          <div style="display: flex; gap: 6px;">
            <input type="text" value="<%= overlayUrl.replace('/overlay/', '/overlay/sponsors/') %>" readonly id="sponsor-url-copy" style="flex: 1; background: var(--bg-surface); border: 1px solid var(--border); color: var(--text-primary); padding: 6px 8px; border-radius: var(--radius-sm); font-size: 11px; font-family: monospace;">
            <button onclick="navigator.clipboard.writeText(document.getElementById('sponsor-url-copy').value); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 1500);" class="btn btn-secondary" style="font-size: 11px; padding: 6px 10px; white-space: nowrap;">Copy</button>
          </div>
        </div>
      <% } else { %>
        <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px; line-height: 1.5;">
          Configure animated notification banners for follows, subs, bits, donations, and raids in your OBS stream.
        </p>
      <% } %>
      <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-top: auto;">
        <a href="/dashboard/overlay" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px; text-decoration: none;"><%= overlayUrl ? 'Overlay Settings' : 'Configure Overlay' %></a>
        <% if (overlayUrl) { %>
        <a href="/dashboard/overlay-builder" style="font-size: 13px; padding: 8px 14px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; background: rgba(145,71,255,0.1); border: 1px solid rgba(145,71,255,0.25); border-radius: var(--radius-sm); color: #9146ff; font-family: var(--font-display); font-weight: 600; transition: all 0.15s;" onmouseover="this.style.background='rgba(145,71,255,0.2)'" onmouseout="this.style.background='rgba(145,71,255,0.1)'">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
          Customize Design
        </a>
        <% } %>
      </div>
    </div>

    <!-- Chatbot Card -->
    <div class="card animate-in animate-in-delay-1" style="padding: 24px; display: flex; flex-direction: column;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
        <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(145,71,255,0.15); display: flex; align-items: center; justify-content: center;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9146ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div style="line-height: 1.2;">
          <h3 style="font-size: 16px; font-weight: 700; margin: 0;">Chatbot</h3>
          <% if (botConnected && streamer.chatbot_enabled) { %>
            <span style="color: var(--success); font-size: 12px; font-weight: 600;">● Online<%= botUsername ? ' as ' + botUsername : '' %></span>
          <% } else if (botConnected && !streamer.chatbot_enabled) { %>
            <span style="color: var(--text-muted); font-size: 12px;">● Bot available — not enabled</span>
          <% } else { %>
            <span style="color: var(--text-muted); font-size: 12px;">● Not configured</span>
          <% } %>
        </div>
      </div>
      <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 16px; line-height: 1.5;">
        <% if (streamer.chatbot_enabled) { %>
          Chatbot is active on <strong>#<%= streamer.twitch_username %></strong> — manage thank-you messages and custom commands.
        <% } else { %>
          Set up a chatbot for your Twitch channel with thank-you messages and custom commands.
        <% } %>
      </p>
      <a href="/dashboard/chatbot" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px; text-decoration: none; margin-top: auto;"><%= streamer.chatbot_enabled ? 'Chatbot Settings' : 'Configure Chatbot' %></a>
    </div>

    <!-- Spotify Card -->
    <div class="card animate-in animate-in-delay-2" style="padding: 24px; display: flex; flex-direction: column;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
        <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(30,215,96,0.15); display: flex; align-items: center; justify-content: center;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
        </div>
        <div style="line-height: 1.2;">
          <h3 style="font-size: 16px; font-weight: 700; margin: 0;">Spotify</h3>
          <% if (streamer.spotify_access_token) { %>
            <span style="color: var(--success); font-size: 12px; font-weight: 600;">● Connected</span>
          <% } else { %>
            <span style="color: var(--text-muted); font-size: 12px;">● Not connected</span>
          <% } %>
        </div>
      </div>
      <% if (streamer.spotify_access_token) { %>
        <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px; line-height: 1.5;">
          Spotify connected — viewers can type <code style="background: var(--bg-elevated); padding: 1px 6px; border-radius: 4px;">!song</code> to see what you're listening to.
        </p>
        <a href="/auth/spotify" class="btn btn-secondary" style="font-size: 13px; padding: 8px 16px; text-decoration: none; margin-top: auto;">Reconnect</a>
      <% } else { %>
        <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px; line-height: 1.5;">
          Connect Spotify so viewers can use <code style="background: var(--bg-elevated); padding: 1px 6px; border-radius: 4px;">!song</code> to see what you're playing.
        </p>
        <a href="/auth/spotify" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px; text-decoration: none; margin-top: auto;">Connect Spotify</a>
      <% } %>
    </div>

    <!-- Sponsor Messages Card -->
    <div class="card animate-in" style="padding: 24px; display: flex; flex-direction: column;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
        <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(247,144,9,0.15); display: flex; align-items: center; justify-content: center;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f79009" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div style="line-height: 1.2;">
          <h3 style="font-size: 16px; font-weight: 700; margin: 0;">Sponsor Messages</h3>
          <span style="color: var(--text-muted); font-size: 12px;">Auto-post sponsor messages to chat</span>
        </div>
      </div>
      <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 12px; line-height: 1.5;">
        Rotate sponsor messages in chat with customizable intervals. For sponsor image overlays, use the Overlay Builder.
      </p>
      <a href="/dashboard/timed-notifications" class="btn btn-primary" style="font-size: 13px; padding: 8px 16px; text-decoration: none; margin-top: auto;">Manage Messages</a>
    </div>

    <!-- Donations Card -->
    <div class="card animate-in" style="padding: 24px; display: flex; flex-direction: column;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
        <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(0,112,186,0.15); display: flex; align-items: center; justify-content: center;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0070ba" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div style="line-height: 1.2;">
          <h3 style="font-size: 16px; font-weight: 700; margin: 0;">Donations</h3>
          <span style="color: var(--text-muted); font-size: 12px;">PayPal donation page for viewers</span>
        </div>
      </div>
      <% if (streamer.paypal_email && streamer.donation_page_enabled) { %>
        <p style="color: var(--success); font-size: 12px; margin-bottom: 8px; display: flex; align-items: center; gap: 4px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
