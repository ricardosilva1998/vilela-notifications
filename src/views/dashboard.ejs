<%- include('header', { title: 'Dashboard', streamer: streamer }) %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;" class="animate-in">
  <div style="display: flex; align-items: center; gap: 12px;">
    <h2 style="font-size: 24px; font-weight: 700;"><%= t('dashboard.title') %></h2>
    <span class="badge badge-tier"><%= (tier || 'free').toUpperCase() %></span>
  </div>
</div>

<% if (msg === 'guild_removed') { %>
  <div class="alert alert-success"><%= t('dashboard.guildRemoved') %></div>
<% } %>
<% if (msg === 'twitch_linked') { %>
  <div class="alert alert-success"><%= t('dashboard.twitchLinked') %></div>
<% } %>
<% if (msg === 'broadcaster_authorized') { %>
  <div class="alert alert-success"><%= t('dashboard.broadcasterAuthorized') %></div>
<% } %>
<% if (msg === 'youtube_saved') { %>
  <div class="alert alert-success"><%= t('dashboard.youtubeSaved') %></div>
<% } %>
<% if (msg === 'guild_limit') { %>
  <div class="alert alert-warning"><%= t('dashboard.guildLimit') %></div>
<% } %>
<% if (msg === 'already_claimed') { %>
  <div class="alert alert-danger"><%= t('dashboard.alreadyClaimed') %></div>
<% } %>

<!-- Quick Links -->
<div style="display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap;" class="animate-in animate-in-delay-1">
  <% if (!streamer.twitch_user_id) { %>
    <a href="/auth/twitch" class="btn btn-primary" style="padding: 8px 16px; font-size: 13px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
      <%= t('dashboard.linkTwitch') %>
    </a>
  <% } else { %>
    <span class="btn btn-secondary" style="cursor: default; padding: 8px 16px; font-size: 13px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      Twitch: <%= streamer.twitch_username %>
    </span>
  <% } %>
  <% if (streamer.twitch_user_id && !streamer.broadcaster_access_token) { %>
    <a href="/auth/broadcaster" class="btn btn-secondary" style="padding: 8px 16px; font-size: 13px;"><%= t('dashboard.enableSubSync') %></a>
  <% } %>
  <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord" style="padding: 8px 16px; font-size: 13px;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    <%= t('dashboard.addBot') %>
  </a>
</div>

<!-- Servers -->
<h3 class="section-title animate-in animate-in-delay-2"><%= t('dashboard.yourServers') %> (<%= guilds.length %>)</h3>

<% if (guilds.length === 0 && unclaimedGuilds.length === 0) { %>
  <div class="card animate-in animate-in-delay-3" style="text-align: center; padding: 48px 24px;">
    <div style="width: 56px; height: 56px; border-radius: 16px; background: var(--bg-elevated); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </div>
    <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 14px;"><%= t('dashboard.noServers') %></p>
    <a href="<%= botInviteUrl %>" target="_blank" rel="noopener" class="btn btn-discord"><%= t('dashboard.addBot') %></a>
  </div>
<% } %>

<div style="display: grid; gap: 16px;">
  <% guilds.forEach(function(g, i) { %>
    <div class="card animate-in" style="animation-delay: <%= 0.1 + i * 0.05 %>s; padding: 20px;">
      <!-- Server Header -->
      <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 16px;">
        <div class="guild-icon">
          <% if (g.icon) { %>
            <img src="<%= g.icon %>" alt="">
          <% } else { %>
            <%= g.name.charAt(0) %>
          <% } %>
        </div>
        <div style="flex: 1; min-width: 0;">
          <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= g.name %></h4>
          <div style="display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 12px; color: var(--text-secondary);">
              <% if (g.botPresent) { %>
                <span class="status-dot online"></span><%= t('dashboard.active') %>
              <% } else { %>
                <span class="status-dot offline"></span><%= t('dashboard.offline') %>
              <% } %>
            </span>
            <span style="font-size: 11px; color: var(--text-muted);"><%= g.twitchCount %> Twitch &middot; <%= g.youtubeCount %> YouTube</span>
          </div>
        </div>
        <div style="display: flex; gap: 6px; flex-shrink: 0;">
          <a href="/dashboard/guild/<%= g.guild_id %>/stats" class="btn btn-secondary" style="padding: 7px 12px; font-size: 12px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Stats
          </a>
          <a href="/dashboard/guild/<%= g.guild_id %>" class="btn btn-primary" style="padding: 7px 12px; font-size: 12px;"><%= t('dashboard.configure') %></a>
        </div>
      </div>

      <!-- Metrics -->
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 10px 12px; border: 1px solid var(--border);">
          <div style="font-size: 18px; font-weight: 700; font-family: var(--font-display); color: var(--accent);"><%= g.stats.live_count %></div>
          <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;">Live Alerts</div>
        </div>
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 10px 12px; border: 1px solid var(--border);">
          <div style="font-size: 18px; font-weight: 700; font-family: var(--font-display); color: #bf94ff;"><%= g.stats.clip_count %></div>
          <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;">Clips</div>
        </div>
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 10px 12px; border: 1px solid var(--border);">
          <div style="font-size: 18px; font-weight: 700; font-family: var(--font-display); color: #f04438;"><%= g.stats.youtube_video_count + g.stats.youtube_live_count %></div>
          <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;">YouTube</div>
        </div>
        <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 10px 12px; border: 1px solid var(--border);">
          <div style="font-size: 18px; font-weight: 700; font-family: var(--font-display); color: var(--text-primary);"><%= g.stats.total %></div>
          <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;">Total</div>
        </div>
      </div>

      <% if (g.stats.recap_count > 0 || g.stats.milestone_count > 0 || g.stats.digest_count > 0) { %>
        <div style="display: flex; gap: 12px; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border);">
          <% if (g.stats.recap_count > 0) { %>
            <span style="font-size: 11px; color: var(--text-muted);"><span style="color: #6d28d9; font-weight: 600;"><%= g.stats.recap_count %></span> Recaps</span>
          <% } %>
          <% if (g.stats.milestone_count > 0) { %>
            <span style="font-size: 11px; color: var(--text-muted);"><span style="color: #f1c40f; font-weight: 600;"><%= g.stats.milestone_count %></span> Milestones</span>
          <% } %>
          <% if (g.stats.digest_count > 0) { %>
            <span style="font-size: 11px; color: var(--text-muted);"><span style="color: #3498db; font-weight: 600;"><%= g.stats.digest_count %></span> Digests</span>
          <% } %>
          <span style="font-size: 11px; color: var(--text-muted); margin-left: auto;"><span style="color: var(--success); font-weight: 600;"><%= g.stats.week_total %></span> this week</span>
        </div>
      <% } else { %>
        <div style="display: flex; justify-content: flex-end; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border);">
          <span style="font-size: 11px; color: var(--text-muted);"><span style="color: var(--success); font-weight: 600;"><%= g.stats.week_total %></span> this week</span>
        </div>
      <% } %>
    </div>
  <% }); %>
</div>

<% if (unclaimedGuilds.length > 0) { %>
  <h3 class="section-title" style="margin-top: 28px;"><%= t('dashboard.availableServers') %></h3>
  <p style="color: var(--text-secondary); margin-bottom: 12px; font-size: 14px;"><%= t('dashboard.availableServersDesc') %></p>
  <div class="guild-list">
    <% unclaimedGuilds.forEach(function(g, i) { %>
      <div class="card guild-card animate-in" style="animation-delay: <%= 0.05 + i * 0.05 %>s;">
        <div class="guild-icon">
          <% if (g.icon) { %>
            <img src="<%= g.icon %>" alt="">
          <% } else { %>
            <%= g.name.charAt(0) %>
          <% } %>
        </div>
        <div class="guild-info">
          <h4><%= g.name %></h4>
          <p style="color: var(--text-muted);"><%= t('dashboard.readyToConfigure') %></p>
        </div>
        <form method="POST" action="/dashboard/claim/<%= g.id %>" style="margin: 0;">
          <button type="submit" class="btn btn-primary" style="padding: 7px 14px; font-size: 12px;"><%= t('dashboard.claim') %></button>
        </form>
      </div>
    <% }); %>
  </div>
<% } %>

<style>
  @media (max-width: 520px) {
    div[style*="grid-template-columns: repeat(4, 1fr)"] { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>

<%- include('footer') %>
