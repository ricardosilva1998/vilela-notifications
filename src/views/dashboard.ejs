<%- include('header', { title: 'Dashboard', streamer: streamer }) %>

<h2 style="margin-bottom: 20px;">Dashboard</h2>

<% if (msg === 'twitch_linked') { %>
  <div class="alert alert-success">Twitch account linked successfully!</div>
<% } %>
<% if (msg === 'broadcaster_authorized') { %>
  <div class="alert alert-success">Broadcaster authorized! Sub sync is now available.</div>
<% } %>
<% if (msg === 'youtube_saved') { %>
  <div class="alert alert-success">YouTube settings saved.</div>
<% } %>

<% if (!streamer.twitch_user_id) { %>
  <div class="alert alert-info">
    <strong>Step 1:</strong> Link your Twitch account to enable live and clip notifications.
    <a href="/auth/twitch" class="btn btn-primary" style="margin-left: 12px; padding: 6px 16px; font-size: 13px;">Link Twitch Account</a>
  </div>
<% } %>

<div style="display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
  <a href="<%= botInviteUrl %>" class="btn btn-discord">Add Bot to a Server</a>
  <% if (streamer.twitch_user_id) { %>
    <a href="/auth/twitch" class="btn btn-secondary">Twitch: <%= streamer.twitch_username %></a>
  <% } %>
  <a href="/dashboard/youtube" class="btn btn-secondary">YouTube Settings</a>
  <% if (streamer.twitch_user_id && !streamer.broadcaster_access_token) { %>
    <a href="/auth/broadcaster" class="btn btn-secondary">Enable Sub Sync</a>
  <% } %>
</div>

<h3 class="section-title">Your Servers</h3>

<% if (guilds.length === 0 && unclaimedGuilds.length === 0) { %>
  <p style="color: #adadb8;">No servers configured yet. Click "Add Bot to a Server" to get started.</p>
<% } %>

<div class="guild-list">
  <% for (const g of guilds) { %>
    <div class="card guild-card">
      <div class="guild-icon">
        <% if (g.icon) { %>
          <img src="<%= g.icon %>" alt="">
        <% } else { %>
          <%= g.name.charAt(0) %>
        <% } %>
      </div>
      <div class="guild-info">
        <h4><%= g.name %></h4>
        <p><%= g.botPresent ? 'Bot active' : 'Bot not in server' %></p>
      </div>
      <a href="/dashboard/guild/<%= g.guild_id %>" class="btn btn-secondary">Configure</a>
    </div>
  <% } %>
</div>

<% if (unclaimedGuilds.length > 0) { %>
  <h3 class="section-title" style="margin-top: 24px;">Available Servers</h3>
  <p style="color: #adadb8; margin-bottom: 12px; font-size: 14px;">The bot is in these servers. Claim one to configure notifications for your channel.</p>
  <div class="guild-list">
    <% for (const g of unclaimedGuilds) { %>
      <div class="card guild-card">
        <div class="guild-icon">
          <% if (g.icon) { %>
            <img src="<%= g.icon %>" alt="">
          <% } else { %>
            <%= g.name.charAt(0) %>
          <% } %>
        </div>
        <div class="guild-info">
          <h4><%= g.name %></h4>
          <p>Not configured</p>
        </div>
        <form method="POST" action="/dashboard/claim/<%= g.id %>" style="margin: 0;">
          <button type="submit" class="btn btn-primary">Claim</button>
        </form>
      </div>
    <% } %>
  </div>
<% } %>

<%- include('footer') %>
