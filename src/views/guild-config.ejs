  <% if (watchedYoutubeChannels.length === 0) { %>
    <div class="card" style="text-align: center; padding: 40px;">
      <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(240,68,56,0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#f04438"/></svg>
      </div>
      <p style="color: var(--text-secondary); font-size: 14px;">No YouTube channels being watched yet.</p>
