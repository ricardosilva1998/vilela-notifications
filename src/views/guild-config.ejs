<%- include('header', { title: guildName + ' - Settings', streamer: streamer }) %>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<h2 style="margin: 16px 0 24px; font-size: 24px; font-weight: 700;" class="animate-in"><%= guildName %></h2>

<!-- Alerts -->
<% if (saved) { %>
  <div class="alert alert-success">Settings saved!</div>
<% } %>
<% if (msg === 'added') { %>
  <div class="alert alert-success">Channel added! Notifications will start shortly.</div>
<% } %>
<% if (msg === 'removed') { %>
  <div class="alert alert-success">Channel removed.</div>
<% } %>
<% if (msg === 'missing_fields') { %>
  <div class="alert alert-danger">Please fill in all required fields.</div>
<% } %>
<% if (msg === 'upgrade_clips') { %>
  <div class="alert alert-warning">Clip notifications require a <a href="/pricing">Starter plan or higher</a>.</div>
<% } %>
<% if (msg === 'upgrade_youtube') { %>
  <div class="alert alert-warning">YouTube notifications require a <a href="/pricing">Starter plan or higher</a>.</div>
<% } %>
<% if (msg === 'channel_limit') { %>
  <div class="alert alert-warning">You've reached the channel limit for your plan. <a href="/pricing">Upgrade</a> to add more.</div>
<% } %>

<!-- Tab Bar -->
<div class="tab-bar animate-in animate-in-delay-1">
  <button class="tab-btn" data-tab="twitch">Twitch</button>
  <button class="tab-btn" data-tab="youtube">YouTube</button>
  <button class="tab-btn" data-tab="discord">Discord</button>
  <button class="tab-btn" data-tab="settings">Settings</button>
</div>

<!-- ==================== TWITCH TAB ==================== -->
<div class="tab-content" id="tab-twitch">
  <div class="card animate-in">
    <h3>Add a Twitch Channel</h3>
    <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 16px;">
      Enter any Twitch username. Choose separate Discord channels for live alerts and clips, or leave one blank to disable it.
    </p>
    <form method="POST" action="/dashboard/guild/<%= guildId %>/channels">
      <div class="form-group">
        <label>Twitch Username</label>
        <input type="text" name="twitch_username" placeholder="e.g. shroud" required>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        <div class="form-group">
          <label>Live Notifications Channel</label>
          <select name="live_channel_id">
            <option value="">-- Disabled --</option>
            <% for (const c of channels) { %>
              <option value="<%= c.id %>">#<%= c.name %></option>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label>Clip Notifications Channel</label>
          <select name="clips_channel_id">
            <option value="">-- Disabled --</option>
            <% for (const c of channels) { %>
              <option value="<%= c.id %>">#<%= c.name %></option>
            <% } %>
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Add Channel</button>
    </form>
  </div>

  <h3 class="section-title" style="margin-top: 24px;">Watched Channels (<%= watchedTwitchChannels.length %>)</h3>

  <% if (watchedTwitchChannels.length === 0) { %>
    <div class="card" style="text-align: center; padding: 40px;">
      <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--accent-glow); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
      </div>
      <p style="color: var(--text-secondary); font-size: 14px;">No Twitch channels being watched yet.</p>
    </div>
  <% } else { %>
    <% for (const wc of watchedTwitchChannels) { %>
      <div class="card" style="display: flex; align-items: center; gap: 16px;">
        <% if (wc.profile_image_url) { %>
          <img src="<%= wc.profile_image_url %>" alt="" style="width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;">
        <% } else { %>
          <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%; background: var(--accent-glow); display: flex; align-items: center; justify-content: center;">
            <span style="color: var(--accent); font-family: var(--font-display); font-weight: 700; font-size: 16px;"><%= wc.twitch_username.charAt(0).toUpperCase() %></span>
          </div>
        <% } %>
        <div style="flex: 1; min-width: 0;">
          <div style="font-weight: 600;">
            <a href="https://twitch.tv/<%= wc.twitch_username %>" target="_blank" style="color: var(--text-primary);"><%= wc.twitch_username %></a>
          </div>
          <div style="font-size: 12px; color: var(--text-secondary);">
            <% if (wc.live_channel_id) { %>Live<% } %>
            <% if (wc.live_channel_id && wc.clips_channel_id) { %> &middot; <% } %>
            <% if (wc.clips_channel_id) { %>Clips<% } %>
            <% if (!wc.live_channel_id && !wc.clips_channel_id) { %>No notifications configured<% } %>
          </div>
        </div>
        <form method="POST" action="/dashboard/guild/<%= guildId %>/channels/<%= wc.id %>/remove" style="margin: 0;">
          <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px;">Remove</button>
        </form>
      </div>
    <% } %>
  <% } %>
</div>

<!-- ==================== YOUTUBE TAB ==================== -->
<div class="tab-content" id="tab-youtube">
  <div class="card animate-in">
    <h3>Add a YouTube Channel</h3>
    <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 16px;">
      Enter a YouTube Channel ID (starts with <code>UC</code>) to get notified about new videos, shorts, and live streams.
      Find any channel ID at <a href="https://commentpicker.com/youtube-channel-id.php" target="_blank">commentpicker.com</a>.
    </p>
    <form method="POST" action="/dashboard/guild/<%= guildId %>/youtube">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        <div class="form-group">
          <label>YouTube Channel ID</label>
          <input type="text" name="youtube_channel_id" placeholder="UCxxxxxxxxxxxxxxxxxxxxxxxx" required>
        </div>
        <div class="form-group">
          <label>Channel Name (optional)</label>
          <input type="text" name="youtube_channel_name" placeholder="e.g. PewDiePie">
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        <div class="form-group">
          <label>Videos/Shorts Notifications</label>
          <select name="videos_channel_id">
            <option value="">-- Disabled --</option>
            <% for (const c of channels) { %>
              <option value="<%= c.id %>">#<%= c.name %></option>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label>Live Notifications</label>
          <select name="live_channel_id">
            <option value="">-- Disabled --</option>
            <% for (const c of channels) { %>
              <option value="<%= c.id %>">#<%= c.name %></option>
            <% } %>
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Add Channel</button>
    </form>
  </div>

  <h3 class="section-title" style="margin-top: 24px;">Watched YouTube Channels (<%= watchedYoutubeChannels.length %>)</h3>

  <% if (watchedYoutubeChannels.length === 0) { %>
    <div class="card" style="text-align: center; padding: 40px;">
      <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(240,68,56,0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#f04438"/></svg>
      </div>
      <p style="color: var(--text-secondary); font-size: 14px;">No YouTube channels being watched yet.</p>
    </div>
  <% } else { %>
    <% for (const wc of watchedYoutubeChannels) { %>
      <div class="card" style="display: flex; align-items: center; gap: 16px;">
        <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%; background: rgba(240,68,56,0.1); display: flex; align-items: center; justify-content: center;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#f04438"/></svg>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div style="font-weight: 600; color: var(--text-primary);">
            <%= wc.youtube_channel_name || wc.youtube_channel_id %>
          </div>
          <div style="font-size: 12px; color: var(--text-secondary);">
            <% if (wc.videos_channel_id) { %>Videos<% } %>
            <% if (wc.videos_channel_id && wc.live_channel_id) { %> &middot; <% } %>
            <% if (wc.live_channel_id) { %>Live<% } %>
            <% if (!wc.videos_channel_id && !wc.live_channel_id) { %>No notifications configured<% } %>
          </div>
        </div>
        <form method="POST" action="/dashboard/guild/<%= guildId %>/youtube/<%= wc.id %>/remove" style="margin: 0;">
          <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px;">Remove</button>
        </form>
      </div>
    <% } %>
  <% } %>
</div>

<!-- ==================== DISCORD TAB ==================== -->
<div class="tab-content" id="tab-discord">
  <form method="POST" action="/dashboard/guild/<%= guildId %>">
    <!-- Hidden fields to preserve existing settings -->
    <input type="hidden" name="twitch_live_channel_id" value="<%= guild.twitch_live_channel_id || '' %>">
    <input type="hidden" name="twitch_clips_channel_id" value="<%= guild.twitch_clips_channel_id || '' %>">
    <input type="hidden" name="twitch_live_enabled" value="on">
    <input type="hidden" name="twitch_clips_enabled" value="on">
    <input type="hidden" name="youtube_channel_id" value="<%= guild.youtube_channel_id || '' %>">
    <input type="hidden" name="youtube_enabled" value="on">

    <div class="card animate-in">
      <h3>Welcome Message</h3>
      <div class="toggle">
        <input type="checkbox" name="welcome_enabled" id="welcome_enabled" <%= guild.welcome_enabled ? 'checked' : '' %>>
        <label for="welcome_enabled">Enable welcome messages</label>
      </div>
      <div class="form-group">
        <label>Send to channel</label>
        <select name="welcome_channel_id">
          <option value="">-- Select channel --</option>
          <% for (const c of channels) { %>
            <option value="<%= c.id %>" <%= guild.welcome_channel_id === c.id ? 'selected' : '' %>>#<%= c.name %></option>
          <% } %>
        </select>
      </div>
      <div class="form-group">
        <label>Custom message (leave blank for default)</label>
        <textarea name="welcome_message" placeholder="Welcome to the server!"><%= guild.welcome_message || '' %></textarea>
      </div>
    </div>

    <div class="card">
      <h3>Subscriber Role Sync</h3>
      <div class="toggle">
        <input type="checkbox" name="sub_sync_enabled" id="sub_sync_enabled" <%= guild.sub_sync_enabled ? 'checked' : '' %>>
        <label for="sub_sync_enabled">Enable subscriber role sync</label>
      </div>
      <div class="form-group">
        <label>Subscriber Role</label>
        <select name="sub_role_id">
          <option value="">-- Select role --</option>
          <% for (const r of roles) { %>
            <option value="<%= r.id %>" <%= guild.sub_role_id === r.id ? 'selected' : '' %>><%= r.name %></option>
          <% } %>
        </select>
      </div>
      <% if (!hasBroadcasterToken) { %>
        <p style="color: var(--text-secondary); font-size: 13px;">You need to <a href="<%= broadcasterAuthUrl %>">authorize broadcaster access</a> for sub sync to work.</p>
      <% } %>
    </div>

    <div class="card">
      <h3>Activity Feed</h3>
      <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 16px;">Automatic posts that keep your server active around stream activity.</p>

      <div class="toggle">
        <input type="checkbox" name="recap_enabled" id="recap_enabled" <%= guild.recap_enabled ? 'checked' : '' %> <% if (!limits.recaps) { %>disabled<% } %>>
        <label for="recap_enabled">Stream Recaps</label>
      </div>
      <p style="color: var(--text-secondary); font-size: 12px; margin: -8px 0 12px 28px;">Post a summary when a stream ends — duration, category, and top clips.</p>
      <% if (!limits.recaps) { %>
        <p style="font-size: 12px; margin: -4px 0 12px 28px;"><a href="/pricing">Upgrade</a> to enable this feature.</p>
      <% } %>

      <div class="toggle">
        <input type="checkbox" name="milestones_enabled" id="milestones_enabled" <%= guild.milestones_enabled ? 'checked' : '' %> <% if (!limits.milestones) { %>disabled<% } %>>
        <label for="milestones_enabled">Milestone Celebrations</label>
      </div>
      <p style="color: var(--text-secondary); font-size: 12px; margin: -8px 0 12px 28px;">Announce when a channel hits follower or subscriber milestones.</p>
      <% if (!limits.milestones) { %>
        <p style="font-size: 12px; margin: -4px 0 12px 28px;"><a href="/pricing">Upgrade</a> to enable this feature.</p>
      <% } else if (!hasBroadcasterToken) { %>
        <p style="color: var(--warning); font-size: 12px; margin: -4px 0 12px 28px;">Requires <a href="<%= broadcasterAuthUrl %>">broadcaster authorization</a> to access follower/sub counts.</p>
      <% } %>

      <div class="toggle">
        <input type="checkbox" name="weekly_highlights_enabled" id="weekly_highlights_enabled" <%= guild.weekly_highlights_enabled ? 'checked' : '' %> <% if (!limits.weeklyHighlights) { %>disabled<% } %>>
        <label for="weekly_highlights_enabled">Weekly Highlights</label>
      </div>
      <p style="color: var(--text-secondary); font-size: 12px; margin: -8px 0 12px 28px;">Post a weekly digest every Monday with stream stats and top clips.</p>
      <% if (!limits.weeklyHighlights) { %>
        <p style="font-size: 12px; margin: -4px 0 12px 28px;"><a href="/pricing">Upgrade</a> to enable this feature.</p>
      <% } %>
    </div>

    <button type="submit" class="btn btn-success" style="width: 100%; padding: 14px; font-size: 15px;">Save Discord Settings</button>
  </form>
</div>

<!-- ==================== SETTINGS TAB ==================== -->
<div class="tab-content" id="tab-settings">
  <div class="card animate-in">
    <h3>Server Summary</h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 12px;">
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border);">
        <div style="font-size: 28px; font-weight: 800; font-family: var(--font-display); color: var(--accent);"><%= watchedTwitchChannels.length %></div>
        <div style="font-size: 13px; color: var(--text-secondary); margin-top: 4px;">Twitch Channels</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 16px; border: 1px solid var(--border);">
        <div style="font-size: 28px; font-weight: 800; font-family: var(--font-display); color: #f04438;"><%= watchedYoutubeChannels.length %></div>
        <div style="font-size: 13px; color: var(--text-secondary); margin-top: 4px;">YouTube Channels</div>
      </div>
    </div>
  </div>

  <div class="card" style="border-color: rgba(240,68,56,0.2); margin-top: 8px;">
    <h3 style="color: var(--danger);">Remove Bot from Server</h3>
    <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 16px;">This will remove all notification settings and make the bot leave this Discord server.</p>
    <form method="POST" action="/dashboard/guild/<%= guildId %>/remove" onsubmit="return confirm('Are you sure? The bot will leave this server and all notification settings will be deleted.')">
      <button type="submit" class="btn btn-danger">Remove Server</button>
    </form>
  </div>
</div>

<!-- Tab switching script -->
<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panes = document.querySelectorAll('.tab-content');
  function switchTab(tabName) {
    tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tabName));
    panes.forEach(p => p.classList.toggle('active', p.id === 'tab-' + tabName));
  }
  tabs.forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));
  switchTab('<%= activeTab || "twitch" %>');
</script>

<%- include('footer') %>
