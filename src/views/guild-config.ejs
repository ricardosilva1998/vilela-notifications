<%- include('header', { title: guildName + ' - Settings', streamer: streamer }) %>

<a href="/dashboard" style="color: #adadb8; font-size: 14px;">&larr; Back to Dashboard</a>
<h2 style="margin: 12px 0 20px;"><%= guildName %></h2>

<% if (typeof saved !== 'undefined' && saved) { %>
  <div class="alert alert-success">Settings saved!</div>
<% } %>

<!-- Navigation -->
<div style="display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap;">
  <a href="/dashboard/guild/<%= guild.guild_id %>/channels" class="btn btn-primary" style="display: flex; align-items: center; gap: 6px;">
    📡 Twitch Channels (<%= typeof watchedTwitchCount !== 'undefined' ? watchedTwitchCount : 0 %>)
  </a>
  <a href="/dashboard/guild/<%= guild.guild_id %>/youtube" class="btn btn-danger" style="display: flex; align-items: center; gap: 6px; background: #ff0000;">
    🎬 YouTube Channels (<%= typeof watchedYoutubeCount !== 'undefined' ? watchedYoutubeCount : 0 %>)
  </a>
</div>

<form method="POST" action="/dashboard/guild/<%= guild.guild_id %>">

  <!-- Hidden fields to preserve existing settings -->
  <input type="hidden" name="twitch_live_channel_id" value="<%= guild.twitch_live_channel_id || '' %>">
  <input type="hidden" name="twitch_clips_channel_id" value="<%= guild.twitch_clips_channel_id || '' %>">
  <input type="hidden" name="twitch_live_enabled" value="on">
  <input type="hidden" name="twitch_clips_enabled" value="on">
  <input type="hidden" name="youtube_channel_id" value="<%= guild.youtube_channel_id || '' %>">
  <input type="hidden" name="youtube_enabled" value="on">

  <div class="card">
    <h3>👋 Welcome Message</h3>
    <div class="toggle">
      <input type="checkbox" name="welcome_enabled" id="welcome_enabled" <%= guild.welcome_enabled ? 'checked' : '' %>>
      <label for="welcome_enabled">Enable welcome messages</label>
    </div>
    <div class="form-group">
      <label>Send to channel</label>
      <select name="welcome_channel_id">
        <option value="">-- Select channel --</option>
        <% for (const c of channels) { %>
          <option value="<%= c.id %>" <%= guild.welcome_channel_id === c.id ? 'selected' : '' %>>#<%= c.name %></option>
        <% } %>
      </select>
    </div>
    <div class="form-group">
      <label>Custom message (leave blank for default)</label>
      <textarea name="welcome_message" placeholder="Welcome to the server!"><%= guild.welcome_message || '' %></textarea>
    </div>
  </div>

  <div class="card">
    <h3>⭐ Subscriber Role Sync</h3>
    <div class="toggle">
      <input type="checkbox" name="sub_sync_enabled" id="sub_sync_enabled" <%= guild.sub_sync_enabled ? 'checked' : '' %>>
      <label for="sub_sync_enabled">Enable subscriber role sync</label>
    </div>
    <div class="form-group">
      <label>Subscriber Role</label>
      <select name="sub_role_id">
        <option value="">-- Select role --</option>
        <% for (const r of roles) { %>
          <option value="<%= r.id %>" <%= guild.sub_role_id === r.id ? 'selected' : '' %>><%= r.name %></option>
        <% } %>
      </select>
    </div>
    <% if (!hasBroadcasterToken) { %>
      <p style="color: #adadb8; font-size: 13px;">You need to <a href="<%= broadcasterAuthUrl %>">authorize broadcaster access</a> for sub sync to work.</p>
    <% } %>
  </div>

  <div class="card">
    <h3>Activity Feed</h3>
    <p style="color: #adadb8; font-size: 13px; margin-bottom: 16px;">Automatic posts that keep your server active around stream activity.</p>

    <div class="toggle">
      <input type="checkbox" name="recap_enabled" id="recap_enabled" <%= guild.recap_enabled ? 'checked' : '' %> <% if (!limits.recaps) { %>disabled<% } %>>
      <label for="recap_enabled">Stream Recaps</label>
      <p style="color: #adadb8; font-size: 12px; margin: 2px 0 12px 0;">Post a summary when a stream ends — duration, category, and top clips.</p>
      <% if (!limits.recaps) { %>
        <p style="font-size: 12px;"><a href="/dashboard/subscription">Upgrade</a> to enable this feature.</p>
      <% } %>
    </div>

    <div class="toggle">
      <input type="checkbox" name="milestones_enabled" id="milestones_enabled" <%= guild.milestones_enabled ? 'checked' : '' %> <% if (!limits.milestones) { %>disabled<% } %>>
      <label for="milestones_enabled">Milestone Celebrations</label>
      <p style="color: #adadb8; font-size: 12px; margin: 2px 0 12px 0;">Announce when a channel hits follower or subscriber milestones.</p>
      <% if (!limits.milestones) { %>
        <p style="font-size: 12px;"><a href="/dashboard/subscription">Upgrade</a> to enable this feature.</p>
      <% } else if (!hasBroadcasterToken) { %>
        <p style="color: #e67e22; font-size: 12px;">Requires <a href="<%= broadcasterAuthUrl %>">broadcaster authorization</a> to access follower/sub counts.</p>
      <% } %>
    </div>

    <div class="toggle">
      <input type="checkbox" name="weekly_highlights_enabled" id="weekly_highlights_enabled" <%= guild.weekly_highlights_enabled ? 'checked' : '' %> <% if (!limits.weeklyHighlights) { %>disabled<% } %>>
      <label for="weekly_highlights_enabled">Weekly Highlights</label>
      <p style="color: #adadb8; font-size: 12px; margin: 2px 0 12px 0;">Post a weekly digest every Monday with stream stats and top clips.</p>
      <% if (!limits.weeklyHighlights) { %>
        <p style="font-size: 12px;"><a href="/dashboard/subscription">Upgrade</a> to enable this feature.</p>
      <% } %>
    </div>
  </div>

  <button type="submit" class="btn btn-success" style="width: 100%; padding: 14px; font-size: 16px;">Save Settings</button>
</form>

<div class="card" style="margin-top: 24px; border-color: #e74c3c44;">
  <h3 style="color: #e74c3c;">Danger Zone</h3>
  <p style="color: #adadb8; font-size: 14px; margin-bottom: 12px;">Remove this server from your account. All notification settings will be deleted.</p>
  <form method="POST" action="/dashboard/guild/<%= guild.guild_id %>/remove" onsubmit="return confirm('Are you sure? This will remove all notification settings for this server.')">
    <button type="submit" class="btn btn-danger">Remove Server</button>
  </form>
</div>

<%- include('footer') %>
