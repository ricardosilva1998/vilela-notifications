<%- include('header', { title: guildName + ' - Settings', streamer: streamer }) %>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<h2 style="margin: 16px 0 24px; font-size: 24px; font-weight: 700;" class="animate-in"><%= guildName %></h2>

<!-- Alerts -->
<% if (saved) { %>
  <div class="alert alert-success">Settings saved!</div>
<% } %>
<% if (msg === 'added') { %>
  <div class="alert alert-success">Channel added! Notifications will start shortly.</div>
<% } %>
<% if (msg === 'updated') { %>
  <div class="alert alert-success">Channel updated!</div>
<% } %>
<% if (msg === 'removed') { %>
  <div class="alert alert-success">Channel removed.</div>
<% } %>
<% if (msg === 'missing_fields') { %>
  <div class="alert alert-danger">Please fill in all required fields.</div>
<% } %>
<% if (msg === 'upgrade_clips') { %>
  <div class="alert alert-warning">Clip notifications require a <a href="/pricing">Starter plan or higher</a>.</div>
<% } %>
<% if (msg === 'upgrade_youtube') { %>
  <div class="alert alert-warning">YouTube notifications require a <a href="/pricing">Starter plan or higher</a>.</div>
<% } %>
<% if (msg === 'channel_limit') { %>
  <div class="alert alert-warning">You've reached the channel limit for your plan. <a href="/pricing">Upgrade</a> to add more.</div>
<% } %>
<% if (msg === 'yt_not_found') { %>
  <div class="alert alert-danger">YouTube channel not found. Please check the @username or channel ID and try again.</div>
<% } %>
<% if (msg === 'upgrade_social') { %>
  <div class="alert alert-warning">Social media notifications require a <a href="/pricing">Starter plan or higher</a>.</div>
<% } %>
<% if (msg === 'social_limit') { %>
  <div class="alert alert-warning">You've reached the social account limit for your plan. <a href="/pricing">Upgrade</a> to add more.</div>
<% } %>
<% if (msg === 'upgrade_iracing') { %>
  <div class="alert alert-warning">iRacing notifications require a <a href="/pricing">Starter plan or higher</a>.</div>
<% } %>
<% if (msg === 'iracing_limit') { %>
  <div class="alert alert-warning">You've reached the iRacing driver limit for your plan. <a href="/pricing">Upgrade</a> to add more.</div>
<% } %>

<!-- Tab Bar -->
<div class="tab-bar animate-in animate-in-delay-1">
  <button class="tab-btn tab-twitch" data-tab="twitch">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zM11 11V7M16 11V7"/></svg>
    Twitch
  </button>
  <% if (features.youtube) { %>
  <button class="tab-btn tab-youtube" data-tab="youtube">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor"/></svg>
    YouTube
