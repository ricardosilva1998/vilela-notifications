          </div>
          <div style="display: flex; gap: 6px;">
            <button onclick="toggleEdit('youtube-<%= wc.id %>')" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px;">Edit</button>
            <form method="POST" action="/dashboard/guild/<%= guildId %>/youtube/<%= wc.id %>/remove" style="margin: 0;">
              <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 12px;">Remove</button>
            </form>
          </div>
        </div>
        <!-- Edit form (hidden by default) -->
        <div id="edit-youtube-<%= wc.id %>" style="display: none; margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border);">
          <form method="POST" action="/dashboard/guild/<%= guildId %>/youtube/<%= wc.id %>/edit">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
              <div class="form-group" style="margin-bottom: 12px;">
                <label>Videos/Shorts Notifications</label>
                <select name="videos_channel_id">
                  <option value="">-- Disabled --</option>
                  <% for (const c of channels) { %>
                    <option value="<%= c.id %>" <%= wc.videos_channel_id === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                  <% } %>
                </select>
              </div>
              <div class="form-group" style="margin-bottom: 12px;">
                <label>Live Notifications</label>
                <select name="live_channel_id">
                  <option value="">-- Disabled --</option>
                  <% for (const c of channels) { %>
                    <option value="<%= c.id %>" <%= wc.live_channel_id === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                  <% } %>
                </select>
              </div>
            </div>
            <div style="display: flex; gap: 8px;">
              <button type="submit" class="btn btn-success" style="padding: 7px 16px; font-size: 12px;">Save Changes</button>
              <button type="button" onclick="toggleEdit('youtube-<%= wc.id %>')" class="btn btn-secondary" style="padding: 7px 16px; font-size: 12px;">Cancel</button>
            </div>
          </form>
        </div>
      </div>
    <% } %>
  <% } %>
</div>
<% } %>

<!-- Instagram and TikTok tabs disabled — no reliable free API available -->
<!-- ==================== DISCORD TAB ==================== -->
<div class="tab-content" id="tab-discord">
  <form method="POST" action="/dashboard/guild/<%= guildId %>">
    <!-- Hidden fields to preserve existing settings -->
    <input type="hidden" name="twitch_live_channel_id" value="<%= guild.twitch_live_channel_id || '' %>">
    <input type="hidden" name="twitch_clips_channel_id" value="<%= guild.twitch_clips_channel_id || '' %>">
    <input type="hidden" name="twitch_live_enabled" value="on">
    <input type="hidden" name="twitch_clips_enabled" value="on">
    <input type="hidden" name="youtube_channel_id" value="<%= guild.youtube_channel_id || '' %>">
    <input type="hidden" name="youtube_enabled" value="on">

    <div class="card animate-in">
      <h3>Welcome Message</h3>
      <div class="toggle">
        <input type="checkbox" name="welcome_enabled" id="welcome_enabled" <%= guild.welcome_enabled ? 'checked' : '' %>>
        <label for="welcome_enabled">Enable welcome messages</label>
      </div>
      <div class="form-group">
        <label>Send to channel</label>
        <select name="welcome_channel_id">
          <option value="">-- Select channel --</option>
          <% for (const c of channels) { %>
            <option value="<%= c.id %>" <%= guild.welcome_channel_id === c.id ? 'selected' : '' %>>#<%= c.name %></option>
          <% } %>
        </select>
      </div>
      <div class="form-group">
        <label>Custom message (leave blank for default)</label>
        <textarea name="welcome_message" placeholder="Welcome to the server!"><%= guild.welcome_message || '' %></textarea>
      </div>
    </div>

    <div class="card">
      <h3>Subscriber Role Sync</h3>
      <div class="toggle">
        <input type="checkbox" name="sub_sync_enabled" id="sub_sync_enabled" <%= guild.sub_sync_enabled ? 'checked' : '' %>>
        <label for="sub_sync_enabled">Enable subscriber role sync</label>
      </div>
      <div class="form-group">
        <label>Subscriber Role</label>
        <select name="sub_role_id">
