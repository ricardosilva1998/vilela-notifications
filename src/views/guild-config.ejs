              <span style="font-weight: 600; color: var(--text-primary);"><%= wc.youtube_channel_name || wc.youtube_channel_id %></span>
              <% if (wc.is_live) { %>
                <span style="display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 4px; background: rgba(240,68,56,0.15); font-size: 10px; font-weight: 700; color: #f04438; font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.5px;">
                  <span style="width: 6px; height: 6px; border-radius: 50%; background: #f04438; animation: pulse 1.5s infinite;"></span>
                  LIVE
