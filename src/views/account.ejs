<%- include('header', { title: 'Account', streamer: streamer }) %>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>

<!-- Profile Header -->
<div style="display: flex; align-items: center; gap: 16px; margin: 20px 0 32px;" class="animate-in">
  <% if (streamer.discord_avatar) { %>
    <img src="<%= streamer.discord_avatar %>" alt="" style="width: 56px; height: 56px; border-radius: 50%; border: 3px solid var(--border);">
  <% } else { %>
    <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; color: white; font-family: var(--font-display); font-weight: 700; font-size: 22px;"><%= (streamer.discord_display_name || streamer.discord_username || '?').charAt(0).toUpperCase() %></div>
  <% } %>
  <div>
    <h2 style="font-size: 22px; font-weight: 700; margin-bottom: 4px;"><%= streamer.discord_display_name || streamer.discord_username %></h2>
    <div style="display: flex; align-items: center; gap: 8px;">
      <span class="badge badge-tier"><%= tier.toUpperCase() %></span>
      <span style="color: var(--text-muted); font-size: 13px;">Member since <%= streamer.created_at ? streamer.created_at.split('T')[0] : 'N/A' %></span>
    </div>
  </div>
</div>

<!-- Overview Cards -->
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px;" class="animate-in animate-in-delay-1">
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 28px; font-weight: 800; font-family: var(--font-display); color: var(--accent);"><%= stats.total_notifications %></div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Total Sent</div>
  </div>
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 28px; font-weight: 800; font-family: var(--font-display); color: var(--success);"><%= stats.notifications_today %></div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Today</div>
  </div>
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 28px; font-weight: 800; font-family: var(--font-display); color: var(--text-primary);"><%= stats.notifications_week %></div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">This Week</div>
  </div>
  <div class="card" style="text-align: center; padding: 20px 12px;">
    <div style="font-size: 28px; font-weight: 800; font-family: var(--font-display); color: var(--text-primary);"><%= stats.notifications_month %></div>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">This Month</div>
  </div>
</div>

<!-- Charts Row -->
<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 24px;" class="animate-in animate-in-delay-2">
  <!-- Notifications Over Time -->
  <div class="card" style="padding: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
      <h3 style="font-size: 15px; margin: 0;">Notifications sent per day (last 30 days)</h3>
    </div>
    <% if (notificationsOverTime.length === 0) { %>
      <div style="text-align: center; padding: 30px 0; color: var(--text-muted); font-size: 13px;">No notifications yet</div>
    <% } else { %>
      <% const maxCount = Math.max(...notificationsOverTime.map(d => d.count), 1); %>
      <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
        <span style="font-size: 9px; color: var(--text-muted);"><%= maxCount %></span>
        <span style="font-size: 9px; color: var(--text-muted);">notifications</span>
      </div>
      <div style="display: flex; align-items: flex-end; gap: 2px; height: 120px; position: relative;">
        <% notificationsOverTime.forEach(function(d) { %>
          <div style="flex: 1; height: 100%; display: flex; flex-direction: column; justify-content: flex-end; cursor: default;" title="<%= d.period %>: <%= d.count %> notification<%= d.count !== 1 ? 's' : '' %>">
            <div style="width: 100%; background: var(--accent); border-radius: 2px 2px 0 0; height: <%= Math.round(Math.max((d.count / maxCount) * 120, d.count > 0 ? 3 : 1)) %>px; opacity: <%= d.count > 0 ? 1 : 0.12 %>;"></div>
          </div>
        <% }); %>
      </div>
      <div style="display: flex; justify-content: space-between; margin-top: 8px;">
        <span style="font-size: 10px; color: var(--text-muted);"><%= notificationsOverTime[0].period %></span>
        <% if (notificationsOverTime.length > 10) { %>
          <span style="font-size: 10px; color: var(--text-muted);"><%= notificationsOverTime[Math.floor(notificationsOverTime.length / 2)].period %></span>
        <% } %>
        <span style="font-size: 10px; color: var(--text-muted);"><%= notificationsOverTime[notificationsOverTime.length - 1].period %></span>
      </div>
    <% } %>
  </div>

  <!-- By Type -->
  <div class="card" style="padding: 24px;">
    <h3 style="font-size: 15px; margin-bottom: 20px;">By Type</h3>
    <% if (notificationsByType.length === 0) { %>
      <p style="color: var(--text-muted); font-size: 13px;">No notifications yet</p>
    <% } else { %>
      <% const typeColors = { twitch_live: '#9146ff', twitch_clip: '#bf94ff', twitch_recap: '#6d28d9', youtube_video: '#f04438', youtube_live: '#ff6b6b', weekly_digest: '#3498db', twitch_milestone: '#f1c40f' }; %>
      <% const typeLabels = { twitch_live: 'Twitch Live', twitch_clip: 'Clips', twitch_recap: 'Recaps', youtube_video: 'YouTube Videos', youtube_live: 'YouTube Live', weekly_digest: 'Weekly Digest', twitch_milestone: 'Milestones' }; %>
      <% const totalByType = notificationsByType.reduce((s, d) => s + d.count, 0); %>
      <div style="display: flex; flex-direction: column; gap: 10px;">
        <% notificationsByType.forEach(function(d) { %>
          <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
              <span style="font-size: 12px; color: var(--text-secondary);"><%= typeLabels[d.type] || d.type %></span>
              <span style="font-size: 12px; color: var(--text-muted);"><%= d.count %></span>
            </div>
            <div style="width: 100%; height: 6px; background: var(--bg-base); border-radius: 3px; overflow: hidden;">
              <div style="width: <%= (d.count / totalByType * 100) %>%; height: 100%; background: <%= typeColors[d.type] || 'var(--accent)' %>; border-radius: 3px;"></div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<!-- Detailed Breakdown -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;" class="animate-in animate-in-delay-2">
  <div class="card" style="padding: 20px;">
    <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 12px; font-family: var(--font-display); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Resources</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 20px; font-weight: 700; font-family: var(--font-display);"><%= stats.total_guilds %></div>
        <div style="font-size: 11px; color: var(--text-muted);">Servers</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 20px; font-weight: 700; font-family: var(--font-display);"><%= stats.total_twitch_channels %></div>
        <div style="font-size: 11px; color: var(--text-muted);">Twitch Channels</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 20px; font-weight: 700; font-family: var(--font-display);"><%= stats.total_youtube_channels %></div>
        <div style="font-size: 11px; color: var(--text-muted);">YouTube Channels</div>
      </div>
      <div style="background: var(--bg-base); border-radius: var(--radius-sm); padding: 14px; border: 1px solid var(--border);">
        <div style="font-size: 20px; font-weight: 700; font-family: var(--font-display); color: var(--success);"><%= stats.notifications_week %></div>
        <div style="font-size: 11px; color: var(--text-muted);">This Week</div>
      </div>
    </div>
  </div>
  <div class="card" style="padding: 20px;">
    <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 12px; font-family: var(--font-display); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Quick Actions</div>

    <a href="/payment/subscription" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); margin-bottom: 8px; color: var(--text-primary); transition: all 0.2s;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      <div><div style="font-size: 13px; font-weight: 600;">Subscription</div><div style="font-size: 11px; color: var(--text-muted);"><%= tier.charAt(0).toUpperCase() + tier.slice(1) %> Plan</div></div>
    </a>

    <div style="padding: 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); margin-bottom: 8px;">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <div style="display: flex; align-items: center; gap: 10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <div style="font-size: 13px; font-weight: 600;">Language</div>
        </div>
        <form method="POST" action="/set-language" style="margin: 0;">
          <select name="lang" onchange="this.form.submit()" style="padding: 5px 8px; background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-primary); font-size: 12px; cursor: pointer;">
            <% SUPPORTED_LANGS.forEach(function(l) { %>
              <option value="<%= l %>" <%= l === lang ? 'selected' : '' %>><%= t('lang.' + l) %></option>
            <% }); %>
          </select>
        </form>
      </div>
    </div>

    <a href="/auth/logout" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: var(--radius-sm); border: 1px solid rgba(240,68,56,0.15); color: var(--danger); transition: all 0.2s;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      <div style="font-size: 13px; font-weight: 600;">Logout</div>
    </a>
  </div>
</div>

<!-- Feedback -->
<div class="card animate-in animate-in-delay-4" style="margin-bottom: 16px;">
  <h3 style="font-size: 15px; margin-bottom: 4px;">Give Feedback</h3>
  <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 14px;">Help us improve! Rate your experience and share your thoughts.</p>
  <% if (typeof feedbackMsg !== 'undefined' && feedbackMsg === 'submitted') { %>
    <div class="alert alert-success" style="margin-bottom: 12px;">Thanks for your feedback!</div>
  <% } %>
  <form method="POST" action="/dashboard/feedback">
    <div style="margin-bottom: 12px;">
      <label style="font-size: 13px; color: var(--text-secondary); display: block; margin-bottom: 6px;">Rating</label>
      <div style="display: flex; gap: 4px;" id="star-rating">
        <% for (let i = 1; i <= 5; i++) { %>
          <label style="cursor: pointer; font-size: 28px; color: var(--text-muted); transition: color 0.15s;" onmouseover="highlightStars(<%= i %>)" onmouseout="resetStars()">
            <input type="radio" name="rating" value="<%= i %>" required style="display: none;">
            <span class="star" data-value="<%= i %>">&#9733;</span>
          </label>
        <% } %>
      </div>
    </div>
    <div class="form-group" style="margin-bottom: 12px;">
      <label>Your feedback</label>
      <textarea name="message" placeholder="What do you like? What could be better?" required style="min-height: 80px;"></textarea>
    </div>
    <button type="submit" class="btn btn-primary" style="padding: 8px 20px; font-size: 13px;">Submit Feedback</button>
  </form>
</div>

<script>
  var selectedRating = 0;
  function highlightStars(n) {
    document.querySelectorAll('#star-rating .star').forEach(function(s) {
      s.style.color = parseInt(s.dataset.value) <= n ? '#f1c40f' : 'var(--text-muted)';
    });
  }
  function resetStars() {
    document.querySelectorAll('#star-rating .star').forEach(function(s) {
      s.style.color = parseInt(s.dataset.value) <= selectedRating ? '#f1c40f' : 'var(--text-muted)';
    });
  }
  document.querySelectorAll('#star-rating input').forEach(function(input) {
    input.addEventListener('change', function() {
      selectedRating = parseInt(this.value);
      highlightStars(selectedRating);
    });
  });
</script>

<style>
  @media (max-width: 640px) {
    div[style*="grid-template-columns: repeat(4"] { grid-template-columns: repeat(2, 1fr) !important; }
    div[style*="grid-template-columns: 2fr 1fr"] { grid-template-columns: 1fr !important; }
    div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>

<%- include('footer') %>
