async function loadTrackDatabase() {
  const grid = document.getElementById('track-db-grid');
  const missingGrid = document.getElementById('missing-tracks-grid');
  try {
    const res = await fetch('/api/track-maps');
    const tracks = await res.json();

    if (!tracks.length) {
      grid.innerHTML = '<div style="color: var(--text-muted); font-size: 12px;">No tracks in database yet. Upload .ibt files above.</div>';
    } else {
      // Filter to only show tracks with display names (not geo IDs like "49.33_8.57")
      const namedTracks = tracks.filter(t => !t.track_name.match(/^-?\d+\.\d+_-?\d+\.\d+$/));
      const geoTracks = tracks.filter(t => t.track_name.match(/^-?\d+\.\d+_-?\d+\.\d+$/));

      grid.innerHTML = '';
      for (const track of namedTracks) {
        const card = document.createElement('div');
        card.style.cssText = 'background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; text-align: center; cursor: pointer; transition: border-color 0.15s;';
        card.onmouseover = function() { this.style.borderColor = 'rgba(145,70,255,0.3)'; };
        card.onmouseout = function() { this.style.borderColor = 'rgba(255,255,255,0.08)'; };
        card.onclick = function() { window.location.href = '/tracks/' + encodeURIComponent(track.track_name); };
        card.innerHTML =
          '<canvas width="140" height="140" style="border-radius: 6px; background: rgba(0,0,0,0.3); margin-bottom: 8px;"></canvas>' +
          '<div style="font-size: 11px; font-weight: 600; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="' + track.track_name.replace(/"/g, '&quot;') + '">' + track.track_name.replace(/</g, '&lt;') + '</div>' +
          '<div style="font-size: 10px; color: var(--text-muted);">' + track.point_count + ' pts</div>';
        grid.appendChild(card);

        // Load and draw track preview
        try {
          const r = await fetch('/api/track-map/' + encodeURIComponent(track.track_name));
          const d = await r.json();
          if (d.trackData) drawTrackPreview(card.querySelector('canvas'), d.trackData);
        } catch(e) {}
      }

      // Show geo-only tracks count
      if (geoTracks.length > 0) {
        const note = document.createElement('div');
        note.style.cssText = 'grid-column: 1 / -1; color: var(--text-muted); font-size: 11px; margin-top: 8px;';
        note.textContent = '+ ' + geoTracks.length + ' tracks stored by GPS coordinates (will match automatically when you race them)';
        grid.appendChild(note);
      }
    }

    // Show missing tracks
    const dbNames = tracks.map(t => t.track_name.toLowerCase());
    const missing = KNOWN_IRACING_TRACKS.filter(name => !dbNames.some(db => db.includes(name.toLowerCase()) || name.toLowerCase().includes(db)));

    if (missing.length === 0) {
      missingGrid.innerHTML = '<div style="color: #3ecf8e; font-size: 12px;">All known tracks are in the database!</div>';
    } else {
      missingGrid.innerHTML = missing.map(name =>
        '<div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 10px 12px; display: flex; align-items: center; gap: 8px;">' +
          '<span style="background: rgba(240,68,56,0.15); color: #f04438; font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 4px;">MISSING</span>' +
          '<span style="font-size: 11px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">' + name + '</span>' +
        '</div>'
      ).join('');
    }
  } catch(e) {
    grid.innerHTML = '<div style="color: #f04438; font-size: 12px;">Failed to load track database</div>';
    missingGrid.innerHTML = '';
  }
}
loadTrackDatabase();

// ─── Next Review Countdown ────────────────────────────────
function updateReviewCountdown() {
  var now = new Date();
  var utcH = now.getUTCHours();
  var nextH = Math.ceil((utcH + 1) / 6) * 6;
  var next = new Date(now);
  next.setUTCHours(nextH, 0, 0, 0);
  if (next <= now) next.setUTCHours(next.getUTCHours() + 6);
  var diff = next - now;
  var h = Math.floor(diff / 3600000);
  var m = Math.floor((diff % 3600000) / 60000);
  var s = Math.floor((diff % 60000) / 1000);
  var el = document.getElementById('next-review-countdown');
  if (el) el.textContent = 'Next review in ' + (h > 0 ? h + 'h ' : '') + m + 'm ' + s + 's';
}
updateReviewCountdown();
setInterval(updateReviewCountdown, 1000);

