<%- include('header', { title: 'iRacing', streamer: streamer }) %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;" class="animate-in">
  <div style="display: flex; align-items: center; gap: 12px;">
    <h2 style="font-size: 24px; font-weight: 700;">iRacing</h2>
  </div>
</div>

  <style>
    .iracing-subtab { padding:8px 16px; font-size:12px; font-weight:600; color:var(--text-muted); background:none; border:none; border-bottom:2px solid transparent; cursor:pointer; transition:all 0.2s; }
    .iracing-subtab:hover { color:var(--text-secondary); }
    .iracing-subtab.active { color:var(--primary); border-bottom-color:var(--primary); }
    .iracing-subtab-content { display:none; }
    .iracing-subtab-content.active { display:block; }
    .log-filter-tab { padding:4px 10px; font-size:10px; font-weight:600; border-radius:6px; border:1px solid rgba(255,255,255,0.08); background:rgba(255,255,255,0.03); color:rgba(255,255,255,0.4); cursor:pointer; transition:all 0.15s; }
    .log-filter-tab:hover { color:rgba(255,255,255,0.7); border-color:rgba(255,255,255,0.15); }
    .log-filter-tab.active { background:var(--primary); color:#fff; border-color:var(--primary); }
  </style>

