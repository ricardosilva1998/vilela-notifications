<script>
// ─── iRacing Sub-Tab Switching ──────────────────────────────
function switchIRacingTab(tab) {
  document.querySelectorAll('.iracing-subtab').forEach(t => t.classList.toggle('active', t.dataset.irtab === tab));
  document.querySelectorAll('.iracing-subtab-content').forEach(p => p.classList.toggle('active', p.id === 'irtab-' + tab));
  localStorage.setItem('iracing_subtab', tab);
  // Track stats now integrated into Track Database (click a track card)
}
const savedIRTab = localStorage.getItem('iracing_subtab');
if (savedIRTab && document.querySelector('[data-irtab="' + savedIRTab + '"]')) switchIRacingTab(savedIRTab);

// ─── IBT Parser (browser-side) ─────────────────────────────
const VAR_TYPE_MAP = ['c', '?', 'i', 'I', 'f', 'd'];
function getTypeSize(t) { return { i: 4, I: 4, f: 4, d: 8, '?': 1, c: 1 }[t] || 0; }

function parseIBT(arrayBuffer) {
  const data = new Uint8Array(arrayBuffer);
  const view = new DataView(arrayBuffer);
  const numVars = view.getInt32(24, true);
  const varHeaderOffset = view.getInt32(28, true);
  const numBuf = view.getInt32(32, true);
  const bufLen = view.getInt32(36, true);
  const recordCount = view.getInt32(140, true);
  const sessionInfoLen = view.getInt32(16, true);
  const sessionInfoOffset = view.getInt32(20, true);

  // Extract track name from session info YAML
  let trackDisplayName = '';
  try {
    const decoder = new TextDecoder();
    const yaml = decoder.decode(data.slice(sessionInfoOffset, sessionInfoOffset + sessionInfoLen));
    const match = yaml.match(/TrackDisplayName:\s*(.+)/);
    if (match) trackDisplayName = match[1].trim();
  } catch(e) {}

  let bestTick = -1, bestBufOffset = 0;
  for (let i = 0; i < numBuf; i++) {
    const off = 48 + i * 16;
    const tick = view.getInt32(off, true);
    const bufOff = view.getInt32(off + 4, true);
    if (tick > bestTick) { bestTick = tick; bestBufOffset = bufOff; }
  }

  const vars = {};
  for (let i = 0; i < numVars; i++) {
    const off = varHeaderOffset + i * 144;
    const type = view.getInt32(off, true);
    const typeChar = VAR_TYPE_MAP[type] || 'i';
    const typeSize = getTypeSize(typeChar);
    const varOffset = view.getInt32(off + 4, true);
    const count = view.getInt32(off + 8, true);
    let name = '';
    for (let j = 0; j < 32; j++) { const b = data[off + 16 + j]; if (b === 0) break; name += String.fromCharCode(b); }
    vars[name] = { typeChar, typeSize, offset: varOffset, count };
  }

  function readVar(name, frameIdx) {
    const v = vars[name];
    if (!v) return null;
    const off = bestBufOffset + v.offset + frameIdx * bufLen;
    const dv = new DataView(arrayBuffer, off, v.typeSize);
    if (v.typeChar === 'f') return dv.getFloat32(0, true);
    if (v.typeChar === 'd') return dv.getFloat64(0, true);
    if (v.typeChar === 'i') return dv.getInt32(0, true);
    return 0;
  }

  return { vars, recordCount, readVar, trackDisplayName };
}

function extractTrackFromParsed(ibt) {
  if (!ibt.vars['Lat'] || !ibt.vars['Lon'] || !ibt.vars['LapDistPct']) return null;
  const SLOTS = 500;
  const RAD_TO_DEG = 180 / Math.PI;
  const slots = new Array(SLOTS).fill(null);
  let filled = 0;
  const sampleRate = Math.max(1, Math.floor(ibt.recordCount / 2000));

  for (let i = 0; i < ibt.recordCount; i += sampleRate) {
    const lat = ibt.readVar('Lat', i);
    const lon = ibt.readVar('Lon', i);
    const pct = ibt.readVar('LapDistPct', i);
    if (lat && lon && pct >= 0 && pct <= 1 && lat !== 0 && lon !== 0) {
      const idx = Math.floor(pct * SLOTS) % SLOTS;
      if (!slots[idx]) filled++;
      slots[idx] = { x: lon * RAD_TO_DEG, y: lat * RAD_TO_DEG, pct };
    }
  }

  if (filled < SLOTS * 0.5) return null;
  const points = [];
  for (let i = 0; i < SLOTS; i++) { if (slots[i]) points.push(slots[i]); }
  const win = 3;
  const smoothed = [];
  for (let i = 0; i < points.length; i++) {
    let sx = 0, sy = 0, c = 0;
    for (let j = -win; j <= win; j++) {
      const idx = (i + j + points.length) % points.length;
      sx += points[idx].x; sy += points[idx].y; c++;
    }
    smoothed.push({ x: sx / c, y: sy / c, pct: points[i].pct });
  }
  const avgY = smoothed.reduce((s, p) => s + p.y, 0) / smoothed.length;
  const avgX = smoothed.reduce((s, p) => s + p.x, 0) / smoothed.length;
  const geoId = avgY.toFixed(2) + '_' + avgX.toFixed(2);
  return { points: smoothed, geoId, filled };
}

function drawTrackPreview(canvas, points) {
  const ctx = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;
  ctx.clearRect(0, 0, w, h);
  if (!points || points.length < 10) return;
  let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
  points.forEach(p => { if (p.x < minX) minX = p.x; if (p.x > maxX) maxX = p.x; if (p.y < minY) minY = p.y; if (p.y > maxY) maxY = p.y; });
  const xR = maxX - minX || 1, yR = maxY - minY || 1;
  const pad = 0.08, aspect = xR / yR;
  let scX = 1, scY = 1;
  if (aspect > 1) scY = 1 / aspect; else scX = aspect;
  const u = 1 - 2 * pad;
  ctx.beginPath();
  ctx.strokeStyle = '#9146ff';
  ctx.lineWidth = 2;
  points.forEach((p, i) => {
    const x = (pad + u * scX * (p.x - minX) / xR + u * (1 - scX) / 2) * w;
    const y = (pad + u * scY * (1 - (p.y - minY) / yR) + u * (1 - scY) / 2) * h;
    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  });
  ctx.closePath();
  ctx.stroke();
  const sf = points[0];
  const sfx = (pad + u * scX * (sf.x - minX) / xR + u * (1 - scX) / 2) * w;
  const sfy = (pad + u * scY * (1 - (sf.y - minY) / yR) + u * (1 - scY) / 2) * h;
  ctx.beginPath(); ctx.arc(sfx, sfy, 4, 0, Math.PI * 2); ctx.fillStyle = '#3ecf8e'; ctx.fill();
}

function handleIBTDrop(e) {
  e.preventDefault();
  e.currentTarget.style.borderColor = 'rgba(255,255,255,0.1)';
  e.currentTarget.style.background = 'none';
  handleIBTFiles(e.dataTransfer.files);
}

async function handleIBTFiles(fileList) {
  const files = Array.from(fileList).filter(f => f.name.endsWith('.ibt'));
  if (files.length === 0) return;
  const progress = document.getElementById('ibt-progress');
  const progressText = document.getElementById('ibt-progress-text');
  const progressBar = document.getElementById('ibt-progress-bar');
  const results = document.getElementById('ibt-results');
  progress.style.display = 'block';
  results.innerHTML = '';
  const extracted = [];

  for (let i = 0; i < files.length; i++) {
    progressText.textContent = 'Processing ' + (i + 1) + '/' + files.length + ': ' + files[i].name;
    progressBar.style.width = ((i + 1) / files.length * 100) + '%';
    try {
      const buf = await files[i].arrayBuffer();
      const ibt = parseIBT(buf);
      const track = extractTrackFromParsed(ibt);
      if (track) extracted.push({ name: files[i].name, trackDisplayName: ibt.trackDisplayName, ...track });
    } catch(e) { console.error('Error parsing ' + files[i].name, e); }
  }

  progress.style.display = 'none';
  if (extracted.length === 0) {
    results.innerHTML = '<p style="color: var(--text-muted); font-size: 13px;">No track data found in the uploaded files. Make sure the .ibt files contain at least one lap of driving data.</p>';
    return;
  }

  const unique = {};
  extracted.forEach(t => { if (!unique[t.geoId] || t.filled > unique[t.geoId].filled) unique[t.geoId] = t; });
  const tracks = Object.values(unique);
  results.innerHTML = '<h4 style="font-size: 14px; font-weight: 600; margin-bottom: 12px;">' + tracks.length + ' track' + (tracks.length > 1 ? 's' : '') + ' found</h4>';

  tracks.forEach(track => {
    const card = document.createElement('div');
    card.style.cssText = 'background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 16px; margin-bottom: 12px; display: flex; gap: 16px; align-items: center;';
    const displayName = track.trackDisplayName || track.name.replace(/</g, '&lt;');
    card.innerHTML = '<canvas width="160" height="160" style="border-radius: 8px; background: rgba(0,0,0,0.3); flex-shrink: 0;"></canvas>' +
      '<div style="flex: 1;">' +
        '<div style="font-size: 14px; font-weight: 700; margin-bottom: 4px;">' + (track.trackDisplayName || 'Unknown Track').replace(/</g, '&lt;') + '</div>' +
        '<div style="font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">File: ' + track.name.replace(/</g, '&lt;') + '</div>' +
        '<div style="font-size: 11px; color: var(--text-muted); margin-bottom: 12px;">' + track.points.length + ' points | ' + track.filled + '/500 slots</div>' +
        '<button class="btn btn-primary" style="font-size: 12px; padding: 6px 16px;" onclick="uploadTrack(this, \'' + track.geoId + '\')">Upload to Database</button>' +
        '<span class="upload-status" style="font-size: 11px; color: var(--text-muted); margin-left: 8px;"></span>' +
      '</div>';
    results.appendChild(card);
    drawTrackPreview(card.querySelector('canvas'), track.points);
    card._trackData = track.points;
    card._trackDisplayName = track.trackDisplayName || '';
  });
}

async function uploadTrack(btn, geoId) {
  const card = btn.closest('div').parentElement;
  const points = card._trackData;
  const trackName = card._trackDisplayName;
  const status = btn.nextElementSibling;
  btn.disabled = true;
  btn.textContent = 'Uploading...';
  status.textContent = '';
  try {
    // Upload under geoId (primary key for bridge geo-based lookup)
    const res = await fetch('/api/track-map', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ trackName: geoId, trackData: points }),
    });
    // Also upload under display name (fallback for bridge name-based lookup)
    if (trackName) {
      await fetch('/api/track-map', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ trackName: trackName, trackData: points }),
      });
    }
    const data = await res.json();
    if (data.status === 'ok') {
      btn.textContent = 'Uploaded';
      btn.style.background = 'var(--success, #3ecf8e)';
      status.textContent = 'Stored in database';
      status.style.color = '#3ecf8e';
    } else if (data.status === 'exists') {
      btn.textContent = 'Already exists';
      btn.style.background = 'rgba(255,255,255,0.1)';
      status.textContent = data.message;
    } else {
      btn.textContent = 'Error';
      status.textContent = data.error || 'Upload failed';
      status.style.color = '#f04438';
      btn.disabled = false;
    }
  } catch(e) {
    btn.textContent = 'Error';
    status.textContent = e.message;
    status.style.color = '#f04438';
    btn.disabled = false;
  }
}

