    <button class="iracing-subtab active" data-irtab="app" onclick="switchIRacingTab('app')">App Download</button>
    <button class="iracing-subtab" data-irtab="logs" onclick="switchIRacingTab('logs')">Bridge</button>
    <button class="iracing-subtab" data-irtab="tracks" onclick="switchIRacingTab('tracks')">Track Database</button>
  </div>

