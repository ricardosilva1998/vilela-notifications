// ─── Track Stats Page (inside Track Database) ───
async function showTrackStatsPage(trackName) {
  document.getElementById('track-db-grid').style.display = 'none';
  const page = document.getElementById('track-stats-page');
  page.style.display = 'block';
  document.getElementById('track-stats-page-name').textContent = trackName;
  document.getElementById('track-stats-page-content').innerHTML = 'Loading stats...';

  try {
    const res = await fetch('/api/track-stats/' + encodeURIComponent(trackName));
    const rows = await res.json();

    // All tracked classes — always show all, even without data
    const ALL_CLASSES = ['GTP', 'LMP2', 'GT3', 'GT4', 'LMP3', 'Mazda', 'TCR', 'Porsche Cup', 'BMW M2', 'Toyota', 'GTE'];
    const typeColors = {
      sprint: '#f7c948', open: '#9146ff', endurance: '#3ecf8e',
      imsa_sprint: '#f7c948', imsa_open: '#9146ff', imsa_endurance: '#3ecf8e',
      vrs_sprint: '#f7c948', vrs_open: '#9146ff', vrs_endurance: '#3ecf8e',
    };

    function formatRaceType(rt) {
      const labels = {
        sprint: 'Sprint', open: 'Open', endurance: 'Endurance',
        regionals: 'Regionals',
        vrs_sprint: 'VRS Sprint', vrs_open: 'VRS Open',
        imsa_sprint: 'IMSA Sprint', imsa_open: 'IMSA Open', imsa_endurance: 'IMSA Endurance',
        global_endurance: 'Global Endurance',
        lmp2_sprint: 'LMP2 Sprint',
        prototype_sprint: 'Proto Sprint',
      };
      return labels[rt] || rt;
    }

    // Race types per class
    function getRaceTypes(cls) {
      if (cls === 'GT3') return ['regionals', 'vrs_sprint', 'imsa_sprint', 'vrs_open', 'imsa_open', 'imsa_endurance', 'global_endurance'];
      if (cls === 'LMP2') return ['lmp2_sprint', 'imsa_sprint', 'imsa_open', 'imsa_endurance', 'global_endurance'];
      if (cls === 'GTP') return ['prototype_sprint', 'imsa_sprint', 'imsa_open', 'imsa_endurance', 'global_endurance'];
      return ['sprint', 'open', 'endurance'];
    }

    // Group existing data by class
    const data = {};
    rows.forEach(r => {
      if (!data[r.car_class]) data[r.car_class] = {};
      data[r.car_class][r.race_type] = r;
    });

    function fmtLap(s) {
      if (!s || s <= 0) return '<span style="color:#3a3a4e;">--</span>';
      const m = Math.floor(s / 60);
      const sec = (s % 60).toFixed(3);
      return m > 0 ? m + ':' + sec.padStart(6, '0') : sec;
    }

    let html = '';
    ALL_CLASSES.forEach(cls => {
      const types = data[cls] || {};
      const hasData = Object.keys(types).length > 0;
      const expectedTypes = getRaceTypes(cls);

      html += '<div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,' + (hasData ? '0.06' : '0.03') + ');border-radius:10px;padding:14px;margin-bottom:10px;' + (!hasData ? 'opacity:0.5;' : '') + '">';
      html += '<h4 style="font-size:13px;font-weight:700;margin:0 0 10px;">' + cls + (!hasData ? ' <span style="font-size:10px;font-weight:400;color:#5c5b6e;">No data yet</span>' : '') + '</h4>';
      html += '<table style="width:100%;border-collapse:collapse;font-size:11px;">';
      html += '<thead><tr style="border-bottom:1px solid rgba(255,255,255,0.08);color:var(--text-muted);font-size:10px;text-transform:uppercase;">';
      html += '<th style="text-align:left;padding:6px 8px;">Race Type</th>';
      html += '<th style="text-align:right;padding:6px 6px;">Avg Lap</th>';
      html += '<th style="text-align:right;padding:6px 6px;">Avg Pit</th>';
      html += '<th style="text-align:right;padding:6px 6px;">Avg Quali</th>';
      html += '<th style="text-align:right;padding:6px 6px;">Est. Laps</th>';
      html += '<th style="text-align:right;padding:6px 6px;">Avg SOF</th>';
      html += '<th style="text-align:right;padding:6px 6px;">Races</th>';
      html += '<th style="text-align:right;padding:6px 8px;">Avg Drivers</th>';
      html += '</tr></thead><tbody>';

      // Show expected types + any extra types that exist in data
      const allTypes = [...new Set([...expectedTypes, ...Object.keys(types)])];
      allTypes.forEach(rt => {
        const r = types[rt];
        const noData = !r;
        const color = typeColors[rt] || '#aaa';
        html += '<tr style="border-bottom:1px solid rgba(255,255,255,0.03);">';
        html += '<td style="padding:8px;"><span style="color:' + color + ';font-weight:700;font-size:11px;text-transform:uppercase;">' + formatRaceType(rt) + '</span></td>';
        html += '<td style="text-align:right;padding:8px 6px;font-family:monospace;color:' + (noData ? '#3a3a4e' : '#e8e6f0') + ';">' + (noData ? '--' : fmtLap(r.avg_lap_time)) + '</td>';
        html += '<td style="text-align:right;padding:8px 6px;font-family:monospace;color:' + (noData ? '#3a3a4e' : '#e8e6f0') + ';">' + (noData ? '--' : (r.avg_pit_time > 0 ? r.avg_pit_time.toFixed(1) + 's' : '--')) + '</td>';
        html += '<td style="text-align:right;padding:8px 6px;font-family:monospace;color:' + (noData ? '#3a3a4e' : '#e8e6f0') + ';">' + (noData ? '--' : fmtLap(r.avg_qualify_time)) + '</td>';
        html += '<td style="text-align:right;padding:8px 6px;font-family:monospace;color:' + (noData ? '#3a3a4e' : '#f7c948') + ';">' + (noData ? '--' : (r.est_laps > 0 ? r.est_laps.toFixed(2) : '--')) + '</td>';
        html += '<td style="text-align:right;padding:8px 6px;font-family:monospace;color:' + (noData ? '#3a3a4e' : '#e8e6f0') + ';">' + (noData ? '--' : (r.avg_sof > 0 ? Math.round(r.avg_sof).toLocaleString() : '--')) + '</td>';
        html += '<td style="text-align:right;padding:8px 6px;font-family:monospace;color:' + (noData ? '#3a3a4e' : 'var(--text-muted)') + ';">' + (noData ? '--' : r.race_count) + '</td>';
        html += '<td style="text-align:right;padding:8px;font-family:monospace;color:' + (noData ? '#3a3a4e' : 'var(--text-muted)') + ';">' + (noData ? '--' : Math.round(r.avg_drivers)) + '</td>';
        html += '</tr>';
      });

      html += '</tbody></table></div>';
    });

    document.getElementById('track-stats-page-content').innerHTML = html;
  } catch(e) {
    document.getElementById('track-stats-page-content').innerHTML = '<p style="color:#f04438;">Failed to load stats: ' + e.message + '</p>';
  }
}

